// Exercises section-driven FFI marshaling: an externref-typed value flows
// through get_context -> fill_rect untouched, while String args are decoded.

extern canvas {
  type Ctx
  fn get_context(id: String) Ctx?
  fn fill_rect(ctx: Ctx, x: Float, y: Float, w: Float, h: Float)
}

extern probe fn record(label: String)

case canvas.get_context("2d") {
  .Some(ctx) => {
    canvas.fill_rect(ctx, 1.0, 2.0, 3.0, 4.0)
    probe.record("ok")
  },
  .None => probe.record("none"),
}
