// Async timer, JSPI suspends Wasm while setTimeout runs.
// The browser event loop stays free during each sleep.
extern timer fn sleep_ms(ms: Int)

extern performance fn now() Float

start := performance.now()

for i in 1..6 {
  timer.sleep_ms(500)
  elapsed := performance.now() - start
  println("tick ${i} at ${elapsed.to_string().slice(0, 6)} ms")
}

println("done, 5 ticks over ~2.5 seconds")
