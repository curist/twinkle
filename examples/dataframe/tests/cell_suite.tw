use @std.testing.assert as assert
use @std.testing as runner
use frame.cell
use frame.cell.{Scalar}

pub fn suite() {
  runner.suite("cell")
    .test(
      "to_string renders each variant",
      fn() {
        ok1 := try assert.equal(cell.to_string(Scalar.CInt(42)), "42")
        ok2 := try assert.equal(cell.to_string(Scalar.CFloat(1.5)), "1.5")
        ok3 := try assert.equal(cell.to_string(Scalar.CStr("hi")), "hi")
        ok4 := try assert.equal(cell.to_string(Scalar.CBool(true)), "true")
        assert.equal(cell.to_string(Scalar.CNull), "null")
      },
    )
    .test(
      "cells are structurally comparable",
      fn() {
        assert.equal(Scalar.CInt(7), Scalar.CInt(7))
      },
    )
}
