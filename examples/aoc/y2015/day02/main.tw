// Runnable entry for a single day: read the pulled input and print answers.
// `make solve YEAR=2015 DAY=2` runs this. Generated by `make new`.

use lib.aoc
use .solution

dir := aoc.day_dir(2015, 2)

case aoc.read_input(dir) {
  .Some(input) => {
    println("2015 day02")
    println("  part1: ${solution.part1(input)}")
    println("  part2: ${solution.part2(input)}")
  },
  .None => {
    println("no input for ${dir} yet — run: make pull YEAR=2015 DAY=2")
  },
}
