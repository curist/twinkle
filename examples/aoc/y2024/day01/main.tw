// Runnable entry for a single day: read the pulled input and print answers.
// `make solve YEAR=2024 DAY=1` runs this. Generated by `make new`; safe to edit.
use lib.aoc

use .solution

dir := aoc.day_dir(2024, 1)

case aoc.read_input(dir) {
  .Some(input) => {
    println("2024 day01")
    println("  part1: ${solution.part1(input)}")
    println("  part2: ${solution.part2(input)}")
  },
  .None => println("no input for ${dir} yet — run: make pull YEAR=2024 DAY=1"),
}
