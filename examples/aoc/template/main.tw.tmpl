// Runnable entry for a single day: read the pulled input and print answers.
// `make solve YEAR=__YEAR__ DAY=__DAY__` runs this. Generated by `make new`.

use lib.aoc
use .solution

dir := aoc.day_dir(__YEAR__, __DAY__)

case aoc.read_input(dir) {
  .Some(input) => {
    println("__YEAR__ day__DD__")
    println("  part1: ${solution.part1(input)}")
    println("  part2: ${solution.part2(input)}")
  },
  .None => {
    println("no input for ${dir} yet — run: make pull YEAR=__YEAR__ DAY=__DAY__")
  },
}
