pub fn suite() {
  dir := aoc.day_dir(__YEAR__, __DAY__)
  sample := aoc.read_sample(dir)

  runner.suite("__YEAR__ day__DD__")
    .test(
      "part1 sample",
      fn() {
        // TODO: replace -1 with the example's part 1 answer.
        assert.equal(part1(sample), -1)
      },
    )
    .test(
      "part2 sample",
      fn() {
        // TODO: replace -1 with the example's part 2 answer.
        assert.equal(part2(sample), -1)
      },
    )
    // Real-input regression: skipped until `make pull` fetches input.txt.
    // Record the answers once `make solve` prints them.
    .test(
      "part1 input",
      fn() {
        case aoc.read_input(dir) {
          .Some(inp) => assert.equal(part1(inp), 0),
          .None => .Ok({}),
        }
      },
    )
    .test(
      "part2 input",
      fn() {
        case aoc.read_input(dir) {
          .Some(inp) => assert.equal(part2(inp), 0),
          .None => .Ok({}),
        }
      },
    )
}
