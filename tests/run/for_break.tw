// Expected output:
//   1
//   2
//   3
//   done
//   found: 7

// Break exits a for loop early
fn print_until_zero(xs: Vector<Int>) Void {
    for x in xs {
        if x == 0 { break }
        println("${x}")
    }
    println("done")
}

print_until_zero([1, 2, 3, 0, 4, 5])

// Break inside a while-style for loop
fn find_gt(xs: Vector<Int>, threshold: Int) String {
    result := "not found"
    for x in xs {
        if x > threshold {
            result = "found: ${x}"
            break
        }
    }
    result
}

println(find_gt([1, 3, 5, 7, 9], 6))
