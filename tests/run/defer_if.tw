// defer is block-scoped: a defer inside an if-branch fires when the block exits,
// not when the function returns.  If the branch is not taken the defer is never
// registered.
// Expected output:
//   inside if
//   after if
//   branch not taken: no defer

fn taken() Void {
    if true {
        defer println("inside if")
    }
    println("after if")
}

fn not_taken() Void {
    if false {
        defer println("should not print")
    }
    println("branch not taken: no defer")
}

taken()
not_taken()
