// Expected output:
//   98
//   97
//   48
//   true
//   true
//   a
//   none

// String.char_code_at returns the byte value
println("${"abc".char_code_at(1)}")
println("${String.char_code_at("abc", 0)}")
println("${"0".char_code_at(0)}")

// Digit check via code points
c := "x5y".char_code_at(1)
r1 := c >= 48 and c <= 57
println("${r1}")

// Letter check
c2 := "Hello".char_code_at(0)
r2 := c2 >= 65 and c2 <= 90
println("${r2}")

// String.from_char_code round-trip
case String.from_char_code(97) {
  .Some(s) => println(s),
  .None => println("none"),
}

// Invalid code point
case String.from_char_code(200) {
  .Some(s) => println(s),
  .None => println("none"),
}
