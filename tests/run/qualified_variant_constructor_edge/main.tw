// Expected output:
//   active
//   inactive
//   ok2:100
//   err2:fail
//   active
//   ok2:7

use types

// Basic qualified constructors
println(types.show_status(types.Status.Active))
println(types.show_status(types.Status.Inactive))

// Generic qualified constructors with explicit payload
println(types.show_result2(types.Result2.Ok2(100)))
println(types.show_result2(types.Result2.Err2("fail")))

// Qualified variant in case arm context (pattern uses .Variant, but construct via module path)
fn roundtrip_status(s: types.Status) types.Status {
  case s {
    .Active => types.Status.Active,
    .Inactive => types.Status.Inactive,
  }
}
println(types.show_status(roundtrip_status(types.Status.Active)))

// Qualified variant as function argument inline
fn apply(r: types.Result2<Int, String>) String {
  types.show_result2(r)
}
println(apply(types.Result2.Ok2(7)))
