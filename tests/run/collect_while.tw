// Expected output:
//   3
//   1
//   3
//   5
//   0
//   2
//   3

fn main() {
  i := 0
  xs := collect i < 8 {
    i = i + 1
    if i % 2 == 0 { continue }
    if i == 7 { break }
    i
  }

  println("${xs.len()}")
  println("${xs[0]}")
  println("${xs[1]}")
  println("${xs[2]}")

  j := 0
  empty := collect j < 0 { j }
  println("${empty.len()}")

  n := 0
  tri := collect n < 4 {
    n = n + 1
    n
  }
  println("${tri[1]}")
  println("${tri[2]}")
}

main()
