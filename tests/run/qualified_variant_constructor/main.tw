// Expected output:
//   red
//   green
//   circle r=3.14
//   rect 2x5
//   unit square
//   empty
//   hold 42

use types

// Zero-arg variant via module.Type.Variant
c1 := types.Color.Red
c2 := types.Color.Green
println(types.describe_color(c1))
println(types.describe_color(c2))

// Parameterized variant via module.Type.Variant(args)
s1 := types.Shape.Circle(3.14)
s2 := types.Shape.Rect(2, 5)
s3 := types.Shape.UnitSquare
println(types.describe_shape(s1))
println(types.describe_shape(s2))
println(types.describe_shape(s3))

// Generic variant via module.Type.Variant
w1: types.Wrapper<Int> = types.Wrapper.Empty
w2 := types.Wrapper.Hold(42)
println(types.describe_wrapper(w1))
println(types.describe_wrapper(w2))
