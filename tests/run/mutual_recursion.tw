// Expected output:
//   true
//   false
//   true
//   false

// Mutually recursive functions — is_even calls is_odd and vice versa.
// All function signatures are pre-registered, so forward references work.
fn is_even(n: Int) Bool {
    if n == 0 { true } else { is_odd(n - 1) }
}

fn is_odd(n: Int) Bool {
    if n == 0 { false } else { is_even(n - 1) }
}

println("${is_even(4)}")
println("${is_even(3)}")
println("${is_odd(7)}")
println("${is_odd(6)}")
