// Expected output:
//   5
//   5
//   3
//   4
//   hello world
//   5

// String method chaining
s := "hello world"
println("${s.slice(0, 5).len()}")        // 5: "hello"
println("${s.slice(3, 8).len()}")        // 5: "lo wo"

// Vector method chaining
a := [1, 2, 3]
b := [4, 5, 6]
println("${a.concat(b).slice(0, 3).len()}")  // 3
println("${a.concat(b).slice(2, 6).len()}")  // 4

// Chaining across string and array ops
words: Vector<String> = ["hello", " ", "world"]
joined := words[0].concat(words[1]).concat(words[2])
println(joined)                               // hello world
println("${joined.slice(0, 5).len()}")   // 5
