// Expected output:
//   got 42
//   none

fn show(o: Option<Int>) {
  case o {
    .Some(n) => println("got ${n}"),
    .None => println("none"),
  }
}

fn main() {
  src: Option<Int> = .Some(42)
  dst: Option<Int> = .None

  // AAssign path: move typed local option through a reassigned local.
  dst = src
  show(dst)

  // AAssign with a fresh variant literal after reassignment.
  dst = .None
  show(dst)
}

main()
