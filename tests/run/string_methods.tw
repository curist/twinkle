// Expected output:
//   hello
//   world
//   lo wo
//
//   11
//   hello world!
//   hello

s := "hello world"
println(s.slice(0, 5))    // hello
println(s.slice(6, 11))   // world
println(s.slice(3, 8))    // lo wo

// Empty slice at end of string
println(s.slice(11, 11))  // "" (empty)

// Qualified calls: String.len, String.concat, String.slice
println("${String.len(s)}")
println(String.concat(s, "!"))
println(String.slice(s, 0, 5))
