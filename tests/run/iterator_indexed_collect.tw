// Expected output:
//   0: a
//   1: b
//   2: c

items := ["a", "b", "c"]
it := Iterator.unfold(0, fn(i: Int) {
  if i < items.len() { UnfoldStep.Yield(items[i], i + 1) }
  else               { UnfoldStep.Done }
})

result := collect x, idx in it { "${idx}: ${x}" }
for s in result {
  println(s)
}
