// Expected output:
//   2
//   true
//   false
//   1
//   false
//   1
//   true
//   false
//   0

m: Dict<String, Int> = Dict.new()
m["a"] = 1
m["b"] = 2

println("${m.len()}")       // 2
println("${m.has("a")}")    // true
println("${m.has("c")}")    // false

m2 := m.remove("a")
println("${m2.len()}")       // 1
println("${m2.has("a")}")    // false

// Qualified calls: Dict.len, Dict.has, Dict.remove
n: Dict<String, Int> = Dict.new()
n["x"] = 10
println("${Dict.len(n)}")         // 1
println("${Dict.has(n, "x")}")    // true
println("${Dict.has(n, "y")}")    // false
n2 := Dict.remove(n, "x")
println("${Dict.len(n2)}")         // 0
