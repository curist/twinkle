// Expected output:
//   fib(24)=46368
//   rec_checksum=927360
//   iter_checksum=231840000
//
// Perf knobs:
// - Increase `n` for more expensive recursive work.
// - Increase `rec_rounds` / `iter_rounds` to scale runtime without changing correctness.

fn fib(n: Int) Int {
  if n < 2 { n } else { fib(n - 1) + fib(n - 2) }
}

fn fib_iter(n: Int) Int {
  a := 0
  b := 1
  i := 0
  for i < n {
    next := a + b
    a = b
    b = next
    i = i + 1
  }
  a
}

n := 24
rec_rounds := 20
iter_rounds := 5000

v := fib(n)
println("fib(${n})=${v}")

rec_checksum := 0
rec_i := 0
for rec_i < rec_rounds {
  rec_checksum = rec_checksum + fib(n)
  rec_i = rec_i + 1
}
println("rec_checksum=${rec_checksum}")

iter_checksum := 0
iter_i := 0
for iter_i < iter_rounds {
  iter_checksum = iter_checksum + fib_iter(n)
  iter_i = iter_i + 1
}
println("iter_checksum=${iter_checksum}")
