// Expected output:
//   42
//   none
//   -7
//   99
//   none
//   none
//   none
//   0
//   3
//   none

// int_from_string — basic
case int_from_string("42") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case int_from_string("abc") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

// int_from_string — sign handling
case int_from_string("-7") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case int_from_string("+99") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

// int_from_string — edge cases
case int_from_string("-") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case int_from_string("") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case int_from_string("12x") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case int_from_string("0") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

// float_from_string
case float_from_string("3.14") {
  .Some(f) => println("${f.to_string().substring(0, 1)}"),
  .None => println("none"),
}

case float_from_string("not_a_number") {
  .Some(f) => println("${f}"),
  .None => println("none"),
}
