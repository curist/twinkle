// Expected output:
//   42
//   none
//   -7
//   99
//   none
//   none
//   none
//   0
//   3
//   none

// Int.from_string — basic
case Int.from_string("42") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case Int.from_string("abc") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

// Int.from_string — sign handling
case Int.from_string("-7") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case Int.from_string("+99") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

// Int.from_string — edge cases
case Int.from_string("-") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case Int.from_string("") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case Int.from_string("12x") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

case Int.from_string("0") {
  .Some(n) => println("${n}"),
  .None => println("none"),
}

// Float.from_string
case Float.from_string("3.14") {
  .Some(f) => println("${f.to_string().substring(0, 1)}"),
  .None => println("none"),
}

case Float.from_string("not_a_number") {
  .Some(f) => println("${f}"),
  .None => println("none"),
}
