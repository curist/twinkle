// Expected output:
//   104
//   none
//   105
//   none

s := "hi"

case s.get(0) {
  .Some(b) => println("${b}"),
  .None => println("none"),
}

case s.get(99) {
  .Some(b) => println("${b}"),
  .None => println("none"),
}

case String.get(s, 1) {
  .Some(b) => println("${b}"),
  .None => println("none"),
}

case String.get(s, -1) {
  .Some(b) => println("${b}"),
  .None => println("none"),
}
