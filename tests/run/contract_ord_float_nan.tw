// Expected output:
//   Gt
//   Lt
//   Eq

fn show_order(o: Order) String {
  case o {
    .Lt => "Lt",
    .Eq => "Eq",
    .Gt => "Gt",
  }
}

// Float.compare NaN handling through Ord contract (generic path)
fn compare_pair<T: Ord>(a: T, b: T) Order {
  a.compare(b)
}

nan := 0.0 / 0.0
println(show_order(compare_pair(nan, 1.0)))   // Gt  (NaN > everything)
println(show_order(compare_pair(1.0, nan)))   // Lt  (everything < NaN)
println(show_order(compare_pair(nan, nan)))   // Eq  (NaN == NaN for sorting)
