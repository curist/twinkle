// Expected output:
//   chars: H e l l o
//   cumul: 1 3 6 10 15
//   labels: item_0=10 item_1=20 item_2=30

// Complex callback: let-bindings, multi-branch conditionals, call results in Yield
// Exercises metadata-driven typing where Yield value is an operation result, not an atom.

// 1. String iterator via byte decoding (mirrors prelude chars() pattern)
fn my_chars(s: String) Iterator<String> {
  Iterator.unfold(0, fn(pos: Int) {
    if pos >= s.len() {
      UnfoldStep.Done
    } else {
      lead := Byte.to_int(s[pos])
      byte_len := if lead < 128 { 1 }
                  else if lead < 224 { 2 }
                  else if lead < 240 { 3 }
                  else { 4 }
      UnfoldStep.Yield(s.slice(pos, pos + byte_len), pos + byte_len)
    }
  })
}

print("chars:")
for ch in my_chars("Hello") {
  print(" ${ch}")
}
println("")

// 2. Cumulative sum: Yield of a binary operation on let-bound intermediate
fn cumulative_sum(n: Int) Iterator<Int> {
  // state = (index, running_sum) packed as index * 10000 + sum
  Iterator.unfold(0, fn(packed: Int) {
    idx := packed / 10000
    running := packed % 10000
    if idx >= n {
      UnfoldStep.Done
    } else {
      next_val := idx + 1
      new_sum := running + next_val
      UnfoldStep.Yield(new_sum, (idx + 1) * 10000 + new_sum)
    }
  })
}

print("cumul:")
for s in cumulative_sum(5) {
  print(" ${s}")
}
println("")

// 3. Callback that calls a helper function whose return type requires metadata
fn make_label(prefix: String, idx: Int, val: Int) String {
  "${prefix}_${idx}=${val}"
}

fn labeled_items(items: Vector<Int>) Iterator<String> {
  n := items.len()
  Iterator.unfold(0, fn(i: Int) {
    if i >= n {
      UnfoldStep.Done
    } else {
      label := make_label("item", i, items[i])
      UnfoldStep.Yield(label, i + 1)
    }
  })
}

print("labels:")
for lbl in labeled_items([10, 20, 30]) {
  print(" ${lbl}")
}
println("")
