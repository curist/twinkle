// Expected output:
//   42
//   hello
//   99
//   hello

type Inner = .{ val: Int }
type Outer = .{ inner: Inner, name: String }

x: Outer = Outer.{ inner: Inner.{ val: 42 }, name: "hello" }
println("${x.inner.val}")
println("${x.name}")

// Update a nested field: x.inner.val = 99
x.inner.val = 99
println("${x.inner.val}")
println("${x.name}")
