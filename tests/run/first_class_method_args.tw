// Expected output:
//   6
//   15

type Point = .{ x: Int, y: Int }

fn translate(p: Point, dx: Int, dy: Int) Int {
  p.x + dx + p.y + dy
}

p := Point.{ x: 1, y: 2 }

// Method with multiple args: fn(Point, Int, Int) Int → fn(Int, Int) Int
f := p.translate
println(f(1, 2).to_string())

// Different receiver
p2 := Point.{ x: 5, y: 5 }
g := p2.translate
println(g(2, 3).to_string())
