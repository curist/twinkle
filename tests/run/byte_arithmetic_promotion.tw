// Expected output:
//   131
//   67
//   68
//   1
//   132
//   33
//   3
//   133
//   true
//   false
//   true
//   195
//   169
//   364
//   295
//   true

a: Byte = "AB"[0] // 65
b: Byte = "AB"[1] // 66

sum: Int = a + b
left_mix: Int = a + 2
right_mix: Int = 2 + b
println("${sum}")
println("${left_mix}")
println("${right_mix}")
println("${b - a}")
println("${b * 2}")
println("${b / 2}")
println("${b % 7}")
println("${a + b + 2}")
println("${a < b}")
println("${a == b}")
println("${a == a}")

// Non-ASCII UTF-8 byte values (>= 128) should promote consistently.
c: Byte = "é"[0] // 195
d: Byte = "é"[1] // 169
non_ascii_sum: Int = c + d
mixed_non_ascii: Int = 100 + c
println("${c + 0}")
println("${d + 0}")
println("${non_ascii_sum}")
println("${mixed_non_ascii}")
println("${c > d}")
