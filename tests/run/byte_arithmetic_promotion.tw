// Expected output:
//   131
//   67
//   68
//   1
//   132
//   33
//   3
//   133
//   true
//   false
//   true

a: Byte = "AB"[0] // 65
b: Byte = "AB"[1] // 66

sum: Int = a + b
left_mix: Int = a + 2
right_mix: Int = 2 + b
println("${sum}")
println("${left_mix}")
println("${right_mix}")
println("${b - a}")
println("${b * 2}")
println("${b / 2}")
println("${b % 7}")
println("${a + b + 2}")
println("${a < b}")
println("${a == b}")
println("${a == a}")
