// Expected output:
//   6
//   1
//   2
//   3
//   4
//   5
//   6
//   3
//   2
//   3
//   4
//   3
//   6
//   3
//   3

a := [1, 2, 3]
b := [4, 5, 6]

// concat returns a new array with elements of b appended to a
c := a.concat(b)
println("${c.len()}")
for x in c { println("${x}") }

// slice(start, end) returns elements [start, end)
d := c.slice(1, 4)
println("${d.len()}")
for x in d { println("${x}") }

// Qualified calls: Array.len, Array.concat, Array.slice
println("${Array.len(a)}")
e := Array.concat(a, b)
println("${Array.len(e)}")
f := Array.slice(e, 0, 3)
println("${Array.len(f)}")

// First-class reference: Array.len as a value
get_len : fn(Array<Int>) Int = Array.len
println("${get_len(a)}")
