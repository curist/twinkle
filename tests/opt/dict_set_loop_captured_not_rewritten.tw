// Dict captured by closure in loop — should NOT rewrite to in-place.
// Expected output:
//   3

fn build(n: Int) Dict<Int, Int> {
    d: Dict<Int, Int> = Dict.new()
    fns: Vector<fn() Int> = []
    for i in range(n) {
        d[i] = i
        fns = fns.push(fn() Int { d.len() })
    }
    d
}

result := build(3)
println("${result.len()}")
