// Helper-wrapped Dict.remove inside a loop should still rewrite in place in the caller loop.
// Expected output:
//   0

fn drop_key(d: Dict<Int, Int>, k: Int) Dict<Int, Int> {
    d.remove(k)
}

fn build_and_remove(n: Int) Dict<Int, Int> {
    d: Dict<Int, Int> = Dict.new()
    for i in range(n) {
        d[i] = i
    }
    for i in range(n) {
        d = drop_key(d, i)
    }
    d
}

result := build_and_remove(5)
println("${result.len()}")
