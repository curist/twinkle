// Dict aliased before loop — should NOT rewrite to in-place.
// Expected output:
//   0
//   3

fn build(n: Int) Dict<Int, Int> {
    d: Dict<Int, Int> = Dict.new()
    alias := d
    for i in range(n) {
        d[i] = i
    }
    println("${alias.len()}")
    d
}

result := build(3)
println("${result.len()}")
