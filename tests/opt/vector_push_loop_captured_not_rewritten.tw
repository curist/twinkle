// Capturing accumulator in closure inside loop blocks rewrite.
// Expected output:
//   0
//   1
//   2
//   3

fn make() Vector<Int> {
    xs: Vector<Int> = []
    for x in [1, 2, 3] {
        f := fn() Int { xs.len() }
        println("${f()}")
        xs = xs.append(x)
    }
    xs
}

println("${make().len()}")
