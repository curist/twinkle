// Aliasing before update means the old value is still observable via alias.
// In-place update would be unsound here.
// Expected output:
//   1

type Point = .{ x: Int, y: Int }

fn alias_view() Int {
    p := Point.{ x: 1, y: 2 }
    q := p
    p.x = 9
    q.x
}

println(alias_view().to_string())
