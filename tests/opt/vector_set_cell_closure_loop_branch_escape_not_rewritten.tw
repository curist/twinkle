// Stress pattern: loop + branch + Cell + closure-captured alias.
// Branch-local `ys := xs` escapes via closure stored in Cell, then xs is updated.
// Must keep VECTOR_SET_UNSAFE (no in-place rewrite), otherwise closure observes
// mutated value through alias.
//
// Expected output:
//   1
//   99

fn fold(xs: Vector<Int>, init: Int, f: fn(Int, Int) Int) Int {
    acc := init
    for x in xs {
        acc = f(acc, x)
    }
    acc
}

fn make(n: Int, c: Bool) Vector<Int> {
    xs := [1, 2, 3]
    slot := Cell.new(fn() Int { 7 })
    idxs := collect i in range(n) { i }
    checksum := fold(idxs, 0, fn(acc, x) {
        (acc + (x * x + 3 * x + 7)) % 1000003
    })

    for i in idxs {
        if c {
            if i == checksum - checksum {
                ys := xs
                Cell.set(slot, fn() Int { ys[0] })
            }
        }
        xs[0] = 99
    }

    f := Cell.get(slot)
    println("${f()}")
    xs
}

println("${make(10000, true)[0]}")
