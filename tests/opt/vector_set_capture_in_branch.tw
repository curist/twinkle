// Capture in a branch taints xs conservatively.
// Update after the branch must not rewrite.

fn make(c: Bool) Vector<Int> {
    xs := [1, 2, 3]
    if c {
        f := fn() Int { xs[0] }
        println("${f()}")
    } else {
        println("z")
    }
    xs[0] = 99
    xs
}

println("${make(true)[0]}")
