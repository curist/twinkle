// Helper-wrapped Dict.set inside a loop should still rewrite in place in the caller loop.
// Expected output:
//   10

fn put(d: Dict<String, Int>, k: String, v: Int) Dict<String, Int> {
    Dict.set(d, k, v)
}

fn build(n: Int) Dict<String, Int> {
    d: Dict<String, Int> = Dict.new()
    for i in range(n) {
        d = put(d, "key_${i}", i)
    }
    d
}

result := build(10)
println("${result.len()}")
