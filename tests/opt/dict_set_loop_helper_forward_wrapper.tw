// Forwarding helper-wrapped Dict.set inside a loop should still rewrite in place.
// Expected output:
//   10

fn put(d: Dict<String, Int>, k: String, v: Int) Dict<String, Int> {
    d2 := d
    out := Dict.set(d2, k, v)
    out2 := out
    out2
}

fn build(n: Int) Dict<String, Int> {
    d: Dict<String, Int> = Dict.new()
    for i in range(n) {
        d = put(d, "key_${i}", i)
    }
    d
}

result := build(10)
println("${result.len()}")
