// Dict remove in a loop on a unique dict should rewrite to __dict_remove_in_place.
// Expected output:
//   0

fn build_and_remove(n: Int) Dict<Int, Int> {
    d: Dict<Int, Int> = Dict.new()
    for i in range(n) {
        d[i] = i
    }
    for i in range(n) {
        d = d.remove(i)
    }
    d
}

result := build_and_remove(5)
println("${result.len()}")
