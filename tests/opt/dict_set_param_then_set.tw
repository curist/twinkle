// Phase B: COW on tainted param produces fresh result; second set should be in-place.
// Expected output:
//   2
//   10
//   20

fn update_twice(d: Dict<String, Int>) Dict<String, Int> {
    d1 := Dict.set(d, "a", 10)
    d2 := Dict.set(d1, "b", 20)
    d2
}

base: Dict<String, Int> = Dict.new()
result := update_twice(base)
println("${result.len()}")
case result["a"] {
    .Some(n) => println("${n}"),
    .None => println("missing"),
}
case result["b"] {
    .Some(n) => println("${n}"),
    .None => println("missing"),
}
