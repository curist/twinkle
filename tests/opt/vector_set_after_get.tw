// Vector.get is read-only (no-retain). The vector stays unique,
// so the subsequent set should be rewritten to in-place.

fn make() Vector<Int> {
    xs := [1, 2, 3]
    probe := xs.get(0)
    case probe {
        .Some(n) => println("${n}"),
        .None => println("none"),
    }
    xs[0] = 99
    xs
}

println("${make()[0]}")
