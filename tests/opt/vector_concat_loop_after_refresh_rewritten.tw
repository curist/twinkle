// Tainted local refreshed from a fresh non-empty vector should be eligible for
// loop concat builder rewrite via builder_from.
// Expected output:
//   4
//   10

fn build(seed: Vector<Int>) Vector<Int> {
    xs := seed
    xs = [1, 2]
    for i in range(2) {
        xs = xs.concat([i + 3])
    }
    xs
}

xs := build([99])
sum := 0
for x in xs {
    sum = sum + x
}
println("${xs.len()}")
println("${sum}")
