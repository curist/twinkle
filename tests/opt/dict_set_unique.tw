// Unique dict updates should rewrite to __dict_set_in_place.
// Expected output:
//   7
//   1

fn make() Dict<String, Int> {
    m: Dict<String, Int> = Dict.new()
    m["a"] = 1
    m["a"] = 7
    m
}

out := make()
case out["a"] {
    .Some(n) => println("${n}"),
    .None => println("missing"),
}
println("${out.len()}")
