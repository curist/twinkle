#!/usr/bin/env bash
set -euo pipefail

rust_files=()
while IFS= read -r file; do
  rust_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rs$' || true)

if [ "${#rust_files[@]}" -eq 0 ]; then
  exit 0
fi

cargo fmt --all -- "${rust_files[@]}"
git add -- "${rust_files[@]}"
