// Keywords
fn test() Void {
// <- keyword.function
  if true {
//^^ keyword.control
    return 42
//  ^^^^^^ keyword.return
  }

  for x in range(10) {
//^^^ keyword.control
//    ^ variable
//      ^^ keyword.control
    defer println("hi")
//  ^^^^^ keyword.control
    break
//  ^^^^^ keyword.control
  }

  case x {
//^^^^ keyword.control
    _ => continue,
//       ^^^^^^^^ keyword.control
  }
}

