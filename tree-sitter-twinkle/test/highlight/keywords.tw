// Keywords
fn test() Void {
// <- keyword
  if true {
//^^ keyword
    return 42
//  ^^^^^^ keyword.return
  }

  for x in range(10) {
//^^^ keyword
//    ^ variable
//      ^^ keyword
    break
//  ^^^^^ keyword.control
  }

  case x {
//^^^^ keyword
    _ => continue,
//       ^^^^^^^^ keyword.control
  }
}

