// Function declarations
fn add(x: Int, y: Int) Int {
// <- keyword.function
// ^^^ function
//     ^ variable.parameter
//             ^ variable.parameter
  x + y
}

// Function calls
result := add(1, 2)
//        ^^^ function.call

// Method calls
text := str.len()
//          ^^^ function.method.call

// Anonymous functions
mapper := fn(x: Int) Int { x * 2 }
//        ^^ keyword.function

// Higher-order functions
nums := [1, 2, 3]
doubled := nums.map(fn(x) { x * 2 })
//              ^^^ function.method.call
