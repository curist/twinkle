// Benchmark: iteration on a tiny vector (len=32, tail-only, shift=0).
// Compares iterator traversal vs indexed access at the tail-only size.
// Expected output:
//   496000000

n := 32
rounds := 1000000
xs := collect x in range(n) { x }

checksum := 0
r := 0
for r < rounds {
  for x in xs {
    checksum = checksum + x
  }
  r = r + 1
}
println("${checksum}")
