// Benchmark: builder-heavy vector construction plus iteration.
// This is a useful control workload because collect lowers through the
// builder fast path rather than repeated persistent append.
// Expected output:
//   2499950000

n := 50000
xs := collect x in range(n) { x * 2 }

sum := 0
for x in xs {
  sum = sum + x
}
println("${sum}")
