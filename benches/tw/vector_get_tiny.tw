// Benchmark: indexed reads on a tiny vector (len=32, tail-only, shift=0).
// This isolates the tail fast path with no trie descent.
// Expected output:
//   496000000

n := 32
rounds := 1000000
xs := collect x in range(n) { x }

checksum := 0
r := 0
for r < rounds {
  i := 0
  for i < n {
    checksum = checksum + xs[i]
    i = i + 1
  }
  r = r + 1
}
println("${checksum}")
