// Benchmark: indexed reads just past the depth boundary (len=1025, shift=10, depth=2).
// Compare with vector_get_1024 to isolate the cost of one extra trie level.
// Total reads: 1025 * 2500 = 2,562,500
// Expected output:
//   1312000000

n := 1025
rounds := 2500
xs := collect x in range(n) { x }

checksum := 0
r := 0
for r < rounds {
  i := 0
  for i < n {
    checksum = checksum + xs[i]
    i = i + 1
  }
  r = r + 1
}
println("${checksum}")
