// Benchmark: repeated indexed reads.
// Sensitive to Vector.get / indexing overhead.
// Expected output:
//   62498750000

n := 50000
rounds := 50
xs := collect x in range(n) { x }

checksum := 0
r := 0
for r < rounds {
  i := 0
  for i < n {
    checksum = checksum + xs[i]
    i = i + 1
  }
  r = r + 1
}
println("${checksum}")
