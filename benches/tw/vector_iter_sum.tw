// Benchmark: repeated iteration with `for x in xs`.
// Useful next to vector_get_sum.tw to separate iterator traversal from direct
// indexed access in user code.
// Expected output:
//   62498750000

n := 50000
rounds := 50
xs := collect x in range(n) { x }

checksum := 0
r := 0
for r < rounds {
  for x in xs {
    checksum = checksum + x
  }
  r = r + 1
}
println("${checksum}")
