// Benchmark: persistent point updates across the full vector.
// Sensitive to Vector.set / set_unsafe complexity.
// Expected output:
//   1250025000

n := 50000
xs := collect x in range(n) { x }

i := 0
for i < n {
  xs[i] = xs[i] + 1
  i = i + 1
}

sum := 0
for x in xs {
  sum = sum + x
}
println("${sum}")
