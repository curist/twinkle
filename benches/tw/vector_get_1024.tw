// Benchmark: indexed reads at the depth-1 ceiling (len=1024, shift=5).
// Compare with vector_get_1025 to isolate one extra trie level.
// Total reads: 1024 * 2500 = 2,560,000
// Expected output:
//   1309440000

n := 1024
rounds := 2500
xs := collect x in range(n) { x }

checksum := 0
r := 0
for r < rounds {
  i := 0
  for i < n {
    checksum = checksum + xs[i]
    i = i + 1
  }
  r = r + 1
}
println("${checksum}")
