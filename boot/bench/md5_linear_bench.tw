//! Probe: does reading message bytes from linear memory (i32.load8_u via __buf_*)
//! speed up MD5 vs reading from a GC Vector<Byte>? Self-contained faithful copy of
//! @std.crypto.md5's compression, with two byte-sources sharing identical rounds, so
//! the A/B isolates only the byte-read cost. Data is filled NATIVELY into each
//! representation (no cross-gather). Correctness gated on MD5("abc") + a vec/linear
//! cross-check (which also catches transcription errors). Throwaway measurement.

use @std.crypto.schedule as sched
use @std.date

fn u32(x: Int) Int {
  x & 0xffffffff
}

fn not32(x: Int) Int {
  x ^ 0xffffffff
}

fn rotl32(x: Int, sh: Int) Int {
  u32(u32(x) << sh | u32(x) >> 32 - sh)
}

fn byte(n: Int) Byte {
  Byte.from_int(n & 0xff).unwrap()
}

fn append_byte(out: Vector<Byte>, n: Int) Vector<Byte> {
  out.append(byte(n & 0xff))
}

fn padded_len(total_len: Int) Int {
  len := total_len + 1
  for len % 64 != 56 {
    len = len + 1
  }
  len + 8
}

fn s(i: Int) Int {
  case i {
    0 => 7,
    1 => 12,
    2 => 17,
    3 => 22,
    4 => 7,
    5 => 12,
    6 => 17,
    7 => 22,
    8 => 7,
    9 => 12,
    10 => 17,
    11 => 22,
    12 => 7,
    13 => 12,
    14 => 17,
    15 => 22,
    16 => 5,
    17 => 9,
    18 => 14,
    19 => 20,
    20 => 5,
    21 => 9,
    22 => 14,
    23 => 20,
    24 => 5,
    25 => 9,
    26 => 14,
    27 => 20,
    28 => 5,
    29 => 9,
    30 => 14,
    31 => 20,
    32 => 4,
    33 => 11,
    34 => 16,
    35 => 23,
    36 => 4,
    37 => 11,
    38 => 16,
    39 => 23,
    40 => 4,
    41 => 11,
    42 => 16,
    43 => 23,
    44 => 4,
    45 => 11,
    46 => 16,
    47 => 23,
    48 => 6,
    49 => 10,
    50 => 15,
    51 => 21,
    52 => 6,
    53 => 10,
    54 => 15,
    55 => 21,
    56 => 6,
    57 => 10,
    58 => 15,
    59 => 21,
    60 => 6,
    61 => 10,
    62 => 15,
    63 => 21,
    _ => error("md5: shift index out of range"),
  }
}

fn k(i: Int) Int {
  case i {
    0 => 0xd76aa478,
    1 => 0xe8c7b756,
    2 => 0x242070db,
    3 => 0xc1bdceee,
    4 => 0xf57c0faf,
    5 => 0x4787c62a,
    6 => 0xa8304613,
    7 => 0xfd469501,
    8 => 0x698098d8,
    9 => 0x8b44f7af,
    10 => 0xffff5bb1,
    11 => 0x895cd7be,
    12 => 0x6b901122,
    13 => 0xfd987193,
    14 => 0xa679438e,
    15 => 0x49b40821,
    16 => 0xf61e2562,
    17 => 0xc040b340,
    18 => 0x265e5a51,
    19 => 0xe9b6c7aa,
    20 => 0xd62f105d,
    21 => 0x02441453,
    22 => 0xd8a1e681,
    23 => 0xe7d3fbc8,
    24 => 0x21e1cde6,
    25 => 0xc33707d6,
    26 => 0xf4d50d87,
    27 => 0x455a14ed,
    28 => 0xa9e3e905,
    29 => 0xfcefa3f8,
    30 => 0x676f02d9,
    31 => 0x8d2a4c8a,
    32 => 0xfffa3942,
    33 => 0x8771f681,
    34 => 0x6d9d6122,
    35 => 0xfde5380c,
    36 => 0xa4beea44,
    37 => 0x4bdecfa9,
    38 => 0xf6bb4b60,
    39 => 0xbebfbc70,
    40 => 0x289b7ec6,
    41 => 0xeaa127fa,
    42 => 0xd4ef3085,
    43 => 0x04881d05,
    44 => 0xd9d4d039,
    45 => 0xe6db99e5,
    46 => 0x1fa27cf8,
    47 => 0xc4ac5665,
    48 => 0xf4292244,
    49 => 0x432aff97,
    50 => 0xab9423a7,
    51 => 0xfc93a039,
    52 => 0x655b59c3,
    53 => 0x8f0ccc92,
    54 => 0xffeff47d,
    55 => 0x85845dd1,
    56 => 0x6fa87e4f,
    57 => 0xfe2ce6e0,
    58 => 0xa3014314,
    59 => 0x4e0811a1,
    60 => 0xf7537e82,
    61 => 0xbd3af235,
