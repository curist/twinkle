/// Internal — unstable. Compiled-program representation for the Pike VM.
/// Not part of the `@std.regexp` public surface.

pub type ClassItem = .{ lo: Int, hi: Int }

pub type Inst = {
  Char(Int),
  AnyChar,
  Class(Vector<ClassItem>, Bool),
  Split(Int, Int),
  Jmp(Int),
  Save(Int),
  AssertStart,
  AssertEnd,
  Match,
}
