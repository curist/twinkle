/// Internal — unstable. Pattern string → Ast. Not part of the public surface.

use .program.{ClassItem}

pub type Ast = {
  Empty,
  Lit(Int),
  AnyChar,
  Class(Vector<ClassItem>, Bool),
  Concat(Vector<Ast>),
  Alt(Vector<Ast>),
  Star(Ast),
  Plus(Ast),
  Opt(Ast),
  Repeat(Ast, Int, Int),
  Group(Ast, Int),
  NonCap(Ast),
  AssertStart,
  AssertEnd,
}

pub type Parsed = .{ ast: Ast, group_count: Int, ignore_case: Bool }
