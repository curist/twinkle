//! Time utilities backed by the host runtime.

extern twinkle_runtime {
  fn now() Float
  fn sleep(ms: Int) Void
}

/// Return monotonic-ish milliseconds elapsed since the runtime time origin.
pub fn now() Float {
  twinkle_runtime.now()
}

/// Suspend for at least `ms` milliseconds when running on an async/JSPI runtime.
pub fn sleep(ms: Int) Void {
  twinkle_runtime.sleep(ms)
}
