//! Standard assertion helpers for `@std.testing` suites.
//! Each returns Result<Void, String> — Ok on pass, Err(message) on fail.
//! Use with `try` inside a test callback: `try assert.equal(actual, expected)`.

pub fn ok(cond_e: Bool, msg: String) Result<Void, String> {
  if cond_e {
    .Ok({})
  } else {
    .Err(msg)
  }
}

pub fn fail(msg: String) Result<Void, String> {
  .Err(msg)
}

pub fn str_contains(actual: String, expected_substring: String) Result<Void, String> {
  if actual.contains(expected_substring) {
    .Ok({})
  } else {
    .Err("expected \"${actual}\" to contain \"${expected_substring}\"")
  }
}

pub fn str_starts_with(actual: String, expected_prefix: String) Result<Void, String> {
  if actual.starts_with(expected_prefix) {
    .Ok({})
  } else {
    .Err("expected \"${actual}\" to start with \"${expected_prefix}\"")
  }
}

pub fn str_ends_with(actual: String, expected_suffix: String) Result<Void, String> {
  if actual.ends_with(expected_suffix) {
    .Ok({})
  } else {
    .Err("expected \"${actual}\" to end with \"${expected_suffix}\"")
  }
}

pub fn equal<T: Eq + Stringify>(actual: T, expected: T) Result<Void, String> {
  if actual == expected {
    .Ok({})
  } else {
    .Err("expected ${expected}, got ${actual}")
  }
}

pub fn is_true(actual: Bool) Result<Void, String> {
  if actual {
    .Ok({})
  } else {
    .Err("expected true, got false")
  }
}

pub fn is_false(actual: Bool) Result<Void, String> {
  if !actual {
    .Ok({})
  } else {
    .Err("expected false, got true")
  }
}

pub fn is_some<A>(opt: A?) Result<Void, String> {
  case opt {
    .Some(_) => .Ok({}),
    .None => .Err("expected Some, got None"),
  }
}

pub fn is_none<A>(opt: A?) Result<Void, String> {
  case opt {
    .Some(_) => .Err("expected None, got Some"),
    .None => .Ok({}),
  }
}

pub fn is_ok<A, E>(res: Result<A, E>) Result<Void, String> {
  case res {
    .Ok(_) => .Ok({}),
    .Err(_) => .Err("expected Ok, got Err"),
  }
}

pub fn is_err<A, E>(res: Result<A, E>) Result<Void, String> {
  case res {
    .Ok(_) => .Err("expected Err, got Ok"),
    .Err(_) => .Ok({}),
  }
}

pub fn err_eq<A>(res: Result<A, String>, expected_error: String) Result<Void, String> {
  case res {
    .Ok(_) => .Err("expected Err(\"${expected_error}\"), got Ok"),
    .Err(actual_error) => equal(actual_error, expected_error),
  }
}

pub fn err_contains<A>(res: Result<A, String>, expected_substring: String) Result<Void, String> {
  case res {
    .Ok(_) => .Err("expected Err containing \"${expected_substring}\", got Ok"),
    .Err(actual_error) => str_contains(actual_error, expected_substring),
  }
}

pub fn vec_len<A>(v: Vector<A>, expected_len: Int) Result<Void, String> {
  if v.len() == expected_len {
    .Ok({})
  } else {
    .Err("expected length ${expected_len}, got ${v.len()}")
  }
}

pub fn vec_contains(v: Vector<String>, item: String) Result<Void, String> {
  for s in v {
    if s == item {
      return .Ok({})
    }
  }

  .Err("expected vector to contain \"${item}\"")
}
