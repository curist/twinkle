extern twinkle_runtime {
  fn stderr_write_bytes(bytes: Vector<Byte>) Void
  fn is_terminal(fd: Int) Bool
}

/// Write raw bytes to stderr.
pub fn write_bytes(bytes: Vector<Byte>) {
  twinkle_runtime.stderr_write_bytes(bytes)
}

/// Write a string to stderr as UTF-8 bytes.
pub fn write_text(text: String) {
  write_bytes(text.utf8_bytes())
}

/// True when stderr is attached to a terminal.
pub fn is_terminal() Bool {
  twinkle_runtime.is_terminal(2)
}
