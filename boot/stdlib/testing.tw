//! Twinkle's standard test runner.
//!
//!   use @std.testing
//!   use @std.testing.assert
//!
//!   pub fn suite() testing.Suite {
//!     testing.suite("my feature")
//!       .test("does the thing", fn() {
//!         try assert.equal(1 + 1, 2)
//!         .Ok({})
//!       })
//!   }
//!
//! A test entry program aggregates suites and calls `testing.run_all([...])`,
//! which exits non-zero when any test fails. Reporting honors `TWK_TEST_FILTER`,
//! `TWK_TEST_REPORT=verbose`, and `NO_COLOR`.

use @std.proc

/// A single named test. `run` returns `.Ok` on success or `.Err(message)` on
/// failure.
pub type Test = .{ name: String, run: fn() Result<Void, String> }

/// A named group of tests, built fluently with `suite(name).test(...)`.
pub type Suite = .{ name: String, tests: Vector<Test> }

/// Reporting options: an optional substring `filter`, ANSI `color`, and
/// `verbose` (per-test) vs compact (dots) output.
pub type RunOptions = .{ filter: String?, color: Bool, verbose: Bool }

/// Aggregate counts for a run: `total` tests, plus how many `passed`, `failed`,
/// and were `filtered` out.
pub type RunStats = .{ total: Int, passed: Int, failed: Int, filtered: Int }

type FailedTest = .{ suite_name: String, test_name: String, message: String }

type SuiteRun = .{ stats: RunStats, failures: Vector<FailedTest> }

// ANSI helpers (inlined to avoid cross-lib dependency)
fn paint(enabled: Bool, code: String, s: String) String {
  if enabled {
    "\e[${code}m${s}\e[0m"
  } else {
    s
  }
}

fn green(enabled: Bool, s: String) String {
  paint(enabled, "32", s)
}

fn red(enabled: Bool, s: String) String {
  paint(enabled, "31", s)
}

fn bold(enabled: Bool, s: String) String {
  paint(enabled, "1", s)
}

fn dim(enabled: Bool, s: String) String {
  paint(enabled, "2", s)
}

fn env_filter() String? {
  out: String? = .None

  case proc.env("TWK_TEST_FILTER") {
    .Some(v) => {
      trimmed := v.trim()

      if trimmed != "" {
        out = .Some(trimmed)
      }
    },
    .None => {},
  }

  out
}

fn env_color_enabled() Bool {
  case proc.env("NO_COLOR") {
    .Some(_) => false,
    .None => true,
  }
}

fn env_verbose_enabled() Bool {
  case proc.env("TWK_TEST_REPORT") {
    .Some(v) => v.trim() == "verbose",
    .None => false,
  }
}

/// Reporting options derived from the environment: `TWK_TEST_FILTER` (substring
/// filter), `TWK_TEST_REPORT=verbose` (per-test output), and `NO_COLOR`.
pub fn default_options() RunOptions {
  .{ filter: env_filter(), color: env_color_enabled(), verbose: env_verbose_enabled() }
}

fn matches_filter(filter: String?, suite_name: String, test_name: String) Bool {
  case filter {
    .Some(f) => {
      // Support matching by bare test name or fully-qualified suite::test.
      test_name.contains(f) or "${suite_name}::${test_name}".contains(f)
    },
    .None => true,
  }
}

/// Start an empty suite named `name`. Chain `.test(...)` to add tests.
pub fn suite(name: String) Suite {
  Suite.{ name, tests: [] }
}

/// Append a test named `name` running `f` to `s`, returning the extended suite.
pub fn test(s: Suite, name: String, f: fn() Result<Void, String>) Suite {
  Suite.{ name: s.name, tests: s.tests.append(Test.{ name, run: f }) }
}

/// Run `s` with the default (environment-derived) options. Returns true when
/// every test passed.
pub fn run(s: Suite) Bool {
  s.run_with(default_options())
}

/// Run `s` with explicit `opts`. Returns true when no test failed.
pub fn run_with(s: Suite, opts: RunOptions) Bool {
  s.suite_stats_with(opts).failed == 0
}

/// Run `s` with default options and return its `RunStats`.
pub fn suite_stats(s: Suite) RunStats {
  s.suite_stats_with(default_options())
}

/// Run `s` with explicit `opts`, print its report, and return its `RunStats`.
pub fn suite_stats_with(s: Suite, opts: RunOptions) RunStats {
  if !opts.verbose {
    opts.print_compact_filter()
  }

  result := opts.run_suite(s)

  if !opts.verbose {
    opts.finish_compact_run(result.failures, result.stats.passed + result.stats.failed)
    opts.print_totals(
      result.stats.total,
      result.stats.passed,
      result.stats.failed,
      result.stats.filtered,
    )
  }

  result.stats
}

fn print_suite_header(opts: RunOptions, s: Suite) Void {
  header := "── ${s.name} ──"

  case opts.filter {
    .Some(f) => {
      header = "${header} ${dim(opts.color, "(filter: ${f})")}"
    },
    .None => {},
  }

  println(bold(opts.color, header))
}

fn print_suite_summary(opts: RunOptions, passed: Int, failed: Int, filtered: Int) Void {
  summary := "${passed} passed"

  if failed > 0 {
    summary = "${summary}, ${red(opts.color, "${failed} failed")}"
  }

  if filtered > 0 {
    summary = "${summary}, ${dim(opts.color, "${filtered} filtered out")}"
  }

  println("  ${summary}")
  println("")
}

fn print_compact_filter(opts: RunOptions) Void {
  case opts.filter {
    .Some(f) => println(dim(opts.color, "filter: ${f}")),
    .None => {},
  }
}

fn print_compact_marker(opts: RunOptions, ok: Bool) Void {
  if ok {
    print(green(opts.color, "."))
  } else {
    print(red(opts.color, "x"))
  }
}

fn print_failures(opts: RunOptions, failures: Vector<FailedTest>) Void {
  if failures.len() == 0 {
    return
  }

  println("")
  println(bold(opts.color, "Failed tests:"))

  for failure in failures {
    println("  ${red(opts.color, "x")} ${failure.suite_name}::${failure.test_name}")
    println("    ${dim(opts.color, "-> ${failure.message}")}")
  }

  println("")
}

fn finish_compact_run(opts: RunOptions, failures: Vector<FailedTest>, executed: Int) Void {
  if executed > 0 {
    println("")
  }

  opts.print_failures(failures)
}

fn run_suite(opts: RunOptions, s: Suite) SuiteRun {
  if opts.verbose {
    opts.print_suite_header(s)
  }

  total := s.tests.len()
  passed := 0
  failed := 0
  filtered := 0
  failures: Vector<FailedTest> = []

  for t in s.tests {
    if matches_filter(opts.filter, s.name, t.name) {
      case t.run() {
        .Ok(_) => {
          if opts.verbose {
            println("  ${green(opts.color, "✓")} ${t.name}")
          } else {
            opts.print_compact_marker(true)
          }

          passed = passed + 1
        },
        .Err(msg) => {
          if opts.verbose {
            println("  ${red(opts.color, "✗")} ${t.name} ${dim(opts.color, "→ ${msg}")}")
          } else {
            opts.print_compact_marker(false)
          }

          failures = .append(FailedTest.{ suite_name: s.name, test_name: t.name, message: msg })
          failed = failed + 1
        },
      }
    } else {
      filtered = filtered + 1
    }
  }

  if opts.verbose {
    opts.print_suite_summary(passed, failed, filtered)
  }

  SuiteRun.{ stats: RunStats.{ total, passed, failed, filtered }, failures }
}

/// Run every suite with default options, printing a combined report, and exit
/// the process non-zero if any test failed. The usual entry point for a test
/// program (`testing.run_all([suite_a.suite(), suite_b.suite()])`).
pub fn run_all(suites: Vector<Suite>) Void {
  run_all_with(suites, default_options())
}

/// Run every suite with default options and return the combined `RunStats`
/// without exiting.
pub fn run_all_stats(suites: Vector<Suite>) RunStats {
  run_all_stats_with(suites, default_options())
}

fn print_totals(opts: RunOptions, total: Int, passed: Int, failed: Int, filtered: Int) Void {
  line := "Ran ${total} tests: ${passed} passed"

  if failed > 0 {
    line = "${line}, ${red(opts.color, "${failed} failed")}"
  }

  if filtered > 0 {
    line = "${line}, ${dim(opts.color, "${filtered} filtered out")}"
  }

  println(bold(opts.color, line))
}

/// Run every suite with explicit `opts`, print the combined report, and return
/// the combined `RunStats` without exiting.
pub fn run_all_stats_with(suites: Vector<Suite>, opts: RunOptions) RunStats {
  total := 0
  passed := 0
  failed := 0
  filtered := 0
  failures: Vector<FailedTest> = []

  if !opts.verbose {
    opts.print_compact_filter()
  }

  for s in suites {
    result := opts.run_suite(s)
    total = total + result.stats.total
    passed = passed + result.stats.passed
    failed = failed + result.stats.failed
    filtered = filtered + result.stats.filtered
    failures = .concat(result.failures)
  }

  if !opts.verbose {
    opts.finish_compact_run(failures, passed + failed)
  } else {
    opts.print_failures(failures)
  }

  opts.print_totals(total, passed, failed, filtered)
  RunStats.{ total, passed, failed, filtered }
}

/// Run every suite with explicit `opts` and exit the process non-zero if any
/// test failed.
pub fn run_all_with(suites: Vector<Suite>, opts: RunOptions) Void {
  st := run_all_stats_with(suites, opts)

  if st.failed > 0 {
    proc.exit(1)
  }
}
