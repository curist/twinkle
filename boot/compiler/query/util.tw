// Shared helpers for query modules (hover, completion, definition, etc.).
/// Return the first mapped value that is not None.
pub fn find_map<A, B>(xs: Vector<A>, f: fn(A) B?) B? {
  for x in xs {
    v := f(x)

    if v.is_some() {
      return v
    }
  }

  .None
}

/// Like find_map but the callback also receives the index.
pub fn find_map_indexed<A, B>(xs: Vector<A>, f: fn(A, Int) B?) B? {
  for x, i in xs {
    v := f(x, i)

    if v.is_some() {
      return v
    }
  }

  .None
}
