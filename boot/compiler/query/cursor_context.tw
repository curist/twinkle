//! Shared cursor/source context helpers for editor-oriented query features.
//!
//! This module intentionally stays syntax-only: it may inspect source text,
//! bytes, and lexer tokens, but it does not perform semantic lookup or build
//! LSP response objects.

use compiler.lexer
use compiler.tokens.{Token}

type ScanResult = .{ name: String, commas: Int, paren_pos: Int }

pub type ImportPrefix = .{
  parent: Vector<String>,
  prefix: String,
  is_stdlib: Bool,
  is_relative: Bool,
}

pub type MemberContext = .{ dot_offset: Int, receiver_name: String? }

pub type RebindTarget = { Ident(String), FieldPath(Vector<String>) }

pub type RebindInfo = .{ dot_offset: Int, target: RebindTarget }

pub type CompletionContext = {
  Member(MemberContext),
  General(String),
  Import(ImportPrefix),
  Variant,
  RebindContinuation(RebindInfo),
}

pub type CallContext = .{ name: String, paren_offset: Int, active_parameter: Int }

/// Classify the source context at `offset` for completion. Cursor-hole lexing
/// keeps text after the cursor from being consumed as a continuation of the
/// construct being completed.
pub fn classify_completion(source: String, offset: Int) CompletionContext {
  lexed := lexer.lex_with_cursor(source, 0, offset)
  tokens := lexed.value
  cursor_idx := find_cursor_hole(tokens)

  if cursor_idx < 0 {
    return .General("")
  }

  if cursor_idx == 0 {
    return .General("")
  }

  prev := tokens[cursor_idx - 1]

  // Import context detection must run before dot/member checks since
  // `use @std.` should be Import, not Member.
  case try_extract_import_path(tokens, cursor_idx, source) {
    .Some(ip) => return .Import(ip),
    .None => {},
  }

  if prev.kind == .Dot {
    if cursor_idx >= 2 {
      before_dot := tokens[cursor_idx - 2]

      if before_dot.kind == .LBrace
        or before_dot.kind == .FatArrow
        or before_dot.kind == .Comma
        or before_dot.kind == .ColonEq
        or before_dot.kind == .Eq {
        return .Variant
      }
    } else {
      return .Variant
    }

    dot_offset := prev.span.start

    return .Member(.{ dot_offset, receiver_name: .Some(extract_ident_before(source, dot_offset)) })
  }

  if prev.kind == .Ident and cursor_idx >= 2 {
    before := tokens[cursor_idx - 2]

    if before.kind == .Dot {
      dot_offset := before.span.start

      return .Member(
        .{ dot_offset, receiver_name: .Some(extract_ident_before(source, dot_offset)) },
      )
    }
  }

  if prev.kind == .Ident {
    if offset >= prev.span.start and offset <= prev.span.end {
      prefix := source.slice(prev.span.start, offset)

      return .General(prefix)
    }
  }

  .General("")
}

/// Find the innermost open call containing `offset` by scanning backward from
/// the cursor through the current source text. This is designed for incomplete
/// editor text where the parser may not have a Call node yet, such as `foo(` or
/// `foo(a,`.
pub fn call_at(source: String, offset: Int) CallContext? {
  bytes := source.utf8_bytes()
  scan := try scan_back_to_call(bytes, offset)
  .Some(.{ name: scan.name, paren_offset: scan.paren_pos, active_parameter: scan.commas })
}

fn find_cursor_hole(tokens: Vector<Token>) Int {
  for i in 0..tokens.len() {
    if tokens[i].kind == .CursorHole {
      return i
    }
  }

  -1
}

fn try_extract_import_path(tokens: Vector<Token>, cursor_idx: Int, source: String) ImportPrefix? {
  if cursor_idx == 0 {
    return .None
  }

  i := cursor_idx - 1
  prefix := ""
  parent: Vector<String> = []
  is_stdlib := false
  found_use := false

  tk := tokens[i]

  if tk.kind == .Use {
    return .Some(.{ parent: [], prefix: "", is_stdlib: false, is_relative: false })
  }

  if tk.kind == .Ident {
    prefix = source.slice(tk.span.start, tk.span.end)
    i = i - 1
  } else if tk.kind == .Dot {
    i = i - 1
  } else {
    return .None
  }

  // Walk backwards through path segments. Stop at newline boundaries so a
  // member access on the next line is not misclassified as an import path.
  for i >= 0 {
    tk = tokens[i]

    if tk.preceded_by_newline and tk.kind != .Use {
      break
    }

    case tk.kind {
      .Use => {
        found_use = true
        break
      },
      .Ident => {
        name := source.slice(tk.span.start, tk.span.end)
        parent = .append(name)
      },
      .Dot => {},
      .At => {
        is_stdlib = true
      },
      _ => break,
    }

    i = i - 1
  }

  if !found_use {
    return .None
  }

  reversed: Vector<String> = []

  for k in 0..parent.len() {
    reversed = .append(parent[parent.len() - 1 - k])
  }

  is_relative := !is_stdlib and i + 1 < tokens.len() and tokens[i + 1].kind == .Dot

  .Some(.{ parent: reversed, prefix, is_stdlib, is_relative })
}

/// Extract the identifier immediately before `offset` from the source text.
/// E.g. for `io.` with offset pointing at the dot, returns `"io"`.
pub fn extract_ident_before(source: String, offset: Int) String {
  end := offset
  start := end

  for start > 0 {
    ch := source.slice(start - 1, start)

    if ch >= "a" and ch <= "z" or ch >= "A" and ch <= "Z" or ch == "_" or ch >= "0" and ch <= "9" {
      start = start - 1
    } else {
      break
    }
  }

  source.slice(start, end)
}

fn scan_back_to_call(bytes: Vector<Byte>, offset: Int) ScanResult? {
  // Walk backward from cursor to find the matching open paren, counting commas
  // at depth 0 relative to the call argument list.
  pos := offset - 1
  depth := 0
  commas := 0

  for pos >= 0 {
    b := bytes[pos].to_int()

    if b == 41 or b == 93 or b == 125 {
      // ) ] } — increase depth while going backward.
      depth = depth + 1
    } else if b == 91 or b == 123 {
      // [ { — decrease depth; if negative, the cursor is not in a call.
      depth = depth - 1

      if depth < 0 {
        return .None
      }
    } else if b == 40 {
      // (
      if depth == 0 {
        name := try extract_name_before(bytes, pos)

        return .Some(.{ name, commas, paren_pos: pos })
      }

      depth = depth - 1
    } else if b == 44 and depth == 0 {
      // , at the active call level.
      commas = commas + 1
    }

    pos = pos - 1
  }

  .None
}

fn extract_name_before(bytes: Vector<Byte>, paren_pos: Int) String? {
  // Walk backward from just before `(`, skipping whitespace, then collect
  // identifier characters. Dots are included so module-qualified names survive.
  pos := paren_pos - 1

  for pos >= 0 and is_whitespace(bytes[pos].to_int()) {
    pos = pos - 1
  }

  if pos < 0 {
    return .None
  }

  end := pos + 1

  for pos >= 0 and is_ident_or_dot(bytes[pos].to_int()) {
    pos = pos - 1
  }

  start := pos + 1

  if start >= end {
    return .None
  }

  name_bytes: Vector<Byte> = []

  for i in start..end {
    name_bytes = .append(bytes[i])
  }

  name := String.from_utf8(name_bytes).unwrap_or("")

  if name == "" {
    return .None
  }

  .Some(name)
}

fn is_whitespace(b: Int) Bool {
  b == 32 or b == 9 or b == 10 or b == 13
}

fn is_ident_or_dot(b: Int) Bool {
  b >= 97 and b <= 122 or b >= 65 and b <= 90 or b >= 48 and b <= 57 or b == 95 or b == 46
}
