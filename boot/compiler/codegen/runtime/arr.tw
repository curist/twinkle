          .ArrayLen,
          .ArrayCopy(t_array, t_array),
          .LocalGet(4),
          .RefAsNonNull,
          .LocalGet(1),
          .LocalGet(3),
          .I32Sub,
          .LocalGet(2),
          .ArraySet(t_array),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_len),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_shift),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_root),
          .LocalGet(4),
          .RefAsNonNull,
          .StructNew(t_pvec),
        ],
        [
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_len),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_shift),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_shift),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_root),
          .RefAsNonNull,
          .RefCast(false, .Eq),
          .LocalGet(1),
          .LocalGet(2),
          .Call("do_set"),
          .RefCast(true, .Named(t_vec_internal)),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_tail),
          .StructNew(t_pvec),
        ],
      ),
    ],
  }
}

// set_in_place(vec: PVec?, idx: i32, val: anyref) -> PVec
// True in-place mutation for vectors proven unique by the optimizer.
fn set_in_place_fn() FuncDef {
  p_vec := 0
  p_idx := 1
  p_val := 2

  // p0=vec, p1=idx, p2=val
  // Reuses get_leaf to find the leaf/tail, then mutates directly.
  .{
    name: "set_in_place",
    params: [pvec_null(), .I32, .Anyref],
    results: [pvec_ref()],
    locals: [],
    body: [
      .LocalGet(p_vec),
      .RefAsNonNull,
      .LocalGet(p_idx),
      .Call("get_leaf"),
      .LocalGet(p_val),
      .ArraySet(t_array),
      .LocalGet(p_vec),
      .RefAsNonNull,
    ],
  }
}

// ═══════════════════════════════════════════════════════════════════════
// Typed i64 persistent vector (PVecI64) — de-risking spike for the typed
// Vector<Int> representation. Mirrors the boxed ops above with i64 leaves and
// tail; the trie-build helpers (new_path/wrap_leaf/concat_trees/vi_nav) are
// shared (leaves are opaque `ref eq`). Only these thin PVecI64-struct wrappers
// are i64-specific. Reads return raw i64 — no BoxedInt pointer-chase or cast.
// ═══════════════════════════════════════════════════════════════════════
// promote_full_tail_i64(prefix: PVecI64, full_tail: ArrayI64) -> PVecI64
// Radix append of one full leaf. The builder only ever produces strict (radix)
// vectors, so we use push_tail + manual root-overflow growth rather than the
// RRB concat_trees (which inspects leaves as boxed Array). new_path/push_tail
// treat leaves as opaque `ref eq`, so ArrayI64 leaves work unchanged.
fn promote_full_tail_i64_fn() FuncDef {
  p_prefix := 0
  p_full_tail := 1
  l_cnt := 2
  l_shift := 3
  l_new_shift := 4
  l_new_root := 5
  l_nc := 6

  .{
    name: "promote_full_tail_i64",
    params: [pvec_i64_ref(), arr_i64_ref()],
    results: [pvec_i64_ref()],
    locals: [.I32, .I32, .I32, ref_eq_null(), vec_children_null()],
    body: [
      .LocalGet(p_prefix),
      .StructGet(t_pvec_i64, pv_len),
      .LocalSet(l_cnt),
      .LocalGet(p_prefix),
      .StructGet(t_pvec_i64, pv_shift),
      .LocalSet(l_shift),
      .LocalGet(p_prefix),
      .StructGet(t_pvec_i64, pv_root),
      .RefIsNull,
      .If(
        .None,
        [
          .I32Const(b_),
          .LocalSet(l_new_shift),
          .I32Const(b_),
          .LocalGet(p_full_tail),
          .RefCast(false, .Eq),
          .Call("new_path"),
          .LocalSet(l_new_root),
        ],
        [
          .LocalGet(l_cnt),
          .I32Const(b_),
          .I32ShrU,
          .I32Const(1),
          .LocalGet(l_shift),
          .I32Shl,
          .I32GeU,
          .If(
            .None,
            [
              .LocalGet(l_shift),
              .I32Const(b_),
              .I32Add,
              .LocalSet(l_new_shift),
              .RefNull(.Eq),
              .I32Const(bf),
              .ArrayNew(t_vec_children),
              .LocalSet(l_nc),
              .LocalGet(l_nc),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(p_prefix),
              .StructGet(t_pvec_i64, pv_root),
              .RefAsNonNull,
              .RefCast(false, .Eq),
              .ArraySet(t_vec_children),
              .LocalGet(l_nc),
              .RefAsNonNull,
              .I32Const(1),
              .LocalGet(l_shift),
              .LocalGet(p_full_tail),
              .RefCast(false, .Eq),
              .Call("new_path"),
              .ArraySet(t_vec_children),
              .LocalGet(l_nc),
              .RefAsNonNull,
              .RefNull(.Named(t_i32_array)),
              .StructNew(t_vec_internal),
              .RefCast(false, .Eq),
              .LocalSet(l_new_root),
            ],
            [
              .LocalGet(l_shift),
              .LocalSet(l_new_shift),
              .LocalGet(l_cnt),
              .I32Const(bf),
              .I32Add,
              .LocalGet(l_shift),
              .LocalGet(p_prefix),
              .StructGet(t_pvec_i64, pv_root),
              .LocalGet(p_full_tail),
              .RefCast(false, .Eq),
              .Call("push_tail"),
              .LocalSet(l_new_root),
            ],
          ),
        ],
      ),
      .LocalGet(l_cnt),
      .I32Const(bf),
      .I32Add,
      .LocalGet(l_new_shift),
      .LocalGet(l_new_root),
      .RefCast(true, .Named(t_vec_internal)),
      .GlobalGet("empty_leaf_i64"),
      .StructNew(t_pvec_i64),
    ],
  }
}

// builder_push_i64(builder: Array?, elem: i64) -> void
fn builder_push_i64_fn() FuncDef {
  ta := t_array
  tai := t_array_i64
  tbi := t_boxed_int

  // p0=builder, p1=elem (BoxedInt anyref); L2=tail_buf, L3=tail_len,
  // L4=pvec_so_far, L5=elem unboxed to i64. Takes a boxed element so the
  // typed-vector router can swap builder_push -> builder_push_i64 without
  // rewriting the (already-boxed) push argument; the unbox is one-time build
  // cost, not the hot read path.
  .{
    name: "builder_push_i64",
    params: [arr_null(), .Anyref],
    results: [],
    locals: [arr_i64_null(), .I32, pvec_i64_null(), .I64],
    body: [
      .LocalGet(1),
      .RefCast(false, .Named(tbi)),
      .StructGet(tbi, 0),
      .LocalSet(5),
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(2),
      .ArrayGet(ta),
      .RefCast(true, .Named(tai)),
      .LocalSet(2),
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(1),
      .ArrayGet(ta),
      .RefCast(false, .I31),
      .I31GetU,
      .LocalSet(3),
      .LocalGet(3),
      .I32Const(bf),
      .I32LtS,
      .If(
        .None,
        [
          .LocalGet(2),
          .RefAsNonNull,
          .LocalGet(3),
          .LocalGet(5),
          .ArraySet(tai),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(1),
          .LocalGet(3),
          .I32Const(1),
          .I32Add,
          .RefI31,
          .ArraySet(ta),
        ],
        [
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(0),
          .ArrayGet(ta),
          .RefCast(true, .Named(t_pvec_i64)),
          .LocalSet(4),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(4),
          .RefAsNonNull,
          .LocalGet(2),
          .RefAsNonNull,
          .Call("promote_full_tail_i64"),
          .ArraySet(ta),
          .I64Const(0),
          .I32Const(bf),
          .ArrayNew(tai),
          .LocalSet(2),
          .LocalGet(2),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(5),
          .ArraySet(tai),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(2),
          .LocalGet(2),
          .ArraySet(ta),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(1),
          .I32Const(1),
          .RefI31,
          .ArraySet(ta),
        ],
      ),
    ],
  }
}

// box_i64(vec: PVecI64?) -> PVec
// Representation-boundary adapter for returning a locally typed Vector<Int>
// through the ordinary boxed Vector<Int> ABI. This pays one boxing pass at the
// boundary while preserving raw i64 storage for in-function indexed reads.
fn box_i64_fn() FuncDef {
  tbi := t_boxed_int

  // p0=vec; L1=n, L2=i, L3=boxed_builder
  .{
    name: "box_i64",
    params: [pvec_i64_null()],
    results: [pvec_ref()],
    locals: [.I32, .I32, arr_null()],
    body: [
      .LocalGet(0),
      .Call("len_i64"),
      .LocalSet(1),
      .I32Const(0),
      .LocalSet(2),
      .Call("builder_new"),
      .LocalSet(3),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(2),
              .LocalGet(1),
              .I32GeS,
              .BrIf("brk"),
              .LocalGet(3),
              .LocalGet(0),
              .LocalGet(2),
              .Call("get_i64"),
              .StructNew(tbi),
              .Call("builder_push"),
              .LocalGet(2),
              .I32Const(1),
              .I32Add,
              .LocalSet(2),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(3),
      .Call("builder_freeze"),
    ],
  }
}

// append_centre(scratch: VecChildren, k: i32, centre: eqref, cs: i32,
//                seam_shift: i32) -> i32
// Append the seam subtree `centre` to scratch[k..]. When centre already sits at
// the seam level it is one child; otherwise it grew a level and we splice in its
// children. Returns the new k.
fn append_centre_fn() FuncDef {
  // p0=scratch, p1=k, p2=centre, p3=cs, p4=seam_shift; L5=cc
  .{
    name: "append_centre",
    params: [vec_children_ref(), .I32, ref_eq_(), .I32, .I32],
    results: [.I32],
    locals: [.I32],
    body: [
      .LocalGet(3),
      .LocalGet(4),
      .I32Eq,
      .If(
        .Some(.I32),
        [
          .LocalGet(0),
          .LocalGet(1),
          .LocalGet(2),
          .ArraySet(t_vec_children),
          .LocalGet(1),
          .I32Const(1),
          .I32Add,
        ],
        [
          .LocalGet(2),
          .RefCast(false, .Named(t_vec_internal)),
          .Call("child_count"),
          .LocalSet(5),
          .LocalGet(0),
          .LocalGet(1),
          .LocalGet(2),
          .RefCast(false, .Named(t_vec_internal)),
          .StructGet(t_vec_internal, vi_children),
          .I32Const(0),
          .LocalGet(5),
          .ArrayCopy(t_vec_children, t_vec_children),
          .LocalGet(1),
          .LocalGet(5),
          .I32Add,
        ],
      ),
    ],
  }
}

// concat_trees(l: VecInternal, sl: i32, r: VecInternal, sr: i32) -> (node, shift)
// RRB spine-merge: recurse along l's right edge and r's left edge to the common
// level, merge the seam, then greedily repack the boundary children into nodes of
// at most 32 (growing a level when the repacked count exceeds 32). Produces
// relaxed seam nodes; make_relaxed canonicalizes back to regular where it can.
fn concat_trees_fn() FuncDef {
