// builder_append_leaf_range(builder: Array?, leaf: Array, start: i32, len: i32) -> void
// Bulk-copy a contiguous leaf range into the builder tail, promoting full tails
// as needed. This preserves the builder-region append fast path without routing
// each element through builder_push.
fn builder_append_leaf_range_fn() FuncDef {
