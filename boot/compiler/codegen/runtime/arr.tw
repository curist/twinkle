          .StructGet(t_pvec(), pv_root()),
          .RefAsNonNull,
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_shift()),
          .LocalGet(2),
          .RefAsNonNull,
          .I32Const(0),
          .Call("copy_leaves"),
          .Drop,
        ],
        [],
      ),
      .LocalGet(5),
      .I32Eqz,
      .If(
        .None,
        [],
        [
          .LocalGet(2),
          .RefAsNonNull,
          .LocalGet(6),
          .LocalGet(4),
          .I32Const(0),
          .LocalGet(5),
          .ArrayCopy(ta, ta),
        ],
      ),
      .LocalGet(2),
      .RefAsNonNull,
    ],
  }
}

// from_read_file_result(v: Variant?) -> Variant?
// Host read_file returns Result<Array, String>; rewrite Ok(Array) to Ok(PVec).
fn from_read_file_result_fn() FuncDef {
  ta := t_array()
  tv := t_variant()
  variant_ref := ValType.Ref(true, .Named(tv))

  // p0=v, L1=payload
  FuncDef.{
    name: "from_read_file_result",
    params: [variant_ref],
    results: [variant_ref],
    locals: [arr_null()],
    body: [
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(tv, 0),
      .I32Const(1),
      .I32Eq,
      .If(
        .Some(variant_ref),
        [
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(tv, 1),
          .I32Eqz,
          .If(
            .Some(variant_ref),
            [
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(tv, 2),
              .LocalSet(1),
              .I32Const(1),
              .I32Const(0),
              .LocalGet(1),
              .RefAsNonNull,
              .I32Const(0),
              .ArrayGet(ta),
              .RefCast(false, .Named(ta)),
              .Call("from_array"),
              .ArrayNewFixed(ta, 1),
              .StructNew(tv),
            ],
            [.LocalGet(0)],
          ),
        ],
        [.LocalGet(0)],
      ),
    ],
  }
}

