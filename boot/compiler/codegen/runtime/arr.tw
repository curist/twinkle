      .RefAsNonNull,
      .StructGet(t_pvec(), pv_len()),
      .LocalSet(1),
      .RefNull(.None_),
      .LocalGet(1),
      .ArrayNew(ta),
      .LocalSet(2),
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_tail()),
      .LocalSet(4),
      .LocalGet(4),
      .ArrayLen,
      .LocalSet(5),
      .LocalGet(1),
      .LocalGet(5),
      .I32Sub,
      .LocalSet(6),
      .LocalGet(6),
      .I32Const(0),
      .I32GtS,
      .If(
        .None,
        [
          .LocalGet(0),
