              .I32Sub,
              .ArrayGet(vc),
              .RefCast(true, .Named(t_array)),
              .LocalSet(12),
              .LocalGet(2),
              .StructGet(vi, vi_children),
              .I32Const(0),
              .ArrayGet(vc),
              .RefCast(true, .Named(t_array)),
              .LocalSet(13),
              .LocalGet(12),
              .RefAsNonNull,
              .ArrayLen,
              .LocalGet(13),
              .RefAsNonNull,
