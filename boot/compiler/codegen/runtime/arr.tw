  }
}

// builder_freeze/builder_freeze_i64(builder: Array?) -> PVec
fn pvec_builder_freeze_fn(f: PVecFamily) FuncDef {
  // p0=builder, L1=pvec_so_far, L2=tail_len, L3=tail_buf, L4=final_tail
  .{
    name: f.builder_freeze_name,
    params: [arr_null()],
    results: [f.pvec_ref],
    locals: [f.pvec_null, .I32, f.arr_null, f.arr_null],
    body: [
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(0),
      .ArrayGet(t_array),
      .RefCast(true, .Named(f.pvec_ty)),
      .LocalSet(1),
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(1),
      .ArrayGet(t_array),
      .RefCast(false, .I31),
      .I31GetU,
      .LocalSet(2),
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(2),
      .ArrayGet(t_array),
      .RefCast(true, .Named(f.arr_ty)),
      .LocalSet(3),
      .LocalGet(2),
      .I32Eqz,
      .If(
        .Some(f.pvec_ref),
        [.LocalGet(1), .RefAsNonNull],
        [
          f.zero_value,
          .LocalGet(2),
          .ArrayNew(f.arr_ty),
          .LocalSet(4),
          .LocalGet(4),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(3),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(2),
          .ArrayCopy(f.arr_ty, f.arr_ty),
          .LocalGet(1),
          .RefAsNonNull,
          .StructGet(f.pvec_ty, pv_len),
          .LocalGet(2),
          .I32Add,
          .LocalGet(1),
          .RefAsNonNull,
          .StructGet(f.pvec_ty, pv_shift),
          .LocalGet(1),
          .RefAsNonNull,
          .StructGet(f.pvec_ty, pv_root),
          .LocalGet(4),
          .RefAsNonNull,
          .StructNew(f.pvec_ty),
        ],
      ),
    ],
  }
}

// set(vec: PVec?, idx: i32, val: anyref) -> PVec
fn set_fn() FuncDef {
  // p0=vec, p1=idx, p2=val, L3=tailoff, L4=new_tail
  .{
    name: "set",
    params: [pvec_null(), .I32, .Anyref],
