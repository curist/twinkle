              .LocalGet(2),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(1),
              .ArraySet(t_vec_children),
              .LocalGet(2),
              .RefAsNonNull,
              .RefNull(.Named(t_i32_array)),
              .StructNew(t_vec_internal),
              .RefCast(false, .Eq),
