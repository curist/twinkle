// ═══════════════════════════════════════════════════════════════════════
// Array ↔ PVec boundary conversion
// ═══════════════════════════════════════════════════════════════════════
// from_array(arr: Array) -> PVec
fn from_array_fn() FuncDef {
  ta := t_array()

  // p0=arr, L1=len, L2=pvec, L3=i, L4=leaf, L5=remaining, L6=tail
  FuncDef.{
    name: "from_array",
    params: [arr_ref()],
    results: [pvec_ref()],
    locals: [.I32, pvec_null(), .I32, arr_null(), .I32, arr_null()],
    body: [
      .LocalGet(0),
      .ArrayLen,
      .LocalSet(1),
      .LocalGet(1),
      .I32Eqz,
      .If(
        .Some(pvec_ref()),
        [.GlobalGet("empty_pvec")],
        [
          .LocalGet(1),
          .I32Const(bf()),
          .I32LeS,
          .If(
            .Some(pvec_ref()),
            [
              .LocalGet(1),
              .I32Const(0),
              .RefNull(.Named(t_vec_internal())),
              .LocalGet(0),
              .StructNew(t_pvec()),
            ],
            [
              .GlobalGet("empty_pvec"),
              .LocalSet(2),
              .I32Const(0),
              .LocalSet(3),
              .Block(
                "brk",
                .None,
                [
                  .Loop(
                    "lp",
                    .None,
                    [
                      .LocalGet(3),
                      .I32Const(bf()),
                      .I32Add,
                      .LocalGet(1),
                      .I32GeS,
                      .BrIf("brk"),
                      .RefNull(.None_),
                      .I32Const(bf()),
                      .ArrayNew(ta),
                      .LocalSet(4),
                      .LocalGet(4),
                      .RefAsNonNull,
                      .I32Const(0),
                      .LocalGet(0),
                      .LocalGet(3),
                      .I32Const(bf()),
                      .ArrayCopy(ta, ta),
                      .LocalGet(2),
                      .RefAsNonNull,
                      .LocalGet(4),
                      .RefAsNonNull,
                      .Call("promote_full_tail"),
                      .LocalSet(2),
                      .LocalGet(3),
                      .I32Const(bf()),
                      .I32Add,
                      .LocalSet(3),
                      .Br("lp"),
                    ],
                  ),
                ],
              ),
              .LocalGet(1),
              .LocalGet(3),
              .I32Sub,
              .LocalSet(5),
              .LocalGet(5),
              .I32Eqz,
              .If(
                .None,
                [.GlobalGet("empty_leaf"), .LocalSet(6)],
                [
                  .RefNull(.None_),
                  .LocalGet(5),
                  .ArrayNew(ta),
                  .LocalSet(6),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(0),
                  .LocalGet(3),
                  .LocalGet(5),
                  .ArrayCopy(ta, ta),
                ],
              ),
              .LocalGet(2),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_len()),
              .LocalGet(5),
              .I32Add,
              .LocalGet(2),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_shift()),
              .LocalGet(2),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_root()),
              .LocalGet(6),
              .RefAsNonNull,
              .StructNew(t_pvec()),
            ],
          ),
        ],
      ),
    ],
  }
}

// to_array(vec: PVec?) -> Array
