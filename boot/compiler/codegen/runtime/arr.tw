}

// slice_from_full_tree(node, shift, len) -> PVec
// Split the full tree back into PVec root + trailing leaf tail.
fn slice_from_full_tree_fn() FuncDef {
  vi := t_vec_internal

  // p0=node, p1=shift, p2=len; L3=tail, L4=root, L5=shift
  .{
    name: "slice_from_full_tree",
    params: [ref_eq_(), .I32, .I32],
    results: [pvec_ref()],
    locals: [arr_null(), vec_internal_null(), .I32],
    body: [
      .LocalGet(2),
      .I32Const(bf),
      .I32LeS,
      .If(
        .Some(pvec_ref()),
        [
          .LocalGet(2),
          .I32Const(0),
          .RefNull(.Named(vi)),
          .LocalGet(0),
          .LocalGet(1),
          .Call("slice_last_leaf"),
          .StructNew(t_pvec),
        ],
        [
          .LocalGet(0),
          .LocalGet(1),
          .Call("slice_last_leaf"),
          .LocalSet(3),
          .LocalGet(2),
          .LocalGet(1),
          .LocalGet(0),
          .RefCast(true, .Named(vi)),
          .Call("pop_tail"),
          .RefCast(true, .Named(vi)),
          .LocalSet(4),
          .LocalGet(1),
          .LocalSet(5),
          .LocalGet(4),
          .LocalGet(5),
          .Call("slice_collapse_root"),
          .LocalSet(5),
          .LocalSet(4),
          .LocalGet(2),
          .LocalGet(5),
          .LocalGet(4),
          .LocalGet(3),
          .RefAsNonNull,
          .StructNew(t_pvec),
        ],
      ),
    ],
  }
}

// slice_take_fast(vec: PVec?, end: i32) -> PVec
// Right-trim for take(0, end) when end > bf and end < len (the result needs a
// root). Mirror of the left-drop fast path: never folds the tail into the trie.
// If end reaches into the tail region (end > trie_count) the whole trie is kept
// and the tail is truncated; otherwise the trie is trimmed on the right and the
// tail is dropped. Caller guarantees the source root is non-null.
fn slice_take_fast_fn() FuncDef {
  ta := t_array

  p_v := 0
  p_end := 1
  l_trie := 2
  l_newtail := 3

  .{
    name: "slice_take_fast",
    params: [pvec_null(), .I32],
    results: [pvec_ref()],
    locals: [.I32, arr_null()],
    body: [
      // trie_count = len - tail.len
      .LocalGet(p_v),
      .RefAsNonNull,
      .StructGet(t_pvec, pv_len),
      .LocalGet(p_v),
      .RefAsNonNull,
      .StructGet(t_pvec, pv_tail),
      .ArrayLen,
      .I32Sub,
      .LocalSet(l_trie),
      .LocalGet(p_end),
      .LocalGet(l_trie),
      .I32GtS,
      .If(
        .Some(pvec_ref()),
        [
          // end reaches the tail: keep the whole trie, truncate the tail to
          // (end - trie_count) elements.
          .RefNull(.None_),
          .LocalGet(p_end),
          .LocalGet(l_trie),
          .I32Sub,
          .ArrayNew(ta),
          .LocalSet(l_newtail),
          .LocalGet(l_newtail),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(p_v),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_tail),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(p_end),
          .LocalGet(l_trie),
          .I32Sub,
          .ArrayCopy(ta, ta),
          .LocalGet(p_end),
          .LocalGet(p_v),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_shift),
          .LocalGet(p_v),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_root),
          .LocalGet(l_newtail),
          .RefAsNonNull,
          .StructNew(t_pvec),
        ],
        [
          // end stays within the trie: trim the trie on the right and drop the
          // tail entirely (slice_from_full_tree re-splits a fresh tail).
          .LocalGet(p_v),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_root),
          .RefAsNonNull,
          .RefCast(false, .Eq),
          .LocalGet(p_v),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_shift),
          .LocalGet(p_end),
          .Call("slice_trim_right"),
          .RefAsNonNull,
          .LocalGet(p_v),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_shift),
          .LocalGet(p_end),
          .Call("slice_from_full_tree"),
        ],
      ),
    ],
  }
}

// slice(vec: PVec?, start: i32, end: i32) -> PVec
fn slice_fn() FuncDef {
  ta := t_array
  vi := t_vec_internal

  // p0=vec, p1=start, p2=end; L3=len, L4=tmp_array, L5=tmp_leaf,
  // L6=full_node, L7=full_shift, L8=trimmed, L9=new_root, L10=new_shift
  .{
    name: "slice",
    params: [pvec_null(), .I32, .I32],
    results: [pvec_ref()],
    locals: [
      .I32,
      arr_null(),
      arr_null(),
      ref_eq_null(),
      .I32,
      ref_eq_null(),
      vec_internal_null(),
      .I32,
    ],
    body: [
      .LocalGet(2),
      .LocalGet(1),
      .I32Sub,
      .LocalSet(3),
      .LocalGet(3),
      .I32Eqz,
      .If(
        .Some(pvec_ref()),
        [.GlobalGet("empty_pvec")],
        [
          .LocalGet(1),
          .I32Eqz,
          .LocalGet(2),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_len),
          .I32Eq,
          .I32And,
          .If(
            .Some(pvec_ref()),
            [.LocalGet(0), .RefAsNonNull],
            [
              // left-drop fast path: the slice ends at len, the result still
              // needs a root, and the source has a trie. Trim only the left
              // spine and SHARE the existing tail, skipping the tail-fold +
              // re-split the general path below performs on every call.
              .LocalGet(2),
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_len),
              .I32Eq,
              .LocalGet(3),
              .I32Const(bf),
              .I32GtS,
              .I32And,
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_root),
              .RefIsNull,
              .I32Eqz,
              .I32And,
              .If(
                .Some(pvec_ref()),
                [
                  .LocalGet(0),
                  .RefAsNonNull,
                  .StructGet(t_pvec, pv_root),
                  .RefAsNonNull,
                  .RefCast(false, .Eq),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .StructGet(t_pvec, pv_shift),
                  .LocalGet(1),
                  .Call("slice_trim_left"),
                  .RefCast(false, .Named(vi)),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .StructGet(t_pvec, pv_shift),
                  .Call("slice_collapse_root"),
                  .LocalSet(10),
                  .LocalSet(9),
                  .LocalGet(3),
                  .LocalGet(10),
                  .LocalGet(9),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .StructGet(t_pvec, pv_tail),
                  .RefAsNonNull,
                  .StructNew(t_pvec),
                ],
                [
                  // take (right-trim) fast path: start==0 (so end<len here) and
                  // the result needs a root. Trim from the right without folding
                  // the tail into the trie like the general path below.
                  .LocalGet(1),
                  .I32Eqz,
                  .LocalGet(3),
                  .I32Const(bf),
                  .I32GtS,
                  .I32And,
                  .If(
                    .Some(pvec_ref()),
                    [.LocalGet(0), .LocalGet(2), .Call("slice_take_fast")],
                    [
                      .LocalGet(3),
                      .I32Const(bf),
                      .I32LeS,
                      .If(
                        .Some(pvec_ref()),
                        [
                          .LocalGet(0),
                          .Call("to_array"),
                          .LocalSet(4),
                          .RefNull(.None_),
                          .LocalGet(3),
                          .ArrayNew(ta),
                          .LocalSet(5),
                          .LocalGet(5),
                          .RefAsNonNull,
                          .I32Const(0),
                          .LocalGet(4),
                          .RefAsNonNull,
                          .LocalGet(1),
                          .LocalGet(3),
                          .ArrayCopy(ta, ta),
                          .LocalGet(5),
                          .RefAsNonNull,
                          .Call("from_array"),
                        ],
                        [
                          .LocalGet(0),
                          .RefAsNonNull,
                          .StructGet(t_pvec, pv_root),
                          .RefIsNull,
                          .If(
                            .None,
                            [
                              .LocalGet(0),
                              .RefAsNonNull,
                              .StructGet(t_pvec, pv_tail),
                              .RefCast(false, .Eq),
                              .LocalSet(6),
                              .I32Const(0),
                              .LocalSet(7),
                            ],
                            [
                              .LocalGet(0),
                              .RefAsNonNull,
                              .StructGet(t_pvec, pv_tail),
                              .ArrayLen,
                              .I32Eqz,
                              .If(
                                .None,
                                [
                                  .LocalGet(0),
                                  .RefAsNonNull,
                                  .StructGet(t_pvec, pv_root),
                                  .RefAsNonNull,
                                  .RefCast(false, .Eq),
                                  .LocalSet(6),
                                  .LocalGet(0),
                                  .RefAsNonNull,
                                  .StructGet(t_pvec, pv_shift),
                                  .LocalSet(7),
                                ],
                                [
                                  .LocalGet(0),
                                  .RefAsNonNull,
                                  .StructGet(t_pvec, pv_root),
                                  .RefAsNonNull,
                                  .LocalGet(0),
                                  .RefAsNonNull,
                                  .StructGet(t_pvec, pv_shift),
                                  .LocalGet(0),
                                  .RefAsNonNull,
                                  .StructGet(t_pvec, pv_tail),
                                  .Call("wrap_leaf"),
                                  .I32Const(b_),
                                  .Call("concat_trees"),
                                  .LocalSet(7),
                                  .LocalSet(6),
                                ],
                              ),
                            ],
                          ),
                          .LocalGet(6),
                          .RefAsNonNull,
                          .LocalGet(7),
                          .LocalGet(2),
                          .Call("slice_trim_right"),
                          .LocalSet(8),
                          .LocalGet(1),
                          .I32Eqz,
                          .If(
                            .None,
                            [],
                            [
                              .LocalGet(8),
                              .RefAsNonNull,
                              .LocalGet(7),
                              .LocalGet(1),
                              .Call("slice_trim_left"),
                              .LocalSet(8),
                            ],
                          ),
                          .LocalGet(8),
                          .RefAsNonNull,
                          .LocalGet(7),
                          .LocalGet(3),
                          .Call("slice_from_full_tree"),
                        ],
                      ),
                    ],
                  ),
                ],
              ),
            ],
          ),
        ],
      ),
    ],
  }
}

// pop_tail(len: i32, level: i32, node: VecInternal?) -> eqref
// Remove the rightmost leaf path from the trie. Relaxed-aware: follows the
// actual last child and rebuilds the spine with fresh size tables.
fn pop_tail_fn() FuncDef {
  p_len := 0
  p_level := 1
  p_node := 2
  l_count := 3
  l_new_children := 4
  l_new_child := 5
  l_new_count := 6

  // p0=len (ignored), p1=level, p2=node
  // L3=count, L4=new_children, L5=newchild, L6=new_count
  .{
    name: "pop_tail",
    params: [.I32, .I32, vec_internal_null()],
    results: [ref_eq_null()],
    locals: [.I32, vec_children_null(), ref_eq_null(), .I32],
    body: [
      .LocalGet(p_node),
      .RefAsNonNull,
      .Call("child_count"),
      .LocalSet(l_count),
      .LocalGet(p_level),
      .I32Const(b_),
      .I32GtS,
      .If(
        .None,
        [
          .LocalGet(p_len),
          .LocalGet(p_level),
          .I32Const(b_),
          .I32Sub,
          .LocalGet(p_node),
          .RefAsNonNull,
          .StructGet(t_vec_internal, vi_children),
          .LocalGet(l_count),
          .I32Const(1),
          .I32Sub,
          .ArrayGet(t_vec_children),
          .RefCast(true, .Named(t_vec_internal)),
          .Call("pop_tail"),
          .LocalSet(l_new_child),
          .LocalGet(l_count),
          .LocalSet(l_new_count),
          .LocalGet(l_new_child),
          .RefIsNull,
          .If(.None, [.LocalGet(l_count), .I32Const(1), .I32Sub, .LocalSet(l_new_count)], []),
        ],
        [
          .LocalGet(l_count),
          .I32Const(1),
          .I32Sub,
          .LocalSet(l_new_count),
          .RefNull(.Eq),
          .LocalSet(l_new_child),
        ],
      ),
      .LocalGet(l_new_count),
      .I32Eqz,
      .If(
        .Some(ref_eq_null()),
        [.RefNull(.Eq)],
        [
          .RefNull(.Eq),
          .I32Const(bf),
          .ArrayNew(t_vec_children),
          .LocalSet(l_new_children),
          .LocalGet(l_new_children),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(p_node),
          .RefAsNonNull,
          .StructGet(t_vec_internal, vi_children),
          .I32Const(0),
          .LocalGet(l_new_count),
          .ArrayCopy(t_vec_children, t_vec_children),
          .LocalGet(l_new_child),
          .RefIsNull,
          .If(
            .None,
            [],
            [
              .LocalGet(l_new_children),
              .RefAsNonNull,
              .LocalGet(l_new_count),
              .I32Const(1),
              .I32Sub,
              .LocalGet(l_new_child),
              .ArraySet(t_vec_children),
            ],
          ),
          .LocalGet(l_new_children),
          .RefAsNonNull,
          .LocalGet(l_new_count),
          .LocalGet(p_level),
          .Call("make_relaxed"),
          .RefCast(false, .Eq),
        ],
      ),
    ],
  }
}

// gather(vec: PVec?, idx: PVec?) -> PVec
// Build a vector where result[i] = vec[idx[i]]. The index vector stores Int
// elements as BoxedInt anyrefs; truncate to i32 before calling get.
fn gather_fn() FuncDef {
  // p0=vec, p1=idx; L2=n, L3=builder, L4=i, L5=k
  .{
    name: "gather",
    params: [pvec_null(), pvec_null()],
    results: [pvec_ref()],
    locals: [.I32, arr_null(), .I32, .I32],
    body: [
      .LocalGet(1),
      .Call("len"),
      .LocalSet(2),
      .Call("builder_new"),
      .LocalSet(3),
      .I32Const(0),
      .LocalSet(4),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(4),
              .LocalGet(2),
              .I32GeS,
              .BrIf("brk"),
              .LocalGet(1),
              .LocalGet(4),
              .Call("get"),
              .RefCast(false, .Named(t_boxed_int)),
              .StructGet(t_boxed_int, 0),
              .I32WrapI64,
              .LocalSet(5),
              .LocalGet(3),
              .LocalGet(0),
              .LocalGet(5),
              .Call("get"),
              .Call("builder_push"),
              .LocalGet(4),
              .I32Const(1),
              .I32Add,
              .LocalSet(4),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(3),
      .Call("builder_freeze"),
    ],
  }
}

// Typed sort element descriptor. The trie/vector scaffolding is shared; only
// leaf array type, boxed input/output type, value type, and comparison op vary.
type VecElem = .{
  suffix: String,
  arr_ty: String,
  arr_null: ValType,
  boxed_ty: String,
  elem_ty: ValType,
  le_op: Instr,
}

fn elem_i64() VecElem {
  .{
    suffix: "i64",
    arr_ty: t_array_i64,
    arr_null: arr_i64_null(),
    boxed_ty: t_boxed_int,
    elem_ty: .I64,
    le_op: .I64LeS,
  }
}

fn elem_f64() VecElem {
  .{
    suffix: "f64",
    arr_ty: t_array_f64,
    arr_null: arr_f64_null(),
    boxed_ty: t_boxed_float,
    elem_ty: .F64,
    le_op: .F64Le,
  }
}

// sort_<suffix>(vec: PVec?) -> PVec
// Native typed value sort over Vector<Int>/Vector<Float>. Boxes once in / once
// out: copies unboxed keys into a dense typed array, runs a stable bottom-up
// merge sort over raw values, then rebuilds a PVec via the builder.
//
// The merge ping-pongs between `src` and `aux`, doubling the run width each
// pass; the final `src` handle holds the sorted data. The merge is stable:
// on a tie the element from the left run is taken first. Float NaN behavior is
// preserved from the old f64 path because the descriptor uses the same f64.le
// instruction.
fn sort_typed_fn(e: VecElem) FuncDef {
  p_vec := 0
  l_n := 1
  l_src := 2
  l_aux := 3
  l_i := 4
  l_builder := 5
  l_width := 6
  l_lo := 7
  l_mid := 8
  l_hi := 9
  l_j := 10
  l_k := 11
  l_tmp := 12

  // p0=vec; L1=n, L2=src(typed[]), L3=aux(typed[]), L4=i/loop, L5=builder,
  // L6=width, L7=lo, L8=mid, L9=hi, L10=j, L11=k, L12=tmp(typed[])
  .{
    name: "sort_${e.suffix}",
    params: [pvec_null()],
    results: [pvec_ref()],
    locals: [
      .I32,
      e.arr_null,
      e.arr_null,
      .I32,
      arr_null(),
      .I32,
      .I32,
      .I32,
      .I32,
      .I32,
      .I32,
      e.arr_null,
    ],
    body: [
      .LocalGet(p_vec),
      .Call("len"),
      .LocalSet(l_n),
      .LocalGet(l_n),
      .I32Const(1),
      .I32LeS,
      .If(
        .Some(pvec_ref()),
        [.LocalGet(p_vec), .RefAsNonNull],
        [
          .LocalGet(l_n),
          .ArrayNewDefault(e.arr_ty),
          .LocalSet(l_src),
          .LocalGet(l_n),
          .ArrayNewDefault(e.arr_ty),
          .LocalSet(l_aux),
          .I32Const(0),
          .LocalSet(l_i),
          .Block(
            "copy_brk",
            .None,
            [
              .Loop(
                "copy_lp",
                .None,
                [
                  .LocalGet(l_i),
                  .LocalGet(l_n),
                  .I32GeS,
                  .BrIf("copy_brk"),
                  .LocalGet(l_src),
                  .RefAsNonNull,
                  .LocalGet(l_i),
                  .LocalGet(p_vec),
                  .LocalGet(l_i),
                  .Call("get"),
                  .RefCast(false, .Named(e.boxed_ty)),
                  .StructGet(e.boxed_ty, 0),
                  .ArraySet(e.arr_ty),
                  .LocalGet(l_i),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(l_i),
                  .Br("copy_lp"),
                ],
              ),
            ],
          ),
          .I32Const(1),
          .LocalSet(l_width),
          .Block(
            "w_brk",
            .None,
            [
              .Loop(
                "w_lp",
                .None,
                [
                  .LocalGet(l_width),
                  .LocalGet(l_n),
                  .I32GeS,
                  .BrIf("w_brk"),
                  .I32Const(0),
                  .LocalSet(l_lo),
                  .Block(
                    "lo_brk",
                    .None,
                    [
                      .Loop(
                        "lo_lp",
                        .None,
                        [
                          .LocalGet(l_lo),
                          .LocalGet(l_n),
                          .I32GeS,
                          .BrIf("lo_brk"),
                          .LocalGet(l_lo),
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_n),
                          .LocalGet(l_lo),
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_n),
                          .I32LtS,
                          .Select,
                          .LocalSet(l_mid),
                          .LocalGet(l_lo),
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_n),
                          .LocalGet(l_lo),
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_n),
                          .I32LtS,
                          .Select,
                          .LocalSet(l_hi),
                          .LocalGet(l_lo),
                          .LocalSet(l_i),
                          .LocalGet(l_mid),
                          .LocalSet(l_j),
                          .LocalGet(l_lo),
                          .LocalSet(l_k),
                          .Block(
                            "m_brk",
                            .None,
                            [
                              .Loop(
                                "m_lp",
                                .None,
                                [
                                  .LocalGet(l_k),
                                  .LocalGet(l_hi),
                                  .I32GeS,
                                  .BrIf("m_brk"),
                                  .LocalGet(l_aux),
                                  .RefAsNonNull,
                                  .LocalGet(l_k),
                                  .LocalGet(l_i),
                                  .LocalGet(l_mid),
                                  .I32GeS,
                                  .If(
                                    .Some(e.elem_ty),
                                    [
                                      .LocalGet(l_src),
                                      .RefAsNonNull,
                                      .LocalGet(l_j),
                                      .ArrayGet(e.arr_ty),
                                      .LocalGet(l_j),
                                      .I32Const(1),
                                      .I32Add,
                                      .LocalSet(l_j),
                                    ],
                                    [
                                      .LocalGet(l_j),
                                      .LocalGet(l_hi),
                                      .I32GeS,
                                      .If(
                                        .Some(e.elem_ty),
                                        [
                                          .LocalGet(l_src),
                                          .RefAsNonNull,
                                          .LocalGet(l_i),
                                          .ArrayGet(e.arr_ty),
                                          .LocalGet(l_i),
                                          .I32Const(1),
                                          .I32Add,
                                          .LocalSet(l_i),
                                        ],
                                        [
                                          .LocalGet(l_src),
                                          .RefAsNonNull,
                                          .LocalGet(l_i),
                                          .ArrayGet(e.arr_ty),
                                          .LocalGet(l_src),
                                          .RefAsNonNull,
                                          .LocalGet(l_j),
                                          .ArrayGet(e.arr_ty),
                                          e.le_op,
                                          .If(
                                            .Some(e.elem_ty),
                                            [
                                              .LocalGet(l_src),
                                              .RefAsNonNull,
                                              .LocalGet(l_i),
                                              .ArrayGet(e.arr_ty),
                                              .LocalGet(l_i),
                                              .I32Const(1),
                                              .I32Add,
                                              .LocalSet(l_i),
                                            ],
                                            [
                                              .LocalGet(l_src),
                                              .RefAsNonNull,
                                              .LocalGet(l_j),
                                              .ArrayGet(e.arr_ty),
                                              .LocalGet(l_j),
                                              .I32Const(1),
                                              .I32Add,
                                              .LocalSet(l_j),
                                            ],
                                          ),
                                        ],
                                      ),
                                    ],
                                  ),
                                  .ArraySet(e.arr_ty),
                                  .LocalGet(l_k),
                                  .I32Const(1),
                                  .I32Add,
                                  .LocalSet(l_k),
                                  .Br("m_lp"),
                                ],
                              ),
                            ],
                          ),
                          .LocalGet(l_lo),
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalGet(l_width),
                          .I32Add,
                          .LocalSet(l_lo),
                          .Br("lo_lp"),
                        ],
                      ),
                    ],
                  ),
                  .LocalGet(l_src),
                  .LocalSet(l_tmp),
                  .LocalGet(l_aux),
                  .LocalSet(l_src),
                  .LocalGet(l_tmp),
                  .LocalSet(l_aux),
                  .LocalGet(l_width),
                  .I32Const(1),
                  .I32Shl,
                  .LocalSet(l_width),
                  .Br("w_lp"),
                ],
              ),
            ],
          ),
          .Call("builder_new"),
          .LocalSet(l_builder),
          .I32Const(0),
          .LocalSet(l_i),
          .Block(
            "push_brk",
            .None,
            [
              .Loop(
                "push_lp",
                .None,
                [
                  .LocalGet(l_i),
                  .LocalGet(l_n),
                  .I32GeS,
                  .BrIf("push_brk"),
                  .LocalGet(l_builder),
                  .LocalGet(l_src),
                  .RefAsNonNull,
                  .LocalGet(l_i),
                  .ArrayGet(e.arr_ty),
                  .StructNew(e.boxed_ty),
                  .Call("builder_push"),
                  .LocalGet(l_i),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(l_i),
                  .Br("push_lp"),
                ],
              ),
            ],
          ),
          .LocalGet(l_builder),
          .Call("builder_freeze"),
        ],
      ),
    ],
  }
}

// drop_last(vec: PVec?) -> PVec
// Return vec without its last element; the empty vector if already empty.
// O(1) amortized: shrinks the tail, pulling the last trie leaf back into the
// tail only at a 32-boundary (then O(log n)). Inverse of push.
fn drop_last_fn() FuncDef {
  p_vec := 0
  l_len := 1
  l_trie_count := 2
  l_tail_len := 3
  l_new_tail := 4
  l_new_root := 5
  l_new_shift := 6
  l_shift := 7
  l_leaf := 8
  l_copy_len := 9

  ta := t_array

  // p0=vec
  // L1=len, L2=trie_count, L3=tail_len, L4=new_tail, L5=new_root, L6=new_shift, L7=shift, L8=leaf, L9=copy_len
  .{
    name: "drop_last",
    params: [pvec_null()],
    results: [pvec_ref()],
    locals: [.I32, .I32, .I32, arr_null(), ref_eq_null(), .I32, .I32, arr_null(), .I32],
    body: [
      .LocalGet(p_vec),
      .RefAsNonNull,
      .StructGet(t_pvec, pv_len),
      .LocalSet(l_len),
      .LocalGet(l_len),
      .I32Const(1),
      .I32LeS,
      .If(
        .Some(pvec_ref()),
        [.GlobalGet("empty_pvec")],
        [
          .LocalGet(p_vec),
          .RefAsNonNull,
          .StructGet(t_pvec, pv_tail),
          .ArrayLen,
          .LocalSet(l_tail_len),
          .LocalGet(l_len),
          .LocalGet(l_tail_len),
          .I32Sub,
          .LocalSet(l_trie_count),
          .LocalGet(l_tail_len),
          .I32Const(1),
          .I32GtS,
          .If(
            .Some(pvec_ref()),
            [
              .RefNull(.None_),
              .LocalGet(l_tail_len),
              .I32Const(1),
              .I32Sub,
              .ArrayNew(ta),
              .LocalSet(l_new_tail),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_tail),
              .I32Const(0),
              .LocalGet(l_tail_len),
              .I32Const(1),
              .I32Sub,
              .ArrayCopy(ta, ta),
              .LocalGet(l_len),
              .I32Const(1),
              .I32Sub,
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_shift),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_root),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .StructNew(t_pvec),
            ],
            [
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_shift),
              .LocalSet(l_shift),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .LocalGet(l_tail_len),
              .I32Eqz,
              .If(
                .Some(.I32),
                [.LocalGet(l_len), .I32Const(1), .I32Sub],
                [.LocalGet(l_len), .I32Const(2), .I32Sub],
              ),
              .Call("get_leaf"),
              .LocalSet(l_copy_len),
              .LocalSet(l_leaf),
              .LocalGet(l_tail_len),
              .I32Eqz,
              .If(.None, [], [.LocalGet(l_leaf), .RefAsNonNull, .ArrayLen, .LocalSet(l_copy_len)]),
              .RefNull(.None_),
              .LocalGet(l_copy_len),
              .ArrayNew(ta),
              .LocalSet(l_new_tail),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(l_leaf),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(l_copy_len),
              .ArrayCopy(ta, ta),
              .LocalGet(l_len),
              .LocalGet(l_shift),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec, pv_root),
              .Call("pop_tail"),
              .LocalSet(l_new_root),
              .LocalGet(l_shift),
              .LocalSet(l_new_shift),
              .LocalGet(l_new_root),
              .RefIsNull,
              .If(
                .None,
                [.I32Const(0), .LocalSet(l_new_shift)],
                [
                  .LocalGet(l_shift),
                  .I32Const(b_),
                  .I32GtS,
                  .If(
                    .None,
                    [
                      .LocalGet(l_new_root),
                      .RefCast(false, .Named(t_vec_internal)),
                      .Call("child_count"),
                      .I32Const(1),
                      .I32Eq,
                      .If(
                        .None,
                        [
                          .LocalGet(l_new_root),
                          .RefCast(false, .Named(t_vec_internal)),
                          .StructGet(t_vec_internal, vi_children),
                          .I32Const(0),
                          .ArrayGet(t_vec_children),
                          .LocalSet(l_new_root),
                          .LocalGet(l_shift),
                          .I32Const(b_),
                          .I32Sub,
                          .LocalSet(l_new_shift),
                        ],
                        [],
                      ),
                    ],
                    [],
                  ),
                ],
              ),
              .LocalGet(l_len),
              .I32Const(1),
              .I32Sub,
              .LocalGet(l_new_shift),
              .LocalGet(l_new_root),
              .RefCast(true, .Named(t_vec_internal)),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .StructNew(t_pvec),
            ],
          ),
        ],
      ),
    ],
  }
}

// ═══════════════════════════════════════════════════════════════════════
// Builder: transient mutable-tail design
//
// Builder layout (3-slot $Array):
//   [0] = pvec_so_far : PVec (trie prefix, tail always empty)
//   [1] = tail_len    : i31ref
//   [2] = tail_buf    : Array (mutable 32-slot buffer)
// ═══════════════════════════════════════════════════════════════════════
// promote_full_tail(prefix: PVec, full_tail: Array) -> PVec
// Integrates a full 32-element tail into the trie, returning a PVec with empty tail.
fn promote_full_tail_fn() FuncDef {
  p_prefix := 0
  p_full_tail := 1
  l_len := 2
  l_shift := 3
  l_new_root := 4

  // p0=prefix, p1=full_tail
  // L2=len (prefix.len + 32), L3=shift, L4=new_root
  .{
    name: "promote_full_tail",
    params: [pvec_ref(), arr_ref()],
    results: [pvec_ref()],
    locals: [.I32, .I32, ref_eq_null()],
    body: [
      .LocalGet(p_prefix),
      .StructGet(t_pvec, pv_len),
      .I32Const(bf),
      .I32Add,
      .LocalSet(l_len),
      .LocalGet(p_prefix),
      .StructGet(t_pvec, pv_shift),
      .LocalSet(l_shift),
      .LocalGet(p_prefix),
      .StructGet(t_pvec, pv_root),
      .RefIsNull,
      .If(
        .None,
        [
          .I32Const(b_),
          .LocalSet(l_shift),
          .I32Const(b_),
          .LocalGet(p_full_tail),
          .RefCast(false, .Eq),
          .Call("new_path"),
          .LocalSet(l_new_root),
        ],
        [
          .LocalGet(p_prefix),
          .StructGet(t_pvec, pv_root),
          .RefAsNonNull,
          .LocalGet(l_shift),
          .LocalGet(p_full_tail),
          .Call("wrap_leaf"),
          .I32Const(b_),
          .Call("concat_trees"),
          .LocalSet(l_shift),
          .LocalSet(l_new_root),
        ],
      ),
      .LocalGet(l_len),
      .LocalGet(l_shift),
      .LocalGet(l_new_root),
      .RefCast(true, .Named(t_vec_internal)),
      .GlobalGet("empty_leaf"),
      .StructNew(t_pvec),
    ],
  }
}

// vec_i64_roundtrip(xs: PVec?) -> PVec
// Internal correctness hook for the typed PVecI64 family: build a PVecI64 from
// a boxed Vector<Int>, then read every element back via len_i64/get_i64 into a
// fresh boxed vector. A test asserts `vec_i64_roundtrip(xs) == xs` across many
// sizes, exercising the typed builder + get over all trie shapes. (Dormant
// until S2 routes idiomatic code to the typed family; remove or fold into a
// unit test then.)
fn vec_i64_roundtrip_fn() FuncDef {
  tbi := t_boxed_int

  // p0=xs; L1=n, L2=bi (i64 builder), L3=i, L4=pv64, L5=bo (boxed builder)
  .{
    name: "vec_i64_roundtrip",
    params: [pvec_null()],
    results: [pvec_ref()],
    locals: [.I32, arr_null(), .I32, pvec_i64_null(), arr_null()],
    body: [
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(t_pvec, pv_len),
      .LocalSet(1),
      .Call("builder_new_i64"),
      .LocalSet(2),
      .I32Const(0),
      .LocalSet(3),
      .Block(
        "bbrk",
        .None,
        [
          .Loop(
            "blp",
            .None,
            [
              .LocalGet(3),
              .LocalGet(1),
              .I32GeS,
              .BrIf("bbrk"),
              .LocalGet(2),
              .LocalGet(0),
              .LocalGet(3),
              .Call("get"),
              .Call("builder_push_i64"),
              .LocalGet(3),
              .I32Const(1),
              .I32Add,
              .LocalSet(3),
              .Br("blp"),
            ],
          ),
        ],
      ),
      .LocalGet(2),
      .Call("builder_freeze_i64"),
      .LocalSet(4),
      .Call("builder_new"),
      .LocalSet(5),
      .I32Const(0),
      .LocalSet(3),
      .Block(
        "rbrk",
        .None,
        [
          .Loop(
            "rlp",
            .None,
            [
              .LocalGet(3),
              .LocalGet(4),
              .Call("len_i64"),
              .I32GeS,
              .BrIf("rbrk"),
              .LocalGet(5),
              .LocalGet(4),
              .LocalGet(3),
              .Call("get_i64"),
              .StructNew(tbi),
              .Call("builder_push"),
              .LocalGet(3),
              .I32Const(1),
              .I32Add,
              .LocalSet(3),
              .Br("rlp"),
            ],
          ),
        ],
      ),
      .LocalGet(5),
      .Call("builder_freeze"),
    ],
  }
}

