// pop_tail(len: i32, level: i32, node: VecInternal?) -> eqref
// Remove the rightmost leaf path from the trie. Relaxed-aware: follows the
// actual last child and rebuilds the spine with fresh size tables.
fn pop_tail_fn() FuncDef {
  p_len := 0
  p_level := 1
  p_node := 2
  l_count := 3
  l_new_children := 4
  l_new_child := 5
  l_new_count := 6

  // p0=len (ignored), p1=level, p2=node
  // L3=count, L4=new_children, L5=newchild, L6=new_count
  .{
    name: "pop_tail",
    params: [.I32, .I32, vec_internal_null()],
    results: [ref_eq_null()],
    locals: [.I32, vec_children_null(), ref_eq_null(), .I32],
    body: [
      .LocalGet(p_node),
      .RefAsNonNull,
      .Call("child_count"),
      .LocalSet(l_count),
      .LocalGet(p_level),
      .I32Const(b_()),
      .I32GtS,
      .If(
        .None,
        [
          .LocalGet(p_len),
          .LocalGet(p_level),
          .I32Const(b_()),
          .I32Sub,
          .LocalGet(p_node),
          .RefAsNonNull,
          .StructGet(t_vec_internal(), vi_children()),
          .LocalGet(l_count),
          .I32Const(1),
          .I32Sub,
          .ArrayGet(t_vec_children()),
          .RefCast(true, .Named(t_vec_internal())),
          .Call("pop_tail"),
          .LocalSet(l_new_child),
          .LocalGet(l_count),
          .LocalSet(l_new_count),
          .LocalGet(l_new_child),
          .RefIsNull,
          .If(.None, [.LocalGet(l_count), .I32Const(1), .I32Sub, .LocalSet(l_new_count)], []),
        ],
        [
          .LocalGet(l_count),
          .I32Const(1),
          .I32Sub,
          .LocalSet(l_new_count),
          .RefNull(.Eq),
          .LocalSet(l_new_child),
        ],
      ),
      .LocalGet(l_new_count),
      .I32Eqz,
      .If(
        .Some(ref_eq_null()),
        [.RefNull(.Eq)],
        [
          .RefNull(.Eq),
          .I32Const(bf()),
          .ArrayNew(t_vec_children()),
          .LocalSet(l_new_children),
          .LocalGet(l_new_children),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(p_node),
          .RefAsNonNull,
          .StructGet(t_vec_internal(), vi_children()),
          .I32Const(0),
          .LocalGet(l_new_count),
          .ArrayCopy(t_vec_children(), t_vec_children()),
          .LocalGet(l_new_child),
          .RefIsNull,
          .If(
            .None,
            [],
            [
              .LocalGet(l_new_children),
              .RefAsNonNull,
              .LocalGet(l_new_count),
              .I32Const(1),
              .I32Sub,
              .LocalGet(l_new_child),
              .ArraySet(t_vec_children()),
            ],
          ),
          .LocalGet(l_new_children),
          .RefAsNonNull,
          .LocalGet(l_new_count),
          .LocalGet(p_level),
          .Call("make_relaxed"),
          .RefCast(false, .Eq),
        ],
      ),
    ],
  }
}

// gather(vec: PVec?, idx: PVec?) -> PVec
// Build a vector where result[i] = vec[idx[i]]. The index vector stores Int
// elements as BoxedInt anyrefs; truncate to i32 before calling get.
fn gather_fn() FuncDef {
  // p0=vec, p1=idx; L2=n, L3=builder, L4=i, L5=k
  .{
    name: "gather",
    params: [pvec_null(), pvec_null()],
    results: [pvec_ref()],
    locals: [.I32, arr_null(), .I32, .I32],
    body: [
      .LocalGet(1),
      .Call("len"),
      .LocalSet(2),
      .Call("builder_new"),
      .LocalSet(3),
      .I32Const(0),
      .LocalSet(4),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(4),
              .LocalGet(2),
              .I32GeS,
              .BrIf("brk"),
              .LocalGet(1),
              .LocalGet(4),
              .Call("get"),
              .RefCast(false, .Named(t_boxed_int())),
              .StructGet(t_boxed_int(), 0),
              .I32WrapI64,
              .LocalSet(5),
              .LocalGet(3),
              .LocalGet(0),
              .LocalGet(5),
              .Call("get"),
              .Call("builder_push"),
              .LocalGet(4),
              .I32Const(1),
              .I32Add,
              .LocalSet(4),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(3),
      .Call("builder_freeze"),
    ],
  }
}

// drop_last(vec: PVec?) -> PVec
// Return vec without its last element; the empty vector if already empty.
// O(1) amortized: shrinks the tail, pulling the last trie leaf back into the
// tail only at a 32-boundary (then O(log n)). Inverse of push.
fn drop_last_fn() FuncDef {
  p_vec := 0
  l_len := 1
  l_trie_count := 2
  l_tail_len := 3
  l_new_tail := 4
  l_new_root := 5
  l_new_shift := 6
  l_shift := 7
  l_leaf := 8
  l_copy_len := 9

  ta := t_array()

  // p0=vec
  // L1=len, L2=trie_count, L3=tail_len, L4=new_tail, L5=new_root, L6=new_shift, L7=shift, L8=leaf, L9=copy_len
  .{
    name: "drop_last",
    params: [pvec_null()],
    results: [pvec_ref()],
    locals: [.I32, .I32, .I32, arr_null(), ref_eq_null(), .I32, .I32, arr_null(), .I32],
    body: [
      .LocalGet(p_vec),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_len()),
      .LocalSet(l_len),
      .LocalGet(l_len),
      .I32Const(1),
      .I32LeS,
      .If(
        .Some(pvec_ref()),
        [.GlobalGet("empty_pvec")],
        [
          .LocalGet(p_vec),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_tail()),
          .ArrayLen,
          .LocalSet(l_tail_len),
          .LocalGet(l_len),
          .LocalGet(l_tail_len),
          .I32Sub,
          .LocalSet(l_trie_count),
          .LocalGet(l_tail_len),
          .I32Const(1),
          .I32GtS,
          .If(
            .Some(pvec_ref()),
            [
              .RefNull(.None_),
              .LocalGet(l_tail_len),
              .I32Const(1),
              .I32Sub,
              .ArrayNew(ta),
              .LocalSet(l_new_tail),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_tail()),
              .I32Const(0),
              .LocalGet(l_tail_len),
              .I32Const(1),
              .I32Sub,
              .ArrayCopy(ta, ta),
              .LocalGet(l_len),
              .I32Const(1),
              .I32Sub,
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_shift()),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_root()),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .StructNew(t_pvec()),
            ],
            [
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_shift()),
              .LocalSet(l_shift),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .LocalGet(l_tail_len),
              .I32Eqz,
              .If(
                .Some(.I32),
                [.LocalGet(l_len), .I32Const(1), .I32Sub],
                [.LocalGet(l_len), .I32Const(2), .I32Sub],
              ),
              .Call("get_leaf"),
              .LocalSet(l_copy_len),
              .LocalSet(l_leaf),
              .LocalGet(l_tail_len),
              .I32Eqz,
              .If(.None, [], [.LocalGet(l_leaf), .RefAsNonNull, .ArrayLen, .LocalSet(l_copy_len)]),
              .RefNull(.None_),
              .LocalGet(l_copy_len),
              .ArrayNew(ta),
              .LocalSet(l_new_tail),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(l_leaf),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(l_copy_len),
              .ArrayCopy(ta, ta),
              .LocalGet(l_len),
              .LocalGet(l_shift),
              .LocalGet(p_vec),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_root()),
              .Call("pop_tail"),
              .LocalSet(l_new_root),
              .LocalGet(l_shift),
              .LocalSet(l_new_shift),
              .LocalGet(l_new_root),
              .RefIsNull,
              .If(
                .None,
                [.I32Const(0), .LocalSet(l_new_shift)],
                [
                  .LocalGet(l_shift),
                  .I32Const(b_()),
                  .I32GtS,
                  .If(
                    .None,
                    [
                      .LocalGet(l_new_root),
                      .RefCast(false, .Named(t_vec_internal())),
                      .Call("child_count"),
                      .I32Const(1),
                      .I32Eq,
                      .If(
                        .None,
                        [
                          .LocalGet(l_new_root),
                          .RefCast(false, .Named(t_vec_internal())),
                          .StructGet(t_vec_internal(), vi_children()),
                          .I32Const(0),
                          .ArrayGet(t_vec_children()),
                          .LocalSet(l_new_root),
                          .LocalGet(l_shift),
                          .I32Const(b_()),
                          .I32Sub,
                          .LocalSet(l_new_shift),
                        ],
                        [],
                      ),
                    ],
                    [],
                  ),
                ],
              ),
              .LocalGet(l_len),
              .I32Const(1),
              .I32Sub,
              .LocalGet(l_new_shift),
              .LocalGet(l_new_root),
              .RefCast(true, .Named(t_vec_internal())),
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .StructNew(t_pvec()),
            ],
          ),
        ],
      ),
    ],
  }
}

// ═══════════════════════════════════════════════════════════════════════
// Builder: transient mutable-tail design
//
// Builder layout (3-slot $Array):
//   [0] = pvec_so_far : PVec (trie prefix, tail always empty)
//   [1] = tail_len    : i31ref
//   [2] = tail_buf    : Array (mutable 32-slot buffer)
// ═══════════════════════════════════════════════════════════════════════
// promote_full_tail(prefix: PVec, full_tail: Array) -> PVec
// Integrates a full 32-element tail into the trie, returning a PVec with empty tail.
fn promote_full_tail_fn() FuncDef {
  p_prefix := 0
  p_full_tail := 1
  l_len := 2
  l_shift := 3
  l_new_root := 4

  // p0=prefix, p1=full_tail
  // L2=len (prefix.len + 32), L3=shift, L4=new_root
  .{
    name: "promote_full_tail",
    params: [pvec_ref(), arr_ref()],
    results: [pvec_ref()],
    locals: [.I32, .I32, ref_eq_null()],
    body: [
      .LocalGet(p_prefix),
      .StructGet(t_pvec(), pv_len()),
      .I32Const(bf()),
      .I32Add,
      .LocalSet(l_len),
      .LocalGet(p_prefix),
      .StructGet(t_pvec(), pv_shift()),
      .LocalSet(l_shift),
      .LocalGet(p_prefix),
      .StructGet(t_pvec(), pv_root()),
      .RefIsNull,
      .If(
        .None,
        [
          .I32Const(b_()),
          .LocalSet(l_shift),
          .I32Const(b_()),
          .LocalGet(p_full_tail),
          .RefCast(false, .Eq),
          .Call("new_path"),
          .LocalSet(l_new_root),
        ],
        [
          .LocalGet(p_prefix),
          .StructGet(t_pvec(), pv_root()),
          .RefAsNonNull,
          .LocalGet(l_shift),
          .LocalGet(p_full_tail),
          .Call("wrap_leaf"),
          .I32Const(b_()),
          .Call("concat_trees"),
          .LocalSet(l_shift),
          .LocalSet(l_new_root),
        ],
      ),
      .LocalGet(l_len),
      .LocalGet(l_shift),
      .LocalGet(l_new_root),
      .RefCast(true, .Named(t_vec_internal())),
      .GlobalGet("empty_leaf"),
      .StructNew(t_pvec()),
    ],
  }
}

// builder_new() -> Array
fn builder_new_fn() FuncDef {
  .{
    name: "builder_new",
