        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(0),
              .RefIsNull,
              .BrIf("brk"),
              .LocalGet(1),
              .I32Const(b_()),
              .I32LeS,
              .BrIf("brk"),
              .LocalGet(0),
              .RefAsNonNull,
              .Call("child_count"),
              .LocalSet(2),
              .LocalGet(2),
              .I32Const(1),
              .I32Ne,
              .BrIf("brk"),
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(vi, vi_children()),
              .I32Const(0),
              .ArrayGet(vc),
              .RefCast(true, .Named(vi)),
              .LocalSet(0),
              .LocalGet(1),
              .I32Const(b_()),
              .I32Sub,
              .LocalSet(1),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(0),
      .LocalGet(1),
    ],
  }
}

// slice_from_full_tree(node, shift, len) -> PVec
// Split the full tree back into PVec root + trailing leaf tail.
fn slice_from_full_tree_fn() FuncDef {
  vi := t_vec_internal()

  // p0=node, p1=shift, p2=len; L3=tail, L4=root, L5=shift
  .{
    name: "slice_from_full_tree",
