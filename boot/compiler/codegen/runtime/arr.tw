          .LocalGet(1),
          .I32Eqz,
          .LocalGet(2),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_len()),
          .I32Eq,
          .I32And,
          .If(
            .Some(pvec_ref()),
            [.LocalGet(0), .RefAsNonNull],
            [
              .LocalGet(3),
              .I32Const(bf()),
              .I32LeS,
              .If(
                .Some(pvec_ref()),
                [
                  .LocalGet(0),
                  .Call("to_array"),
                  .LocalSet(4),
                  .RefNull(.None_),
                  .LocalGet(3),
                  .ArrayNew(ta),
                  .LocalSet(5),
                  .LocalGet(5),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(4),
                  .RefAsNonNull,
                  .LocalGet(1),
                  .LocalGet(3),
                  .ArrayCopy(ta, ta),
                  .LocalGet(5),
                  .RefAsNonNull,
                  .Call("from_array"),
                ],
                [
                  .LocalGet(0),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_root()),
                  .RefIsNull,
                  .If(
                    .None,
                    [
                      .LocalGet(0),
                      .RefAsNonNull,
                      .StructGet(t_pvec(), pv_tail()),
                      .RefCast(false, .Eq),
                      .LocalSet(6),
                      .I32Const(0),
                      .LocalSet(7),
                    ],
                    [
                      .LocalGet(0),
                      .RefAsNonNull,
                      .StructGet(t_pvec(), pv_tail()),
                      .ArrayLen,
                      .I32Eqz,
                      .If(
                        .None,
                        [
                          .LocalGet(0),
                          .RefAsNonNull,
                          .StructGet(t_pvec(), pv_root()),
                          .RefAsNonNull,
                          .RefCast(false, .Eq),
                          .LocalSet(6),
                          .LocalGet(0),
                          .RefAsNonNull,
                          .StructGet(t_pvec(), pv_shift()),
                          .LocalSet(7),
                        ],
                        [
                          .LocalGet(0),
                          .RefAsNonNull,
                          .StructGet(t_pvec(), pv_root()),
                          .RefAsNonNull,
                          .LocalGet(0),
                          .RefAsNonNull,
                          .StructGet(t_pvec(), pv_shift()),
                          .LocalGet(0),
                          .RefAsNonNull,
                          .StructGet(t_pvec(), pv_tail()),
                          .Call("wrap_leaf"),
                          .I32Const(b_()),
                          .Call("concat_trees"),
                          .LocalSet(7),
                          .LocalSet(6),
                        ],
                      ),
                    ],
                  ),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .LocalGet(7),
                  .LocalGet(2),
                  .Call("slice_trim_right"),
                  .LocalSet(8),
                  .LocalGet(1),
                  .I32Eqz,
                  .If(
                    .None,
