          .LocalGet(2),
          .ArraySet(t_vec_children()),
          .LocalGet(1),
          .I32Const(1),
          .I32Add,
        ],
        [
          .LocalGet(2),
          .RefCast(false, .Named(t_vec_internal())),
          .Call("child_count"),
          .LocalSet(5),
          .LocalGet(0),
          .LocalGet(1),
