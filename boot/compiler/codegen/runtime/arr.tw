// push(vec: PVec, val: anyref) -> PVec
fn push_fn() FuncDef {
  p_vec := 0
  p_val := 1
  l_len := 2
  l_tail_len := 3
  l_new_tail := 4
  l_new_root := 5
  l_new_shift := 6
  l_new_children := 7

  // p0=vec, p1=val
  // L2=len, L3=tail_len, L4=new_tail, L5=new_root, L6=new_shift, L7=new_children
  FuncDef.{
    name: "push",
    params: [pvec_ref(), .Anyref],
    results: [pvec_ref()],
    locals: [.I32, .I32, arr_null(), ref_eq_null(), .I32, vec_children_null()],
    body: [
      .LocalGet(p_vec),
      .StructGet(t_pvec(), pv_len()),
      .LocalSet(l_len),
      .LocalGet(p_vec),
      .StructGet(t_pvec(), pv_tail()),
      .ArrayLen,
      .LocalSet(l_tail_len),
      .LocalGet(l_tail_len),
      .I32Const(bf()),
      .I32LtS,
      .If(
        .Some(pvec_ref()),
        [
          .RefNull(.None_),
          .LocalGet(l_tail_len),
          .I32Const(1),
          .I32Add,
          .ArrayNew(t_array()),
          .LocalSet(l_new_tail),
          .LocalGet(l_tail_len),
          .I32Eqz,
          .If(
            .None,
            [],
            [
              .LocalGet(l_new_tail),
              .RefAsNonNull,
              .I32Const(0),
              .LocalGet(p_vec),
              .StructGet(t_pvec(), pv_tail()),
              .I32Const(0),
              .LocalGet(l_tail_len),
              .ArrayCopy(t_array(), t_array()),
            ],
          ),
          .LocalGet(l_new_tail),
          .RefAsNonNull,
          .LocalGet(l_tail_len),
          .LocalGet(p_val),
          .ArraySet(t_array()),
          .LocalGet(l_len),
          .I32Const(1),
          .I32Add,
          .LocalGet(p_vec),
          .StructGet(t_pvec(), pv_shift()),
          .LocalGet(p_vec),
          .StructGet(t_pvec(), pv_root()),
          .LocalGet(l_new_tail),
          .RefAsNonNull,
          .StructNew(t_pvec()),
        ],
        [
          .LocalGet(p_vec),
          .StructGet(t_pvec(), pv_shift()),
          .LocalSet(l_new_shift),
          .LocalGet(p_vec),
          .StructGet(t_pvec(), pv_root()),
          .RefIsNull,
          .If(
            .None,
            [
              .I32Const(b_()),
              .LocalSet(l_new_shift),
              .I32Const(b_()),
              .LocalGet(p_vec),
              .StructGet(t_pvec(), pv_tail()),
              .RefCast(false, .Eq),
              .Call("new_path"),
              .LocalSet(l_new_root),
            ],
            [
              .LocalGet(p_vec),
              .StructGet(t_pvec(), pv_root()),
              .RefAsNonNull,
              .LocalGet(l_new_shift),
              .LocalGet(p_vec),
              .StructGet(t_pvec(), pv_tail()),
              .Call("wrap_leaf"),
              .I32Const(b_()),
              .Call("concat_trees"),
              .LocalSet(l_new_shift),
              .LocalSet(l_new_root),
            ],
          ),
          .LocalGet(p_val),
          .ArrayNewFixed(t_array(), 1),
          .LocalSet(l_new_tail),
          .LocalGet(l_len),
          .I32Const(1),
          .I32Add,
          .LocalGet(l_new_shift),
          .LocalGet(l_new_root),
          .RefCast(true, .Named(t_vec_internal())),
          .LocalGet(l_new_tail),
          .RefAsNonNull,
          .StructNew(t_pvec()),
        ],
      ),
    ],
  }
}

