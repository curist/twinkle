              .LocalGet(3),
              .I32Eqz,
              .BrIf("brk"),
              .LocalGet(0),
              .RefAsNonNull,
              .I32Const(2),
              .ArrayGet(ta),
              .RefCast(true, .Named(ta)),
              .LocalSet(4),
              .LocalGet(0),
              .RefAsNonNull,
              .I32Const(1),
              .ArrayGet(ta),
              .RefCast(false, .I31),
