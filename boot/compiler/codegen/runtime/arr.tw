      ),
    ],
  }
}

// concat_trees(l: VecInternal, sl: i32, r: VecInternal, sr: i32) -> (node, shift)
// RRB spine-merge: recurse along l's right edge and r's left edge to the common
// level, merge the seam, then greedily repack the boundary children into nodes of
// at most 32 (growing a level when the repacked count exceeds 32). Produces
// relaxed seam nodes; make_relaxed canonicalizes back to regular where it can.
fn concat_trees_fn() FuncDef {
  vc := t_vec_children()
  vi := t_vec_internal()
  vir := ValType.Ref(false, .Named(vi))

  // p0=l, p1=sl, p2=r, p3=sr
  // L4=centre, L5=cs, L6=scratch, L7=k, L8=countL, L9=countR, L10=resnode, L11=resshift
  // L12=left_leaf, L13=right_leaf, L14=merged_len, L15=merged_leaf
  .{
    name: "concat_trees",
    params: [vir, .I32, vir, .I32],
    results: [ref_eq_(), .I32],
    locals: [
      ref_eq_null(),
      .I32,
      vec_children_null(),
      .I32,
      .I32,
      .I32,
      ref_eq_null(),
      .I32,
      arr_null(),
      arr_null(),
      .I32,
      arr_null(),
    ],
    body: [
      .RefNull(.Eq),
      .I32Const(96),
      .ArrayNew(vc),
      .LocalSet(6),
      .I32Const(0),
      .LocalSet(7),
      .LocalGet(1),
      .LocalGet(3),
      .I32Eq,
      .If(
        .None,
        [
          .LocalGet(1),
          .I32Const(b_()),
          .I32Eq,
          .If(
            .None,
            [
              .LocalGet(0),
              .Call("child_count"),
              .LocalSet(8),
              .LocalGet(2),
              .Call("child_count"),
              .LocalSet(9),
              .LocalGet(0),
              .StructGet(vi, vi_children()),
              .LocalGet(8),
              .I32Const(1),
              .I32Sub,
              .ArrayGet(vc),
              .RefCast(true, .Named(t_array())),
              .LocalSet(12),
              .LocalGet(2),
              .StructGet(vi, vi_children()),
              .I32Const(0),
              .ArrayGet(vc),
              .RefCast(true, .Named(t_array())),
              .LocalSet(13),
              .LocalGet(12),
