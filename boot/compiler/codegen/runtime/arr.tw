              .LocalGet(3),
              .I32Eqz,
              .BrIf("brk"),
              .LocalGet(0),
              .RefAsNonNull,
              .I32Const(2),
              .ArrayGet(ta),
              .RefCast(true, .Named(ta)),
              .LocalSet(4),
              .LocalGet(0),
              .RefAsNonNull,
              .I32Const(1),
              .ArrayGet(ta),
              .RefCast(false, .I31),
              .I31GetU,
              .LocalSet(5),
              .LocalGet(5),
              .I32Const(bf),
              .I32Eq,
              .If(
                .None,
                [
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(0),
                  .ArrayGet(ta),
                  .RefCast(true, .Named(t_pvec)),
                  .LocalSet(8),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(8),
                  .RefAsNonNull,
                  .LocalGet(4),
                  .RefAsNonNull,
                  .Call("promote_full_tail"),
                  .ArraySet(ta),
                  .RefNull(.None_),
                  .I32Const(bf),
                  .ArrayNew(ta),
                  .LocalSet(4),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(2),
                  .LocalGet(4),
                  .ArraySet(ta),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(1),
                  .I32Const(0),
                  .RefI31,
                  .ArraySet(ta),
                  .Br("lp"),
                ],
