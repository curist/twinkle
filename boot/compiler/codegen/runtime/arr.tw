// builder_extend_node(builder: Array?, node: VecInternal, shift: i32) -> void
// Relaxed-aware leaf traversal for builder_extend: walks actual children and
// copies whole leaf ranges into the builder tail buffer.
fn builder_extend_node_fn() FuncDef {
  ta := t_array()

  // p0=builder, p1=node, p2=shift; L3=count, L4=i, L5=child, L6=leaf
  .{
    name: "builder_extend_node",
    params: [arr_null(), .Ref(false, .Named(t_vec_internal())), .I32],
    results: [],
    locals: [.I32, .I32, ref_eq_null(), arr_null()],
    body: [
      .LocalGet(1),
      .Call("child_count"),
      .LocalSet(3),
      .I32Const(0),
      .LocalSet(4),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(4),
              .LocalGet(3),
              .I32GeS,
              .BrIf("brk"),
              .LocalGet(1),
              .StructGet(t_vec_internal(), vi_children()),
              .LocalGet(4),
              .ArrayGet(t_vec_children()),
              .LocalSet(5),
              .LocalGet(2),
              .I32Const(b_()),
              .I32Eq,
              .If(
                .None,
                [
                  .LocalGet(5),
                  .RefAsNonNull,
                  .RefCast(false, .Named(ta)),
                  .LocalSet(6),
                  .LocalGet(0),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .ArrayLen,
                  .Call("builder_append_leaf_range"),
                ],
                [
                  .LocalGet(0),
                  .LocalGet(5),
                  .RefAsNonNull,
                  .RefCast(false, .Named(t_vec_internal())),
                  .LocalGet(2),
                  .I32Const(b_()),
                  .I32Sub,
                  .Call("builder_extend_node"),
                ],
              ),
              .LocalGet(4),
              .I32Const(1),
              .I32Add,
              .LocalSet(4),
              .Br("lp"),
            ],
          ),
        ],
      ),
    ],
  }
}

// builder_extend(builder: Array?, vec: PVec?) -> void
fn builder_extend_fn() FuncDef {
  // p0=builder, p1=vec, L2=vec_len, L3=tail_len, L4=trie_count
  .{
    name: "builder_extend",
    params: [arr_null(), pvec_null()],
    results: [],
    locals: [.I32, .I32, .I32],
    body: [
      .LocalGet(1),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_len()),
      .LocalSet(2),
      .LocalGet(2),
      .I32Eqz,
      .If(.None, [.Return], []),
      .LocalGet(1),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_tail()),
      .ArrayLen,
      .LocalSet(3),
      .LocalGet(2),
      .LocalGet(3),
      .I32Sub,
      .LocalSet(4),
      .LocalGet(4),
      .I32Eqz,
      .If(
        .None,
        [],
        [
          .LocalGet(0),
          .LocalGet(1),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_root()),
          .RefAsNonNull,
          .LocalGet(1),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_shift()),
          .Call("builder_extend_node"),
        ],
      ),
      .LocalGet(3),
      .I32Eqz,
      .If(
        .None,
        [],
        [
          .LocalGet(0),
          .LocalGet(1),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_tail()),
          .I32Const(0),
          .LocalGet(3),
          .Call("builder_append_leaf_range"),
        ],
      ),
    ],
  }
}

