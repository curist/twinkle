          .LocalGet(2),
          .LocalGet(0),
          .Call("vi_nav"),
          .LocalSet(2),
          .LocalSet(5),
          .RefNull(.Eq),
          .I32Const(bf),
          .ArrayNew(t_vec_children),
          .LocalSet(4),
          .LocalGet(4),
