                  .I32Const(1),
                  .I32Sub,
                  .LocalSet(7),
                ],
                [
                  .LocalGet(6),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(0),
                  .StructGet(vi, vi_children),
