        .Some(pvec_ref()),
        [
          .LocalGet(2),
          .I32Const(0),
          .RefNull(.Named(vi)),
          .LocalGet(0),
          .LocalGet(1),
          .Call("slice_last_leaf"),
          .StructNew(t_pvec()),
