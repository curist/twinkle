      .ArrayNew(t_array()),
      .ArrayNewFixed(t_array(), 3),
    ],
  }
}

// builder_from(vec: PVec?) -> Array
fn builder_from_fn() FuncDef {
  ta := t_array()

  // p0=vec, L1=tail_data, L2=tail_len, L3=new_tail_buf, L4=trie_prefix
  .{
    name: "builder_from",
    params: [pvec_null()],
    results: [arr_ref()],
    locals: [arr_null(), .I32, arr_null(), pvec_null()],
    body: [
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_tail()),
      .LocalSet(1),
      .LocalGet(1),
      .RefAsNonNull,
      .ArrayLen,
      .LocalSet(2),
      .RefNull(.None_),
      .I32Const(bf()),
      .ArrayNew(ta),
      .LocalSet(3),
      .LocalGet(2),
      .I32Eqz,
      .If(
        .None,
        [],
        [
          .LocalGet(3),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(1),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(2),
          .ArrayCopy(ta, ta),
        ],
      ),
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_len()),
      .LocalGet(2),
      .I32Sub,
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_shift()),
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_root()),
      .GlobalGet("empty_leaf"),
      .StructNew(t_pvec()),
      .LocalSet(4),
      .LocalGet(4),
      .RefAsNonNull,
      .LocalGet(2),
      .RefI31,
      .LocalGet(3),
      .ArrayNewFixed(ta, 3),
    ],
  }
}

// builder_push(builder: Array?, elem: anyref) -> void
fn builder_push_fn() FuncDef {
  ta := t_array()

  // p0=builder, p1=elem
  // L2=tail_buf, L3=tail_len, L4=pvec_so_far
  .{
    name: "builder_push",
    params: [arr_null(), .Anyref],
    results: [],
    locals: [arr_null(), .I32, pvec_null()],
    body: [
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(2),
      .ArrayGet(ta),
      .RefCast(true, .Named(ta)),
      .LocalSet(2),
      .LocalGet(0),
      .RefAsNonNull,
      .I32Const(1),
      .ArrayGet(ta),
      .RefCast(false, .I31),
      .I31GetU,
      .LocalSet(3),
      .LocalGet(3),
      .I32Const(bf()),
      .I32LtS,
      .If(
        .None,
        [
          .LocalGet(2),
          .RefAsNonNull,
          .LocalGet(3),
          .LocalGet(1),
          .ArraySet(ta),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(1),
          .LocalGet(3),
          .I32Const(1),
          .I32Add,
          .RefI31,
          .ArraySet(ta),
        ],
        [
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(0),
          .ArrayGet(ta),
          .RefCast(true, .Named(t_pvec())),
          .LocalSet(4),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(4),
          .RefAsNonNull,
          .LocalGet(2),
          .RefAsNonNull,
          .Call("promote_full_tail"),
          .ArraySet(ta),
          .RefNull(.None_),
          .I32Const(bf()),
          .ArrayNew(ta),
          .LocalSet(2),
          .LocalGet(2),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(1),
          .ArraySet(ta),
          .LocalGet(0),
          .RefAsNonNull,
          .I32Const(2),
          .LocalGet(2),
          .ArraySet(ta),
          .LocalGet(0),
