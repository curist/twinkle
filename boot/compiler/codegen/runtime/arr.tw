// make(len: i32, fill: anyref) -> PVec
fn make_fn() FuncDef {
  // p0=len, p1=fill, L2=vec, L3=i
  .{
    name: "make",
    params: [.I32, .Anyref],
    results: [pvec_ref()],
    locals: [pvec_null(), .I32],
    body: [
      .LocalGet(0),
      .I32Eqz,
      .If(
        .Some(pvec_ref()),
        [.GlobalGet("empty_pvec")],
        [
          .GlobalGet("empty_pvec"),
          .LocalSet(2),
          .I32Const(0),
          .LocalSet(3),
          .Block(
            "brk",
            .None,
            [
              .Loop(
                "lp",
                .None,
                [
                  .LocalGet(3),
                  .LocalGet(0),
                  .I32GeS,
                  .BrIf("brk"),
                  .LocalGet(2),
                  .RefAsNonNull,
                  .LocalGet(1),
                  .Call("push"),
                  .LocalSet(2),
                  .LocalGet(3),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(3),
                  .Br("lp"),
                ],
              ),
            ],
          ),
          .LocalGet(2),
          .RefAsNonNull,
        ],
      ),
    ],
  }
}

type PVecFamily = .{
  len_name: String,
  get_name: String,
  builder_new_name: String,
  builder_freeze_name: String,
  pvec_ty: String,
  pvec_null: ValType,
  pvec_ref: ValType,
  arr_ty: String,
  arr_null: ValType,
  elem_ty: ValType,
  empty_pvec_global: String,
  zero_value: Instr,
}

fn family_boxed() PVecFamily {
  .{
    len_name: "len",
    get_name: "get",
    builder_new_name: "builder_new",
    builder_freeze_name: "builder_freeze",
    pvec_ty: t_pvec,
    pvec_null: pvec_null(),
    pvec_ref: pvec_ref(),
    arr_ty: t_array,
    arr_null: arr_null(),
    elem_ty: .Anyref,
    empty_pvec_global: "empty_pvec",
    zero_value: .RefNull(.None_),
  }
}

fn family_i64() PVecFamily {
  .{
    len_name: "len_i64",
    get_name: "get_i64",
    builder_new_name: "builder_new_i64",
    builder_freeze_name: "builder_freeze_i64",
    pvec_ty: t_pvec_i64,
    pvec_null: pvec_i64_null(),
    pvec_ref: pvec_i64_ref(),
    arr_ty: t_array_i64,
    arr_null: arr_i64_null(),
    elem_ty: .I64,
    empty_pvec_global: "empty_pvec_i64",
    zero_value: .I64Const(0),
  }
}

// len/len_i64(vec: PVec?) -> i32
fn pvec_len_fn(f: PVecFamily) FuncDef {
  .{
    name: f.len_name,
    params: [f.pvec_null],
    results: [.I32],
    locals: [],
    body: [.LocalGet(0), .RefAsNonNull, .StructGet(f.pvec_ty, pv_len)],
  }
}

// get/get_i64(vec: PVec?, idx: i32) -> elem
fn pvec_get_fn(f: PVecFamily) FuncDef {
  // p0=vec, p1=idx, L2=len, L3=tailoff, L4=node, L5=level, L6=slot, L7=sizes
  .{
    name: f.get_name,
    params: [f.pvec_null, .I32],
    results: [f.elem_ty],
    locals: [.I32, .I32, vec_internal_null(), .I32, .I32, i32_array_null()],
    body: [
      .LocalGet(0),
      .RefAsNonNull,
      .StructGet(f.pvec_ty, pv_len),
      .LocalSet(2),
      .LocalGet(2),
      .I32Const(bf),
      .I32LeS,
      .If(
        .Some(f.elem_ty),
        [
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(f.pvec_ty, pv_tail),
          .LocalGet(1),
          .I32Const(mask),
          .I32And,
          .ArrayGet(f.arr_ty),
        ],
        [
          .LocalGet(2),
          .LocalGet(0),
          .RefAsNonNull,
          .StructGet(f.pvec_ty, pv_tail),
          .ArrayLen,
          .I32Sub,
          .LocalSet(3),
          .LocalGet(1),
          .LocalGet(3),
          .I32GeS,
          .If(
            .Some(f.elem_ty),
            [
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(f.pvec_ty, pv_tail),
              .LocalGet(1),
              .LocalGet(3),
              .I32Sub,
              .ArrayGet(f.arr_ty),
            ],
            [
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(f.pvec_ty, pv_root),
              .LocalSet(4),
              .LocalGet(0),
              .RefAsNonNull,
              .StructGet(f.pvec_ty, pv_shift),
              .LocalSet(5),
              .Block(
                "brk",
                .None,
                [
                  .Loop(
                    "lp",
                    .None,
                    [
                      .LocalGet(5),
                      .I32Const(b_),
                      .I32LeS,
                      .BrIf("brk"),
                      .LocalGet(4),
                      .RefAsNonNull,
                      .StructGet(t_vec_internal, vi_sizes),
                      .LocalSet(7),
                      .LocalGet(7),
                      .RefIsNull,
                      .If(
                        .None,
                        [
                          .LocalGet(1),
                          .LocalGet(5),
                          .I32ShrU,
                          .I32Const(mask),
                          .I32And,
                          .LocalSet(6),
                        ],
                        [
                          .LocalGet(4),
                          .RefAsNonNull,
                          .LocalGet(1),
                          .LocalGet(5),
                          .Call("vi_nav"),
                          .LocalSet(1),
                          .LocalSet(6),
                        ],
                      ),
                      .LocalGet(4),
                      .RefAsNonNull,
                      .StructGet(t_vec_internal, vi_children),
                      .LocalGet(6),
                      .ArrayGet(t_vec_children),
                      .RefCast(true, .Named(t_vec_internal)),
                      .LocalSet(4),
                      .LocalGet(5),
                      .I32Const(b_),
                      .I32Sub,
                      .LocalSet(5),
                      .Br("lp"),
                    ],
                  ),
                ],
              ),
              .LocalGet(4),
              .RefAsNonNull,
              .StructGet(t_vec_internal, vi_sizes),
              .LocalSet(7),
              .LocalGet(7),
              .RefIsNull,
              .If(
                .None,
                [.LocalGet(1), .LocalGet(5), .I32ShrU, .I32Const(mask), .I32And, .LocalSet(6)],
                [
                  .LocalGet(4),
                  .RefAsNonNull,
                  .LocalGet(1),
                  .LocalGet(5),
                  .Call("vi_nav"),
                  .LocalSet(1),
                  .LocalSet(6),
                ],
              ),
              .LocalGet(4),
              .RefAsNonNull,
              .StructGet(t_vec_internal, vi_children),
              .LocalGet(6),
              .ArrayGet(t_vec_children),
              .RefCast(false, .Named(f.arr_ty)),
              .LocalGet(1),
              .I32Const(mask),
              .I32And,
              .ArrayGet(f.arr_ty),
            ],
          ),
        ],
      ),
    ],
  }
}

// builder_new/builder_new_i64() -> Array
