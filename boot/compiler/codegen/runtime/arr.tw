              .LocalSet(7),
              .LocalGet(4),
              .RefAsNonNull,
              .LocalGet(5),
              .LocalGet(1),
              .LocalGet(2),
              .LocalGet(7),
              .ArrayCopy(ta, ta),
              .LocalGet(5),
              .LocalGet(7),
              .I32Add,
              .LocalSet(5),
              .LocalGet(0),
              .RefAsNonNull,
              .I32Const(1),
              .LocalGet(5),
              .RefI31,
              .ArraySet(ta),
              .LocalGet(2),
              .LocalGet(7),
              .I32Add,
              .LocalSet(2),
              .LocalGet(3),
              .LocalGet(7),
              .I32Sub,
              .LocalSet(3),
              .LocalGet(5),
              .I32Const(bf),
              .I32Eq,
              .LocalGet(3),
              .I32Const(0),
              .I32GtS,
              .I32And,
              .If(
                .None,
