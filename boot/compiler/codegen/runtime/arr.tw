              .If(
                .None,
                [
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(0),
                  .ArrayGet(ta),
                  .RefCast(true, .Named(t_pvec())),
                  .LocalSet(8),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(8),
                  .RefAsNonNull,
                  .LocalGet(4),
                  .RefAsNonNull,
                  .Call("promote_full_tail"),
                  .ArraySet(ta),
                  .RefNull(.None_),
                  .I32Const(bf()),
                  .ArrayNew(ta),
                  .LocalSet(4),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(2),
                  .LocalGet(4),
                  .ArraySet(ta),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(1),
                  .I32Const(0),
                  .RefI31,
                  .ArraySet(ta),
                  .Br("lp"),
                ],
                [],
              ),
              .I32Const(bf()),
              .LocalGet(5),
              .I32Sub,
              .LocalSet(6),
              .LocalGet(3),
              .LocalGet(6),
              .I32LtS,
              .If(.Some(.I32), [.LocalGet(3)], [.LocalGet(6)]),
              .LocalSet(7),
              .LocalGet(4),
              .RefAsNonNull,
              .LocalGet(5),
              .LocalGet(1),
              .LocalGet(2),
              .LocalGet(7),
              .ArrayCopy(ta, ta),
              .LocalGet(5),
              .LocalGet(7),
              .I32Add,
              .LocalSet(5),
              .LocalGet(0),
              .RefAsNonNull,
              .I32Const(1),
              .LocalGet(5),
              .RefI31,
              .ArraySet(ta),
              .LocalGet(2),
              .LocalGet(7),
              .I32Add,
              .LocalSet(2),
              .LocalGet(3),
              .LocalGet(7),
              .I32Sub,
              .LocalSet(3),
              .LocalGet(5),
              .I32Const(bf()),
              .I32Eq,
              .LocalGet(3),
              .I32Const(0),
              .I32GtS,
              .I32And,
              .If(
                .None,
                [
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(0),
                  .ArrayGet(ta),
                  .RefCast(true, .Named(t_pvec())),
                  .LocalSet(8),
                  .LocalGet(0),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(8),
                  .RefAsNonNull,
                  .LocalGet(4),
                  .RefAsNonNull,
                  .Call("promote_full_tail"),
                  .ArraySet(ta),
                  .RefNull(.None_),
                  .I32Const(bf()),
