      .I32Const(b_),
      .I32Eq,
      .If(
        .None,
        [.LocalGet(4), .RefAsNonNull, .LocalGet(5), .LocalGet(3), .ArraySet(t_vec_children)],
        [
          .LocalGet(2),
          .RefAsNonNull,
          .StructGet(t_vec_internal, vi_children),
          .LocalGet(5),
          .ArrayGet(t_vec_children),
          .LocalSet(6),
          .LocalGet(6),
          .RefIsNull,
          .If(
            .Some(ref_eq_()),
            [.LocalGet(1), .I32Const(b_), .I32Sub, .LocalGet(3), .Call("new_path")],
            [
              .LocalGet(0),
              .LocalGet(1),
              .I32Const(b_),
              .I32Sub,
              .LocalGet(6),
              .RefCast(true, .Named(t_vec_internal)),
              .LocalGet(3),
              .Call("push_tail"),
            ],
          ),
          .LocalSet(6),
          .LocalGet(4),
          .RefAsNonNull,
          .LocalGet(5),
          .LocalGet(6),
          .ArraySet(t_vec_children),
        ],
      ),
      .LocalGet(4),
      .RefAsNonNull,
      .RefNull(.Named(t_i32_array)),
