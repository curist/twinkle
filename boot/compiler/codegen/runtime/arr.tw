          .LocalGet(0),
          .LocalGet(1),
          .Call("slice_last_leaf"),
          .LocalSet(3),
          .LocalGet(2),
          .LocalGet(1),
          .LocalGet(0),
          .RefCast(true, .Named(vi)),
          .Call("pop_tail"),
          .RefCast(true, .Named(vi)),
          .LocalSet(4),
          .LocalGet(1),
          .LocalSet(5),
          .LocalGet(4),
          .LocalGet(5),
          .Call("slice_collapse_root"),
          .LocalSet(5),
          .LocalSet(4),
          .LocalGet(2),
          .LocalGet(5),
          .LocalGet(4),
          .LocalGet(3),
          .RefAsNonNull,
          .StructNew(t_pvec()),
        ],
      ),
    ],
  }
}

// slice(vec: PVec?, start: i32, end: i32) -> PVec
