}

// concat(a: PVec?, b: PVec?) -> PVec
fn concat_fn() FuncDef {
  p_a := 0
  p_b := 1
  l_builder := 2
  l_a_node := 3
  l_a_shift := 4
  l_merged := 5
  l_merged_shift := 6

  vi := t_vec_internal()

  // p0=a, p1=b; L2=builder, L3=aL, L4=aLs, L5=merged, L6=ms
  .{
    name: "concat",
    params: [pvec_null(), pvec_null()],
    results: [pvec_ref()],
    locals: [arr_null(), ref_eq_null(), .I32, ref_eq_null(), .I32],
    body: [
      .LocalGet(p_b),
      .RefAsNonNull,
      .StructGet(t_pvec(), pv_len()),
      .I32Eqz,
      .If(
        .Some(pvec_ref()),
        [.LocalGet(p_a), .RefAsNonNull],
        [
          .LocalGet(p_a),
          .RefAsNonNull,
          .StructGet(t_pvec(), pv_len()),
          .I32Eqz,
          .If(
            .Some(pvec_ref()),
            [.LocalGet(p_b), .RefAsNonNull],
            [
              .LocalGet(p_b),
              .RefAsNonNull,
              .StructGet(t_pvec(), pv_root()),
              .RefIsNull,
              .If(
                .Some(pvec_ref()),
                [
                  .LocalGet(p_a),
                  .Call("builder_from"),
                  .LocalSet(l_builder),
                  .LocalGet(l_builder),
                  .LocalGet(p_b),
                  .Call("builder_extend"),
                  .LocalGet(l_builder),
                  .Call("builder_freeze"),
                ],
                [
                  .LocalGet(p_a),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_root()),
                  .RefIsNull,
                  .If(
                    .None,
                    [
                      .LocalGet(p_a),
                      .RefAsNonNull,
                      .StructGet(t_pvec(), pv_tail()),
                      .Call("wrap_leaf"),
                      .LocalSet(l_a_node),
                      .I32Const(b_()),
                      .LocalSet(l_a_shift),
                    ],
                    [
                      .LocalGet(p_a),
                      .RefAsNonNull,
                      .StructGet(t_pvec(), pv_root()),
                      .RefAsNonNull,
                      .LocalGet(p_a),
                      .RefAsNonNull,
                      .StructGet(t_pvec(), pv_shift()),
                      .LocalGet(p_a),
                      .RefAsNonNull,
                      .StructGet(t_pvec(), pv_tail()),
                      .Call("wrap_leaf"),
                      .I32Const(b_()),
                      .Call("concat_trees"),
                      .LocalSet(l_a_shift),
                      .LocalSet(l_a_node),
                    ],
                  ),
                  .LocalGet(l_a_node),
                  .RefAsNonNull,
                  .RefCast(false, .Named(vi)),
                  .LocalGet(l_a_shift),
                  .LocalGet(p_b),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_root()),
                  .RefAsNonNull,
                  .LocalGet(p_b),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_shift()),
                  .Call("concat_trees"),
                  .LocalSet(l_merged_shift),
                  .LocalSet(l_merged),
                  .LocalGet(p_a),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_len()),
                  .LocalGet(p_b),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_len()),
                  .I32Add,
                  .LocalGet(l_merged_shift),
                  .LocalGet(l_merged),
                  .RefAsNonNull,
                  .RefCast(false, .Named(vi)),
                  .LocalGet(p_b),
                  .RefAsNonNull,
                  .StructGet(t_pvec(), pv_tail()),
                  .StructNew(t_pvec()),
                ],
              ),
            ],
          ),
        ],
      ),
    ],
  }
}

