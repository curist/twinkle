                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(12),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(12),
                  .RefAsNonNull,
                  .ArrayLen,
                  .ArrayCopy(t_array, t_array),
                  .LocalGet(15),
                  .RefAsNonNull,
                  .LocalGet(12),
                  .RefAsNonNull,
                  .ArrayLen,
                  .LocalGet(13),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(13),
                  .RefAsNonNull,
                  .ArrayLen,
                  .ArrayCopy(t_array, t_array),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(0),
                  .StructGet(vi, vi_children),
                  .I32Const(0),
                  .LocalGet(8),
                  .I32Const(1),
                  .I32Sub,
                  .ArrayCopy(vc, vc),
                  .LocalGet(8),
                  .I32Const(1),
                  .I32Sub,
                  .LocalSet(7),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .LocalGet(7),
                  .LocalGet(15),
                  .RefAsNonNull,
                  .ArraySet(vc),
                  .LocalGet(7),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(7),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .LocalGet(7),
                  .LocalGet(2),
                  .StructGet(vi, vi_children),
                  .I32Const(1),
