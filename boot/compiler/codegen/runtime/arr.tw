//! rt.arr — persistent bit-partitioned trie vector operations.
//!
//! Mirrors stage0 src/runtime/arr.rs.
//! Branching factor 32, tail buffer, O(log32 N) get/set, amortized O(1) push.

use compiler.codegen.wasm_ir.{ExportDef, FuncDef, Instr, ValType, WasmModule}

// ── Constants ───────────────────────────────────────────────────────
b_ := 5 // bits per level

bf := 32 // branching factor = 1 << 5

mask := 31 // bf - 1

// ── Qualified type names (after linking) ────────────────────────────
t_array := "rt_types__Array"

t_pvec := "rt_types__PVec"

t_vec_children := "rt_types__VecChildren"

t_vec_internal := "rt_types__VecInternal"

t_i32_array := "rt_types__I32Array"

t_array_i64 := "rt_types__ArrayI64"

t_array_f64 := "rt_types__ArrayF64"

t_boxed_int := "rt_types__BoxedInt"

t_boxed_float := "rt_types__BoxedFloat"

t_variant := "rt_types__Variant"

// ── Ref type helpers ────────────────────────────────────────────────
fn arr_null() ValType {
  .Ref(true, .Named(t_array))
}

fn arr_ref() ValType {
  .Ref(false, .Named(t_array))
}

fn pvec_null() ValType {
  .Ref(true, .Named(t_pvec))
}

fn pvec_ref() ValType {
  .Ref(false, .Named(t_pvec))
}

fn vec_children_null() ValType {
  .Ref(true, .Named(t_vec_children))
}

fn vec_children_ref() ValType {
  .Ref(false, .Named(t_vec_children))
}

fn vec_internal_null() ValType {
  .Ref(true, .Named(t_vec_internal))
}

fn i32_array_null() ValType {
  .Ref(true, .Named(t_i32_array))
}

fn arr_i64_null() ValType {
  .Ref(true, .Named(t_array_i64))
}

fn arr_f64_null() ValType {
  .Ref(true, .Named(t_array_f64))
}

fn ref_eq_() ValType {
  .Ref(false, .Eq)
}

fn ref_eq_null() ValType {
  .Ref(true, .Eq)
}

// Typed i64 persistent vector helpers (rt.arr_i64 family). The trie-build
// helpers (new_path/wrap_leaf/concat_trees) are shared with the boxed family —
// they treat leaves as opaque `ref eq` — so only these thin PVecI64-struct
// wrappers are i64-specific.
t_pvec_i64 := "rt_types__PVecI64"

fn pvec_i64_null() ValType {
  .Ref(true, .Named(t_pvec_i64))
}

fn pvec_i64_ref() ValType {
  .Ref(false, .Named(t_pvec_i64))
}

fn arr_i64_ref() ValType {
  .Ref(false, .Named(t_array_i64))
}

// PVec field indices
pv_len := 0

pv_shift := 1

pv_root := 2

pv_tail := 3

// VecInternal field indices
vi_children := 0

vi_sizes := 1

// ── Module ──────────────────────────────────────────────────────────
pub fn module() WasmModule {
  funcs := [
    tailoff_fn(),
    vi_nav_fn(),
    child_count_fn(),
    copy_leaves_fn(),
    node_total_size_fn(),
    make_relaxed_fn(),
    pack_children_fn(),
    append_centre_fn(),
    concat_trees_fn(),
    wrap_leaf_fn(),
    get_leaf_fn(),
    new_path_fn(),
    push_tail_fn(),
    do_set_fn(),
    push_fn(),
    promote_full_tail_fn(),
    make_fn(),
    family_boxed().pvec_get_fn(),
    set_fn(),
    set_in_place_fn(),
    family_boxed().pvec_len_fn(),
    concat_fn(),
    slice_trim_right_fn(),
    slice_trim_left_fn(),
    slice_last_leaf_fn(),
    slice_collapse_root_fn(),
    slice_from_full_tree_fn(),
    slice_fn(),
    slice_take_fast_fn(),
    pop_tail_fn(),
    drop_last_fn(),
    gather_fn(),
    elem_i64().sort_typed_fn(),
    elem_f64().sort_typed_fn(),
    family_i64().pvec_len_fn(),
    family_i64().pvec_get_fn(),
    promote_full_tail_i64_fn(),
    family_i64().pvec_builder_new_fn(),
    builder_push_i64_fn(),
    family_i64().pvec_builder_freeze_fn(),
    box_i64_fn(),
    vec_i64_roundtrip_fn(),
    family_boxed().pvec_builder_new_fn(),
    builder_from_fn(),
    builder_push_fn(),
    builder_append_leaf_range_fn(),
    builder_extend_node_fn(),
    builder_extend_fn(),
    family_boxed().pvec_builder_freeze_fn(),
    from_array_fn(),
    to_array_fn(),
    from_read_file_result_fn(),
    make_empty_fn(),
  ]
  exports := collect f in funcs {
    ExportDef.{ wasm_name: f.name, func_sym: f.name }
  }
  .{
    namespace: "rt.arr",
    types: [],
    imports: [],
    funcs,
    globals: [
      .{ name: "empty_leaf", mutable: false, ty: arr_ref(), init: [.ArrayNewFixed(t_array, 0)] },
      .{
        name: "empty_pvec",
        mutable: false,
        ty: pvec_ref(),
        init: [
          .I32Const(0),
          .I32Const(0),
          .RefNull(.Named(t_vec_internal)),
          .GlobalGet("empty_leaf"),
          .StructNew(t_pvec),
        ],
      },
      .{
        name: "empty_leaf_i64",
        mutable: false,
        ty: arr_i64_ref(),
        init: [.ArrayNewFixed(t_array_i64, 0)],
      },
      .{
        name: "empty_pvec_i64",
        mutable: false,
        ty: pvec_i64_ref(),
        init: [
          .I32Const(0),
          .I32Const(0),
          .RefNull(.Named(t_vec_internal)),
          .GlobalGet("empty_leaf_i64"),
          .StructNew(t_pvec_i64),
        ],
      },
    ],
    tables: [],
    elems: [],
    exports,
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
}

// ═══════════════════════════════════════════════════════════════════════
// Internal helpers
// ═══════════════════════════════════════════════════════════════════════
// tailoff(len: i32) -> i32
// if len <= 32 { 0 } else { ((len - 1) >> 5) << 5 }
fn tailoff_fn() FuncDef {
  .{
    name: "tailoff",
    params: [.I32],
    results: [.I32],
    locals: [],
    body: [
      .LocalGet(0),
      .I32Const(bf),
      .I32LeS,
      .If(
        .Some(.I32),
        [.I32Const(0)],
        [.LocalGet(0), .I32Const(1), .I32Sub, .I32Const(b_), .I32ShrU, .I32Const(b_), .I32Shl],
      ),
    ],
  }
}

// vi_nav(node: VecInternal, idx: i32, shift: i32) -> (slot, sub_idx)
// One level of trie descent that works for both regular and relaxed (RRB) nodes.
//
// Convention: regular (radix) nodes leave idx UNCHANGED so the fully-regular
// fast path is byte-identical to the original pure-radix navigation (callers
// still take the in-leaf index as `idx & mask`). A relaxed node first *rebases*
// idx to be relative to its own subtree — clearing the high bits that regular
// ancestors selected via radix but never subtracted — then advances from the
// radix guess (a lower bound) while sizes[slot] <= idx and subtracts the
// preceding cumulative size. Mixed regular/relaxed paths stay correct because
// every relaxed node re-derives its subtree-relative index from scratch.
//
// Hot get/set inline the regular branch and only *call* this for the rare
// relaxed case, so the size-table tax never touches append-built vectors.
fn vi_nav_fn() FuncDef {
  // p0=node, p1=idx, p2=shift; L3=sizes, L4=slot
  .{
    name: "vi_nav",
    params: [.Ref(false, .Named(t_vec_internal)), .I32, .I32],
    results: [.I32, .I32],
    locals: [i32_array_null(), .I32],
    body: [
      .LocalGet(0),
      .StructGet(t_vec_internal, vi_sizes),
      .LocalSet(3),
      .LocalGet(3),
      .RefIsNull,
      .If(
        .None,
        [.LocalGet(1), .LocalGet(2), .I32ShrU, .I32Const(mask), .I32And, .LocalSet(4)],
        [
          .LocalGet(1),
          .I32Const(1),
          .LocalGet(2),
          .I32Const(b_),
          .I32Add,
          .I32Shl,
          .I32Const(1),
          .I32Sub,
          .I32And,
          .LocalSet(1),
          .LocalGet(1),
          .LocalGet(2),
          .I32ShrU,
          .I32Const(mask),
          .I32And,
          .LocalSet(4),
          .Block(
            "sbrk",
            .None,
            [
              .Loop(
                "slp",
                .None,
                [
                  .LocalGet(3),
                  .RefAsNonNull,
                  .LocalGet(4),
                  .ArrayGet(t_i32_array),
                  .LocalGet(1),
                  .I32GtS,
                  .BrIf("sbrk"),
                  .LocalGet(4),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(4),
                  .Br("slp"),
                ],
              ),
            ],
          ),
          .LocalGet(4),
          .I32Eqz,
          .If(
            .None,
            [],
            [
              .LocalGet(1),
              .LocalGet(3),
              .RefAsNonNull,
              .LocalGet(4),
              .I32Const(1),
              .I32Sub,
              .ArrayGet(t_i32_array),
              .I32Sub,
              .LocalSet(1),
            ],
          ),
        ],
      ),
      .LocalGet(4),
      .LocalGet(1),
    ],
  }
}

// child_count(node: VecInternal) -> i32
// Number of live children. Relaxed nodes carry sizes whose length is exactly the
// child count; regular nodes are filled left-to-right, so scan to the first null
// (or the full branching factor).
fn child_count_fn() FuncDef {
  // p0=node; L1=sizes, L2=i
  .{
    name: "child_count",
    params: [.Ref(false, .Named(t_vec_internal))],
    results: [.I32],
    locals: [i32_array_null(), .I32],
    body: [
      .LocalGet(0),
      .StructGet(t_vec_internal, vi_sizes),
      .LocalSet(1),
      .LocalGet(1),
      .RefIsNull,
      .If(
        .Some(.I32),
        [
          .I32Const(0),
          .LocalSet(2),
          .Block(
            "brk",
            .None,
            [
              .Loop(
                "lp",
                .None,
                [
                  .LocalGet(2),
                  .I32Const(bf),
                  .I32GeS,
                  .BrIf("brk"),
                  .LocalGet(0),
                  .StructGet(t_vec_internal, vi_children),
                  .LocalGet(2),
                  .ArrayGet(t_vec_children),
                  .RefIsNull,
                  .BrIf("brk"),
                  .LocalGet(2),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(2),
                  .Br("lp"),
                ],
              ),
            ],
          ),
          .LocalGet(2),
        ],
        [.LocalGet(1), .RefAsNonNull, .ArrayLen],
      ),
    ],
  }
}

// copy_leaves(node: VecInternal, shift: i32, dest: Array, off: i32) -> i32
// Append every element under `node` to `dest` starting at `off`, left to right,
// returning the next free offset. Relaxed-aware: walks actual children/leaf
// lengths rather than assuming full 32-element leaves.
fn copy_leaves_fn() FuncDef {
  ta := t_array

  // p0=node, p1=shift, p2=dest, p3=off; L4=count, L5=i, L6=child
  .{
    name: "copy_leaves",
    params: [.Ref(false, .Named(t_vec_internal)), .I32, arr_ref(), .I32],
    results: [.I32],
    locals: [.I32, .I32, ref_eq_null()],
    body: [
      .LocalGet(0),
      .Call("child_count"),
      .LocalSet(4),
      .I32Const(0),
      .LocalSet(5),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(5),
              .LocalGet(4),
              .I32GeS,
              .BrIf("brk"),
              .LocalGet(0),
              .StructGet(t_vec_internal, vi_children),
              .LocalGet(5),
              .ArrayGet(t_vec_children),
              .LocalSet(6),
              .LocalGet(1),
              .I32Const(b_),
              .I32Eq,
              .If(
                .None,
                [
                  .LocalGet(2),
                  .LocalGet(3),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .RefCast(false, .Named(ta)),
                  .I32Const(0),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .RefCast(false, .Named(ta)),
                  .ArrayLen,
                  .ArrayCopy(ta, ta),
                  .LocalGet(3),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .RefCast(false, .Named(ta)),
                  .ArrayLen,
                  .I32Add,
                  .LocalSet(3),
                ],
                [
                  .LocalGet(6),
                  .RefAsNonNull,
                  .RefCast(false, .Named(t_vec_internal)),
                  .LocalGet(1),
                  .I32Const(b_),
                  .I32Sub,
                  .LocalGet(2),
                  .LocalGet(3),
                  .Call("copy_leaves"),
                  .LocalSet(3),
                ],
              ),
              .LocalGet(5),
              .I32Const(1),
              .I32Add,
              .LocalSet(5),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(3),
    ],
  }
}

// node_total_size(node: eqref, shift: i32) -> i32
// Element count in the subtree rooted at `node`. shift==0 means `node` is a
// leaf Array. Relaxed nodes read sizes[last]; regular nodes are full for all
// but the last child.
fn node_total_size_fn() FuncDef {
  // p0=node, p1=shift; L2=sizes, L3=count
  .{
    name: "node_total_size",
    params: [ref_eq_(), .I32],
    results: [.I32],
    locals: [i32_array_null(), .I32],
    body: [
      .LocalGet(1),
      .I32Eqz,
      .If(
        .Some(.I32),
        [.LocalGet(0), .RefCast(false, .Named(t_array)), .ArrayLen],
        [
          .LocalGet(0),
          .RefCast(false, .Named(t_vec_internal)),
          .StructGet(t_vec_internal, vi_sizes),
          .LocalSet(2),
          .LocalGet(2),
          .RefIsNull,
          .If(
            .Some(.I32),
            [
              .LocalGet(0),
              .RefCast(false, .Named(t_vec_internal)),
              .Call("child_count"),
              .LocalSet(3),
              .LocalGet(3),
              .I32Const(1),
              .I32Sub,
              .I32Const(1),
              .LocalGet(1),
              .I32Shl,
              .I32Mul,
              .LocalGet(0),
              .RefCast(false, .Named(t_vec_internal)),
              .StructGet(t_vec_internal, vi_children),
              .LocalGet(3),
              .I32Const(1),
              .I32Sub,
              .ArrayGet(t_vec_children),
              .RefAsNonNull,
              .LocalGet(1),
              .I32Const(b_),
              .I32Sub,
              .Call("node_total_size"),
              .I32Add,
            ],
            [
              .LocalGet(2),
              .RefAsNonNull,
              .LocalGet(2),
              .RefAsNonNull,
              .ArrayLen,
              .I32Const(1),
              .I32Sub,
              .ArrayGet(t_i32_array),
            ],
          ),
        ],
      ),
    ],
  }
}

// make_relaxed(children: VecChildren, count: i32, node_shift: i32) -> VecInternal
// Build an internal node from `count` children (at level node_shift-5). Computes
// a cumulative size table; canonicalizes to a regular node (sizes=null) when
// every child but the last is full for the level. `children` is referenced as-is.
fn make_relaxed_fn() FuncDef {
  // p0=children, p1=count, p2=node_shift; L3=sizes, L4=acc, L5=i, L6=regular, L7=csize
  .{
    name: "make_relaxed",
    params: [vec_children_ref(), .I32, .I32],
    results: [.Ref(false, .Named(t_vec_internal))],
    locals: [i32_array_null(), .I32, .I32, .I32, .I32],
    body: [
      .I32Const(0),
      .LocalGet(1),
      .ArrayNew(t_i32_array),
      .LocalSet(3),
      .I32Const(0),
      .LocalSet(4),
      .I32Const(0),
      .LocalSet(5),
      .I32Const(1),
      .LocalSet(6),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(5),
              .LocalGet(1),
              .I32GeS,
              .BrIf("brk"),
              .LocalGet(0),
              .LocalGet(5),
              .ArrayGet(t_vec_children),
              .RefAsNonNull,
              .LocalGet(2),
              .I32Const(b_),
              .I32Sub,
              .Call("node_total_size"),
              .LocalSet(7),
              .LocalGet(4),
              .LocalGet(7),
              .I32Add,
              .LocalSet(4),
              .LocalGet(3),
              .RefAsNonNull,
              .LocalGet(5),
              .LocalGet(4),
              .ArraySet(t_i32_array),
              .LocalGet(5),
              .LocalGet(1),
              .I32Const(1),
              .I32Sub,
              .I32LtS,
              .If(
                .None,
                [
                  .LocalGet(7),
                  .I32Const(1),
                  .LocalGet(2),
                  .I32Shl,
                  .I32Ne,
                  .If(.None, [.I32Const(0), .LocalSet(6)], []),
                ],
                [],
              ),
              .LocalGet(5),
              .I32Const(1),
              .I32Add,
              .LocalSet(5),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(6),
      .If(
        .Some(.Ref(false, .Named(t_vec_internal))),
        [.LocalGet(0), .RefNull(.Named(t_i32_array)), .StructNew(t_vec_internal)],
        [.LocalGet(0), .LocalGet(3), .RefAsNonNull, .StructNew(t_vec_internal)],
      ),
    ],
  }
}

// pack_children(scratch: VecChildren, count: i32, node_shift: i32) -> (node, shift)
// Group `count` children (level node_shift-5) into internal node(s) at node_shift,
// at most 32 children each. <=32 children -> one node at node_shift; otherwise
// several nodes wrapped under one grandparent at node_shift+5. Overflow children
// are distributed evenly across the minimum number of parents: this is the local
// balance rule used by the current spine merge, and avoids the single-child
// overflow chains that cause repeated-prepend height creep.
fn pack_children_fn() FuncDef {
  // p0=scratch, p1=count, p2=node_shift
  // L3=ch, L4=off, L5=chunk, L6=parents, L7=pi, L8=resultnode, L9=resultshift
  // L10=parent_count, L11=base_chunk, L12=large_chunks
  .{
    name: "pack_children",
    params: [vec_children_ref(), .I32, .I32],
    results: [ref_eq_(), .I32],
    locals: [
      vec_children_null(),
      .I32,
      .I32,
      vec_children_null(),
      .I32,
      ref_eq_null(),
      .I32,
      .I32,
      .I32,
      .I32,
    ],
    body: [
      .LocalGet(1),
      .I32Const(bf),
      .I32LeS,
      .If(
        .None,
        [
          .RefNull(.Eq),
          .I32Const(bf),
          .ArrayNew(t_vec_children),
          .LocalSet(3),
          .LocalGet(3),
          .RefAsNonNull,
          .I32Const(0),
          .LocalGet(0),
          .I32Const(0),
          .LocalGet(1),
          .ArrayCopy(t_vec_children, t_vec_children),
          .LocalGet(3),
          .RefAsNonNull,
          .LocalGet(1),
          .LocalGet(2),
          .Call("make_relaxed"),
          .LocalSet(8),
          .LocalGet(2),
          .LocalSet(9),
        ],
        [
          .LocalGet(1),
          .I32Const(bf),
          .I32Const(1),
          .I32Sub,
          .I32Add,
          .I32Const(b_),
          .I32ShrU,
          .LocalSet(10),
          .LocalGet(1),
          .LocalGet(10),
          .I32DivS,
          .LocalSet(11),
          .LocalGet(1),
          .LocalGet(11),
          .LocalGet(10),
          .I32Mul,
          .I32Sub,
          .LocalSet(12),
          .RefNull(.Eq),
          .I32Const(bf),
          .ArrayNew(t_vec_children),
          .LocalSet(6),
          .I32Const(0),
          .LocalSet(4),
          .I32Const(0),
          .LocalSet(7),
          .Block(
            "brk",
            .None,
            [
              .Loop(
                "lp",
                .None,
                [
                  .LocalGet(4),
                  .LocalGet(1),
                  .I32GeS,
                  .BrIf("brk"),
                  .LocalGet(11),
                  .LocalGet(7),
                  .LocalGet(12),
                  .I32LtS,
                  .I32Add,
                  .LocalSet(5),
                  .RefNull(.Eq),
                  .I32Const(bf),
                  .ArrayNew(t_vec_children),
                  .LocalSet(3),
                  .LocalGet(3),
                  .RefAsNonNull,
                  .I32Const(0),
                  .LocalGet(0),
                  .LocalGet(4),
                  .LocalGet(5),
                  .ArrayCopy(t_vec_children, t_vec_children),
                  .LocalGet(6),
                  .RefAsNonNull,
                  .LocalGet(7),
                  .LocalGet(3),
                  .RefAsNonNull,
                  .LocalGet(5),
                  .LocalGet(2),
                  .Call("make_relaxed"),
                  .ArraySet(t_vec_children),
                  .LocalGet(7),
                  .I32Const(1),
                  .I32Add,
                  .LocalSet(7),
                  .LocalGet(4),
                  .LocalGet(5),
                  .I32Add,
                  .LocalSet(4),
                  .Br("lp"),
                ],
              ),
            ],
          ),
          .LocalGet(6),
          .RefAsNonNull,
          .LocalGet(7),
          .LocalGet(2),
          .I32Const(b_),
          .I32Add,
          .Call("make_relaxed"),
          .LocalSet(8),
          .LocalGet(2),
          .I32Const(b_),
          .I32Add,
          .LocalSet(9),
        ],
      ),
      .LocalGet(8),
      .RefAsNonNull,
      .LocalGet(9),
    ],
  }
}

// get_leaf(vec: PVec, idx: i32) -> (Array, i32)
fn get_leaf_fn() FuncDef {
  p_vec := 0
  p_idx := 1
  l_trie_count := 2
  l_node := 3
  l_level := 4
  l_slot := 5

  // p0=vec, p1=idx, L2=trie_count, L3=node, L4=level, L5=slot
  .{
    name: "get_leaf",
    params: [pvec_ref(), .I32],
    results: [arr_ref(), .I32],
    locals: [.I32, vec_internal_null(), .I32, .I32],
    body: [
      .LocalGet(p_vec),
      .StructGet(t_pvec, pv_len),
      .LocalGet(p_vec),
      .StructGet(t_pvec, pv_tail),
      .ArrayLen,
      .I32Sub,
      .LocalSet(l_trie_count),
      .LocalGet(p_idx),
      .LocalGet(l_trie_count),
      .I32GeS,
      .If(
        .None,
        [
          .LocalGet(p_vec),
          .StructGet(t_pvec, pv_tail),
          .LocalGet(p_idx),
          .LocalGet(l_trie_count),
          .I32Sub,
          .Return,
        ],
        [],
      ),
      .LocalGet(p_vec),
      .StructGet(t_pvec, pv_root),
      .LocalSet(l_node),
      .LocalGet(p_vec),
      .StructGet(t_pvec, pv_shift),
      .LocalSet(l_level),
      .Block(
        "brk",
        .None,
        [
          .Loop(
            "lp",
            .None,
            [
              .LocalGet(l_level),
              .I32Const(b_),
              .I32LeS,
              .BrIf("brk"),
              .LocalGet(l_node),
              .RefAsNonNull,
              .LocalGet(p_idx),
              .LocalGet(l_level),
              .Call("vi_nav"),
              .LocalSet(p_idx),
              .LocalSet(l_slot),
              .LocalGet(l_node),
              .RefAsNonNull,
              .StructGet(t_vec_internal, vi_children),
              .LocalGet(l_slot),
              .ArrayGet(t_vec_children),
              .RefCast(true, .Named(t_vec_internal)),
              .LocalSet(l_node),
              .LocalGet(l_level),
              .I32Const(b_),
              .I32Sub,
              .LocalSet(l_level),
              .Br("lp"),
            ],
          ),
        ],
      ),
      .LocalGet(l_node),
      .RefAsNonNull,
      .LocalGet(p_idx),
      .LocalGet(l_level),
      .Call("vi_nav"),
      .LocalSet(p_idx),
      .LocalSet(l_slot),
      .LocalGet(l_node),
      .RefAsNonNull,
      .StructGet(t_vec_internal, vi_children),
      .LocalGet(l_slot),
      .ArrayGet(t_vec_children),
      .RefCast(false, .Named(t_array)),
      .LocalGet(p_idx),
      .I32Const(mask),
      .I32And,
    ],
  }
}

// new_path(level: i32, node: eqref) -> eqref
fn new_path_fn() FuncDef {
