//! rt.core — equality, trap, and host I/O bindings.
//!
//! Mirrors stage0 src/runtime/core.rs.

use compiler.codegen.wasm_ir.{ExportDef, FuncDef, HeapType, ImportDef, Instr, ValType, WasmModule}
use compiler.codegen.wasm_layout.{EqTypeLayouts, WasmRecordLayout, WasmSumLayout}

fn str_null() ValType {
  ValType.Ref(true, HeapType.Named("rt_types__String"))
}

fn str_ref() ValType {
  ValType.Ref(false, HeapType.Named("rt_types__String"))
}

fn arr_null() ValType {
  ValType.Ref(true, HeapType.Named("rt_types__Array"))
}

fn arr_ref() ValType {
  ValType.Ref(false, HeapType.Named("rt_types__Array"))
}

fn pvec_ref() ValType {
  ValType.Ref(false, HeapType.Named("rt_types__PVec"))
}

fn pdict_ref() ValType {
  ValType.Ref(false, HeapType.Named("rt_types__PDict"))
}

fn variant_ref() ValType {
  ValType.Ref(false, HeapType.Named("rt_types__Variant"))
}

t_array := "rt_types__Array"

t_string := "rt_types__String"

t_pvec := "rt_types__PVec"

t_pdict := "rt_types__PDict"

t_variant := "rt_types__Variant"

t_boxed_int := "rt_types__BoxedInt"

t_boxed_float := "rt_types__BoxedFloat"

pv_len := 0

pd_size := 0

v_type_id := 0

v_variant_id := 1

v_payload := 2

pub fn module(eq_layouts: EqTypeLayouts) WasmModule {
  rec_eq_funcs := collect rec in eq_layouts.records {
    gen_record_eq_fn(rec)
  }
  sum_eq_funcs := collect sum in eq_layouts.sums {
    gen_sum_eq_fn(sum)
  }
  funcs := [
    print_fn(),
    println_fn(),
    eprint_fn(),
    eprintln_fn(),
    trap_fn(),
    eq_array_fn(),
    eq_vec_fn(),
    eq_dict_fn(),
    eq_variant_fn(),
  ]
    .concat(rec_eq_funcs)
    .concat(sum_eq_funcs)
    .append(eq_fn(eq_layouts))
  exports := collect f in funcs {
    ExportDef.{ wasm_name: f.name, func_sym: f.name }
  }
  WasmModule.{
    namespace: "rt.core",
    types: [],
    imports: [
      ImportDef.{
        module: "twinkle_runtime",
        name: "print",
        as_sym: "host_print",
        params: [str_null()],
        results: [],
      },
      ImportDef.{
        module: "twinkle_runtime",
        name: "println",
        as_sym: "host_println",
        params: [str_null()],
        results: [],
      },
      ImportDef.{
        module: "twinkle_runtime",
        name: "error",
        as_sym: "host_error",
        params: [str_null()],
        results: [],
      },
      ImportDef.{
        module: "twinkle_runtime",
        name: "eprint",
        as_sym: "host_eprint",
        params: [str_null()],
        results: [],
      },
      ImportDef.{
        module: "twinkle_runtime",
        name: "eprintln",
        as_sym: "host_eprintln",
        params: [str_null()],
        results: [],
      },
      ImportDef.{
        module: "rt.str",
        name: "eq",
        as_sym: "rt_str__eq",
        params: [str_ref(), str_ref()],
        results: [.I32],
      },
      ImportDef.{
        module: "rt.arr",
        name: "len",
        as_sym: "rt_arr__len",
        params: [ValType.Ref(true, HeapType.Named("rt_types__PVec"))],
        results: [.I32],
      },
      ImportDef.{
        module: "rt.arr",
        name: "get",
        as_sym: "rt_arr__get",
        params: [ValType.Ref(true, HeapType.Named("rt_types__PVec")), .I32],
        results: [.Anyref],
      },
      ImportDef.{
        module: "rt.dict",
        name: "len",
        as_sym: "rt_dict__len",
        params: [ValType.Ref(true, HeapType.Named("rt_types__PDict"))],
        results: [.I32],
      },
      ImportDef.{
        module: "rt.dict",
        name: "get",
        as_sym: "rt_dict__get",
        params: [ValType.Ref(true, HeapType.Named("rt_types__PDict")), .Anyref],
        results: [.Anyref],
      },
      ImportDef.{
        module: "rt.dict",
        name: "get_option",
        as_sym: "rt_dict__get_option",
        params: [ValType.Ref(true, HeapType.Named("rt_types__PDict")), .Anyref],
        results: [variant_ref()],
      },
      ImportDef.{
        module: "rt.dict",
        name: "keys",
        as_sym: "rt_dict__keys",
        params: [ValType.Ref(true, HeapType.Named("rt_types__PDict"))],
        results: [pvec_ref()],
      },
    ],
    funcs,
    globals: [],
    tables: [],
    elems: [],
    exports,
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
}

fn print_fn() FuncDef {
  FuncDef.{
    name: "print",
    params: [str_null()],
    results: [],
    locals: [],
    body: [Instr.LocalGet(0), Instr.Call("host_print")],
  }
}

fn println_fn() FuncDef {
  FuncDef.{
    name: "println",
    params: [str_null()],
    results: [],
    locals: [],
    body: [Instr.LocalGet(0), Instr.Call("host_println")],
  }
}

