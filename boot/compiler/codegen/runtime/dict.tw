// rt.dict — persistent HAMT dictionary with insertion-order tracking.
//
// Mirrors stage0 src/runtime/dict.rs.
// Key comparison uses rt.core.eq (structural equality).
// Key types: Int (BoxedInt or I31/Byte), String.

use compiler.codegen.wasm_ir.{ ValType, FuncDef, ExportDef, WasmModule }

// ── ValType helpers ──────────────────────────────────────────────────────────

fn pdict_null() ValType { .Ref(true, .Named("rt_types__PDict")) }
fn pdict_ref() ValType { .Ref(false, .Named("rt_types__PDict")) }
fn hamt_node_null() ValType { .Ref(true, .Named("rt_types__HamtNode")) }
fn hamt_node_ref() ValType { .Ref(false, .Named("rt_types__HamtNode")) }
fn hamt_entry_null() ValType { .Ref(true, .Named("rt_types__HamtEntry")) }
fn hamt_entry_ref() ValType { .Ref(false, .Named("rt_types__HamtEntry")) }
fn hamt_collision_null() ValType { .Ref(true, .Named("rt_types__HamtCollision")) }
fn hamt_collision_ref() ValType { .Ref(false, .Named("rt_types__HamtCollision")) }
fn arr_null() ValType { .Ref(true, .Named("rt_types__Array")) }
fn arr_ref() ValType { .Ref(false, .Named("rt_types__Array")) }
fn pvec_ref() ValType { .Ref(false, .Named("rt_types__PVec")) }
fn pvec_null() ValType { .Ref(true, .Named("rt_types__PVec")) }
fn variant_ref() ValType { .Ref(false, .Named("rt_types__Variant")) }
fn string_null() ValType { .Ref(true, .Named("rt_types__String")) }
fn boxed_int_null() ValType { .Ref(true, .Named("rt_types__BoxedInt")) }
fn vec_internal_null() ValType { .Ref(true, .Named("rt_types__VecInternal")) }

fn t_pdict() String { "rt_types__PDict" }
fn t_hamt_node() String { "rt_types__HamtNode" }
fn t_hamt_entry() String { "rt_types__HamtEntry" }
fn t_hamt_collision() String { "rt_types__HamtCollision" }
fn t_array() String { "rt_types__Array" }
fn t_pvec() String { "rt_types__PVec" }
fn t_variant() String { "rt_types__Variant" }
fn t_string() String { "rt_types__String" }
fn t_boxed_int() String { "rt_types__BoxedInt" }
fn t_vec_internal() String { "rt_types__VecInternal" }

// Field indices
fn he_hash() Int { 0 }
fn he_key() Int { 1 }
fn he_val() Int { 2 }
fn hn_bitmap() Int { 0 }
fn hn_entries() Int { 1 }
fn hc_hash() Int { 0 }
fn hc_entries() Int { 1 }
fn pd_size() Int { 0 }
fn pd_root() Int { 1 }
fn pd_order() Int { 2 }

pub fn module() WasmModule {
  funcs := [
    popcount_fn(), arr_insert_at_fn(), arr_replace_at_fn(), arr_remove_at_fn(),
    hash_i64_fn(), hash_string_fn(), hash_key_fn(),
    collision_get_fn(), collision_set_fn(),
    node_get_fn(), node_set_fn(), node_remove_fn(),
    order_remove_key_fn(),
    make_fn(), len_fn(), keys_fn(), has_fn(), get_fn(), get_option_fn(),
    set_fn(), remove_fn(), set_in_place_fn(), remove_in_place_fn(),
  ]
  exports := collect f in funcs {
    ExportDef.{ wasm_name: f.name, func_sym: f.name }
  }
  .{
    namespace: "rt.dict",
    types: [],
    imports: [
      .{ module: "rt.core", name: "eq", as_sym: "core_eq",
         params: [.Anyref, .Anyref], results: [.I32] },
      .{ module: "rt.arr", name: "push", as_sym: "arr_push",
         params: [pvec_ref(), .Anyref], results: [pvec_ref()] },
      .{ module: "rt.arr", name: "len", as_sym: "arr_len",
         params: [pvec_null()], results: [.I32] },
      .{ module: "rt.arr", name: "get", as_sym: "arr_get",
         params: [pvec_null(), .I32], results: [.Anyref] },
    ],
    funcs: funcs,
    globals: [],
    tables: [],
    elems: [],
    exports: exports,
    data: [],
    start: .None,
  }
}

// ── popcount(v: i32) -> i32 ──────────────────────────────────────────────────
fn popcount_fn() FuncDef {
  FuncDef.{ name: "popcount", params: [.I32], results: [.I32],
    locals: [.I32],
    body: [
      .I32Const(0), .LocalSet(1),
      .Block("exit", .None, [
        .Loop("loop", .None, [
          .LocalGet(0), .I32Eqz, .BrIf("exit"),
          .LocalGet(0), .LocalGet(0), .I32Const(1), .I32Sub, .I32And, .LocalSet(0),
          .LocalGet(1), .I32Const(1), .I32Add, .LocalSet(1),
          .Br("loop"),
        ]),
      ]),
      .LocalGet(1),
    ],
  }
}

// ── arr_insert_at(arr, idx, val) -> Array ────────────────────────────────────
fn arr_insert_at_fn() FuncDef {
  // p0=arr, p1=idx, p2=val; L3=n, L4=new_arr, L5=tail_len
  FuncDef.{ name: "arr_insert_at", params: [arr_ref(), .I32, .Anyref], results: [arr_ref()],
    locals: [.I32, arr_null(), .I32],
    body: [
      .LocalGet(0), .ArrayLen, .LocalSet(3),
      .RefNull(.Any), .LocalGet(3), .I32Const(1), .I32Add, .ArrayNew(t_array()), .LocalSet(4),
      .LocalGet(1), .I32Const(0), .I32GtS,
      .If(.None, [
        .LocalGet(4), .RefAsNonNull, .I32Const(0),
        .LocalGet(0), .I32Const(0), .LocalGet(1),
        .ArrayCopy(t_array(), t_array()),
      ], []),
      .LocalGet(4), .RefAsNonNull, .LocalGet(1), .LocalGet(2), .ArraySet(t_array()),
      .LocalGet(3), .LocalGet(1), .I32Sub, .LocalSet(5),
      .LocalGet(5), .I32Const(0), .I32GtS,
      .If(.None, [
        .LocalGet(4), .RefAsNonNull,
        .LocalGet(1), .I32Const(1), .I32Add,
        .LocalGet(0), .LocalGet(1), .LocalGet(5),
        .ArrayCopy(t_array(), t_array()),
      ], []),
      .LocalGet(4), .RefAsNonNull,
    ],
  }
}

// ── arr_replace_at(arr, idx, val) -> Array ───────────────────────────────────
fn arr_replace_at_fn() FuncDef {
  // p0=arr, p1=idx, p2=val; L3=n, L4=new_arr
  FuncDef.{ name: "arr_replace_at", params: [arr_ref(), .I32, .Anyref], results: [arr_ref()],
    locals: [.I32, arr_null()],
    body: [
      .LocalGet(0), .ArrayLen, .LocalSet(3),
      .RefNull(.Any), .LocalGet(3), .ArrayNew(t_array()), .LocalSet(4),
      .LocalGet(4), .RefAsNonNull, .I32Const(0),
      .LocalGet(0), .I32Const(0), .LocalGet(3),
      .ArrayCopy(t_array(), t_array()),
      .LocalGet(4), .RefAsNonNull, .LocalGet(1), .LocalGet(2), .ArraySet(t_array()),
      .LocalGet(4), .RefAsNonNull,
    ],
  }
}

// ── arr_remove_at(arr, idx) -> Array ─────────────────────────────────────────
fn arr_remove_at_fn() FuncDef {
  // p0=arr, p1=idx; L2=n, L3=new_arr, L4=tail_len
  FuncDef.{ name: "arr_remove_at", params: [arr_ref(), .I32], results: [arr_ref()],
    locals: [.I32, arr_null(), .I32],
    body: [
      .LocalGet(0), .ArrayLen, .LocalSet(2),
      .RefNull(.Any), .LocalGet(2), .I32Const(1), .I32Sub, .ArrayNew(t_array()), .LocalSet(3),
      .LocalGet(1), .I32Const(0), .I32GtS,
      .If(.None, [
        .LocalGet(3), .RefAsNonNull, .I32Const(0),
        .LocalGet(0), .I32Const(0), .LocalGet(1),
        .ArrayCopy(t_array(), t_array()),
      ], []),
      .LocalGet(2), .LocalGet(1), .I32Sub, .I32Const(1), .I32Sub, .LocalSet(4),
      .LocalGet(4), .I32Const(0), .I32GtS,
      .If(.None, [
        .LocalGet(3), .RefAsNonNull, .LocalGet(1),
        .LocalGet(0), .LocalGet(1), .I32Const(1), .I32Add, .LocalGet(4),
        .ArrayCopy(t_array(), t_array()),
      ], []),
      .LocalGet(3), .RefAsNonNull,
    ],
  }
}

// ── hash_i64(v: i64) -> i32 ──────────────────────────────────────────────────
fn hash_i64_fn() FuncDef {
  FuncDef.{ name: "hash_i64", params: [.I64], results: [.I32],
    locals: [.I32],
    body: [
      .LocalGet(0), .I32WrapI64,
      .LocalGet(0), .I64Const(32), .I64ShrS, .I32WrapI64,
      .I32Xor, .LocalSet(1),
      .LocalGet(1), .I32Const(-1640531527), .I32Mul,
    ],
  }
}

// ── hash_string(s: ref null $String) -> i32 ──────────────────────────────────
fn hash_string_fn() FuncDef {
  // p0=s; L1=hash, L2=n, L3=i
  FuncDef.{ name: "hash_string", params: [string_null()], results: [.I32],
    locals: [.I32, .I32, .I32],
    body: [
      .I32Const(-2128831035), .LocalSet(1),
      .LocalGet(0), .RefAsNonNull, .ArrayLen, .LocalSet(2),
      .I32Const(0), .LocalSet(3),
      .Block("exit", .None, [
        .Loop("loop", .None, [
          .LocalGet(3), .LocalGet(2), .I32GeS, .BrIf("exit"),
          .LocalGet(0), .RefAsNonNull, .LocalGet(3), .ArrayGetU(t_string()),
          .LocalGet(1), .I32Xor,
          .I32Const(16777619), .I32Mul, .LocalSet(1),
          .LocalGet(3), .I32Const(1), .I32Add, .LocalSet(3),
          .Br("loop"),
        ]),
      ]),
      .LocalGet(1),
    ],
  }
}

// ── hash_key(key: anyref) -> i32 ─────────────────────────────────────────────
fn hash_key_fn() FuncDef {
  FuncDef.{ name: "hash_key", params: [.Anyref], results: [.I32],
    locals: [],
    body: [
      .LocalGet(0), .RefTest(false, .I31),
      .If(.None, [
        .LocalGet(0), .RefCast(false, .I31), .I31GetU,
        .I64ExtendI32U, .Call("hash_i64"), .Return,
      ], []),
      .LocalGet(0), .RefTest(false, .Named(t_boxed_int())),
      .If(.None, [
        .LocalGet(0), .RefCast(false, .Named(t_boxed_int())),
        .StructGet(t_boxed_int(), 0), .Call("hash_i64"), .Return,
      ], []),
      .LocalGet(0), .RefCast(true, .Named(t_string())),
      .Call("hash_string"),
    ],
  }
}

// ── collision_get(c, key) -> anyref ──────────────────────────────────────────
fn collision_get_fn() FuncDef {
  // p0=c, p1=key; L2=entries, L3=n, L4=i, L5=entry
  FuncDef.{ name: "collision_get", params: [hamt_collision_null(), .Anyref], results: [.Anyref],
    locals: [arr_null(), .I32, .I32, hamt_entry_null()],
    body: [
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_collision(), hc_entries()), .LocalSet(2),
      .LocalGet(2), .RefAsNonNull, .ArrayLen, .LocalSet(3),
      .I32Const(0), .LocalSet(4),
      .Block("exit", .None, [
        .Loop("scan", .None, [
          .LocalGet(4), .LocalGet(3), .I32GeS, .BrIf("exit"),
          .LocalGet(2), .RefAsNonNull, .LocalGet(4), .ArrayGet(t_array()),
          .RefCast(false, .Named(t_hamt_entry())), .LocalSet(5),
          .LocalGet(5), .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(1), .Call("core_eq"),
          .If(.None, [
            .LocalGet(5), .StructGet(t_hamt_entry(), he_val()), .Return,
          ], []),
          .LocalGet(4), .I32Const(1), .I32Add, .LocalSet(4),
          .Br("scan"),
        ]),
      ]),
      .RefNull(.Any),
    ],
  }
}

// ── collision_set(c, hash, key, val) -> HamtCollision ────────────────────────
fn collision_set_fn() FuncDef {
  // p0=c, p1=hash, p2=key, p3=val; L4=entries, L5=n, L6=i, L7=entry, L8=new_entries
  FuncDef.{ name: "collision_set",
    params: [hamt_collision_null(), .I32, .Anyref, .Anyref],
    results: [hamt_collision_ref()],
    locals: [arr_null(), .I32, .I32, hamt_entry_null(), arr_null()],
    body: [
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_collision(), hc_entries()), .LocalSet(4),
      .LocalGet(4), .RefAsNonNull, .ArrayLen, .LocalSet(5),
      .I32Const(0), .LocalSet(6),
      .Block("found_exit", .None, [
        .Loop("scan", .None, [
          .LocalGet(6), .LocalGet(5), .I32GeS, .BrIf("found_exit"),
          .LocalGet(4), .RefAsNonNull, .LocalGet(6), .ArrayGet(t_array()),
          .RefCast(false, .Named(t_hamt_entry())), .LocalSet(7),
          .LocalGet(7), .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(2), .Call("core_eq"),
          .If(.None, [
            .LocalGet(1), .LocalGet(2), .LocalGet(3),
            .StructNew(t_hamt_entry()), .LocalSet(7),
            .LocalGet(4), .RefAsNonNull, .LocalGet(6), .LocalGet(7),
            .Call("arr_replace_at"), .LocalSet(8),
            .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_collision(), hc_hash()),
            .LocalGet(8), .RefAsNonNull, .StructNew(t_hamt_collision()), .Return,
          ], []),
          .LocalGet(6), .I32Const(1), .I32Add, .LocalSet(6),
          .Br("scan"),
        ]),
      ]),
      // Not found: append
      .LocalGet(1), .LocalGet(2), .LocalGet(3), .StructNew(t_hamt_entry()), .LocalSet(7),
      .LocalGet(4), .RefAsNonNull, .LocalGet(5), .LocalGet(7),
      .Call("arr_insert_at"), .LocalSet(8),
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_collision(), hc_hash()),
      .LocalGet(8), .RefAsNonNull, .StructNew(t_hamt_collision()),
    ],
  }
}

// ── node_get(node, hash, depth, key) -> anyref ───────────────────────────────
fn node_get_fn() FuncDef {
  // p0=node, p1=hash, p2=depth, p3=key
  // L4=fragment, L5=bit, L6=bitmap, L7=idx, L8=slot, L9=entries
  FuncDef.{ name: "node_get",
    params: [hamt_node_null(), .I32, .I32, .Anyref], results: [.Anyref],
    locals: [.I32, .I32, .I32, .I32, .Anyref, arr_null()],
    body: [
      .LocalGet(0), .RefIsNull,
      .If(.None, [.RefNull(.Any), .Return], []),
      .LocalGet(2), .I32Const(7), .I32GeU,
      .If(.None, [.RefNull(.Any), .Return], []),
      .LocalGet(1), .LocalGet(2), .I32Const(5), .I32Mul, .I32ShrU,
      .I32Const(31), .I32And, .LocalSet(4),
      .I32Const(1), .LocalGet(4), .I32Shl, .LocalSet(5),
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_bitmap()), .LocalSet(6),
      .LocalGet(6), .LocalGet(5), .I32And, .I32Eqz,
      .If(.None, [.RefNull(.Any), .Return], []),
      .LocalGet(6), .LocalGet(5), .I32Const(1), .I32Sub,
      .I32And, .Call("popcount"), .LocalSet(7),
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()), .LocalSet(9),
      .LocalGet(7), .LocalGet(9), .RefAsNonNull, .ArrayLen, .I32GeU,
      .If(.None, [.RefNull(.Any), .Return], []),
      .LocalGet(9), .RefAsNonNull, .LocalGet(7), .ArrayGet(t_array()), .LocalSet(8),
      // HamtEntry?
      .LocalGet(8), .RefTest(false, .Named(t_hamt_entry())),
      .If(.None, [
        .LocalGet(8), .RefCast(false, .Named(t_hamt_entry())),
        .StructGet(t_hamt_entry(), he_hash()),
        .LocalGet(1), .I32Eq,
        .If(.None, [
          .LocalGet(8), .RefCast(false, .Named(t_hamt_entry())),
          .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(3), .Call("core_eq"),
          .If(.None, [
            .LocalGet(8), .RefCast(false, .Named(t_hamt_entry())),
            .StructGet(t_hamt_entry(), he_val()), .Return,
          ], []),
        ], []),
        .RefNull(.Any), .Return,
      ], []),
      // HamtNode?
      .LocalGet(8), .RefTest(false, .Named(t_hamt_node())),
      .If(.None, [
        .LocalGet(8), .RefCast(true, .Named(t_hamt_node())),
        .LocalGet(1), .LocalGet(2), .I32Const(1), .I32Add,
        .LocalGet(3), .Call("node_get"), .Return,
      ], []),
      // HamtCollision
      .LocalGet(8), .RefCast(true, .Named(t_hamt_collision())),
      .LocalGet(3), .Call("collision_get"),
    ],
  }
}

// ── node_set(node, hash, depth, key, val) -> HamtNode ────────────────────────
fn node_set_fn() FuncDef {
  // p0=node, p1=hash, p2=depth, p3=key, p4=val
  // L5=new_entry, L6=shift, L7=fragment, L8=bit, L9=bitmap, L10=idx
  // L11=slot, L12=new_entries, L13=old_entry, L14=tmp_node, L15=collision, L16=new_collision
  FuncDef.{ name: "node_set",
    params: [hamt_node_null(), .I32, .I32, .Anyref, .Anyref],
    results: [hamt_node_ref()],
    locals: [
      hamt_entry_null(), .I32, .I32, .I32, .I32, .I32,
      .Anyref, arr_null(), hamt_entry_null(),
      hamt_node_null(), hamt_collision_null(), hamt_collision_null(),
    ],
    body: [
      .LocalGet(1), .LocalGet(3), .LocalGet(4),
      .StructNew(t_hamt_entry()), .LocalSet(5),

      // null node: single-entry node
      .LocalGet(0), .RefIsNull,
      .If(.None, [
        .LocalGet(1), .LocalGet(2), .I32Const(5), .I32Mul, .I32ShrU,
        .I32Const(31), .I32And, .LocalSet(7),
        .I32Const(1), .LocalGet(7), .I32Shl, .LocalSet(8),
        .LocalGet(8),
        .LocalGet(5), .ArrayNewFixed(t_array(), 1),
        .StructNew(t_hamt_node()), .Return,
      ], []),

      .LocalGet(2), .I32Const(5), .I32Mul, .LocalSet(6),
      .LocalGet(1), .LocalGet(6), .I32ShrU, .I32Const(31), .I32And, .LocalSet(7),
      .I32Const(1), .LocalGet(7), .I32Shl, .LocalSet(8),
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_bitmap()), .LocalSet(9),
      .LocalGet(9), .LocalGet(8), .I32Const(1), .I32Sub,
      .I32And, .Call("popcount"), .LocalSet(10),

      // no slot: insert
      .LocalGet(9), .LocalGet(8), .I32And, .I32Eqz,
      .If(.None, [
        .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()),
        .LocalGet(10), .LocalGet(5), .Call("arr_insert_at"), .LocalSet(12),
        .LocalGet(9), .LocalGet(8), .I32Or,
        .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
      ], []),

      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()), .LocalSet(12),
      .LocalGet(10), .LocalGet(12), .RefAsNonNull, .ArrayLen, .I32GeU,
      .If(.None, [
        .LocalGet(12), .RefAsNonNull,
        .LocalGet(12), .RefAsNonNull, .ArrayLen,
        .LocalGet(5), .Call("arr_insert_at"), .LocalSet(12),
        .LocalGet(9), .LocalGet(8), .I32Or,
        .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
      ], []),
      .LocalGet(12), .RefAsNonNull, .LocalGet(10), .ArrayGet(t_array()), .LocalSet(11),

      // HamtEntry slot
      .LocalGet(11), .RefTest(false, .Named(t_hamt_entry())),
      .If(.None, [
        .LocalGet(11), .RefCast(false, .Named(t_hamt_entry())), .LocalSet(13),
        .LocalGet(13), .StructGet(t_hamt_entry(), he_hash()),
        .LocalGet(1), .I32Eq,
        .If(.None, [
          .LocalGet(13), .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(3), .Call("core_eq"),
          .If(.None, [
            // same key: update
            .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()),
            .LocalGet(10), .LocalGet(5), .Call("arr_replace_at"), .LocalSet(12),
            .LocalGet(9), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
          ], [
            // same hash, diff key: collision
            .LocalGet(13), .LocalGet(5), .ArrayNewFixed(t_array(), 2), .LocalSet(12),
            .LocalGet(1), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_collision()), .LocalSet(15),
            .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()),
            .LocalGet(10), .LocalGet(15),
            .Call("arr_replace_at"), .LocalSet(12),
            .LocalGet(9), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
          ]),
        ], [
          // different hash: sub-node, unless all 32 hash bits are already consumed
          .LocalGet(2), .I32Const(6), .I32GeU,
          .If(.None, [
            .LocalGet(13), .LocalGet(5), .ArrayNewFixed(t_array(), 2), .LocalSet(12),
            .LocalGet(1), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_collision()), .LocalSet(15),
            .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()),
            .LocalGet(10), .LocalGet(15),
            .Call("arr_replace_at"), .LocalSet(12),
            .LocalGet(9), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
          ], []),
          .RefNull(.Named(t_hamt_node())),
          .LocalGet(13), .StructGet(t_hamt_entry(), he_hash()),
          .LocalGet(2), .I32Const(1), .I32Add,
          .LocalGet(13), .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(13), .StructGet(t_hamt_entry(), he_val()),
          .Call("node_set"), .LocalSet(14),
          .LocalGet(14),
          .LocalGet(1), .LocalGet(2), .I32Const(1), .I32Add,
          .LocalGet(3), .LocalGet(4), .Call("node_set"), .LocalSet(14),
          .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()),
          .LocalGet(10), .LocalGet(14),
          .Call("arr_replace_at"), .LocalSet(12),
          .LocalGet(9), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
        ]),
      ], []),

      // HamtNode slot: recurse
      .LocalGet(11), .RefTest(false, .Named(t_hamt_node())),
      .If(.None, [
        .LocalGet(11), .RefCast(true, .Named(t_hamt_node())),
