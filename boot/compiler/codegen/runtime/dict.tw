// ── node_remove(node, hash, depth, key) -> HamtNode? ─────────────────────────
fn node_remove_fn() FuncDef {
  // p0=node, p1=hash, p2=depth, p3=key
  // L4=fragment, L5=bit, L6=bitmap, L7=idx, L8=slot, L9=entries, L10=n_entries
  // L11=old_entry, L12=new_entries, L13=sub, L14=new_sub
  // L15=collision, L16=c_entries, L17=c_n, L18=found_j, L19=j, L20=ce, L21=new_c
  FuncDef.{ name: "node_remove",
    params: [hamt_node_null(), .I32, .I32, .Anyref],
    results: [hamt_node_null()],
    locals: [
      .I32, .I32, .I32, .I32, .Anyref,
      arr_null(), .I32,
      hamt_entry_null(), arr_null(),
      hamt_node_null(), hamt_node_null(),
      hamt_collision_null(), arr_null(), .I32,
      .I32, .I32, hamt_entry_null(), hamt_collision_null(),
    ],
    body: [
      .LocalGet(0), .RefIsNull,
      .If(.None, [.RefNull(.Named(t_hamt_node())), .Return], []),
      .LocalGet(1), .LocalGet(2), .I32Const(5), .I32Mul,
      .I32ShrU, .I32Const(31), .I32And, .LocalSet(4),
      .I32Const(1), .LocalGet(4), .I32Shl, .LocalSet(5),
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_bitmap()), .LocalSet(6),
      .LocalGet(6), .LocalGet(5), .I32And, .I32Eqz,
      .If(.None, [.LocalGet(0), .Return], []),
      .LocalGet(6), .LocalGet(5), .I32Const(1), .I32Sub,
      .I32And, .Call("popcount"), .LocalSet(7),
      .LocalGet(0), .RefAsNonNull, .StructGet(t_hamt_node(), hn_entries()), .LocalSet(9),
      .LocalGet(9), .RefAsNonNull, .ArrayLen, .LocalSet(10),
      .LocalGet(9), .RefAsNonNull, .LocalGet(7), .ArrayGet(t_array()), .LocalSet(8),

      // HamtEntry
      .LocalGet(8), .RefTest(false, .Named(t_hamt_entry())),
      .If(.None, [
        .LocalGet(8), .RefCast(false, .Named(t_hamt_entry())), .LocalSet(11),
        .LocalGet(11), .StructGet(t_hamt_entry(), he_hash()),
        .LocalGet(1), .I32Eq,
        .If(.None, [
          .LocalGet(11), .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(3), .Call("core_eq"),
          .If(.None, [
            .LocalGet(10), .I32Const(1), .I32Eq,
            .If(.None, [.RefNull(.Named(t_hamt_node())), .Return], []),
            .LocalGet(9), .RefAsNonNull, .LocalGet(7), .Call("arr_remove_at"), .LocalSet(12),
            .LocalGet(6), .LocalGet(5), .I32Sub,
            .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
          ], [.LocalGet(0), .Return]),
        ], [.LocalGet(0), .Return]),
      ], []),

      // HamtNode: recurse
      .LocalGet(8), .RefTest(false, .Named(t_hamt_node())),
      .If(.None, [
        .LocalGet(8), .RefCast(true, .Named(t_hamt_node())), .LocalSet(13),
        .LocalGet(13), .LocalGet(1), .LocalGet(2), .I32Const(1), .I32Add,
        .LocalGet(3), .Call("node_remove"), .LocalSet(14),
        .LocalGet(14), .RefIsNull,
        .If(.None, [
          .LocalGet(10), .I32Const(1), .I32Eq,
          .If(.None, [.RefNull(.Named(t_hamt_node())), .Return], []),
          .LocalGet(9), .RefAsNonNull, .LocalGet(7), .Call("arr_remove_at"), .LocalSet(12),
          .LocalGet(6), .LocalGet(5), .I32Sub,
          .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
        ], []),
        .LocalGet(9), .RefAsNonNull, .LocalGet(7), .LocalGet(14),
        .Call("arr_replace_at"), .LocalSet(12),
        .LocalGet(6), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
      ], []),

      // HamtCollision
      .LocalGet(8), .RefCast(true, .Named(t_hamt_collision())), .LocalSet(15),
      .LocalGet(15), .RefAsNonNull, .StructGet(t_hamt_collision(), hc_entries()), .LocalSet(16),
      .LocalGet(16), .RefAsNonNull, .ArrayLen, .LocalSet(17),
      .I32Const(-1), .LocalSet(18),
      .I32Const(0), .LocalSet(19),
      .Block("find_exit", .None, [
        .Loop("find", .None, [
          .LocalGet(19), .LocalGet(17), .I32GeS, .BrIf("find_exit"),
          .LocalGet(16), .RefAsNonNull, .LocalGet(19), .ArrayGet(t_array()),
          .RefCast(false, .Named(t_hamt_entry())), .LocalSet(20),
          .LocalGet(20), .StructGet(t_hamt_entry(), he_key()),
          .LocalGet(3), .Call("core_eq"),
          .If(.None, [.LocalGet(19), .LocalSet(18), .Br("find_exit")], []),
          .LocalGet(19), .I32Const(1), .I32Add, .LocalSet(19),
          .Br("find"),
        ]),
      ]),
      .LocalGet(18), .I32Const(1), .I32Add, .I32Eqz,
      .If(.None, [.LocalGet(0), .Return], []),
      .LocalGet(16), .RefAsNonNull, .LocalGet(18), .Call("arr_remove_at"), .LocalSet(12),
      .LocalGet(12), .RefAsNonNull, .ArrayLen, .I32Const(1), .I32Eq,
      .If(.None, [
        .LocalGet(12), .RefAsNonNull, .I32Const(0), .ArrayGet(t_array()), .LocalSet(8),
        .LocalGet(9), .RefAsNonNull, .LocalGet(7), .LocalGet(8),
        .Call("arr_replace_at"), .LocalSet(12),
        .LocalGet(6), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()), .Return,
      ], []),
      .LocalGet(15), .RefAsNonNull, .StructGet(t_hamt_collision(), hc_hash()),
      .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_collision()), .LocalSet(21),
      .LocalGet(9), .RefAsNonNull, .LocalGet(7), .LocalGet(21),
      .Call("arr_replace_at"), .LocalSet(12),
      .LocalGet(6), .LocalGet(12), .RefAsNonNull, .StructNew(t_hamt_node()),
    ],
