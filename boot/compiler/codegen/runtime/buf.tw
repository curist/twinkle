fn load_i64_fn() FuncDef {
  .{
    name: "buf_load_i64",
    params: [.I32, .I32],
    results: [.I64],
    locals: [],
    body: [.LocalGet(0), .LocalGet(1), .I32Add, .I64Load(0, 0)],
  }
}

// buf_store_i64(base, off, v) — writes i64 v at addr = base + off.
fn store_i64_fn() FuncDef {
  .{
    name: "buf_store_i64",
    params: [.I32, .I32, .I64],
    results: [],
    locals: [],
    body: [.LocalGet(0), .LocalGet(1), .I32Add, .LocalGet(2), .I64Store(0, 0)],
  }
}

// buf_load_f64(base, off) -> f64 at addr = base + off.
fn load_f64_fn() FuncDef {
  .{
    name: "buf_load_f64",
    params: [.I32, .I32],
    results: [.F64],
    locals: [],
    body: [.LocalGet(0), .LocalGet(1), .I32Add, .F64Load(0, 0)],
