// buf_store_f64(base, off, v) — writes f64 v at addr = base + off.
fn store_f64_fn() FuncDef {
  .{
    name: "buf_store_f64",
    params: [.I32, .I32, .F64],
    results: [],
    locals: [],
    body: [.LocalGet(0), .LocalGet(1), .I32Add, .LocalGet(2), .F64Store(0, 0)],
  }
}
