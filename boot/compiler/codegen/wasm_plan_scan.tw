//! Lightweight prepared-body scan for wasm planning.
//!
//! This deliberately collects only planner-side body facts:
//! - string literals
//! - closure-materialized FuncIds from AMakeClosure
//! - direct builtin FuncIds from ACall callee sites
//! - explicit module-global references from non-init prepared bodies

use compiler.backend.prepare.{PreparedModule}
use compiler.backend.prepared_ir.{
  PreparedAtom, PreparedExpr, PreparedOp, PreparedPattern, SlotId, SlotInfo,
}
use compiler.builtins as bi
use compiler.builtins.{BuiltinRegistry}
use compiler.codegen.wasm_layout.{mono_to_key}
use compiler.mono_type.{MonoType}

// A payload-free variant literal actually constructed in some body, keyed by
// "${mono_to_key(mono)}#${vid}". Carries the result mono so the planner can
// resolve the sum layout and (if eligible) hoist the value to a shared global.
pub type NullaryVariantReq = .{ mono: MonoType, vid: Int }

pub type ScanResult = .{
  strings: Dict<String, Bool>,
  closure_materialized_funcs: Dict<Int, Bool>,
  closure_materialized_monos: Dict<Int, MonoType>,
  direct_builtin_calls: Dict<Int, Bool>,
  module_globals: Dict<Int, Bool>,
  nullary_variants: Dict<String, NullaryVariantReq>,
}

pub fn scan_module_bodies(input: PreparedModule, builtins: BuiltinRegistry) ScanResult {
  out := ScanResult.{
    strings: Dict.new(),
    closure_materialized_funcs: Dict.new(),
    closure_materialized_monos: Dict.new(),
    direct_builtin_calls: Dict.new(),
    module_globals: Dict.new(),
    nullary_variants: Dict.new(),
  }

  for func in input.funcs {
    out = scan_expr(func.body, builtins, func.is_init, out)
  }

  // Extract concrete monos from AMakeClosure slot info so that generic
  // builtins (Cell.update, Iterator.unfold) get specialized signatures
  for func in input.funcs {
    out = extract_closure_monos(func.body, func.slots, out)
  }

  out
}

fn scan_expr(expr: PreparedExpr, builtins: BuiltinRegistry, is_init: Bool, out: ScanResult) ScanResult {
  case expr {
    .Let(_, op, body) => {
      cur := scan_op(op, builtins, is_init, out)
      scan_expr(body, builtins, is_init, cur)
    },
    .Atom(atom) => scan_atom(atom, is_init, out),
    .Return(.Some(atom)) => scan_atom(atom, is_init, out),
    .Break(.Some(atom)) => scan_atom(atom, is_init, out),
    .Return(.None) => out,
    .Break(.None) => out,
    .Continue => out,
  }
}

fn scan_op(op: PreparedOp, builtins: BuiltinRegistry, is_init: Bool, out: ScanResult) ScanResult {
  case op {
    .ACall(callee, args) => {
      cur := scan_atom(callee, is_init, out)

      for arg in args {
        cur = scan_atom(arg, is_init, cur)
      }

      case callee {
        .AGlobalFunc(fid) => case bi.entry(builtins, fid) {
          .Some(_) => {
            cur.direct_builtin_calls[fid.id] = true
            cur
          },
          .None => cur,
        },
        _ => cur,
      }
    },
    .AIf(cond_e, then_e, else_e) => {
      cur := scan_atom(cond_e, is_init, out)
      cur = scan_expr(then_e, builtins, is_init, cur)
      scan_expr(else_e, builtins, is_init, cur)
    },
    .AMatch(scrutinee, arms) => {
      cur := scan_atom(scrutinee, is_init, out)

      for arm in arms {
        cur = scan_pattern(arm.pattern, cur)
        cur = scan_expr(arm.body, builtins, is_init, cur)
      }

      cur
    },
    .ALoop(body) => scan_expr(body, builtins, is_init, out),
    .ADefer(body) => scan_expr(body, builtins, is_init, out),
    .ABinOp(_, left, right, _) => {
      cur := scan_atom(left, is_init, out)
      scan_atom(right, is_init, cur)
    },
    .AUnOp(_, inner, _) => scan_atom(inner, is_init, out),
    .AMakeClosure(fid, free_vars) => {
      cur := out
      cur.closure_materialized_funcs[fid.id] = true

      for fv in free_vars {
        cur = scan_atom(.ASlot(fv), is_init, cur)
      }

      cur
    },
    .ARecord(_, fields) => {
      cur := out

      for field in fields {
        cur = scan_atom(field.value, is_init, cur)
      }

      cur
    },
    .ARecordGet(target, _, _) => scan_atom(target, is_init, out),
    .ARecordUpdate(base, _, value, _, _) => {
      cur := scan_atom(base, is_init, out)
      scan_atom(value, is_init, cur)
    },
    .AVariant(_, _, args) => scan_atoms(args, is_init, out),
    .AArrayLit(items) => scan_atoms(items, is_init, out),
    .AIndex(base, index, _, _) => {
      cur := scan_atom(base, is_init, out)
      scan_atom(index, is_init, cur)
    },
    .AInit(atom) => scan_atom(atom, is_init, out),
    .AAssign(_, atom) => scan_atom(atom, is_init, out),
    .AGlobalSet(gid, atom) => {
      // Register the written global so it gets a registry entry and a wasm
      // global declaration even if no read of it is scanned.
      cur := scan_atom(atom, is_init, out)
      cur.module_globals[gid.id] = true
      cur
    },
    .AWrapAnyref(atom, _) => scan_atom(atom, is_init, out),
    .AUnwrapAnyref(atom, _) => scan_atom(atom, is_init, out),
  }
}

fn scan_atoms(atoms: Vector<PreparedAtom>, is_init: Bool, out: ScanResult) ScanResult {
  cur := out

  for atom in atoms {
    cur = scan_atom(atom, is_init, cur)
  }

  cur
}

fn scan_atom(atom: PreparedAtom, is_init: Bool, out: ScanResult) ScanResult {
  case atom {
    .ALitStr(s) => {
      out.strings[s] = true
      out
    },
    .AGlobalLocal(lid) => {
      // Register the global whether the read is in a regular function or in an
      // init function (top-level user code lowers into an init function, and a
      // module global like `math.pi` may be read only from there).
      out.module_globals[lid.id] = true
      out
    },
    _ => out,
  }
}

fn scan_pattern(pattern: PreparedPattern, out: ScanResult) ScanResult {
  case pattern {
    .LitStr(s) => {
      out.strings[s] = true
      out
    },
    .Variant(_, _, fields) => {
      cur := out

      for field in fields {
        cur = scan_pattern(field, cur)
      }

      cur
    },
    _ => out,
  }
}

// ── Closure mono extraction ────────────────────────────────────────
// Second pass: walk prepared bodies to extract the concrete MonoType
// from the slot that each AMakeClosure result is bound to. This gives
// the planner specialized types for generic builtins.
fn extract_closure_monos(expr: PreparedExpr, slots: Dict<Int, SlotInfo>, out: ScanResult) ScanResult {
  case expr {
    .Let(sid, op, body) => {
      cur := extract_closure_monos_op(sid, op, slots, out)
      extract_closure_monos(body, slots, cur)
    },
    _ => out,
  }
}

fn extract_closure_monos_op(
  sid: SlotId,
  op: PreparedOp,
  slots: Dict<Int, SlotInfo>,
  out: ScanResult,
) ScanResult {
  case op {
    .AMakeClosure(fid, _) => case slots[sid.id] {
      .Some(info) => {
        out.closure_materialized_monos[fid.id] = info.mono
        out
      },
      .None => out,
    },
    // Payload-free variant literal: record its result mono (from the slot it
    // binds to) so the planner can hoist it to a shared module global.
    .AVariant(_, vid, args) => if args.len() == 0 {
      case slots[sid.id] {
        .Some(info) => {
          key := "${mono_to_key(info.mono)}#${vid.id}"
          out.nullary_variants[key] = .{ mono: info.mono, vid: vid.id }
          out
        },
        .None => out,
      }
    } else {
      out
    },
    .AIf(_, then_e, else_e) => {
      cur := extract_closure_monos(then_e, slots, out)
      extract_closure_monos(else_e, slots, cur)
    },
    .AMatch(_, arms) => {
      cur := out

      for arm in arms {
        cur = extract_closure_monos(arm.body, slots, cur)
      }

      cur
    },
    .ALoop(body) => extract_closure_monos(body, slots, out),
    .ADefer(body) => extract_closure_monos(body, slots, out),
    _ => out,
  }
}
