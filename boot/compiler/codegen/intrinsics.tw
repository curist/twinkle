fn string_utf8_bytes_helper_fn() FuncDef {
  FuncDef.{
    name: "string_utf8_bytes_helper",
    params: [str_null()],
    results: [arr_ref()],
    locals: [.I32, .I32, arr_ref()],
    body: [
      .LocalGet(0),
      .ArrayLen,
      .LocalSet(1),
      .LocalGet(1),
      .ArrayNewDefault("rt_types__Array"),
      .LocalSet(3),
      .I32Const(0),
      .LocalSet(2),
      .Block(
        "utf8_bytes_break",
        .None,
        [
          .Loop(
            "utf8_bytes_continue",
            .None,
            [
              .LocalGet(2),
              .LocalGet(1),
              .I32GeU,
              .BrIf("utf8_bytes_break"),
              .LocalGet(3),
              .LocalGet(2),
              .LocalGet(0),
              .LocalGet(2),
              .ArrayGetU("rt_types__String"),
              .RefI31,
              .ArraySet("rt_types__Array"),
              .LocalGet(2),
              .I32Const(1),
              .I32Add,
              .LocalSet(2),
              .Br("utf8_bytes_continue"),
            ],
          ),
        ],
      ),
      .LocalGet(3),
    ],
  }
}

fn utf8_validate_multibyte(n: Int) Vector<Instr> {
  instrs: Vector<Instr> = [
    .LocalGet(2),
    .I32Const(n - 1),
    .I32Add,
    .LocalGet(1),
    .I32GeU,
    .If(.None, [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")], []),
  ]
  off := 1

  for off < n {
    instrs = append_instrs(
      instrs,
      [
        .LocalGet(0),
        .LocalGet(2),
        .I32Const(off),
        .I32Add,
        .ArrayGet("rt_types__Array"),
        .RefCast(false, .I31),
        .I31GetU,
        .I32Const(192),
        .I32And,
        .I32Const(128),
        .I32Ne,
        .If(.None, [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")], []),
      ],
    )
    off = off + 1
  }

  if n == 3 {
    instrs = append_instrs(
      instrs,
      [
        .LocalGet(4),
        .I32Const(224),
        .I32Eq,
        .If(
          .None,
          [
            .LocalGet(0),
            .LocalGet(2),
            .I32Const(1),
            .I32Add,
            .ArrayGet("rt_types__Array"),
            .RefCast(false, .I31),
            .I31GetU,
            .I32Const(160),
            .I32LtU,
            .If(
              .None,
              [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
              [],
            ),
          ],
          [],
        ),
        .LocalGet(4),
        .I32Const(237),
        .I32Eq,
        .If(
          .None,
          [
            .LocalGet(0),
            .LocalGet(2),
            .I32Const(1),
            .I32Add,
            .ArrayGet("rt_types__Array"),
            .RefCast(false, .I31),
            .I31GetU,
            .I32Const(160),
            .I32GeU,
            .If(
              .None,
              [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
              [],
            ),
          ],
          [],
        ),
      ],
    )
  }

  if n == 4 {
    instrs = append_instrs(
      instrs,
      [
        .LocalGet(4),
        .I32Const(240),
        .I32Eq,
        .If(
          .None,
          [
            .LocalGet(0),
            .LocalGet(2),
            .I32Const(1),
            .I32Add,
            .ArrayGet("rt_types__Array"),
            .RefCast(false, .I31),
            .I31GetU,
            .I32Const(144),
            .I32LtU,
            .If(
              .None,
              [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
              [],
            ),
          ],
          [],
        ),
        .LocalGet(4),
        .I32Const(244),
        .I32Eq,
        .If(
          .None,
          [
            .LocalGet(0),
            .LocalGet(2),
            .I32Const(1),
            .I32Add,
            .ArrayGet("rt_types__Array"),
            .RefCast(false, .I31),
            .I31GetU,
            .I32Const(144),
            .I32GeU,
            .If(
              .None,
              [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
              [],
            ),
          ],
          [],
        ),
      ],
    )
  }

  append_instrs(instrs, [.LocalGet(2), .I32Const(n), .I32Add, .LocalSet(2)])
}

fn string_from_utf8_helper_fn() FuncDef {
  none_body: Vector<Instr> = [
    .I32Const(0),
    .I32Const(0),
    .ArrayNewFixed("rt_types__Array", 0),
    .StructNew("rt_types__Variant"),
  ]
  some_body: Vector<Instr> = [
    .LocalGet(1),
    .ArrayNewDefault("rt_types__String"),
    .LocalSet(3),
    .I32Const(0),
    .LocalSet(2),
    .Block(
      "utf8_copy_break",
      .None,
      [
        .Loop(
          "utf8_copy_continue",
          .None,
          [
            .LocalGet(2),
            .LocalGet(1),
            .I32GeU,
            .BrIf("utf8_copy_break"),
            .LocalGet(3),
            .LocalGet(2),
            .LocalGet(0),
            .LocalGet(2),
            .ArrayGet("rt_types__Array"),
            .RefCast(false, .I31),
            .I31GetU,
            .ArraySet("rt_types__String"),
            .LocalGet(2),
            .I32Const(1),
            .I32Add,
            .LocalSet(2),
            .Br("utf8_copy_continue"),
          ],
        ),
      ],
    ),
    .I32Const(0),
    .I32Const(1),
    .LocalGet(3),
    .ArrayNewFixed("rt_types__Array", 1),
    .StructNew("rt_types__Variant"),
  ]
  FuncDef.{
    name: "string_from_utf8_helper",
    params: [arr_null()],
    results: [.Anyref],
    locals: [.I32, .I32, str_null(), .I32, .I32, .I32],
    body: [
      .LocalGet(0),
      .ArrayLen,
      .LocalSet(1),
      .I32Const(1),
      .LocalSet(5),
      .I32Const(0),
      .LocalSet(2),
      .Block(
        "utf8_validate_break",
        .None,
        [
          .Loop(
            "utf8_validate_continue",
            .None,
            [
              .LocalGet(2),
              .LocalGet(1),
              .I32GeU,
              .BrIf("utf8_validate_break"),
              .LocalGet(0),
              .LocalGet(2),
              .ArrayGet("rt_types__Array"),
              .RefCast(false, .I31),
              .I31GetU,
              .LocalSet(4),
              .LocalGet(4),
              .I32Const(128),
              .I32LtU,
              .If(
                .None,
                [.LocalGet(2), .I32Const(1), .I32Add, .LocalSet(2)],
                [
                  .LocalGet(4),
                  .I32Const(192),
                  .I32GeU,
                  .LocalGet(4),
                  .I32Const(223),
                  .I32LeU,
                  .I32And,
                  .If(
                    .None,
                    [
                      .LocalGet(4),
                      .I32Const(194),
                      .I32LtU,
                      .If(
                        .None,
                        [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
                        [],
                      ),
                      .LocalGet(2),
                      .I32Const(1),
                      .I32Add,
                      .LocalGet(1),
                      .I32GeU,
                      .If(
                        .None,
                        [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
                        [],
                      ),
                      .LocalGet(0),
                      .LocalGet(2),
                      .I32Const(1),
                      .I32Add,
                      .ArrayGet("rt_types__Array"),
                      .RefCast(false, .I31),
                      .I31GetU,
                      .LocalSet(6),
                      .LocalGet(6),
                      .I32Const(192),
                      .I32And,
                      .I32Const(128),
                      .I32Ne,
                      .If(
                        .None,
                        [.I32Const(0), .LocalSet(5), .Br("utf8_validate_break")],
                        [],
                      ),
                      .LocalGet(2),
                      .I32Const(2),
                      .I32Add,
                      .LocalSet(2),
                    ],
                    [
                      .LocalGet(4),
                      .I32Const(224),
                      .I32GeU,
                      .LocalGet(4),
                      .I32Const(239),
                      .I32LeU,
                      .I32And,
                      .If(
                        .None,
                        utf8_validate_multibyte(3),
                        [
                          .LocalGet(4),
                          .I32Const(240),
                          .I32GeU,
                          .LocalGet(4),
                          .I32Const(244),
                          .I32LeU,
                          .I32And,
                          .If(
                            .None,
                            utf8_validate_multibyte(4),
                            [
                              .I32Const(0),
                              .LocalSet(5),
                              .Br("utf8_validate_break"),
                            ],
                          ),
                        ],
                      ),
                    ],
                  ),
                ],
              ),
              .Br("utf8_validate_continue"),
            ],
          ),
        ],
      ),
      .LocalGet(5),
      .I32Eqz,
      .If(.Some(.Anyref), none_body, some_body),
    ],
  }
}

fn float_from_string_helper_fn() FuncDef {
  some_body: Vector<Instr> = [
    .I32Const(0),
    .I32Const(1),
    .LocalGet(1),
    .StructNew("rt_types__BoxedFloat"),
    .ArrayNewFixed("rt_types__Array", 1),
    .StructNew("rt_types__Variant"),
  ]
  none_body: Vector<Instr> = [
    .I32Const(0),
    .I32Const(0),
    .ArrayNewFixed("rt_types__Array", 0),
    .StructNew("rt_types__Variant"),
  ]
  FuncDef.{
    name: "float_from_string_helper",
    params: [str_null()],
    results: [.Anyref],
    locals: [.F64, .I32],
    body: [
      .LocalGet(0),
      .Call("host_parse_float"),
      .LocalSet(2),
      .LocalSet(1),
      .LocalGet(2),
      .If(.Some(.Anyref), some_body, none_body),
    ],
  }
}
