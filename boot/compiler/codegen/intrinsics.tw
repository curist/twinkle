// codegen.intrinsics — internal helper functions for boot intrinsic lowering.
//
// These helpers support the backend's lowering strategy, but they are not part
// of the public runtime module surface. Keeping them here lets emit.tw lower to
// helper calls without also owning the helper implementations.
use compiler.codegen.wasm_ir.{
  ExportDef, FuncDef, ImportDef, Instr, ValType, WasmModule,
}

fn str_null() ValType {
  .Ref(true, .Named("rt_types__String"))
}

fn str_ref() ValType {
  .Ref(false, .Named("rt_types__String"))
}

fn arr_null() ValType {
  .Ref(true, .Named("rt_types__Array"))
}

fn arr_ref() ValType {
  .Ref(false, .Named("rt_types__Array"))
}

pub fn module() WasmModule {
  funcs := [
    int_from_string_helper_fn(),
    from_code_point_helper_fn(),
    string_utf8_bytes_helper_fn(),
    string_from_utf8_helper_fn(),
    float_from_string_helper_fn(),
  ]
  exports := collect f in funcs {
    ExportDef.{ wasm_name: f.name, func_sym: f.name }
  }
  .{
    namespace: "codegen.intrinsics",
    types: [],
    imports: [
      ImportDef.{
        module: "host",
        name: "parse_float",
        as_sym: "host_parse_float",
        params: [str_null()],
        results: [.F64, .I32],
      },
    ],
    funcs: funcs,
    globals: [],
    tables: [],
    elems: [],
    exports: exports,
    data: [],
    start: .None,
  }
}

fn append_instrs(base: Vector<Instr>, tail: Vector<Instr>) Vector<Instr> {
  out := base

  for i in tail { out = .append(i) }

  out
}

