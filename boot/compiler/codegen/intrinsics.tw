                    [
                      .LocalGet(2),
                      .LocalGet(3),
                      .I32GeS,
                      .BrIf(done_label),
                      .LocalGet(0),
                      .RefAsNonNull,
                      .LocalGet(2),
                      .ArrayGetU("rt_types__String"),
                      .LocalSet(5),
                      .LocalGet(5),
