// ── If emission ────────────────────────────────────────────────────────

fn emit_if_op(cond: PreparedAtom, then_e: PreparedExpr, else_e: PreparedExpr, result_idx: Int, result_vt: ValType?, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  control_emit.emit_if_op(cond, then_e, else_e, result_idx, result_vt, result_mono, ctx, buf, control_emit.ControlEmitFns.{
    emit_atom: emit_atom,
    emit_expr: emit_expr,
  })
}

fn emit_loop_op(body: PreparedExpr, result_idx: Int, result_vt: ValType?, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  control_emit.emit_loop_op(body, result_idx, result_vt, ctx, buf, control_emit.ControlEmitFns.{
    emit_atom: emit_atom,
    emit_expr: emit_expr,
  })
}

// ── Match emission ─────────────────────────────────────────────────────

fn emit_match_op(scrutinee: PreparedAtom, arms: Vector<PreparedMatchArm>, result_idx: Int, result_vt: ValType?, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  match_emit.emit_match_op(scrutinee, arms, result_idx, result_vt, result_mono, ctx, buf, match_emit.MatchEmitFns.{
    emit_atom: emit_atom,
    emit_expr: emit_expr,
    match_scrutinee_mono: match_scrutinee_mono,
    emit_pattern_condition: emit_pattern_condition,
    emit_pattern_bindings: emit_pattern_bindings,
  })
}

fn can_match_variant_pattern(scrutinee_mono: MonoType, env: ResolvedEnv) Bool {
  case scrutinee_mono {
    .Optional(_) => true,
    .Result(_, _) => true,
    .Named(tid, args) => {
      def := case env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => { return false },
      }
      case def {
        .Sum(_, _, _) => true,
        .Alias(_, type_params, target) => can_match_variant_pattern(subst_type_params(target, type_params, args), env),
        _ => false,
      }
    },
    _ => false,
  }
}

fn emit_pattern_condition(pattern: PreparedPattern, scrutinee_instrs: Vector<Instr>, scrutinee_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case pattern {
    .Wildcard => buf.append(.I32Const(1)),
    .Var(_) => buf.append(.I32Const(1)),
    .LitInt(n) => {
      buf.concat(scrutinee_instrs).append(.I64Const(n)).append(.I64Eq)
    },
    .LitBool(b) => {
      buf.concat(scrutinee_instrs).append(.I32Const(if b { 1 } else { 0 })).append(.I32Eq)
    },
    .LitStr(s) => {
      // String comparison via rt_str__eq
      out := buf.concat(scrutinee_instrs)
      case ctx.registry.string_pool[s] {
        .Some(entry) => {
          out.append(.Call(entry.getter_sym)).append(.Call("rt_str__eq"))
        },
        .None => error("emit_pattern_condition: string not in pool"),
      }
    },
    .Variant(tid, vid, fields) => {
      if !can_match_variant_pattern(scrutinee_mono, ctx.env) {
        buf.append(.I32Const(0))
      } else {
        emit_variant_pattern_condition(tid, vid, fields, scrutinee_instrs, scrutinee_mono, ctx, buf)
      }
    },
  }
}

fn emit_variant_pattern_condition(
  tid: TypeId, vid: VariantId, fields: Vector<PreparedPattern>,
  scrutinee_instrs: Vector<Instr>, scrutinee_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>,
) Vector<Instr> {
  sum_layout := get_sum_layout_ctx(scrutinee_mono, ctx)

  // Tag check — build as a separate small vector, then prepend to buf
  tag_check := scrutinee_instrs
    .append(.StructGet(sum_layout.sym, 0))
    .append(.I32Const(vid.id))
    .append(.I32Eq)

  // Check for non-trivial sub-patterns
  has_inner := false
  for fp in fields {
    if !pattern_is_trivial(fp) { has_inner = true }
  }
  if !has_inner { return buf.concat(tag_check) }

  // Short-circuit inner checks
  variant_layout := find_variant_layout(sum_layout, vid)
  inner_checks: Vector<Vector<Instr>> = []
  for fp,i in fields {
    if !pattern_is_trivial(fp) {
      offset := variant_layout.struct_field_offset + i
      field_instrs := scrutinee_instrs
      field_instrs = field_instrs.append(.StructGet(sum_layout.sym, offset))
      field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
      case field_mono {
        .Void => {
          case fp {
            .Variant(_, nested_vid, _) => {
              fid_text := case ctx.current_func_id {
                .Some(fid) => fid.id.to_string(),
                .None => "?",
              }
              error("emit_variant_pattern_condition: nested variant pattern on void field in FuncId(${fid_text}), scrutinee=${mono_to_key(scrutinee_mono)}, variant=${vid.id}, field=${i}, nested_variant=${nested_vid.id}")
            },
            _ => {},
          }
        },
        _ => {},
      }
      inner_checks = inner_checks.append(
        // Each inner check is used as a sub-body — pass [] as buf
        emit_pattern_condition(fp, field_instrs, field_mono, ctx, [])
      )
    }
  }

  inner_cond := combine_and_checks(inner_checks)

  buf.concat(tag_check).append(.If(.Some(.I32), inner_cond, [.I32Const(0)]))
}

fn emit_pattern_bindings(pattern: PreparedPattern, scrutinee_instrs: Vector<Instr>, scrutinee_mono: MonoType, ctx: EmitCtx) Vector<Instr> {
  case pattern {
    .Wildcard => [],
    .LitInt(_) => [],
    .LitBool(_) => [],
    .LitStr(_) => [],
    .Var(sid) => {
      entry := lookup_slot(ctx, sid)
      out := scrutinee_instrs
      out.append(.LocalSet(entry.index))
    },
    .Variant(tid, vid, fields) => {
      if !can_match_variant_pattern(scrutinee_mono, ctx.env) {
        []
      } else {
        sum_layout := get_sum_layout_ctx(scrutinee_mono, ctx)
        variant_layout := find_variant_layout(sum_layout, vid)
        out: Vector<Instr> = []
        for fp,i in fields {
          offset := variant_layout.struct_field_offset + i
          field_instrs := scrutinee_instrs
          field_instrs = field_instrs.append(.StructGet(sum_layout.sym, offset))
          field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
          out = out.concat(emit_pattern_bindings(fp, field_instrs, field_mono, ctx))
        }
        out
      }
    },
  }
}

// ── Closure emission ───────────────────────────────────────────────────

fn emit_make_closure(fid: FuncId, free_vars: Vector<SlotId>, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  closure_emit.emit_make_closure(fid, free_vars, ctx, buf)
}

fn emit_closure_call(callee: PreparedAtom, lid: SlotId, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  closure_emit.emit_closure_call(callee, lid, args, result_idx, result_mono, ctx, buf, closure_emit.ClosureEmitFns.{
    emit_atom: emit_atom,
    atom_mono: atom_mono,
  })
}

fn emit_trampolines_for_func(func: PreparedFunc, ctx: EmitCtx) Vector<FuncDef> {
  closure_emit.emit_trampolines_for_func(func, ctx)
}

fn emit_builtin_trampolines(ctx: EmitCtx) Vector<FuncDef> {
  closure_emit.emit_builtin_trampolines(ctx)
}

// ── Boxing / unboxing (AWrapAnyref / AUnwrapAnyref) ────────────────────

fn emit_wrap_anyref(atom: PreparedAtom, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf = emit_atom(atom, ctx, buf)
  emit_box_to_anyref(mono, ctx.env, buf)
}

fn emit_unwrap_anyref(atom: PreparedAtom, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf = emit_atom(atom, ctx, buf)
  emit_unbox_from_anyref(mono, ctx.env, buf)
}

// ── Checked i32 narrowing ──────────────────────────────────────────────

fn emit_checked_i32_narrow(atom: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Safe i64→i32: trap if < 0 or > i32::MAX (2147483647).
  // Emits the atom three times: twice for the range check, once for the wrap.
  // Atoms are cheap (local.get / const), so re-emission is fine.
  buf = emit_atom(atom, ctx, buf)
  buf = buf.concat([.I64Const(0), .I64GeS])  // value >= 0
  buf = emit_atom(atom, ctx, buf)
  buf = buf.concat([.I64Const(2147483647), .I64LeS])  // value <= i32::MAX
  buf = buf.concat([.I32And, .I32Eqz, .If(.None, [.Unreachable], [])])
  buf = emit_atom(atom, ctx, buf)
  buf.append(.I32WrapI64)
}

