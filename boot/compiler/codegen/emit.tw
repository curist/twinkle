// ── If emission ────────────────────────────────────────────────────────
fn try_emit_if_spine(
  cond_e: PreparedAtom,
  then_e: PreparedExpr,
  else_e: PreparedExpr,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr>? {
  spine := collect_tail_if_else_spine(cond_e, then_e, else_e)

  if spine.frames.len() <= 512 {
    return .None
  }

  done_label := "$if_spine_${result_idx}"
  body: Vector<Instr> = []

  for frame in spine.frames {
    cond_instrs := emit_if_prefix(frame.prefix, ctx, [])
    cond_instrs = emit_atom(frame.condition, ctx, cond_instrs)
    then_body := emit_expr(frame.then_expr, result_mono, ctx, [])
    then_body = control_emit.append_result_store(then_body, result_idx, result_mono)
    then_body = .append(.Br(done_label))

    body = .concat(cond_instrs).append(.If(.None, then_body, []))
  }

  tail_body := emit_expr(spine.tail, result_mono, ctx, [])
  tail_body = control_emit.append_result_store(tail_body, result_idx, result_mono)

  body = .concat(tail_body)
  .Some(buf.append(.Block(done_label, .None, body)))
}

fn emit_if_op(
  cond_e: PreparedAtom,
  then_e: PreparedExpr,
  else_e: PreparedExpr,
  result_idx: Int,
  result_vt: ValType?,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  case try_emit_if_spine(cond_e, then_e, else_e, result_idx, result_mono, ctx, buf) {
    .Some(out) => out,
    .None => control_emit.emit_if_op(
      cond_e,
      then_e,
      else_e,
      result_idx,
      result_vt,
      result_mono,
      ctx,
      buf,
      control_emit.ControlEmitFns.{ emit_atom, emit_expr },
    ),
  }
}

