fn emit_index_op(base: PreparedAtom, index: PreparedAtom, kind: IndexKind, result_ty: MonoType, result_vt: ValType?, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  array_emit.emit_index_op(base, index, kind, result_ty, result_vt, ctx, buf, array_emit.ArrayEmitFns.{
