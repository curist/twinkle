}

fn emit_record_update(base: PreparedAtom, fid: FieldId, value: PreparedAtom, can_reuse: Bool, tid: TypeId, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  record_emit.emit_record_update(base, fid, value, can_reuse, tid, result_mono, ctx, buf, record_emit.RecordEmitFns.{
