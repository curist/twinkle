  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  buf2 := emit_atom(args[0], ctx, buf) // dict
  buf3 := emit_erased_container_ingress(args[1], ctx, buf2) // key (erased)
  emit_erased_container_egress(result_mono, ctx.env, buf3.append(.Call("rt_dict__get"))).append(
    .LocalSet(result_idx),
  )
}

// ── string_get: s.get(i) → Option<Byte> ───────────────────────────────
fn emit_intrinsic_string_get(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  sum_layout := get_sum_layout_ctx(result_mono, ctx)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else {
    []
  }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs: Vector<Instr> = [Instr.I32Const(1)].concat(emit_atom(args[0], ctx, []))
    .concat(emit_checked_i32_narrow(args[1], ctx, []))
    .concat([.ArrayGetU("rt_types__String"), .StructNew(sum_layout.sym)])
  else_instrs: Vector<Instr> = [Instr.I32Const(0)].concat(default_payload)
    .concat([.StructNew(sum_layout.sym)])

  // Bounds check in i64 domain
  buf2 := emit_atom(args[1], ctx, buf) // index (i64)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[1], ctx, buf3)
  buf5 := emit_atom(args[0], ctx, buf4) // string
  buf5.append(.ArrayLen)
    .append(.I64ExtendI32U)
    .append(.I64LtS)
    .append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs))
    .append(.LocalSet(result_idx))
}

// ── string_slice: s.slice(start, end) ──────────────────────────────────
// Emit max(arg, 0) as i32: select(val, 0, val >= 0) then i32.wrap
fn emit_clamped_i32(arg: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_atom(arg, ctx, buf) // val (i64)
  buf3 := buf2.append(.I64Const(0)) // 0 (i64)
  buf4 := emit_atom(arg, ctx, buf3) // val again
  buf4.append(.I64Const(0)).append(.I64GeS).append(.Select).append(.I32WrapI64)
}

fn emit_intrinsic_string_slice(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Clamp start/end to >= 0, then UTF-8 boundary validation, then call
  // rt_str__substring (which clamps to len and normalizes end >= start).
  buf2 := emit_utf8_boundary_check_clamped(args[0], args[1], ctx, buf)
  buf3 := emit_utf8_boundary_check_clamped(args[0], args[2], ctx, buf2)
  buf4 := emit_atom(args[0], ctx, buf3)
  buf5 := emit_clamped_i32(args[1], ctx, buf4)
  buf6 := emit_clamped_i32(args[2], ctx, buf5)
  buf6.append(.Call("rt_str__substring")).append(.LocalSet(result_idx))
}

fn emit_utf8_boundary_check(
  str_atom: PreparedAtom,
  idx_atom: PreparedAtom,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // if idx > 0 && idx < len: check (s[idx] & 0xC0) != 0x80
  // The check sub-body is a nested Wasm control flow body — use fresh []
  check_buf1 := emit_atom(str_atom, ctx, [])
  check_buf2 := emit_checked_i32_narrow(idx_atom, ctx, check_buf1)
  check: Vector<Instr> = check_buf2.append(.ArrayGetU("rt_types__String"))
    .append(.I32Const(192))
    .append(.I32And)
    .append(.I32Const(128))
    .append(.I32Eq)
    .append(.If(.None, [.Unreachable], []))
  buf2 := emit_atom(idx_atom, ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GtS) // idx > 0
  buf4 := emit_atom(idx_atom, ctx, buf3)
  buf5 := emit_atom(str_atom, ctx, buf4)
  buf5.append(.ArrayLen)
    .append(.I64ExtendI32U)
    .append(.I64LtS)
    .append(.I32And)
    .append(.If(.None, check, []))
}

fn emit_utf8_boundary_check_clamped(
  str_atom: PreparedAtom,
  idx_atom: PreparedAtom,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Like emit_utf8_boundary_check but uses clamped idx (max(idx, 0) as i32).
  // if clamped_idx > 0 && clamped_idx < len: check (s[clamped_idx] & 0xC0) != 0x80
  // Build the check body
  check_buf1 := emit_atom(str_atom, ctx, [])
  check_buf2 := emit_clamped_i32(idx_atom, ctx, check_buf1)
  check: Vector<Instr> = check_buf2.append(.ArrayGetU("rt_types__String"))
    .append(.I32Const(192))
    .append(.I32And)
    .append(.I32Const(128))
    .append(.I32Eq)
    .append(.If(.None, [.Unreachable], []))

  // Condition: clamped > 0 && clamped < len
  buf2 := emit_clamped_i32(idx_atom, ctx, buf)
  buf3 := buf2.append(.I32Const(0)).append(.I32GtU)
  buf4 := emit_clamped_i32(idx_atom, ctx, buf3)
  buf5 := emit_atom(str_atom, ctx, buf4)
  buf5.append(.ArrayLen).append(.I32LtU).append(.I32And).append(.If(.None, check, []))
}

// ── char_code_at ───────────────────────────────────────────────────────
fn emit_intrinsic_char_code_at(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Trap if out of bounds, then read byte
  buf2 := emit_atom(args[1], ctx, buf) // index (i64)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[1], ctx, buf3)
  buf5 := emit_atom(args[0], ctx, buf4)
  buf6 := buf5.append(.ArrayLen)
    .append(.I64ExtendI32U)
    .append(.I64LtS)
    .append(.I32And)
    .append(.I32Eqz)
  buf7 := buf6.append(.If(.None, [.Unreachable], []))
  buf8 := emit_atom(args[0], ctx, buf7)
  buf9 := emit_checked_i32_narrow(args[1], ctx, buf8)
  buf9.append(.ArrayGetU("rt_types__String")).append(.I64ExtendI32U).append(.LocalSet(result_idx))
}

// ── from_char_code: Int → Option<String> ───────────────────────────────
fn emit_intrinsic_from_char_code(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  sum_layout := get_sum_layout_ctx(result_mono, ctx)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else {
    []
  }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs: Vector<Instr> = [Instr.I32Const(1)].concat(emit_atom(args[0], ctx, []))
    .concat([.I32WrapI64, .ArrayNewFixed("rt_types__String", 1), .StructNew(sum_layout.sym)])
  else_instrs: Vector<Instr> = [Instr.I32Const(0)].concat(default_payload)
    .concat([.StructNew(sum_layout.sym)])

  // Check 0 <= code < 128
  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[0], ctx, buf3)
  buf4.append(.I64Const(128))
    .append(.I64LtS)
    .append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs))
    .append(.LocalSet(result_idx))
}

// ── from_byte: Byte → Option<String> ───────────────────────────────────
fn emit_intrinsic_from_byte(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  sum_layout := get_sum_layout_ctx(result_mono, ctx)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else {
    []
  }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))
  then_instrs: Vector<Instr> = [Instr.I32Const(1)].concat(emit_atom(args[0], ctx, []))
    .concat([.ArrayNewFixed("rt_types__String", 1), .StructNew(sum_layout.sym)])
  else_instrs: Vector<Instr> = [Instr.I32Const(0)].concat(default_payload)
    .concat([.StructNew(sum_layout.sym)])

  // Only ASCII bytes are valid one-byte UTF-8 scalars.
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.I32Const(128))
    .append(.I32LtU)
    .append(.If(.Some(result_ref), then_instrs, else_instrs))
    .append(.LocalSet(result_idx))
}

// ── from_code_point: Int → Option<String> ──────────────────────────────
fn emit_intrinsic_from_code_point(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Helper returns the generic runtime Variant encoding for Option<String>.
  // Adapt it to the concrete Option<String> layout used by the current module.
  // Unlike indexing intrinsics, invalid code points are recoverable and must
  // return None instead of trapping during i64→i32 narrowing.
  then_instrs: Vector<Instr> = emit_atom(args[0], ctx, []).concat([.I32WrapI64])
  else_instrs: Vector<Instr> = [.I32Const(-1)]

  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[0], ctx, buf3)
  buf4.append(.I64Const(0x10FFFF))
    .append(.I64LeS)
    .append(.I32And)
    .append(.If(.Some(.I32), then_instrs, else_instrs))
    .append(.Call("from_code_point_helper"))
    .append(.RefCast(true, .Named("rt_types__Variant")))
    .append(.Call(option_from_variant_helper_sym(MonoType.String)))
    .append(.LocalSet(result_idx))
}

// ── string_utf8_bytes ──────────────────────────────────────────────────
fn emit_intrinsic_string_utf8_bytes(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Helper returns flat $Array; wrap to PVec
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.Call("string_utf8_bytes_helper"))
    .append(.Call("rt_arr__from_array"))
    .append(.LocalSet(result_idx))
}

// ── string_from_utf8 ──────────────────────────────────────────────────
fn emit_intrinsic_string_from_utf8(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // User passes PVec; helper expects flat $Array
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.Call("rt_arr__to_array"))
    .append(.Call("string_from_utf8_helper"))
    .append(.RefCast(true, .Named("rt_types__Variant")))
    .append(.Call(option_from_variant_helper_sym(MonoType.String)))
    .append(.LocalSet(result_idx))
}

// ── byte_from_int: Int → Option<Byte> ──────────────────────────────────
fn emit_intrinsic_byte_from_int(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  sum_layout := get_sum_layout_ctx(result_mono, ctx)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else {
    []
  }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs: Vector<Instr> = [Instr.I32Const(1)].concat(emit_atom(args[0], ctx, []))
    .concat([.I32WrapI64, .StructNew(sum_layout.sym)])
  else_instrs: Vector<Instr> = [Instr.I32Const(0)].concat(default_payload)
    .concat([.StructNew(sum_layout.sym)])

  // Check 0 <= n <= 255
  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[0], ctx, buf3)
  buf4.append(.I64Const(256))
    .append(.I64LtS)
    .append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs))
    .append(.LocalSet(result_idx))
}

// ── Cell intrinsics ────────────────────────────────────────────────────
fn emit_cell_value_arg(
  arg: PreparedAtom,
  inner_mono: MonoType,
  sym: String,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  actual_vt := atom_val_type(arg, ctx)
  target_vt := if sym == "$Cell_anyref" {
    ValType.Anyref
  } else {
    val_type_of_mono(inner_mono, ctx.env)
  }
  buf2 := emit_atom(arg, ctx, buf)
  emit_coerce_stack(actual_vt, target_vt, inner_mono, ctx, buf2)
}

fn emit_intrinsic_cell_new(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Cell<T> is a single-field mutable struct
  inner_mono: MonoType = case result_mono {
    .Named(_, type_args) => if type_args.len() > 0 {
      type_args[0]
    } else {
      .Void
    },
    _ => .Void,
  }
  sym := cell_struct_sym(inner_mono, ctx.env)
  buf2 := emit_cell_value_arg(args[0], inner_mono, sym, ctx, buf)
  buf2.append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_cell_get(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Get Cell<T>'s inner type from the cell arg's mono
  cell_mono := require_typed_record_atom(args[0], ctx, "emit_intrinsic_cell_get")
  inner_mono := case cell_mono {
    .Named(_, type_args) => if type_args.len() > 0 {
      type_args[0]
    } else {
      MonoType.Void
    },
    _ => MonoType.Void,
  }
  sym := cell_struct_sym(inner_mono, ctx.env)
  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.StructGet(sym, 0))
  buf4 := if sym == "$Cell_anyref" {
    emit_unbox_from_anyref(inner_mono, ctx.env, buf3)
  } else {
    buf3
  }
  buf4.append(.LocalSet(result_idx))
}

fn emit_intrinsic_cell_set(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  cell_mono := require_typed_record_atom(args[0], ctx, "emit_intrinsic_cell_set")
  inner_mono := cell_inner_mono(cell_mono)
  sym := cell_struct_sym(inner_mono, ctx.env)
  buf2 := emit_atom(args[0], ctx, buf) // cell ref
  buf3 := emit_cell_value_arg(args[1], inner_mono, sym, ctx, buf2)
  buf3.append(.StructSet(sym, 0)).append(.I32Const(0)).append(.RefI31).append(.LocalSet(result_idx)) // return void
}

fn emit_intrinsic_cell_update(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // cell_update(cell, fn(T) T) — apply function to cell value, store result
  cell_mono := require_typed_record_atom(args[0], ctx, "emit_intrinsic_cell_update")
  inner_mono := cell_inner_mono(cell_mono)
  sym := cell_struct_sym(inner_mono, ctx.env)

  // For simplicity, use the universal closure path
  buf2 := emit_atom(args[0], ctx, buf) // cell ref for struct.set target
  buf3 := emit_atom(args[1], ctx, buf2)
  buf4 := buf3.append(.StructGet("rt_types__Closure", 1)) // env (field 1)
  buf5 := emit_atom(args[0], ctx, buf4)
  buf6 := buf5.append(.StructGet(sym, 0)) // current cell value
  buf7 := if sym != "$Cell_anyref" {
    emit_box_to_anyref(inner_mono, ctx.env, buf6)
  } else {
    buf6
  }
  buf8 := buf7.append(.ArrayNewFixed("rt_types__Array", 1)) // args array
  buf9 := emit_atom(args[1], ctx, buf8)
  buf10 := buf9.append(.StructGet("rt_types__Closure", 0)).append(.CallRef("rt_types__ClosureFunc"))
  buf11 := if sym != "$Cell_anyref" {
    emit_unbox_from_anyref(inner_mono, ctx.env, buf10)
  } else {
    buf10
  }
  buf11.append(.StructSet(sym, 0))
    .append(.I32Const(0))
    .append(.RefI31)
    .append(.LocalSet(result_idx)) // return void
}

// ── Task intrinsics (Phase 2: scheduler-based) ────────────────────────
// Task.spawn(f) creates a Task struct with a run-to-completion frame
// and enqueues it.  Task.await(task) drives the scheduler until the
// target task completes, then unboxes the result.
fn emit_intrinsic_task_spawn(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Check if this spawn is for a suspending task body
  case args[0] {
    .ASlot(closure_sid) => case current_prepared_func(ctx) {
      .Some(pf) => case find_closure_for_slot(pf.body, closure_sid.id) {
        .Some(closure_info) => case ctx.suspending_bodies[closure_info.body_fid.id] {
          .Some(resume_info) => {
            return emit_spawn_suspending(closure_info, resume_info, result_idx, ctx, buf)
          },
          .None => {},
        },
        .None => {},
      },
      .None => {},
    },
    _ => {},
  }

  // Non-suspending path (default): FrameRtc + resume_rtc
  emit_spawn_rtc(args, result_idx, result_mono, ctx, buf)
}

fn emit_intrinsic_task_await(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Phase 2 top-level await: fast-path check + scheduler fallback.
  //
  // The task atom (args[0]) already has its own local, so we can
  // re-emit it multiple times without needing a temp.
  //
  // if task.state == DONE:
  //   result = unbox(task.result)
  // else:
  //   result = unbox(sched_run_until(task))
  // Check task.state == DONE (3)
  buf = emit_atom(args[0], ctx, buf)
  buf = .append(.RefCast(false, .Named("rt_types__Task")))
  buf = .append(.StructGet("rt_types__Task", 0)) // state field
  buf = .append(.I32Const(3)) // DONE
  buf = .append(.I32Eq)

  // We need to re-emit the atom inside each branch since
  // the If consumes the condition and starts with empty stack.
  // Build the then/else branch instruction vectors separately.
  then_branch: Vector<Instr> = []
  then_branch = emit_atom(args[0], ctx, then_branch)
  then_branch = .append(.RefCast(false, .Named("rt_types__Task")))
  then_branch = .append(.StructGet("rt_types__Task", 3)) // result field
  else_branch: Vector<Instr> = []
  else_branch = emit_atom(args[0], ctx, else_branch)
  else_branch = .append(.RefCast(false, .Named("rt_types__Task")))
  else_branch = .append(.Call("sched_run_until")) // returns anyref
  buf = .append(.If(.Some(.Anyref), then_branch, else_branch))

  // Unbox the anyref result to the concrete type
  buf = emit_unbox_from_anyref(result_mono, ctx.env, buf)
  buf.append(.LocalSet(result_idx))
}

// ── Task spawn helpers ────────────────────────────────────────────────
fn emit_spawn_rtc(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Non-suspending: FrameRtc + resume_rtc
  buf = .append(.I32Const(0)) // state = RUNNABLE
  buf = emit_atom(args[0], ctx, buf) // closure
  buf = .append(.StructNew("rt_types__FrameRtc"))
  buf = .append(.RefFunc("resume_rtc")) // resume function ref
  buf = .append(.RefNull(.None_)) // result = null
  buf = .append(.RefNull(.Named("rt_types__Array"))) // waiters = null
  buf = .append(.StructNew("rt_types__Task"))
  buf = .append(.LocalSet(result_idx))
  buf = .append(.LocalGet(result_idx))
  buf = .append(.RefAsNonNull)
  buf = .append(.Call("sched_enqueue"))
  buf
}

fn emit_spawn_suspending(
  closure_info: ClosureInfo,
  resume_info: TaskResumeInfo,
  result_idx: Int,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  body_pf := case ctx.prepared_funcs[closure_info.body_fid.id] {
    .Some(pf) => pf,
    .None => error("emit_spawn_suspending: missing PreparedFunc"),
  }

  // Task fields: state, frame, resume, result, waiters
  buf = .append(.I32Const(0)) // state = RUNNABLE

  // Frame fields: pc, captures..., hoisted_locals..., await_targets...
  buf = .append(.I32Const(0)) // pc = 0

  for cap_sid in closure_info.captures {
    buf = emit_atom(.ASlot(cap_sid), ctx, buf)
  }

  // Default values for non-capture hoisted locals
  num_captures := closure_info.captures.len()
  i := num_captures

  for i < resume_info.hoisted_slots.len() {
    sid := resume_info.hoisted_slots[i]
    info_s := facts.slot_info(body_pf, sid)
    vt := val_type_of_mono(info_s.mono, ctx.env)
    buf = .append(default_for_vt(vt))
    i = i + 1
  }

  // Null for await target fields
  for af_idx in resume_info.await_target_fields {
    if af_idx >= 0 {
      buf = .append(.RefNull(.None_))
    }
  }

  buf = .append(.StructNew(resume_info.frame_sym))
  buf = .append(.RefFunc(resume_info.resume_sym))
  buf = .append(.RefNull(.None_)) // result = null
  buf = .append(.RefNull(.Named("rt_types__Array"))) // waiters = null
  buf = .append(.StructNew("rt_types__Task"))
  buf = .append(.LocalSet(result_idx))
  buf = .append(.LocalGet(result_idx))
  buf = .append(.RefAsNonNull)
  buf = .append(.Call("sched_enqueue"))
  buf
}

fn default_for_vt(vt: ValType) Instr {
  case vt {
    .I32 => .I32Const(0),
    .I64 => .I64Const(0),
    .F64 => .F64Const(0.0),
    .Ref(_, ht) => .RefNull(ht),
    _ => .RefNull(.None_),
  }
}

// ── Resume function generation ────────────────────────────────────────
fn emit_resume_func(info: TaskResumeInfo, func: PreparedFunc, base_ctx: EmitCtx) FuncDef {
  // Resume function: (ref $Task) -> i32
  // local 0: task (param)
  // local 1: frame (extra)
  // local 2: pc (extra)
  // local 3+: one per slot
  // last: result_temp (anyref)
  task_local := 0
  frame_local := 1
  pc_local := 2
  next_local := 3
  extra_locals: Vector<ValType> = [ValType.Ref(true, .Named(info.frame_sym)), .I32]
  local_map: Dict<Int, LocalEntry> = Dict.new()

  for sid in func.captures {
    info_s := facts.slot_info(func, sid)
    vt := val_type_of_mono(info_s.mono, base_ctx.env)
    local_map[sid.id] = LocalEntry.{
      index: next_local,
      val_type: vt,
      mono: info_s.mono,
      repr: info_s.repr,
      source_local: info_s.source_local,
    }
    extra_locals = .append(vt)
    next_local = next_local + 1
  }

  for sid in func.params {
    info_s := facts.slot_info(func, sid)
    vt := val_type_of_mono(info_s.mono, base_ctx.env)
    local_map[sid.id] = LocalEntry.{
      index: next_local,
      val_type: vt,
      mono: info_s.mono,
      repr: info_s.repr,
      source_local: info_s.source_local,
    }
    extra_locals = .append(vt)
    next_local = next_local + 1
  }

  for sid in func.locals {
    info_s := facts.slot_info(func, sid)
    vt := val_type_of_mono(info_s.mono, base_ctx.env)
    local_map[sid.id] = LocalEntry.{
      index: next_local,
      val_type: vt,
      mono: info_s.mono,
      repr: info_s.repr,
      source_local: info_s.source_local,
    }
    extra_locals = .append(vt)
    next_local = next_local + 1
  }

  result_temp_local := next_local
  extra_locals = .append(.Anyref)
  next_local = next_local + 1
  ctx := EmitCtx.{
    registry: base_ctx.registry,
    builtins: base_ctx.builtins,
    env: base_ctx.env,
    local_map,
    next_local,
    wasm_locals: extra_locals,
    label_stack: [],
    current_func_id: .Some(func.func_id),
    func_sym_map: base_ctx.func_sym_map,
    prepared_funcs: base_ctx.prepared_funcs,
    is_init_func: false,
    loop_depth: 0,
    suspending_bodies: base_ctx.suspending_bodies,
    intrinsic_table: base_ctx.intrinsic_table,
  }
  body: Vector<Instr> = []

  // Prologue: load frame from task
  body = .append(.LocalGet(task_local))
  body = .append(.StructGet("rt_types__Task", 1))
  body = .append(.RefCast(false, .Named(info.frame_sym)))
  body = .append(.LocalSet(frame_local))

  // Load pc
  body = .append(.LocalGet(frame_local))
  body = .append(.StructGet(info.frame_sym, 0))
  body = .append(.LocalSet(pc_local))

  // Build segment bodies
  segment_bodies: Vector<Vector<Instr>> = []

  for seg_idx in 0..info.num_segments {
    seg_body := emit_resume_segment(
      seg_idx,
      info,
      func,
      task_local,
      frame_local,
      result_temp_local,
      ctx,
    )
    segment_bodies = .append(seg_body)
  }

  // PC dispatch — wrapped in a loop so await fast-path can re-dispatch
  dispatch := build_pc_dispatch(pc_local, segment_bodies, 0)

  // Reload pc at loop top (await fast-path updates pc then branches here)
  loop_body: Vector<Instr> = [
    Instr.LocalGet(frame_local),
    Instr.StructGet(info.frame_sym, 0),
    Instr.LocalSet(pc_local),
  ]

  for instr in dispatch {
    loop_body = .append(instr)
  }

  body = .append(Instr.Loop("$resume_loop", .Some(.I32), loop_body))
  FuncDef.{
    name: info.resume_sym,
    params: [ValType.Ref(false, .Named("rt_types__Task"))],
    results: [.I32],
    locals: ctx.wasm_locals,
    body,
  }
}

fn emit_resume_segment(
  seg_idx: Int,
  info: TaskResumeInfo,
  func: PreparedFunc,
  task_local: Int,
  frame_local: Int,
  result_temp_local: Int,
  ctx: EmitCtx,
) Vector<Instr> {
  buf: Vector<Instr> = []

  // Binding range for this segment
  start_idx := if seg_idx == 0 {
    0
  } else {
    info.suspension_points[seg_idx - 1].index + 1
  }
  end_idx := if seg_idx < info.suspension_points.len() {
    info.suspension_points[seg_idx].index
  } else {
    info.bindings.len()
  }

  // Restore hoisted locals from frame
  for slot_sid in info.hoisted_slots {
    case info.hoisted_set[slot_sid.id] {
      .Some(field_idx) => {
        entry := lookup_slot(ctx, slot_sid)
        buf = .append(.LocalGet(frame_local))
        buf = .append(.StructGet(info.frame_sym, field_idx))

        case entry.val_type {
          .Ref(false, ht) => {
            buf = .append(.RefCast(false, ht))
          },
          _ => {},
        }

        buf = .append(.LocalSet(entry.index))
      },
      .None => {},
    }
  }

  // Handle resume value for segments after a suspension point
  if seg_idx > 0 {
    prev_sp := info.suspension_points[seg_idx - 1]

    case prev_sp.kind {
      .Await => {
        at_field := info.await_target_fields[seg_idx - 1]

        if at_field >= 0 {
          entry := lookup_slot(ctx, prev_sp.slot)
          buf = .append(.LocalGet(frame_local))
          buf = .append(.StructGet(info.frame_sym, at_field))
          buf = .append(.RefCast(false, .Named("rt_types__Task")))
          buf = .append(.StructGet("rt_types__Task", 3)) // result
          buf = emit_unbox_from_anyref(entry.mono, ctx.env, buf)
          buf = .append(.LocalSet(entry.index))

          // Null out await target field
          buf = .append(.LocalGet(frame_local))
          buf = .append(.RefNull(.None_))
          buf = .append(.StructSet(info.frame_sym, at_field))
        }
      },
      .Yield => {
        entry := lookup_slot(ctx, prev_sp.slot)
        buf = .append(.I32Const(0))
        buf = .append(.RefI31)
        buf = .append(.LocalSet(entry.index))
      },
    }
  }

  // Build sub-expression for this segment and emit it
  if seg_idx < info.suspension_points.len() {
    // Intermediate segment: emit bindings, then suspend
    seg_expr := build_segment_expr(info.bindings, start_idx, end_idx, PreparedExpr.Atom(.ALitVoid))
    seg_instrs := emit_expr(seg_expr, MonoType.Void, ctx, [])

    for instr in seg_instrs {
      buf = .append(instr)
    }

    // Save hoisted locals to frame
    buf = save_hoisted_to_frame(info, frame_local, ctx, buf)

    // Set next pc
    buf = .append(.LocalGet(frame_local))
    buf = .append(.I32Const(seg_idx + 1))
    buf = .append(.StructSet(info.frame_sym, 0))
    sp := info.suspension_points[seg_idx]

    case sp.kind {
      .Yield => {
        buf = .append(.I32Const(1)) // YIELD
      },
      .Await => {
        await_binding := info.bindings[sp.index]

        case await_binding.op {
          .ACall(_, args) => if args.len() > 0 {
            at_field := info.await_target_fields[seg_idx]
            entry := lookup_slot(ctx, sp.slot)

            // Emit the awaited task ref
            buf = emit_atom(args[0], ctx, buf)
            buf = .append(.RefCast(false, .Named("rt_types__Task")))
            buf = .append(.LocalSet(result_temp_local))

            // Fast path: if target.state == DONE, read result and continue
            fast_path: Vector<Instr> = []

            // Read result, unbox, store to await slot
            fast_path = .append(.LocalGet(result_temp_local))
            fast_path = .append(.RefCast(false, .Named("rt_types__Task")))
            fast_path = .append(.StructGet("rt_types__Task", 3))
            fast_path = emit_unbox_from_anyref(entry.mono, ctx.env, fast_path)
            fast_path = .append(.LocalSet(entry.index))

            // Save the target too: the next segment's normal resume
            // prologue consumes await_target to materialize the await slot.
            fast_path = .append(.LocalGet(frame_local))
            fast_path = .append(.LocalGet(result_temp_local))
            fast_path = .append(.StructSet(info.frame_sym, at_field))

            // Save hoisted, bump pc, re-dispatch
            fast_path = save_hoisted_to_frame(info, frame_local, ctx, fast_path)
            fast_path = .append(.LocalGet(frame_local))
            fast_path = .append(.I32Const(seg_idx + 1))
            fast_path = .append(.StructSet(info.frame_sym, 0))
            fast_path = .append(.Br("$resume_loop"))

            // Slow path: block and suspend
            slow_path: Vector<Instr> = []

            // Save target to frame
            slow_path = .append(.LocalGet(frame_local))
            slow_path = .append(.LocalGet(result_temp_local))
            slow_path = .append(.StructSet(info.frame_sym, at_field))

            // Set task state to BLOCKED
            slow_path = .append(.LocalGet(task_local))
            slow_path = .append(.I32Const(2))
            slow_path = .append(.StructSet("rt_types__Task", 0))

            // Increment sched_blocked
            slow_path = .append(.GlobalGet("rt_sched__sched_blocked"))
            slow_path = .append(.I32Const(1))
            slow_path = .append(.I32Add)
            slow_path = .append(.GlobalSet("rt_sched__sched_blocked"))

            // Register as waiter
            slow_path = .append(.LocalGet(result_temp_local))
            slow_path = .append(.RefCast(false, .Named("rt_types__Task")))
            slow_path = .append(.LocalGet(task_local))
            slow_path = .append(.Call("sched_append_waiter"))
            slow_path = .append(.I32Const(2)) // AWAIT

            // Check: target.state == DONE?
            buf = .append(.LocalGet(result_temp_local))
            buf = .append(.RefCast(false, .Named("rt_types__Task")))
            buf = .append(.StructGet("rt_types__Task", 0))
            buf = .append(.I32Const(3)) // DONE
            buf = .append(.I32Eq)
            buf = .append(.If(.Some(.I32), fast_path, slow_path))
          } else {
            buf = .append(.I32Const(1))
          },
          _ => {
            buf = .append(.I32Const(1))
          },
        }
      },
    }
  } else {
    // Last segment: emit bindings + tail, box result, store, return COMPLETE
    seg_expr := build_segment_expr(
      info.bindings,
      start_idx,
      end_idx,
      PreparedExpr.Atom(info.tail_atom),
    )
    seg_instrs := emit_expr(seg_expr, func.return_mono, ctx, [])

    for instr in seg_instrs {
      buf = .append(instr)
    }

    // Void expressions do not leave a stack value when emitted with a Void
    // expected type, but task results are always stored as an anyref sentinel.
    case func.return_mono {
      .Void => {
        buf = .append(.I32Const(0))
        buf = .append(.RefI31)
      },
      _ => {},
    }

    // Box the result
    buf = emit_box_to_anyref(func.return_mono, ctx.env, buf)
    buf = .append(.LocalSet(result_temp_local))

    // Store in task.result
    buf = .append(.LocalGet(task_local))
    buf = .append(.LocalGet(result_temp_local))
    buf = .append(.StructSet("rt_types__Task", 3))

    // Null out the frame
    buf = .append(.LocalGet(task_local))
    buf = .append(.RefNull(.None_))
    buf = .append(.StructSet("rt_types__Task", 1))
    buf = .append(.I32Const(0)) // COMPLETE
  }

  buf
}

fn build_segment_expr(bindings: Vector<LetBinding>, start: Int, end: Int, tail: PreparedExpr) PreparedExpr {
  result := tail
  i := end - 1

  for i >= start {
    b := bindings[i]
    result = PreparedExpr.Let(b.slot, b.op, result)
    i = i - 1
  }

  result
}

fn build_pc_dispatch(pc_local: Int, segment_bodies: Vector<Vector<Instr>>, idx: Int) Vector<Instr> {
  if idx >= segment_bodies.len() {
    return [Instr.Unreachable]
  }

  if idx == segment_bodies.len() - 1 {
    return segment_bodies[idx]
  }

  then_body := segment_bodies[idx]
  else_body := build_pc_dispatch(pc_local, segment_bodies, idx + 1)
  buf: Vector<Instr> = []
  buf = .append(.LocalGet(pc_local))
  buf = .append(.I32Const(idx))
  buf = .append(.I32Eq)
  buf = .append(.If(.Some(.I32), then_body, else_body))
  buf
}

fn save_hoisted_to_frame(info: TaskResumeInfo, frame_local: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<
  Instr,
> {
  for slot_sid in info.hoisted_slots {
    case info.hoisted_set[slot_sid.id] {
      .Some(field_idx) => {
        entry := lookup_slot(ctx, slot_sid)
        buf = .append(.LocalGet(frame_local))
        buf = .append(.LocalGet(entry.index))
        buf = .append(.StructSet(info.frame_sym, field_idx))
      },
      .None => {},
    }
  }

  buf
}

// ── Range intrinsics ───────────────────────────────────────────────────
fn emit_intrinsic_range(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // 0..end → Range struct (start=0, end=end, step=1)
  layout := cached_layout_of(result_mono, ctx)
  sym := case layout {
    .Record(r) => r.sym,
    _ => error("range: expected Record layout"),
  }
  buf2 := buf.append(.I64Const(0)) // start
  buf3 := emit_atom(args[0], ctx, buf2) // end
  buf3.append(.I64Const(1)).append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_range_from(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // start..end → Range struct
  layout := cached_layout_of(result_mono, ctx)
  sym := case layout {
    .Record(r) => r.sym,
    _ => error("range_from: expected Record layout"),
  }
  buf2 := emit_atom(args[0], ctx, buf) // start
  buf3 := emit_atom(args[1], ctx, buf2) // end
  buf3.append(.I64Const(1)).append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_range_step(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // range_step(start, end, step) → Range struct
  layout := cached_layout_of(result_mono, ctx)
  sym := case layout {
    .Record(r) => r.sym,
    _ => error("range_step: expected Record layout"),
  }
  buf2 := emit_atom(args[0], ctx, buf) // start
  buf3 := emit_atom(args[1], ctx, buf2) // end
  buf4 := emit_atom(args[2], ctx, buf3) // step
  buf4.append(.StructNew(sym)).append(.LocalSet(result_idx))
}

// ── Iterator intrinsics ────────────────────────────────────────────────
fn emit_intrinsic_iterator_unfold(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // iterator_unfold(seed, step_fn) → IteratorState struct
  layout := cached_layout_of(result_mono, ctx)
  sym := case layout {
    .Record(r) => r.sym,
    .Iterator_(it) => it.state_sym,
    _ => error("iterator_unfold: unexpected layout"),
  }
  buf2 := emit_erased_container_ingress(args[0], ctx, buf) // seed (erased anyref state field)
  buf3 := emit_atom(args[1], ctx, buf2)
  buf3.append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_iterator_next(
  args: Vector<PreparedAtom>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.Call(iterator_next_helper_sym(result_mono))).append(.LocalSet(result_idx))
}

// ── Record operations ──────────────────────────────────────────────────
fn emit_record_literal(
  tid: TypeId,
  fields: Vector<PreparedFieldAtom>,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  record_emit.emit_record_literal(
    tid,
    fields,
    result_mono,
    ctx,
    buf,
    record_emit.RecordEmitFns.{ emit_atom, atom_val_type, atom_mono, require_typed_record_atom },
  )
}

fn emit_record_get(
  target: PreparedAtom,
  fid: FieldId,
  tid: TypeId,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  record_emit.emit_record_get(
    target,
    fid,
    tid,
    result_mono,
    ctx,
    buf,
    record_emit.RecordEmitFns.{ emit_atom, atom_val_type, atom_mono, require_typed_record_atom },
  )
}

fn emit_record_update(
  base: PreparedAtom,
  fid: FieldId,
  value: PreparedAtom,
  can_reuse: Bool,
  tid: TypeId,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  record_emit.emit_record_update(
    base,
    fid,
    value,
    can_reuse,
    tid,
    result_mono,
    ctx,
    buf,
    record_emit.RecordEmitFns.{ emit_atom, atom_val_type, atom_mono, require_typed_record_atom },
  )
}

// ── Variant operations ─────────────────────────────────────────────────
fn emit_variant_literal(
  tid: TypeId,
  vid: VariantId,
  args: Vector<PreparedAtom>,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  variant_emit.emit_variant_literal(
    tid,
    vid,
    args,
    result_mono,
    ctx,
    buf,
    variant_emit.VariantEmitFns.{ emit_atom, atom_val_type, atom_mono },
  )
}

// ── Array operations ───────────────────────────────────────────────────
fn emit_array_literal(
  items: Vector<PreparedAtom>,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  array_emit.emit_array_literal(
    items,
    result_mono,
    ctx,
    buf,
    array_emit.ArrayEmitFns.{
      emit_atom,
      atom_val_type,
      atom_mono,
      emit_checked_i32_narrow,
      emit_erased_container_ingress,
    },
  )
}

fn emit_index_op(
  base: PreparedAtom,
  index: PreparedAtom,
  kind: IndexKind,
  result_ty: MonoType,
  result_vt: ValType?,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  array_emit.emit_index_op(
    base,
    index,
    kind,
    result_ty,
    result_vt,
    ctx,
    buf,
    array_emit.ArrayEmitFns.{
      emit_atom,
      atom_val_type,
      atom_mono,
      emit_checked_i32_narrow,
      emit_erased_container_ingress,
    },
  )
}

