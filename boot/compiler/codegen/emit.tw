  record_emit.emit_record_get(target, fid, tid, result_mono, ctx, buf, record_emit.RecordEmitFns.{
    emit_atom: emit_atom,
    atom_val_type: atom_val_type,
    atom_mono: atom_mono,
    require_typed_record_atom: require_typed_record_atom,
