// ── Boxing / unboxing (AWrapAnyref / AUnwrapAnyref) ────────────────────
fn emit_wrap_anyref(atom: PreparedAtom, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<
  Instr,
> {
  buf = emit_atom(atom, ctx, buf)
  emit_box_to_anyref(mono, ctx.env, buf)
}

fn emit_unwrap_anyref(atom: PreparedAtom, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<
  Instr,
> {
  buf = emit_atom(atom, ctx, buf)
  emit_unbox_from_anyref(mono, ctx.env, buf)
}

// ── Checked i32 narrowing ──────────────────────────────────────────────
fn emit_checked_i32_narrow(atom: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Safe i64→i32: trap if < 0 or > i32::MAX (2147483647).
  // Emits the atom three times: twice for the range check, once for the wrap.
  // Atoms are cheap (local.get / const), so re-emission is fine.
  buf = emit_atom(atom, ctx, buf)
  buf = .concat([.I64Const(0), .I64GeS]) // value >= 0
  buf = emit_atom(atom, ctx, buf)
  buf = .concat([.I64Const(2147483647), .I64LeS]) // value <= i32::MAX
  buf = .concat([.I32And, .I32Eqz, .If(.None, [.Unreachable], [])])
  buf = emit_atom(atom, ctx, buf)
  buf.append(.I32WrapI64)
}

