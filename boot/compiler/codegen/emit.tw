// Core emission — prepared backend module → WasmModule
//
// Translates the prepared backend module into Wasm IR.
// Key simplification vs stage0:
//   - No flow-sensitive metadata — layout derived from MonoType via registry
//   - No SumRepr — all sums are typed structs
//   - Boundaries explicit — AWrapAnyref / AUnwrapAnyref already in IR
//   - Pattern match emission is inline (single implementation)

use compiler.resolver.{MonoType, TypeId, ResolvedEnv, ResolvedTypeDef, ResolvedVariant}
use compiler.core_ir.{LocalId, FuncId, FieldId, VariantId, Param, BinOp, UnOp}
use compiler.builtins as bi
use compiler.builtins.{BuiltinRegistry, BuiltinEntry, BuiltinKind, RuntimeInfo}
use compiler.anf.{
  OpKind, IndexKind, AnfMatchArm, AnfFunctionDef, AnfModule,
}
use compiler.codegen.wasm_ir.{
  ValType, HeapType, Instr, TypeDef, FieldDef, FuncDef, ImportDef,
  GlobalDef, ExportDef, TableDef, ElemDef, DataSegment, WasmModule, AbiContract,
}
use compiler.codegen.wasm_layout.{
  WasmLayout, WasmValType, WasmRecordLayout, WasmFieldLayout,
  WasmSumLayout, WasmVariantLayout, WasmClosureLayout, WasmIteratorLayout,
  layout_of, val_type_of, val_type_of_mono, mono_to_key,
}
use compiler.codegen.wasm_plan_types.{
  WasmTypeRegistry, FuncSigEntry, StringPoolEntry, ModuleGlobalEntry,
}
use compiler.backend.prepared_ir.{
  CaptureParam, PreparedFunc, SlotId, SlotInfo, ReprKind,
  PreparedAtom, PreparedExpr, PreparedOp, PreparedFieldAtom, PreparedMatchArm,
  PreparedPattern,
}
use compiler.backend.prepare.{PreparedModule}
use compiler.backend.repr_assign.{repr_of_mono}
use compiler.backend.callable_targets as callable_targets

// ── Types ──────────────────────────────────────────────────────────────

pub type LocalEntry = .{
  index: Int,
  val_type: ValType,
  mono: MonoType,
  repr: ReprKind,
  source_local: LocalId,
}

pub type LabelPair = .{
  break_label: String,
  continue_label: String,
}

pub type EmitCtx = .{
  registry: WasmTypeRegistry,
  builtins: BuiltinRegistry,
  env: ResolvedEnv,
  local_map: Dict<Int, LocalEntry>,  // SlotId.id → LocalEntry
  next_local: Int,
  wasm_locals: Vector<ValType>,       // additional locals (beyond params)
  label_stack: Vector<LabelPair>,
  current_func_id: FuncId?,
  func_sym_map: Dict<Int, String>,    // FuncId → wasm symbol
  prepared_funcs: Dict<Int, PreparedFunc>,
  init_func_id: FuncId?,
  loop_depth: Int,
}

// ── Module emission ────────────────────────────────────────────────────

pub fn emit_module(
  prepared: PreparedModule,
  reg: WasmTypeRegistry,
  builtins: BuiltinRegistry,
  env: ResolvedEnv,
) WasmModule {
  anf := prepared.anf

  // Build FuncId → symbol map and prepared-function lookup
  func_sym_map: Dict<Int, String> = Dict.new()
  prepared_funcs: Dict<Int, PreparedFunc> = Dict.new()
  for func in anf.functions {
    sym := "$f${func.func_id.id}_${sanitize_name(func.name)}"
    func_sym_map[func.func_id.id] = sym
  }
  for pf in prepared.funcs {
    prepared_funcs[pf.func_id.id] = pf
  }

  // Base context (per-function state will be reset in emit_func)
  base_ctx := EmitCtx.{
    registry: reg,
    builtins: builtins,
    env: env,
    local_map: Dict.new(),
    next_local: 0,
    wasm_locals: [],
    label_stack: [],
    current_func_id: .None,
    func_sym_map: func_sym_map,
    prepared_funcs: prepared_funcs,
    init_func_id: anf.init_func_id,
    loop_depth: 0,
  }

  // Emit user functions
  funcs: Vector<FuncDef> = []
  trampolines: Vector<FuncDef> = []
  for func in anf.functions {
    pf := case prepared_funcs[func.func_id.id] {
      .Some(f) => f,
      .None => error("emit_module: missing PreparedFunc for F${func.func_id.id}"),
    }
    result := emit_func(func, pf, base_ctx)
    funcs = funcs.append(result.func_def)
    for t in result.trampolines { trampolines = trampolines.append(t) }
  }
  for t in trampolines { funcs = funcs.append(t) }
  for t in emit_builtin_trampolines(base_ctx) { funcs = funcs.append(t) }

  iterator_helpers := collect_iterator_next_helpers(prepared.funcs, builtins)
  for mono in iterator_helpers {
    funcs = funcs.append(emit_iterator_next_helper(mono, env))
  }
  sum_helpers := collect_sum_variant_helpers(prepared.funcs, env)
  for mono in sum_helpers {
    funcs = funcs.append(emit_sum_to_variant_helper(mono, env))
      .append(emit_variant_to_sum_helper(mono, env))
  }
  funcs = funcs.append(emit_host_read_file_result_helper(env))
    .append(emit_option_from_variant_helper(MonoType.String, env))
    .append(emit_option_from_variant_helper(MonoType.Int, env))
    .append(emit_option_from_variant_helper(MonoType.Float, env))

  // String pool: globals, getter functions, data segment
  str_globals := emit_string_pool_globals(reg)
  str_getters := emit_string_pool_getters(reg)
  for g in str_getters { funcs = funcs.append(g) }
  str_data := emit_string_data_segment(reg)

  // Module globals
  mod_globals := emit_module_globals(reg, anf, env)

  // Assemble all globals
  globals: Vector<GlobalDef> = mod_globals.concat(str_globals)

  // Data segments
  data: Vector<DataSegment> = []
  case str_data {
    .Some(d) => { data = data.append(d) },
    .None => {},
  }

  // Start function
  start: String? = case anf.init_func_id {
    .Some(fid) => func_sym_map[fid.id],
    .None => .None,
  }

  type_defs: Vector<TypeDef> = reg.type_defs
  runtime_imports: Vector<ImportDef> = reg.runtime_imports.append(.{
    module: "codegen.intrinsics",
    name: "int_from_string_helper",
    as_sym: "int_from_string_helper",
    params: [.Ref(true, .Named("rt_types__String"))],
    results: [.Anyref],
  }).append(.{
    module: "codegen.intrinsics",
    name: "from_code_point_helper",
    as_sym: "from_code_point_helper",
    params: [.I32],
    results: [.Anyref],
  }).append(.{
    module: "codegen.intrinsics",
    name: "string_utf8_bytes_helper",
    as_sym: "string_utf8_bytes_helper",
    params: [.Ref(true, .Named("rt_types__String"))],
    results: [.Ref(false, .Named("rt_types__Array"))],
  }).append(.{
    module: "codegen.intrinsics",
    name: "string_from_utf8_helper",
    as_sym: "string_from_utf8_helper",
    params: [.Ref(true, .Named("rt_types__Array"))],
    results: [.Anyref],
  }).append(.{
    module: "codegen.intrinsics",
    name: "float_from_string_helper",
    as_sym: "float_from_string_helper",
    params: [.Ref(true, .Named("rt_types__String"))],
    results: [.Anyref],
  })

  WasmModule.{
    namespace: "user",
    types: type_defs,
    imports: runtime_imports,
    funcs: funcs,
    globals: globals,
    tables: [],
    elems: [],
    exports: [],
    data: data,
    start: start,
  }
}

fn sanitize_name(name: String) String {
  // Replace non-alphanumeric chars with _
  collect b in name {
    c := byte_to_int_local(b)
    if (c >= 48 and c <= 57) or (c >= 65 and c <= 90) or (c >= 97 and c <= 122) or c == 95 {
      b.to_string()
    } else {
      "_"
    }
  }.join("")
}

fn byte_to_int_local(b: Byte) Int {
  b.to_int()
}

// ── Function emission ──────────────────────────────────────────────────

type FuncResult = .{
  func_def: FuncDef,
  trampolines: Vector<FuncDef>,
}

fn emit_func(func: AnfFunctionDef, prepared: PreparedFunc, base_ctx: EmitCtx) FuncResult {
  // Local handling is slot-based. PreparedFunc provides the authoritative
  // ABI/local ordering, so emission does not reconstruct it by scanning ANF.
  builder_slots := collect_vector_builder_slots(prepared.body, base_ctx.builtins)
  local_map: Dict<Int, LocalEntry> = Dict.new()
  param_types: Vector<ValType> = []
  extra_locals: Vector<ValType> = []
  idx := 0

  for sid in prepared.captures {
    info := slot_info(prepared, sid)
    vt := if builder_slots.has(sid.id) { ValType.Anyref } else { info.wasm_type }
    repr := if builder_slots.has(sid.id) { ReprKind.OpaqueAnyref } else { info.repr }
    local_map[sid.id] = LocalEntry.{
      index: idx,
      val_type: vt,
      mono: info.mono,
      repr: repr,
      source_local: info.source_local,
    }
    param_types = param_types.append(vt)
    idx = idx + 1
  }

  for sid in prepared.params {
    info := slot_info(prepared, sid)
    vt := if builder_slots.has(sid.id) { ValType.Anyref } else { info.wasm_type }
    repr := if builder_slots.has(sid.id) { ReprKind.OpaqueAnyref } else { info.repr }
    local_map[sid.id] = LocalEntry.{
      index: idx,
      val_type: vt,
      mono: info.mono,
      repr: repr,
      source_local: info.source_local,
    }
    param_types = param_types.append(vt)
    idx = idx + 1
  }

  for sid in prepared.locals {
    info := slot_info(prepared, sid)
    vt := if builder_slots.has(sid.id) { ValType.Anyref } else { info.wasm_type }
    repr := if builder_slots.has(sid.id) { ReprKind.OpaqueAnyref } else { info.repr }
    local_map[sid.id] = LocalEntry.{
      index: idx,
      val_type: vt,
      mono: info.mono,
      repr: repr,
      source_local: info.source_local,
    }
    extra_locals = extra_locals.append(vt)
    idx = idx + 1
  }

  // Return type
  ret_vt: Vector<ValType> = case prepared.return_mono {
    .Void => [],
    .Never => [],
    _ => [val_type_of_mono(func.return_ty, base_ctx.env)],
  }

  ctx := EmitCtx.{
    registry: base_ctx.registry,
    builtins: base_ctx.builtins,
    env: base_ctx.env,
    local_map: local_map,
    next_local: idx,
    wasm_locals: extra_locals,
    label_stack: [],
    current_func_id: .Some(func.func_id),
    func_sym_map: base_ctx.func_sym_map,
    prepared_funcs: base_ctx.prepared_funcs,
    init_func_id: base_ctx.init_func_id,
    loop_depth: 0,
  }

  body_instrs := emit_expr(prepared.body, prepared.return_mono, ctx, [])

  sym := lookup_func_sym(base_ctx.func_sym_map, func.func_id)
  fd := FuncDef.{
    name: sym,
    params: param_types,
    results: ret_vt,
    locals: ctx.wasm_locals,
    body: body_instrs,
  }

  // Generate trampolines if this function is used as a closure
  tramps := emit_trampolines_for_func(prepared, ctx)

  FuncResult.{ func_def: fd, trampolines: tramps }
}

fn lookup_func_sym(map: Dict<Int, String>, fid: FuncId) String {
  case map[fid.id] {
    .Some(s) => s,
    .None => error("lookup_func_sym: unknown FuncId ${fid.id}"),
  }
}

fn collect_vector_builder_slots(expr: PreparedExpr, builtins: BuiltinRegistry) Dict<Int, Bool> {
  builder_new := bi.id(builtins, "vector_builder_new")
  builder_from := bi.id(builtins, "vector_builder_from")
  builder_push := bi.id(builtins, "vector_builder_push")
  builder_freeze := bi.id(builtins, "vector_builder_freeze")
  collect_vector_builder_slots_expr(expr, builder_new, builder_from, builder_push, builder_freeze, Dict.new())
}

fn collect_vector_builder_slots_expr(
  expr: PreparedExpr,
  builder_new: FuncId,
  builder_from: FuncId,
  builder_push: FuncId,
  builder_freeze: FuncId,
  known: Dict<Int, Bool>,
) Dict<Int, Bool> {
  case expr {
    .Let(sid, op, body) => {
      cur := known
      cur = collect_vector_builder_slots_op(op, sid, builder_new, builder_from, builder_push, builder_freeze, cur)
      collect_vector_builder_slots_expr(body, builder_new, builder_from, builder_push, builder_freeze, cur)
    },
    _ => known,
  }
}

fn collect_vector_builder_slots_op(
  op: PreparedOp,
  sid: SlotId,
  builder_new: FuncId,
  builder_from: FuncId,
  builder_push: FuncId,
  builder_freeze: FuncId,
  known: Dict<Int, Bool>,
) Dict<Int, Bool> {
  cur := known
  case op {
    .ACall(.AGlobalFunc(fid), args) => {
      if fid.id == builder_new.id or fid.id == builder_from.id {
        cur[sid.id] = true
      }
      if (fid.id == builder_push.id or fid.id == builder_freeze.id) and args.len() > 0 {
        case args[0] {
          .ASlot(builder_sid) => cur[builder_sid.id] = true,
          _ => {},
        }
      }
      cur
    },
    .AInit(.ASlot(src)) => {
      if known.has(src.id) {
        cur[sid.id] = true
      }
      cur
    },
    .AAssign(target, .ASlot(src)) => {
      if known.has(src.id) {
        cur[target.id] = true
      }
      cur
    },
    .AIf(_, then_e, else_e) => {
      cur = collect_vector_builder_slots_expr(then_e, builder_new, builder_from, builder_push, builder_freeze, cur)
      collect_vector_builder_slots_expr(else_e, builder_new, builder_from, builder_push, builder_freeze, cur)
    },
    .AMatch(_, arms) => {
      out := cur
      for arm in arms {
        out = collect_vector_builder_slots_expr(arm.body, builder_new, builder_from, builder_push, builder_freeze, out)
      }
      out
    },
    .ALoop(body) => collect_vector_builder_slots_expr(body, builder_new, builder_from, builder_push, builder_freeze, cur),
    .ADefer(body) => collect_vector_builder_slots_expr(body, builder_new, builder_from, builder_push, builder_freeze, cur),
    _ => cur,
  }
}

// ── Expression emission ────────────────────────────────────────────────

fn emit_expr(expr: PreparedExpr, expected_ty: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case expr {
    .Let(local, op, body) => emit_let(local, op, body, expected_ty, ctx, buf),
    .Atom(atom) => {
      case expected_ty {
        .Void => {
          // In ANF, side effects happen in the enclosing Let op; a trailing
          // Void atom is just the pure sentinel value for that statement.
          mono := atom_mono(atom, ctx)
          case mono {
            .Void => buf,
            .Never => emit_atom(atom, ctx, buf),
            _ => {
              buf2 := emit_atom(atom, ctx, buf)
              buf2.append(.Drop)
            },
          }
        },
        .Never => {
          buf2 := emit_atom(atom, ctx, buf)
          buf2.append(.Unreachable)
        },
        _ => emit_atom(atom, ctx, buf),
      }
    },
    .Return(.Some(atom)) => {
      buf2 := emit_atom(atom, ctx, buf)
      buf2.append(.Return)
    },
    .Return(.None) => buf.append(.Return),
    .Break(.Some(atom)) => {
      if ctx.label_stack.len() == 0 {
        error("emit_expr: Break with no label stack")
      }
      lp := ctx.label_stack[ctx.label_stack.len() - 1]
      buf2 := emit_atom(atom, ctx, buf)
      buf2.append(.Br(lp.break_label))
    },
    .Break(.None) => {
      if ctx.label_stack.len() == 0 {
        error("emit_expr: Break with no label stack")
      }
      lp := ctx.label_stack[ctx.label_stack.len() - 1]
      buf.append(.Br(lp.break_label))
    },
    .Continue => {
      if ctx.label_stack.len() == 0 {
        error("emit_expr: Continue with no label stack")
      }
      lp := ctx.label_stack[ctx.label_stack.len() - 1]
      buf.append(.Br(lp.continue_label))
    },
  }
}

// ── Let emission ───────────────────────────────────────────────────────

fn emit_let(local: SlotId, op: PreparedOp, body: PreparedExpr, expected_ty: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Flatten the Let chain iteratively: each op pushes directly into buf,
  // rather than creating intermediate vectors and concating (O(N²) with PVec).
  cur_local := local
  cur_op := op
  cur_body := body
  for true {
    entry := lookup_slot(ctx, cur_local)
    result_mono := entry.mono
    case result_mono {
      .Never => {
        buf = emit_op(cur_op, entry.index, .None, result_mono, ctx, buf)
        return buf.append(.Unreachable)
      },
      _ => {
        buf = emit_op(cur_op, entry.index, .Some(entry.val_type), result_mono, ctx, buf)
        is_init := case ctx.init_func_id {
          .Some(ifid) => case ctx.current_func_id {
            .Some(cfid) => cfid.id == ifid.id,
            .None => false,
          },
          .None => false,
        }
        if is_init {
          case ctx.registry.module_globals[entry.source_local.id] {
            .Some(gentry) => {
              buf = buf.append(.LocalGet(entry.index))
              buf = buf.append(.GlobalSet(gentry.sym))
            },
            .None => {},
          }
        }
        case cur_body {
          .Let(next_local, next_op, next_body) => {
            cur_local = next_local
            cur_op = next_op
            cur_body = next_body
          },
          _ => {
            return emit_expr(cur_body, expected_ty, ctx, buf)
          },
        }
      },
    }
  }
  buf
}

// ── Op emission ────────────────────────────────────────────────────────

fn emit_op(op: PreparedOp, result_idx: Int, result_vt: ValType?, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case op {
    .AInit(atom) => {
      emit_atom(atom, ctx, buf).append(.LocalSet(result_idx))
    },
    .AAssign(target, atom) => {
      tgt := lookup_slot(ctx, target)
      buf2 := emit_atom(atom, ctx, buf)
      buf2 = buf2.append(.LocalSet(tgt.index))
      // For module globals in __init__, also set the global
      is_init := case ctx.init_func_id {
        .Some(ifid) => case ctx.current_func_id {
          .Some(cfid) => cfid.id == ifid.id,
          .None => false,
        },
        .None => false,
      }
      if is_init {
        case ctx.registry.module_globals[tgt.source_local.id] {
          .Some(gentry) => {
            buf2 = buf2.append(.LocalGet(tgt.index))
            buf2 = buf2.append(.GlobalSet(gentry.sym))
          },
          .None => {},
        }
      }
      // AAssign produces void — set result to void
      buf2 = buf2.append(.I32Const(0))
      buf2 = buf2.append(.RefI31)
      buf2.append(.LocalSet(result_idx))
    },
    .ABinOp(bop, left, right, kind) => {
      buf2 := emit_binop(bop, left, right, kind, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AUnOp(uop, operand, kind) => {
      buf2 := emit_unop(uop, operand, kind, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .ACall(callee, args) => {
      emit_call(callee, args, result_idx, result_mono, ctx, buf)
    },
    .AIf(cond, then_e, else_e) => {
      emit_if_op(cond, then_e, else_e, result_idx, result_vt, result_mono, ctx, buf)
    },
    .AMatch(scrutinee, arms) => {
      emit_match_op(scrutinee, arms, result_idx, result_vt, result_mono, ctx, buf)
    },
    .ALoop(body) => {
      emit_loop_op(body, result_idx, result_vt, ctx, buf)
    },
    .ARecord(tid, fields) => {
      buf2 := emit_record_literal(tid, fields, result_mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .ARecordGet(target, fid, tid) => {
      buf2 := emit_record_get(target, fid, tid, result_mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .ARecordUpdate(base, fid, value, can_reuse, tid) => {
      buf2 := emit_record_update(base, fid, value, can_reuse, tid, result_mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AVariant(tid, vid, args) => {
      buf2 := emit_variant_literal(tid, vid, args, result_mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AArrayLit(items) => {
      buf2 := emit_array_literal(items, result_mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AIndex(base, index, kind, mono) => {
      buf2 := emit_index_op(base, index, kind, mono, result_vt, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AMakeClosure(fid, free_vars) => {
      buf2 := emit_make_closure(fid, free_vars, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AWrapAnyref(atom, mono) => {
      buf2 := emit_wrap_anyref(atom, mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .AUnwrapAnyref(atom, mono) => {
      buf2 := emit_unwrap_anyref(atom, mono, ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    .ADefer(_) => error("ADefer must be eliminated before codegen"),
  }
}

// ── Atom emission ──────────────────────────────────────────────────────

fn emit_atom(atom: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case atom {
    .ALitInt(n) => buf.append(.I64Const(n)),
    .ALitFloat(f) => buf.append(.F64Const(f)),
    .ALitBool(b) => buf.append(.I32Const(if b { 1 } else { 0 })),
    .ALitVoid => buf.append(.I32Const(0)).append(.RefI31),
    .ALitStr(s) => {
      case ctx.registry.string_pool[s] {
        .Some(entry) => buf.append(.Call(entry.getter_sym)),
        .None => error("emit_atom: string not in pool: ${s}"),
      }
    },
    .ASlot(sid) => {
      is_init := case ctx.init_func_id {
        .Some(ifid) => case ctx.current_func_id {
          .Some(cfid) => cfid.id == ifid.id,
          .None => false,
        },
        .None => false,
      }
      entry := lookup_slot(ctx, sid)
      if !is_init {
        case ctx.registry.module_globals[entry.source_local.id] {
          .Some(gentry) => {
            return buf.append(.GlobalGet(gentry.sym))
          },
          .None => {},
        }
      }
      buf.append(.LocalGet(entry.index))
    },
    .AGlobalLocal(lid) => {
      case ctx.registry.module_globals[lid.id] {
        .Some(gentry) => buf.append(.GlobalGet(gentry.sym)),
        .None => error("emit_atom: unknown module-global local L${lid.id}"),
      }
    },
    .AGlobalFunc(fid) => {
      sym := lookup_func_sym(ctx.func_sym_map, fid)
      buf.append(.RefFunc(sym))
    },
  }
}

fn atom_mono(atom: PreparedAtom, ctx: EmitCtx) MonoType {
  case atom {
    .ALitInt(_) => .Int,
    .ALitFloat(_) => .Float,
    .ALitBool(_) => .Bool,
    .ALitStr(_) => .String,
    .ALitVoid => .Void,
    .ASlot(sid) => {
      entry := lookup_slot(ctx, sid)
      entry.mono
    },
    .AGlobalLocal(lid) => {
      case ctx.registry.module_globals[lid.id] {
        .Some(gentry) => gentry.mono,
        .None => .Void,
      }
    },
    .AGlobalFunc(_) => .Void,  // function refs handled specially
  }
}

fn atom_repr(atom: PreparedAtom, ctx: EmitCtx) ReprKind {
  case atom {
    .ALitInt(_) => .I64,
    .ALitFloat(_) => .F64,
    .ALitBool(_) => .I32,
    .ALitStr(_) => .TypedRef(.String),
    .ALitVoid => .OpaqueAnyref,
    .ASlot(sid) => {
      entry := lookup_slot(ctx, sid)
      entry.repr
    },
    .AGlobalLocal(lid) => {
      case ctx.registry.module_globals[lid.id] {
        .Some(gentry) => repr_of_mono(gentry.mono, ctx.env),
        .None => .OpaqueAnyref,
      }
    },
    .AGlobalFunc(_) => .ClosureRef,
  }
}

fn atom_val_type(atom: PreparedAtom, ctx: EmitCtx) ValType {
  case atom {
    .ALitInt(_) => .I64,
    .ALitFloat(_) => .F64,
    .ALitBool(_) => .I32,
    .ALitStr(_) => .Ref(true, .Named("rt_types__String")),
    .ALitVoid => .Anyref,
    .ASlot(sid) => {
      entry := lookup_slot(ctx, sid)
      entry.val_type
    },
    .AGlobalLocal(lid) => {
      case ctx.registry.module_globals[lid.id] {
        .Some(gentry) => val_type_of_mono(gentry.mono, ctx.env),
        .None => .Anyref,
      }
    },
    .AGlobalFunc(_) => .Ref(false, .Func),
  }
}

fn require_typed_record_atom(atom: PreparedAtom, ctx: EmitCtx, context: String) MonoType {
  mono := atom_mono(atom, ctx)
  repr := atom_repr(atom, ctx)
  case mono {
    .Void => .Void,
    _ => {
      case repr {
        .TypedRef(_) => mono,
        _ => error("${context}: expected typed record ref, got ${repr_name(repr)} for ${mono_to_key(mono)}"),
      }
    },
  }
}

fn require_typed_sum_atom(atom: PreparedAtom, ctx: EmitCtx, context: String) MonoType {
  mono := atom_mono(atom, ctx)
  repr := atom_repr(atom, ctx)
  case repr {
    .TypedSum(sum_mono) => sum_mono,
    _ => error("${context}: expected typed sum repr, got ${repr_name(repr)} for ${mono_to_key(mono)}"),
  }
}

fn match_scrutinee_mono(atom: PreparedAtom, ctx: EmitCtx) MonoType {
  case atom_repr(atom, ctx) {
    .TypedSum(sum_mono) => sum_mono,
    _ => atom_mono(atom, ctx),
  }
}

fn require_closure_atom(atom: PreparedAtom, ctx: EmitCtx, context: String) MonoType {
  mono := atom_mono(atom, ctx)
  repr := atom_repr(atom, ctx)
  case repr {
    .ClosureRef => mono,
    _ => error("${context}: expected closure repr, got ${repr_name(repr)} for ${mono_to_key(mono)}"),
  }
}

// ── Binary operations ──────────────────────────────────────────────────

fn emit_binop(bop: BinOp, left: PreparedAtom, right: PreparedAtom, kind: OpKind, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case kind {
    .Int => emit_int_binop(bop, left, right, ctx, buf),
    .Float => emit_float_binop(bop, left, right, ctx, buf),
    .Bool => emit_bool_binop(bop, left, right, ctx, buf),
    .Str => emit_str_binop(bop, left, right, ctx, buf),
  }
}

// Emit an atom and coerce to i64 if the atom is Byte-typed (i32).
fn emit_atom_as_i64(atom: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_atom(atom, ctx, buf)
  case atom_mono(atom, ctx) {
    .Byte => buf2.append(.I64ExtendI32S),
    _ => buf2,
  }
}

fn emit_int_binop(bop: BinOp, left: PreparedAtom, right: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  instr : Instr = case bop {
    .Add => .I64Add,
    .Sub => .I64Sub,
    .Mul => .I64Mul,
    .Div => .I64DivS,
    .Mod => .I64RemS,
    .Eq => .I64Eq,
    .Ne => .I64Ne,
    .Lt => .I64LtS,
    .Le => .I64LeS,
    .Gt => .I64GtS,
    .Ge => .I64GeS,
    .BitAnd => .I64And,
    .BitOr => .I64Or,
    .BitXor => .I64Xor,
    .Shl => .I64Shl,
    .Shr => .I64ShrS,
    .And => error("emit_int_binop: And not valid for Int"),
    .Or => error("emit_int_binop: Or not valid for Int"),
  }
  buf2 := emit_atom_as_i64(left, ctx, buf)
  buf3 := emit_atom_as_i64(right, ctx, buf2)
  buf3.append(instr)
}

fn emit_float_binop(bop: BinOp, left: PreparedAtom, right: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  instr : Instr = case bop {
    .Add => .F64Add,
    .Sub => .F64Sub,
    .Mul => .F64Mul,
    .Div => .F64Div,
    .Eq => .F64Eq,
    .Ne => .F64Ne,
    .Lt => .F64Lt,
    .Le => .F64Le,
    .Gt => .F64Gt,
    .Ge => .F64Ge,
    _ => error("emit_float_binop: unsupported op"),
  }
  buf2 := emit_atom(left, ctx, buf)
  buf3 := emit_atom(right, ctx, buf2)
  buf3.append(instr)
}

fn emit_bool_binop(bop: BinOp, left: PreparedAtom, right: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  instr : Instr = case bop {
    .Eq => .I32Eq,
    .Ne => .I32Ne,
    .And => .I32And,
    .Or => .I32Or,
    _ => error("emit_bool_binop: unsupported op"),
  }
  buf2 := emit_atom(left, ctx, buf)
  buf3 := emit_atom(right, ctx, buf2)
  buf3.append(instr)
}

fn emit_str_binop(bop: BinOp, left: PreparedAtom, right: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_atom(left, ctx, buf)
  buf3 := emit_atom(right, ctx, buf2)
  case bop {
    .Add => buf3.append(.Call("rt_str__concat")),
    .Eq => buf3.append(.Call("rt_str__eq")),
    .Ne => buf3.append(.Call("rt_str__eq")).append(.I32Eqz),
    .Lt => buf3.append(.Call("rt_str__cmp")).append(.I32Const(0)).append(.I32LtS),
    .Le => buf3.append(.Call("rt_str__cmp")).append(.I32Const(1)).append(.I32LtS),
    .Gt => buf3.append(.Call("rt_str__cmp")).append(.I32Const(0)).append(.I32GtS),
    .Ge => buf3.append(.Call("rt_str__cmp")).append(.I32Const(-1)).append(.I32GtS),
    _ => error("emit_str_binop: unsupported op"),
  }
}

// ── Unary operations ───────────────────────────────────────────────────

fn emit_unop(uop: UnOp, operand: PreparedAtom, kind: OpKind, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case uop {
    .Neg => case kind {
      .Int => {
        buf2 := buf.append(.I64Const(0))
        buf3 := emit_atom_as_i64(operand, ctx, buf2)
        buf3.append(.I64Sub)
      },
      .Float => {
        buf2 := emit_atom(operand, ctx, buf)
        buf2.append(.F64Neg)
      },
      _ => error("emit_unop: Neg not valid for this type"),
    },
    .Not => case kind {
      .Bool => {
        buf2 := emit_atom(operand, ctx, buf)
        buf2.append(.I32Eqz)
      },
      .Int => {
        // BitNot: x XOR -1
        buf2 := emit_atom_as_i64(operand, ctx, buf)
        buf2.append(.I64Const(-1)).append(.I64Xor)
      },
      _ => error("emit_unop: Not not valid for this type"),
    },
  }
}

// ── Call dispatch ──────────────────────────────────────────────────────

fn emit_call(callee: PreparedAtom, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case callee {
    .AGlobalFunc(fid) => {
      // Check if it's a builtin
      case bi.entry(ctx.builtins, fid) {
        .Some(entry) => {
          case entry.kind {
            .Runtime(info) => emit_runtime_call(fid, info, args, result_idx, result_mono, ctx, buf),
            .Intrinsic => emit_intrinsic_call(fid, entry.name, args, result_idx, result_mono, ctx, buf),
          }
        },
        .None => {
          // User function — direct call
          emit_direct_call(fid, args, result_idx, result_mono, ctx, buf)
        },
      }
    },
    .ASlot(sid) => {
      // Closure call — indirect
      emit_closure_call(callee, sid, args, result_idx, result_mono, ctx, buf)
    },
    _ => error("emit_call: unexpected callee atom"),
  }
}

fn emit_direct_call(fid: FuncId, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  sym := lookup_func_sym(ctx.func_sym_map, fid)
  out := buf
  for a in args {
    out = emit_atom(a, ctx, out)
  }
  out = out.append(.Call(sym))
  case result_mono {
    .Void => {
      out = out.append(.I32Const(0))
      out = out.append(.RefI31)
      out.append(.LocalSet(result_idx))
    },
    .Never => out,
    _ => out.append(.LocalSet(result_idx)),
  }
}

// Host boundary helpers: identify functions that cross the Array/PVec boundary
fn is_host_vector_returning(name: String) Bool {
  name == "host_args" or name == "host_list_dir" or name == "host_env"
}
fn is_host_read_file(name: String) Bool {
  name == "host_read_file"
}
fn is_host_vector_arg(name: String, index: Int) Bool {
  (name == "host_write_bytes" and index == 1)
  or (name == "host_run_wasm" and (index == 0 or index == 1))
}

fn is_vector_builder_array_arg(name: String, index: Int) Bool {
  (name == "vector_builder_push" and index == 0) or (name == "vector_builder_freeze" and index == 0)
}

fn is_vector_builder_push(name: String) Bool {
  name == "vector_builder_push"
}

fn is_vector_builder_seed(name: String) Bool {
  name == "vector_builder_new" or name == "vector_builder_from"
}

// ABI shim: builder regions keep transient builders as erased anyref locals;
// cast back to concrete Array before the push/freeze call.
fn emit_builder_arg_shim(entry_name: String, index: Int, buf: Vector<Instr>) Vector<Instr> {
  if is_vector_builder_array_arg(entry_name, index) {
    return buf.append(.RefCast(true, .Named("rt_types__Array")))
  }
  buf
}

// ABI shim: host_write_bytes expects a flat Array, not a PVec.
fn emit_host_arg_shim(entry_name: String, index: Int, buf: Vector<Instr>) Vector<Instr> {
  if is_host_vector_arg(entry_name, index) {
    return buf.append(.Call("rt_arr__to_array"))
  }
  buf
}

// ABI shim: wrap flat Array or variant results back into PVec after host calls.
fn host_read_file_result_helper_sym() String {
  "host_read_file_result_helper"
}

fn emit_host_result_shim(entry_name: String, buf: Vector<Instr>) Vector<Instr> {
  if is_host_vector_returning(entry_name) {
    return buf.append(.Call("rt_arr__from_array"))
  }
  if is_host_read_file(entry_name) {
    return buf
      .append(.RefCast(true, .Named("rt_types__Variant")))
      .append(.Call("rt_arr__from_read_file_result"))
      .append(.Call(host_read_file_result_helper_sym()))
  }
  buf
}

fn emit_runtime_arg(a: PreparedAtom, abi: AbiContract?, index: Int, entry_name: String, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  param_vt: ValType? = case abi {
    .Some(ab) => {
      if index < ab.param_types.len() { .Some(ab.param_types[index]) } else { .None }
    },
    .None => .None,
  }

  // ABI shim: checked i64→i32 narrowing with trap for runtime functions that take I32.
  // This is not coercion — it traps on out-of-range values.
  needs_narrow := case param_vt {
    .Some(.I32) => case atom_mono(a, ctx) { .Int => true, _ => false },
    _ => false,
  }
  if needs_narrow {
    return emit_checked_i32_narrow(a, ctx, buf)
  }

  out := emit_atom(a, ctx, buf)

  // Builder regions keep transient Array builders in erased anyref slots even
  // though the surrounding Twinkle surface type is Vector<T>. For the builder
  // buffer argument, cast directly back to Array and skip the generic
  // mono-driven anyref→Vector coercion path.
  if is_vector_builder_array_arg(entry_name, index) {
    return emit_builder_arg_shim(entry_name, index, out)
  }

  // Host boundary: host_write_bytes is surface-typed as Vector<Byte> / PVec,
  // but the raw host ABI takes a flat Array. The explicit shim performs the
  // PVec -> Array conversion, so the generic ABI coercion must not run first or
  // it will insert an invalid PVec-as-Array ref.cast before rt_arr__to_array.
  if is_host_vector_arg(entry_name, index) {
    return emit_host_arg_shim(entry_name, index, out)
  }

  // Coercion: adapt actual physical type to expected ABI param type via canonical path.
  out2 := case param_vt {
    .Some(expected_vt) => emit_coerce_stack(atom_val_type(a, ctx), expected_vt, atom_mono(a, ctx), ctx, out),
    .None => out,
  }

  // ABI shims: representation reshaping for specific runtime/host surfaces.
  emit_host_arg_shim(entry_name, index, out2)
}

fn emit_runtime_call(fid: FuncId, info: RuntimeInfo, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  import_sym := "${info.wasm_module}__${info.wasm_name}"
  abi: AbiContract? = case ctx.builtins.by_id[fid.id] {
    .Some(entry) => .Some(entry.abi),
    .None => .None,
  }
  entry_name := case ctx.builtins.by_id[fid.id] {
    .Some(e) => e.name,
    .None => "",
  }
  out := buf
  for a,i in args {
    out = emit_runtime_arg(a, abi, i, entry_name, ctx, out)
  }
  out = out.append(.Call(import_sym))
  // ABI shim: reshape host results back into PVec representation.
  out = emit_host_result_shim(entry_name, out)
  // Some runtime calls return void or never return at all.
  case result_mono {
    .Void => {
      out = out.append(.I32Const(0))
      out = out.append(.RefI31)
      out.append(.LocalSet(result_idx))
    },
    .Never => out,
    _ => {
      if is_vector_builder_push(entry_name) {
        out = emit_default_value(val_type_of_mono(result_mono, ctx.env), out)
      } else {
        if !is_vector_builder_seed(entry_name) {
          out = out.concat(adapt_runtime_result(fid, result_mono, ctx))
        }
      }
      out.append(.LocalSet(result_idx))
    },
  }
}

fn heap_type_eq(a: HeapType, b: HeapType) Bool {
  case a {
    .Named(name_a) => case b { .Named(name_b) => name_a == name_b, _ => false },
    .Any => case b { .Any => true, _ => false },
    .Eq => case b { .Eq => true, _ => false },
    .I31 => case b { .I31 => true, _ => false },
    .Func => case b { .Func => true, _ => false },
    .None_ => case b { .None_ => true, _ => false },
    .Extern => case b { .Extern => true, _ => false },
  }
}

fn val_type_eq(a: ValType, b: ValType) Bool {
  case a {
    .I8 => case b { .I8 => true, _ => false },
    .I32 => case b { .I32 => true, _ => false },
    .I64 => case b { .I64 => true, _ => false },
    .F64 => case b { .F64 => true, _ => false },
    .Anyref => case b { .Anyref => true, _ => false },
    .I31ref => case b { .I31ref => true, _ => false },
    .Funcref => case b { .Funcref => true, _ => false },
    .Ref(nullable_a, heap_a) => case b {
      .Ref(nullable_b, heap_b) => nullable_a == nullable_b and heap_type_eq(heap_a, heap_b),
      _ => false,
    },
  }
}

fn emit_coerce_stack(from: ValType, to: ValType, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  if val_type_eq(from, to) { return buf }
  case to {
    .Anyref => { return emit_box_to_anyref(mono, ctx.env, buf) },
    _ => {},
  }
  case from {
    .Anyref => { return emit_unbox_from_anyref(mono, ctx.env, buf) },
    _ => {},
  }
  case from {
    .I32 => {
      case to {
        .I64 => { return buf.append(.I64ExtendI32S) },
        _ => {},
      }
    },
    .I64 => {
      case to {
        .I32 => { return buf.append(.I32WrapI64) },
        _ => {},
      }
    },
    .Ref(false, from_heap) => {
      case to {
        .Ref(true, to_heap) => {
          if heap_type_eq(from_heap, to_heap) { return buf }
        },
        _ => {},
      }
    },
    .Ref(true, from_heap) => {
      case to {
        .Ref(false, to_heap) => {
          if heap_type_eq(from_heap, to_heap) { return buf.append(.RefAsNonNull) }
        },
        _ => {},
      }
    },
    _ => {},
  }
  case from {
    .Ref(_, _) => {
      case to {
        .Ref(nullable, heap) => { return buf.append(.RefCast(nullable, heap)) },
        _ => {},
      }
    },
    _ => {},
  }
  buf
}

fn adapt_runtime_result(fid: FuncId, result_mono: MonoType, ctx: EmitCtx) Vector<Instr> {
  abi_opt: AbiContract? = case ctx.builtins.by_id[fid.id] {
    .Some(entry) => .Some(entry.abi),
    .None => .None,
  }
  case abi_opt {
    .Some(abi) => {
      if abi.result_types.len() == 1 {
        emit_coerce_stack(abi.result_types[0], val_type_of_mono(result_mono, ctx.env), result_mono, ctx, [])
      } else {
        []
      }
    },
    .None => [],
  }
}

// ── Intrinsic emission ─────────────────────────────────────────────────

fn emit_intrinsic_call(fid: FuncId, name: String, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case name {
    "string_to_string" => {
      // Identity — just return the string
      buf2 := emit_atom(args[0], ctx, buf)
      buf2.append(.LocalSet(result_idx))
    },
    "vector_append"       => emit_intrinsic_vector_append(args, result_idx, ctx, buf),
    "vector_get"          => emit_intrinsic_vector_get(args, result_idx, result_mono, ctx, buf),
    "vector_set"          => emit_intrinsic_vector_set(args, result_idx, result_mono, ctx, buf),
    "vector_make"         => emit_intrinsic_vector_make(args, result_idx, ctx, buf),
    "vector_set_in_place" => emit_intrinsic_vector_set_in_place(args, result_idx, ctx, buf),
    "dict_get_unsafe"     => emit_intrinsic_dict_get_unsafe(args, result_idx, result_mono, ctx, buf),
    "string_get"          => emit_intrinsic_string_get(args, result_idx, result_mono, ctx, buf),
    "string_slice"        => emit_intrinsic_string_slice(args, result_idx, ctx, buf),
    "char_code_at"        => emit_intrinsic_char_code_at(args, result_idx, ctx, buf),
    "from_char_code"      => emit_intrinsic_from_char_code(args, result_idx, result_mono, ctx, buf),
    "from_code_point"     => emit_intrinsic_from_code_point(args, result_idx, result_mono, ctx, buf),
    "string_utf8_bytes"   => emit_intrinsic_string_utf8_bytes(args, result_idx, ctx, buf),
    "string_from_utf8"    => emit_intrinsic_string_from_utf8(args, result_idx, result_mono, ctx, buf),
    "byte_to_int" => {
      buf2 := emit_atom(args[0], ctx, buf)
      buf2.append(.I64ExtendI32U).append(.LocalSet(result_idx))
    },
    "float_bits" => {
      buf2 := emit_atom(args[0], ctx, buf)
      buf2.append(.I64ReinterpretF64).append(.LocalSet(result_idx))
    },
    "byte_from_int"  => emit_intrinsic_byte_from_int(args, result_idx, result_mono, ctx, buf),
    "byte_to_string" => {
      // Zero-extend byte to i64, call int_to_string
      buf2 := emit_atom(args[0], ctx, buf)
      buf2.append(.I64ExtendI32U).append(.Call("rt_str__from_i64")).append(.LocalSet(result_idx))
    },
    "cell_new"    => emit_intrinsic_cell_new(args, result_idx, result_mono, ctx, buf),
    "cell_get"    => emit_intrinsic_cell_get(args, result_idx, result_mono, ctx, buf),
    "cell_set"    => emit_intrinsic_cell_set(args, result_idx, ctx, buf),
    "cell_update" => emit_intrinsic_cell_update(args, result_idx, ctx, buf),
    "range_from"  => emit_intrinsic_range_from(args, result_idx, result_mono, ctx, buf),
    "range"       => emit_intrinsic_range(args, result_idx, result_mono, ctx, buf),
    "range_step"  => emit_intrinsic_range_step(args, result_idx, result_mono, ctx, buf),
    "iterator_next"   => emit_intrinsic_iterator_next(args, result_idx, result_mono, ctx, buf),
    "iterator_unfold" => emit_intrinsic_iterator_unfold(args, result_idx, result_mono, ctx, buf),
    "int_from_string" => {
      buf2 := emit_atom(args[0], ctx, buf)
      buf2.append(.Call("int_from_string_helper"))
        .append(.RefCast(true, .Named("rt_types__Variant")))
        .append(.Call(option_from_variant_helper_sym(MonoType.Int)))
        .append(.LocalSet(result_idx))
    },
    "float_from_string" => {
      buf2 := emit_atom(args[0], ctx, buf)
      buf2.append(.Call("float_from_string_helper"))
        .append(.RefCast(true, .Named("rt_types__Variant")))
        .append(.Call(option_from_variant_helper_sym(MonoType.Float)))
        .append(.LocalSet(result_idx))
    },
    _ => error("emit_intrinsic_call: unknown intrinsic '${name}'"),
  }
}

// ── vector_append: COW append via concat ─────────────────────────────────

// Erased container ingress: emit a typed/scalar value and coerce it to anyref
// for storage in a vector or dict (rt_arr__*, rt_dict__* surfaces).
fn emit_erased_container_ingress(arg: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_atom(arg, ctx, buf)
  emit_coerce_stack(atom_val_type(arg, ctx), .Anyref, atom_mono(arg, ctx), ctx, buf2)
}

// Erased container egress: unbox an anyref element loaded from a vector or
// iterator state array back to its typed representation.
fn emit_erased_container_egress(mono: MonoType, env: ResolvedEnv, buf: Vector<Instr>) Vector<Instr> {
  emit_unbox_from_anyref(mono, env, buf)
}

fn emit_intrinsic_vector_append(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // vector_append(vec, elem) → rt_arr__push(vec, elem)
  buf2 := emit_atom(args[0], ctx, buf)  // vec (PVec, nullable)
  buf3 := buf2.append(.RefAsNonNull)    // push takes non-null PVec
  buf4 := emit_erased_container_ingress(args[1], ctx, buf3)
  buf4.append(.Call("rt_arr__push")).append(.LocalSet(result_idx))
}

// ── vector_get: bounds-checked → Option<T> ─────────────────────────────

fn emit_intrinsic_vector_get(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Result is Option<T> → typed sum struct
  sum_layout := get_sum_layout(result_mono, ctx.env)
  elem_mono := case result_mono {
    .Optional(inner) => inner,
    _ => .Anyref_,
  }
  some_variant := sum_layout.variants[1]
  default_payload := if some_variant.payload_types.len() > 0 {
    emit_default_value(some_variant.payload_types[0], [])
  } else { [] }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs : Vector<Instr> = [Instr.I32Const(1)]  // tag = Some
      .concat(emit_atom(args[0], ctx, []))  // vec
      .concat(emit_checked_i32_narrow(args[1], ctx, []))  // index
      .concat([.Call("rt_arr__get")])
      .concat(emit_erased_container_egress(elem_mono, ctx.env, []))
      .concat([.StructNew(sum_layout.sym)])

  else_instrs : Vector<Instr> = [Instr.I32Const(0)]  // tag = None
      .concat(default_payload)
      .concat([.StructNew(sum_layout.sym)])

  // Bounds check: 0 <= index < len (index is i64, len is i32)
  buf2 := emit_atom(args[1], ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)  // index >= 0
  buf4 := emit_atom(args[1], ctx, buf3)
  buf5 := emit_atom(args[0], ctx, buf4)
  buf5.append(.RefAsNonNull).append(.StructGet("rt_types__PVec", 0)).append(.I64ExtendI32U).append(.I64LtS).append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs)).append(.LocalSet(result_idx))
}

// ── vector_set: bounds-checked COW → Option<Vector<T>> ─────────────────

fn emit_intrinsic_vector_set(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  sum_layout := get_sum_layout(result_mono, ctx.env)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else { [] }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs : Vector<Instr> = [Instr.I32Const(1)]  // tag = Some
      .concat(emit_atom(args[0], ctx, []))  // vec
      .concat(emit_checked_i32_narrow(args[1], ctx, []))  // index
      .concat(emit_erased_container_ingress(args[2], ctx, []))
      .concat([.Call("rt_arr__set"), .StructNew(sum_layout.sym)])

  else_instrs : Vector<Instr> = [Instr.I32Const(0)]  // tag = None
      .concat(default_payload)
      .concat([.StructNew(sum_layout.sym)])

  buf2 := emit_atom(args[1], ctx, buf)  // index (i64)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[1], ctx, buf3)
  buf5 := emit_atom(args[0], ctx, buf4)
  buf5.append(.RefAsNonNull).append(.StructGet("rt_types__PVec", 0)).append(.I64ExtendI32U).append(.I64LtS).append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs)).append(.LocalSet(result_idx))
}

// ── vector_make: make(size, default) ───────────────────────────────────

fn emit_intrinsic_vector_make(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_checked_i32_narrow(args[0], ctx, buf)  // size (i32)
  buf3 := emit_erased_container_ingress(args[1], ctx, buf2)
  buf3.append(.Call("rt_arr__make")).append(.LocalSet(result_idx))
}

// ── vector_set_in_place ────────────────────────────────────────────────

fn emit_intrinsic_vector_set_in_place(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // vector_set_in_place: initially lowers to persistent set (correctness over perf)
  buf2 := emit_atom(args[0], ctx, buf)  // vec
  buf3 := emit_checked_i32_narrow(args[1], ctx, buf2)  // index
  buf4 := emit_erased_container_ingress(args[2], ctx, buf3)
  buf4.append(.Call("rt_arr__set")).append(.LocalSet(result_idx))
}

// ── dict_get_unsafe ────────────────────────────────────────────────────

fn emit_intrinsic_dict_get_unsafe(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_atom(args[0], ctx, buf)  // dict
  buf3 := emit_erased_container_ingress(args[1], ctx, buf2)  // key (erased)
  emit_erased_container_egress(result_mono, ctx.env, buf3.append(.Call("rt_dict__get")))
    .append(.LocalSet(result_idx))
}

// ── string_get: s.get(i) → Option<Byte> ───────────────────────────────

fn emit_intrinsic_string_get(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  sum_layout := get_sum_layout(result_mono, ctx.env)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else { [] }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs : Vector<Instr> = [Instr.I32Const(1)]  // tag = Some
      .concat(emit_atom(args[0], ctx, []))
      .concat(emit_checked_i32_narrow(args[1], ctx, []))
      .concat([.ArrayGetU("rt_types__String"), .StructNew(sum_layout.sym)])

  else_instrs : Vector<Instr> = [Instr.I32Const(0)]  // tag = None
      .concat(default_payload)
      .concat([.StructNew(sum_layout.sym)])

  // Bounds check in i64 domain
  buf2 := emit_atom(args[1], ctx, buf)  // index (i64)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[1], ctx, buf3)
  buf5 := emit_atom(args[0], ctx, buf4)  // string
  buf5.append(.ArrayLen).append(.I64ExtendI32U).append(.I64LtS).append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs)).append(.LocalSet(result_idx))
}

// ── string_slice: s.slice(start, end) ──────────────────────────────────

fn emit_intrinsic_string_slice(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Bounds checks + UTF-8 boundary validation, then call rt_str__substring
  buf2 := emit_atom(args[1], ctx, buf)  // start >= 0
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[2], ctx, buf3)  // end >= 0
  buf5 := buf4.append(.I64Const(0)).append(.I64GeS).append(.I32And)
  buf6 := emit_atom(args[1], ctx, buf5)
  buf7 := emit_atom(args[2], ctx, buf6)
  buf8 := buf7.append(.I64LeS).append(.I32And)  // start <= end
  buf9 := emit_atom(args[2], ctx, buf8)
  buf10 := emit_atom(args[0], ctx, buf9)
  buf11 := buf10.append(.ArrayLen).append(.I64ExtendI32U).append(.I64LeS).append(.I32And)  // end <= len
  buf12 := buf11.append(.I32Eqz).append(.If(.None, [.Unreachable], []))
  buf13 := emit_utf8_boundary_check(args[0], args[1], ctx, buf12)
  buf14 := emit_utf8_boundary_check(args[0], args[2], ctx, buf13)
  buf15 := emit_atom(args[0], ctx, buf14)
  buf16 := emit_checked_i32_narrow(args[1], ctx, buf15)
  buf17 := emit_checked_i32_narrow(args[2], ctx, buf16)
  buf17.append(.Call("rt_str__substring")).append(.LocalSet(result_idx))
}

fn emit_utf8_boundary_check(str_atom: PreparedAtom, idx_atom: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // if idx > 0 && idx < len: check (s[idx] & 0xC0) != 0x80
  // The check sub-body is a nested Wasm control flow body — use fresh []
  check_buf1 := emit_atom(str_atom, ctx, [])
  check_buf2 := emit_checked_i32_narrow(idx_atom, ctx, check_buf1)
  check : Vector<Instr> = check_buf2
    .append(.ArrayGetU("rt_types__String"))
    .append(.I32Const(192))   // 0xC0
    .append(.I32And)
    .append(.I32Const(128))   // 0x80
    .append(.I32Eq)
    .append(.If(.None, [.Unreachable], []))

  buf2 := emit_atom(idx_atom, ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GtS)  // idx > 0
  buf4 := emit_atom(idx_atom, ctx, buf3)
  buf5 := emit_atom(str_atom, ctx, buf4)
  buf5.append(.ArrayLen).append(.I64ExtendI32U).append(.I64LtS).append(.I32And)
    .append(.If(.None, check, []))
}

// ── char_code_at ───────────────────────────────────────────────────────

fn emit_intrinsic_char_code_at(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Trap if out of bounds, then read byte
  buf2 := emit_atom(args[1], ctx, buf)  // index (i64)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[1], ctx, buf3)
  buf5 := emit_atom(args[0], ctx, buf4)
  buf6 := buf5.append(.ArrayLen).append(.I64ExtendI32U).append(.I64LtS).append(.I32And).append(.I32Eqz)
  buf7 := buf6.append(.If(.None, [.Unreachable], []))
  buf8 := emit_atom(args[0], ctx, buf7)
  buf9 := emit_checked_i32_narrow(args[1], ctx, buf8)
  buf9.append(.ArrayGetU("rt_types__String")).append(.I64ExtendI32U).append(.LocalSet(result_idx))
}

// ── from_char_code: Int → Option<String> ───────────────────────────────

fn emit_intrinsic_from_char_code(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  sum_layout := get_sum_layout(result_mono, ctx.env)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else { [] }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs : Vector<Instr> = [Instr.I32Const(1)]  // tag = Some
      .concat(emit_atom(args[0], ctx, []))
      .concat([.I32WrapI64, .ArrayNewFixed("rt_types__String", 1), .StructNew(sum_layout.sym)])

  else_instrs : Vector<Instr> = [Instr.I32Const(0)]  // tag = None
      .concat(default_payload)
      .concat([.StructNew(sum_layout.sym)])

  // Check 0 <= code < 128
  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[0], ctx, buf3)
  buf4.append(.I64Const(128)).append(.I64LtS).append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs)).append(.LocalSet(result_idx))
}

// ── from_code_point: Int → Option<String> ──────────────────────────────

fn emit_intrinsic_from_code_point(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Helper returns the generic runtime Variant encoding for Option<String>.
  // Adapt it to the concrete Option<String> layout used by the current module.
  buf2 := emit_checked_i32_narrow(args[0], ctx, buf)
  buf2.append(.Call("from_code_point_helper"))
    .append(.RefCast(true, .Named("rt_types__Variant")))
    .append(.Call(option_from_variant_helper_sym(MonoType.String)))
    .append(.LocalSet(result_idx))
}

// ── string_utf8_bytes ──────────────────────────────────────────────────

fn emit_intrinsic_string_utf8_bytes(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Helper returns flat $Array; wrap to PVec
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.Call("string_utf8_bytes_helper")).append(.Call("rt_arr__from_array")).append(.LocalSet(result_idx))
}

// ── string_from_utf8 ──────────────────────────────────────────────────

fn emit_intrinsic_string_from_utf8(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // User passes PVec; helper expects flat $Array
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.Call("rt_arr__to_array"))
    .append(.Call("string_from_utf8_helper"))
    .append(.RefCast(true, .Named("rt_types__Variant")))
    .append(.Call(option_from_variant_helper_sym(MonoType.String)))
    .append(.LocalSet(result_idx))
}

// ── byte_from_int: Int → Option<Byte> ──────────────────────────────────

fn emit_intrinsic_byte_from_int(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  sum_layout := get_sum_layout(result_mono, ctx.env)
  some_v := sum_layout.variants[1]
  default_payload := if some_v.payload_types.len() > 0 {
    emit_default_value(some_v.payload_types[0], [])
  } else { [] }
  result_ref := ValType.Ref(false, .Named(sum_layout.sym))

  // Nested sub-bodies must use fresh []
  then_instrs : Vector<Instr> = [Instr.I32Const(1)]
      .concat(emit_atom(args[0], ctx, []))
      .concat([.I32WrapI64, .StructNew(sum_layout.sym)])

  else_instrs : Vector<Instr> = [Instr.I32Const(0)]
      .concat(default_payload)
      .concat([.StructNew(sum_layout.sym)])

  // Check 0 <= n <= 255
  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.I64Const(0)).append(.I64GeS)
  buf4 := emit_atom(args[0], ctx, buf3)
  buf4.append(.I64Const(256)).append(.I64LtS).append(.I32And)
    .append(.If(.Some(result_ref), then_instrs, else_instrs)).append(.LocalSet(result_idx))
}

// ── Cell intrinsics ────────────────────────────────────────────────────

fn cell_struct_sym(inner_mono: MonoType, env: ResolvedEnv) String {
  inner_layout := layout_of(inner_mono, env)
  key := case inner_layout {
    .Scalar(.WI32) => "i32",
    .Scalar(.WI64) => "i64",
    .Scalar(.WF64) => "f64",
    .Scalar(.WAnyref) => "anyref",
    _ => "anyref",
  }
  "$Cell_${key}"
}

fn emit_cell_value_arg(arg: PreparedAtom, inner_mono: MonoType, sym: String, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  actual_vt := atom_val_type(arg, ctx)
  target_vt := if sym == "$Cell_anyref" { ValType.Anyref } else { val_type_of_mono(inner_mono, ctx.env) }
  buf2 := emit_atom(arg, ctx, buf)
  emit_coerce_stack(actual_vt, target_vt, inner_mono, ctx, buf2)
}

fn emit_intrinsic_cell_new(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Cell<T> is a single-field mutable struct
  inner_mono : MonoType = case result_mono {
    .Named(_, type_args) => {
      if type_args.len() > 0 { type_args[0] } else { .Void }
    },
    _ => .Void,
  }
  sym := cell_struct_sym(inner_mono, ctx.env)
  buf2 := emit_cell_value_arg(args[0], inner_mono, sym, ctx, buf)
  buf2.append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_cell_get(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Get Cell<T>'s inner type from the cell arg's mono
  cell_mono := require_typed_record_atom(args[0], ctx, "emit_intrinsic_cell_get")
  inner_mono := case cell_mono {
    .Named(_, type_args) => {
      if type_args.len() > 0 { type_args[0] } else { MonoType.Void }
    },
    _ => MonoType.Void,
  }
  sym := cell_struct_sym(inner_mono, ctx.env)
  buf2 := emit_atom(args[0], ctx, buf)
  buf3 := buf2.append(.StructGet(sym, 0))
  buf4 := if sym == "$Cell_anyref" { emit_unbox_from_anyref(inner_mono, ctx.env, buf3) } else { buf3 }
  buf4.append(.LocalSet(result_idx))
}

fn emit_intrinsic_cell_set(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  cell_mono := require_typed_record_atom(args[0], ctx, "emit_intrinsic_cell_set")
  inner_mono := cell_inner_mono(cell_mono)
  sym := cell_struct_sym(inner_mono, ctx.env)
  buf2 := emit_atom(args[0], ctx, buf)  // cell ref
  buf3 := emit_cell_value_arg(args[1], inner_mono, sym, ctx, buf2)
  buf3.append(.StructSet(sym, 0)).append(.I32Const(0)).append(.RefI31).append(.LocalSet(result_idx))  // return void
}

fn cell_inner_mono(cell_mono: MonoType) MonoType {
  case cell_mono {
    .Named(_, type_args) => {
      if type_args.len() > 0 { type_args[0] } else { MonoType.Void }
    },
    _ => MonoType.Void,
  }
}

fn emit_intrinsic_cell_update(args: Vector<PreparedAtom>, result_idx: Int, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // cell_update(cell, fn(T) T) — apply function to cell value, store result
  cell_mono := require_typed_record_atom(args[0], ctx, "emit_intrinsic_cell_update")
  inner_mono := cell_inner_mono(cell_mono)
  sym := cell_struct_sym(inner_mono, ctx.env)
  // For simplicity, use the universal closure path
  buf2 := emit_atom(args[0], ctx, buf)  // cell ref for struct.set target
  buf3 := emit_atom(args[1], ctx, buf2)
  buf4 := buf3.append(.StructGet("rt_types__Closure", 1))  // env (field 1)
  buf5 := emit_atom(args[0], ctx, buf4)
  buf6 := buf5.append(.StructGet(sym, 0))  // current cell value
  buf7 := if sym != "$Cell_anyref" { emit_box_to_anyref(inner_mono, ctx.env, buf6) } else { buf6 }
  buf8 := buf7.append(.ArrayNewFixed("rt_types__Array", 1))  // args array
  buf9 := emit_atom(args[1], ctx, buf8)
  buf10 := buf9.append(.StructGet("rt_types__Closure", 0)).append(.CallRef("rt_types__ClosureFunc"))
  buf11 := if sym != "$Cell_anyref" { emit_unbox_from_anyref(inner_mono, ctx.env, buf10) } else { buf10 }
  buf11.append(.StructSet(sym, 0)).append(.I32Const(0)).append(.RefI31).append(.LocalSet(result_idx))  // return void
}

// ── Range intrinsics ───────────────────────────────────────────────────

fn emit_intrinsic_range(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // range(end) → Range struct (start=0, end=end, step=1)
  layout := layout_of(result_mono, ctx.env)
  sym := case layout { .Record(r) => r.sym, _ => error("range: expected Record layout") }
  buf2 := buf.append(.I64Const(0))  // start
  buf3 := emit_atom(args[0], ctx, buf2)  // end
  buf3.append(.I64Const(1)).append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_range_from(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // range_from(start, end) → Range struct
  layout := layout_of(result_mono, ctx.env)
  sym := case layout { .Record(r) => r.sym, _ => error("range_from: expected Record layout") }
  buf2 := emit_atom(args[0], ctx, buf)  // start
  buf3 := emit_atom(args[1], ctx, buf2)  // end
  buf3.append(.I64Const(1)).append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn emit_intrinsic_range_step(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // range_step(start, end, step) → Range struct
  layout := layout_of(result_mono, ctx.env)
  sym := case layout { .Record(r) => r.sym, _ => error("range_step: expected Record layout") }
  buf2 := emit_atom(args[0], ctx, buf)  // start
  buf3 := emit_atom(args[1], ctx, buf2)  // end
  buf4 := emit_atom(args[2], ctx, buf3)  // step
  buf4.append(.StructNew(sym)).append(.LocalSet(result_idx))
}

// ── Iterator intrinsics ────────────────────────────────────────────────

fn emit_intrinsic_iterator_unfold(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // iterator_unfold(seed, step_fn) → IteratorState struct
  layout := layout_of(result_mono, ctx.env)
  sym := case layout {
    .Record(r) => r.sym,
    .Iterator_(it) => it.state_sym,
    _ => error("iterator_unfold: unexpected layout"),
  }
  buf2 := emit_erased_container_ingress(args[0], ctx, buf)  // seed (erased anyref state field)
  buf3 := emit_atom(args[1], ctx, buf2)
  buf3.append(.StructNew(sym)).append(.LocalSet(result_idx))
}

fn iterator_next_helper_sym(result_mono: MonoType) String {
  "iterator_next_helper_${mono_to_key(result_mono)}"
}

fn emit_intrinsic_iterator_next(args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf2 := emit_atom(args[0], ctx, buf)
  buf2.append(.Call(iterator_next_helper_sym(result_mono))).append(.LocalSet(result_idx))
}

// ── Record operations ──────────────────────────────────────────────────

fn record_layout_of(mono: MonoType, env: ResolvedEnv) WasmRecordLayout {
  layout := layout_of(mono, env)
  case layout {
    .Record(r) => r,
    _ => {
      case mono {
        .Named(tid, args) => {
          case env.lookup_type_def(tid) {
            .Some(.Alias(_, type_params, target)) => record_layout_of(subst_type_params(target, type_params, args), env),
            _ => error("record_layout_of: expected Record layout for ${mono_to_key(mono)}"),
          }
        },
        _ => error("record_layout_of: expected Record layout for ${mono_to_key(mono)}"),
      }
    },
  }
}

fn emit_record_literal(tid: TypeId, fields: Vector<PreparedFieldAtom>, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  rec_layout := record_layout_of(result_mono, ctx.env)
  sym := rec_layout.sym

  // Emit fields in order of the struct definition
  out := buf
  for fl in rec_layout.fields {
    found := false
    for fa in fields {
      if fa.field.id == fl.field_id.id {
        out = emit_atom(fa.value, ctx, out)
        out = emit_coerce_stack(atom_val_type(fa.value, ctx), fl.val_type, atom_mono(fa.value, ctx), ctx, out)
        found = true
      }
    }
    if !found {
      out = emit_default_value(fl.val_type, out)
    }
  }
  out.append(.StructNew(sym))
}

fn emit_record_get(target: PreparedAtom, fid: FieldId, tid: TypeId, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Determine the record type from the target atom's mono type.
  // Dead/impossible branches can leave a pattern-bound local typed as Void;
  // in that case emit an arbitrary default of the requested result type.
  target_mono := require_typed_record_atom(target, ctx, "emit_record_get")
  case target_mono {
    .Void => emit_default_value(val_type_of_mono(result_mono, ctx.env), buf),
    _ => {
      rec := record_layout_of(target_mono, ctx.env)
      field_idx := find_field_index(rec, fid)
      emit_atom(target, ctx, buf).append(.StructGet(rec.sym, field_idx))
    },
  }
}

fn emit_record_update(base: PreparedAtom, fid: FieldId, value: PreparedAtom, can_reuse: Bool, tid: TypeId, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  base_mono := require_typed_record_atom(base, ctx, "emit_record_update")
  case base_mono {
    .Void => {
      rec := record_layout_of(result_mono, ctx.env)
      for fl in rec.fields {
        if fl.field_id.id == fid.id {
          buf = emit_atom(value, ctx, buf)
          buf = emit_coerce_stack(atom_val_type(value, ctx), fl.val_type, atom_mono(value, ctx), ctx, buf)
        } else {
          buf = emit_default_value(fl.val_type, buf)
        }
      }
      return buf.append(.StructNew(rec.sym))
    },
    _ => {},
  }

  rec := record_layout_of(base_mono, ctx.env)
  field_idx := find_field_index(rec, fid)

  field_vt := rec.fields[field_idx].val_type
  if can_reuse {
    // In-place update: struct.set then return same ref
    buf = emit_atom(base, ctx, buf)      // struct ref for StructSet
    buf = emit_atom(value, ctx, buf)    // new field value
    buf = emit_coerce_stack(atom_val_type(value, ctx), field_vt, atom_mono(value, ctx), ctx, buf)
    buf = buf.append(.StructSet(rec.sym, field_idx))
    // Return the mutated struct
    emit_atom(base, ctx, buf)
  } else {
    // Copy: build new struct with all fields from base, except the updated one
    for fl,i in rec.fields {
      if fl.field_id.id == fid.id {
        buf = emit_atom(value, ctx, buf)
        buf = emit_coerce_stack(atom_val_type(value, ctx), fl.val_type, atom_mono(value, ctx), ctx, buf)
      } else {
        buf = emit_atom(base, ctx, buf)
        buf = buf.append(.StructGet(rec.sym, i))
      }
    }
    buf.append(.StructNew(rec.sym))
  }
}

fn find_field_index(rec: WasmRecordLayout, fid: FieldId) Int {
  for f,i in rec.fields {
    if f.field_id.id == fid.id { return i }
  }
  error("find_field_index: FieldId ${fid.id} not found in ${rec.sym}")
}

// ── Variant operations ─────────────────────────────────────────────────

fn emit_variant_literal(tid: TypeId, vid: VariantId, args: Vector<PreparedAtom>, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // All variants → typed sum struct
  layout := layout_of(result_mono, ctx.env)
  sum := case layout {
    .Sum(s) => s,
    _ => error("emit_variant_literal: expected Sum layout for type"),
  }

  // Emit tag
  out := buf.append(.I32Const(vid.id))

  // Emit all payload fields for ALL variants (typed struct has slots for all)
  for v in sum.variants {
    if v.variant_id.id == vid.id {
      // This variant — emit actual args, coerced to expected payload slot types
      for a,i in args {
        out = emit_atom(a, ctx, out)
        out = emit_coerce_stack(atom_val_type(a, ctx), v.payload_types[i], atom_mono(a, ctx), ctx, out)
      }
    } else {
      // Other variant — emit default values for its payload slots
      for pt in v.payload_types {
        out = emit_default_value(pt, out)
      }
    }
  }
  out.append(.StructNew(sum.sym))
}

// ── Array operations ───────────────────────────────────────────────────

fn emit_array_literal(items: Vector<PreparedAtom>, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  n := items.len()

  // Small literals fit entirely in the tail.
  if n <= 32 {
    out := buf.append(.I32Const(n)).append(.I32Const(0)).append(.RefNull(.Named("rt_types__VecInternal")))
    for item in items {
      out = emit_atom(item, ctx, out)
      out = emit_box_to_anyref(atom_mono(item, ctx), ctx.env, out)
    }
    return out.append(.ArrayNewFixed("rt_types__Array", n)).append(.StructNew("rt_types__PVec"))
  }

  // Larger literals must populate the trie prefix as elements spill past the
  // tail. Build them by repeated rt.arr.push calls so the runtime maintains the
  // correct root/tail shape.
  out := buf.append(.I32Const(0)).append(.I32Const(0))
    .append(.RefNull(.Named("rt_types__VecInternal")))
    .append(.ArrayNewFixed("rt_types__Array", 0))
    .append(.StructNew("rt_types__PVec"))
  for item in items {
    out = emit_atom(item, ctx, out)
    out = emit_box_to_anyref(atom_mono(item, ctx), ctx.env, out)
    out = out.append(.Call("rt_arr__push"))
  }
  out
}

// ── Index operations ───────────────────────────────────────────────────


fn emit_index_op(base: PreparedAtom, index: PreparedAtom, kind: IndexKind, result_ty: MonoType, result_vt: ValType?, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case kind {
    .Array => {
      // Vector indexing returns erased anyref from rt_arr__get. Cast/unbox here
      // when the destination slot is already typed; leave raw anyref alone when
      // boundary insertion requested an intermediate anyref local.
      // Bounds check in i64 domain
      out := emit_atom(index, ctx, buf).append(.I64Const(0)).append(.I64GeS)
      out = emit_atom(index, ctx, out)
      out = emit_atom(base, ctx, out)
      out = out.append(.RefAsNonNull)
        .append(.StructGet("rt_types__PVec", 0))  // vec.len
        .append(.I64ExtendI32U)
        .append(.I64LtS)
        .append(.I32And)
        .append(.I32Eqz)
        .append(.If(.None, [.Unreachable], []))
      // Get element
      out = emit_atom(base, ctx, out)
      out = emit_checked_i32_narrow(index, ctx, out)
      out = out.append(.Call("rt_arr__get"))
      // Erased container egress: coerce anyref element to the expected typed slot.
      case result_vt {
        .Some(expected_vt) => {
          emit_coerce_stack(.Anyref, expected_vt, result_ty, ctx, out)
        },
        .None => out,
      }
    },
    .Dict => {
      // Dict indexing returns Option<V>. Materialize the concrete typed Option
      // around rt_dict__get's null-on-miss ABI instead of routing through the
      // generic rt_dict__get_option Variant helper.
      sum_layout := get_sum_layout(result_ty, ctx.env)
      value_mono := case result_ty {
        .Optional(inner) => inner,
        _ => error("emit_index_op: dict index expected Optional result, got ${mono_to_key(result_ty)}"),
      }

      // Nested sub-bodies must use fresh []
      none_instrs: Vector<Instr> = [.I32Const(0)]
      some_variant := sum_layout.variants[1]
      if some_variant.payload_types.len() > 0 {
        none_instrs = emit_default_value(some_variant.payload_types[0], none_instrs)
      }
      none_instrs = none_instrs.append(.StructNew(sum_layout.sym))

      some_instrs: Vector<Instr> = [.I32Const(1)]
      some_instrs = some_instrs.concat(emit_atom(base, ctx, []))
      some_instrs = some_instrs.concat(emit_erased_container_ingress(index, ctx, []))
      some_instrs = some_instrs.append(.Call("rt_dict__get"))
      some_instrs = emit_erased_container_egress(value_mono, ctx.env, some_instrs)
      some_instrs = some_instrs.append(.StructNew(sum_layout.sym))

      out := emit_atom(base, ctx, buf)
      out = emit_erased_container_ingress(index, ctx, out)
      out.append(.Call("rt_dict__get"))
        .append(.RefIsNull)
        .append(.If(.Some(.Ref(false, .Named(sum_layout.sym))), none_instrs, some_instrs))
    },
    .Str => {
      // String indexing: bounds check + array.get_u → byte (i32)
      // Bounds check
      out := emit_atom(index, ctx, buf)
      out= out.append(.I64Const(0)).append(.I64GeS)
      out= emit_atom(index, ctx, out)
      out= emit_atom(base, ctx, out)
      out= out.append(.ArrayLen).append(.I64ExtendI32U).append(.I64LtS).append(.I32And)
        .append(.I32Eqz)
        .append(.If(.None, [.Unreachable], []))
      // Get byte
      out = emit_atom(base, ctx, out)
      out = emit_checked_i32_narrow(index, ctx, out)
      out.append(.ArrayGetU("rt_types__String"))
    },
  }
}

// ── If emission ────────────────────────────────────────────────────────

fn emit_if_op(cond: PreparedAtom, then_e: PreparedExpr, else_e: PreparedExpr, result_idx: Int, result_vt: ValType?, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  out := emit_atom(cond, ctx, buf)

  // Nested sub-bodies must use fresh []
  then_instrs := emit_expr(then_e, result_mono, ctx, [])
  else_instrs := emit_expr(else_e, result_mono, ctx, [])

  then_div := expr_always_diverges(then_e)
  else_div := expr_always_diverges(else_e)

  if then_div and else_div {
    // Both diverge — no result
    out = out.append(.If(.None, then_instrs, else_instrs))
    out.append(.Unreachable)
  } else {
    // Store result into local
    // If one branch diverges, it won't produce a value, but that's OK
    // because it ends with Unreachable/Br
    then_body := then_instrs
    if !then_div {
      then_body = append_result_store(then_body, result_idx, result_mono)
    }
    else_body := else_instrs
    if !else_div {
      else_body = append_result_store(else_body, result_idx, result_mono)
    }
    out.append(.If(.None, then_body, else_body))
  }
}

// ── Loop emission ──────────────────────────────────────────────────────

fn emit_loop_op(body: PreparedExpr, result_idx: Int, result_vt: ValType?, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  depth := ctx.loop_depth
  break_label := "$break_${depth}"
  cont_label := "$continue_${depth}"

  // Push labels onto label_stack
  new_labels := ctx.label_stack.append(LabelPair.{
    break_label: break_label,
    continue_label: cont_label,
  })
  loop_ctx := EmitCtx.{
    registry: ctx.registry,
    builtins: ctx.builtins,
    env: ctx.env,
    local_map: ctx.local_map,
    next_local: ctx.next_local,
    wasm_locals: ctx.wasm_locals,
    label_stack: new_labels,
    current_func_id: ctx.current_func_id,
    func_sym_map: ctx.func_sym_map,
    prepared_funcs: ctx.prepared_funcs,
    init_func_id: ctx.init_func_id,
    loop_depth: ctx.loop_depth + 1,
  }

  // Loop body is a nested sub-body — use fresh []
  body_instrs := emit_expr(body, .Void, loop_ctx, [])
  // Implicit continue at end of loop body
  body_instrs = body_instrs.append(.Br(cont_label))

  loop_instr := Instr.Loop(cont_label, .None, body_instrs)
  block_instrs: Vector<Instr> = [loop_instr]

  // Block wraps the loop for break target
  out := buf.append(.Block(break_label, .None, block_instrs))

  // Loop produces void — set result to void
  out.append(.I32Const(0)).append(.RefI31).append(.LocalSet(result_idx))
}

fn append_result_store(body: Vector<Instr>, result_idx: Int, result_mono: MonoType) Vector<Instr> {
  case result_mono {
    .Void => {
      out := body.append(.I32Const(0))
      out = out.append(.RefI31)
      out.append(.LocalSet(result_idx))
    },
    .Never => body,
    _ => body.append(.LocalSet(result_idx)),
  }
}

// ── Match emission ─────────────────────────────────────────────────────

fn emit_match_op(scrutinee: PreparedAtom, arms: Vector<PreparedMatchArm>, result_idx: Int, result_vt: ValType?, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  scrutinee_mono := match_scrutinee_mono(scrutinee, ctx)
  // scrutinee_instrs is used as sub-body content, so keep as fresh []
  scrutinee_instrs := emit_atom(scrutinee, ctx, [])
  emit_arm_chain(scrutinee_instrs, scrutinee_mono, arms, result_idx, result_mono, ctx, buf)
}

fn emit_arm_chain(
  scrutinee_instrs: Vector<Instr>,
  scrutinee_mono: MonoType,
  arms: Vector<PreparedMatchArm>,
  result_idx: Int,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  if arms.len() == 0 {
    return buf.append(.Unreachable)
  }

  head := arms[0]
  tail: Vector<PreparedMatchArm> = arms.slice(1, arms.len())

  // Pattern condition is used as sub-body content — use fresh []
  cond_instrs := emit_pattern_condition(head.pattern, scrutinee_instrs, scrutinee_mono, ctx, [])

  // Then: bindings + body + store result — all fresh [] (sub-body)
  bindings := emit_pattern_bindings(head.pattern, scrutinee_instrs, scrutinee_mono, ctx)
  body_instrs := emit_expr(head.body, result_mono, ctx, [])
  head_div := expr_always_diverges(head.body)

  then_body := bindings.concat(body_instrs)
  then_body = if !head_div {
    append_result_store(then_body, result_idx, result_mono)
  } else { then_body }

  // Else: recurse on tail — fresh [] (sub-body)
  else_body := emit_arm_chain(scrutinee_instrs, scrutinee_mono, tail, result_idx, result_mono, ctx, [])

  tail_div := all_arms_diverge(tail)
  both_div := head_div and tail_div

  out := buf.concat(cond_instrs).append(.If(.None, then_body, else_body))
  if both_div {
    out = out.append(.Unreachable)
  }
  out
}

fn can_match_variant_pattern(scrutinee_mono: MonoType, env: ResolvedEnv) Bool {
  case scrutinee_mono {
    .Optional(_) => true,
    .Result(_, _) => true,
    .Named(tid, args) => {
      def := case env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => { return false },
      }
      case def {
        .Sum(_, _, _) => true,
        .Alias(_, type_params, target) => can_match_variant_pattern(subst_type_params(target, type_params, args), env),
        _ => false,
      }
    },
    _ => false,
  }
}

fn emit_pattern_condition(pattern: PreparedPattern, scrutinee_instrs: Vector<Instr>, scrutinee_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  case pattern {
    .Wildcard => buf.append(.I32Const(1)),
    .Var(_) => buf.append(.I32Const(1)),
    .LitInt(n) => {
      buf.concat(scrutinee_instrs).append(.I64Const(n)).append(.I64Eq)
    },
    .LitBool(b) => {
      buf.concat(scrutinee_instrs).append(.I32Const(if b { 1 } else { 0 })).append(.I32Eq)
    },
    .LitStr(s) => {
      // String comparison via rt_str__eq
      out := buf.concat(scrutinee_instrs)
      case ctx.registry.string_pool[s] {
        .Some(entry) => {
          out.append(.Call(entry.getter_sym)).append(.Call("rt_str__eq"))
        },
        .None => error("emit_pattern_condition: string not in pool"),
      }
    },
    .Variant(tid, vid, fields) => {
      if !can_match_variant_pattern(scrutinee_mono, ctx.env) {
        buf.append(.I32Const(0))
      } else {
        emit_variant_pattern_condition(tid, vid, fields, scrutinee_instrs, scrutinee_mono, ctx, buf)
      }
    },
  }
}

fn emit_variant_pattern_condition(
  tid: TypeId, vid: VariantId, fields: Vector<PreparedPattern>,
  scrutinee_instrs: Vector<Instr>, scrutinee_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>,
) Vector<Instr> {
  sum_layout := get_sum_layout(scrutinee_mono, ctx.env)

  // Tag check — build as a separate small vector, then prepend to buf
  tag_check := scrutinee_instrs
    .append(.StructGet(sum_layout.sym, 0))
    .append(.I32Const(vid.id))
    .append(.I32Eq)

  // Check for non-trivial sub-patterns
  has_inner := false
  for fp in fields {
    if !pattern_is_trivial(fp) { has_inner = true }
  }
  if !has_inner { return buf.concat(tag_check) }

  // Short-circuit inner checks
  variant_layout := find_variant_layout(sum_layout, vid)
  inner_checks: Vector<Vector<Instr>> = []
  for fp,i in fields {
    if !pattern_is_trivial(fp) {
      offset := variant_layout.struct_field_offset + i
      field_instrs := scrutinee_instrs
      field_instrs = field_instrs.append(.StructGet(sum_layout.sym, offset))
      field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
      case field_mono {
        .Void => {
          case fp {
            .Variant(_, nested_vid, _) => {
              fid_text := case ctx.current_func_id {
                .Some(fid) => fid.id.to_string(),
                .None => "?",
              }
              error("emit_variant_pattern_condition: nested variant pattern on void field in FuncId(${fid_text}), scrutinee=${mono_to_key(scrutinee_mono)}, variant=${vid.id}, field=${i}, nested_variant=${nested_vid.id}")
            },
            _ => {},
          }
        },
        _ => {},
      }
      inner_checks = inner_checks.append(
        // Each inner check is used as a sub-body — pass [] as buf
        emit_pattern_condition(fp, field_instrs, field_mono, ctx, [])
      )
    }
  }

  inner_cond := combine_and_checks(inner_checks)

  buf.concat(tag_check).append(.If(.Some(.I32), inner_cond, [.I32Const(0)]))
}

fn emit_pattern_bindings(pattern: PreparedPattern, scrutinee_instrs: Vector<Instr>, scrutinee_mono: MonoType, ctx: EmitCtx) Vector<Instr> {
  case pattern {
    .Wildcard => [],
    .LitInt(_) => [],
    .LitBool(_) => [],
    .LitStr(_) => [],
    .Var(sid) => {
      entry := lookup_slot(ctx, sid)
      out := scrutinee_instrs
      out.append(.LocalSet(entry.index))
    },
    .Variant(tid, vid, fields) => {
      if !can_match_variant_pattern(scrutinee_mono, ctx.env) {
        []
      } else {
        sum_layout := get_sum_layout(scrutinee_mono, ctx.env)
        variant_layout := find_variant_layout(sum_layout, vid)
        out: Vector<Instr> = []
        for fp,i in fields {
          offset := variant_layout.struct_field_offset + i
          field_instrs := scrutinee_instrs
          field_instrs = field_instrs.append(.StructGet(sum_layout.sym, offset))
          field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
          out = out.concat(emit_pattern_bindings(fp, field_instrs, field_mono, ctx))
        }
        out
      }
    },
  }
}

// ── Closure emission ───────────────────────────────────────────────────

fn emit_make_closure(fid: FuncId, free_vars: Vector<SlotId>, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Build env array from captured variables.
  // Keep the env instructions separate so closure materialization stays
  // centralized in one place.
  env_buf: Vector<Instr> = []
  for fv in free_vars {
    entry := lookup_slot(ctx, fv)
    env_buf = env_buf.append(.LocalGet(entry.index))
    env_buf = emit_box_to_anyref(entry.mono, ctx.env, env_buf)
  }
  if free_vars.len() > 0 {
    env_buf = env_buf.append(.ArrayNewFixed("rt_types__ClosureEnv", free_vars.len()))
  } else {
    env_buf = env_buf.append(.RefNull(.None_))
  }

  if ctx.prepared_funcs.has(fid.id) {
    return emit_materialized_closure(fid, env_buf, ctx, buf)
  }

  case callable_targets.callable_target(fid, ctx.prepared_funcs, ctx.builtins, ctx.env) {
    .Some(info) => {
      if !info.closure_materializable {
        error("emit_make_closure: builtin ${fid.id} is not closure-materializable")
      }
      emit_materialized_closure(fid, env_buf, ctx, buf)
    },
    .None => error("emit_make_closure: unknown callable target F${fid.id}"),
  }
}

fn emit_materialized_closure(
  fid: FuncId,
  env_buf: Vector<Instr>,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  tramp_sym := "$tramp_${fid.id}"
  emit_universal_closure_value(tramp_sym, env_buf, buf)
}

fn emit_universal_closure_value(tramp_sym: String, env_buf: Vector<Instr>, buf: Vector<Instr>) Vector<Instr> {
  buf.append(.RefFunc(tramp_sym))
    .concat(env_buf)
    .append(.StructNew("rt_types__Closure"))
}

fn emit_closure_call(callee: PreparedAtom, lid: SlotId, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  entry := lookup_slot(ctx, lid)
  emit_universal_closure_call(entry, args, result_idx, result_mono, ctx, buf)
}

fn emit_universal_closure_call(entry: LocalEntry, args: Vector<PreparedAtom>, result_idx: Int, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Get env (field 1)
  out := buf.append(.LocalGet(entry.index))
    .append(.RefCast(true, .Named("rt_types__Closure")))
    .append(.StructGet("rt_types__Closure", 1))
  // Pack args into anyref array
  out = if args.len() > 0 {
    for a in args {
      out = emit_atom(a, ctx, out)
      out = emit_box_to_anyref(atom_mono(a, ctx), ctx.env, out)
    }
    out.append(.ArrayNewFixed("rt_types__Array", args.len()))
  } else {
    out.append(.RefNull(.None_))
  }
  // Get universal funcref (field 0)
  out = out.append(.LocalGet(entry.index))
    .append(.RefCast(true, .Named("rt_types__Closure")))
    .append(.StructGet("rt_types__Closure", 0))
  // call_ref with universal func type
  out = out.append(.CallRef("rt_types__ClosureFunc"))
  // Unbox result
  case result_mono {
    .Void => {
      out.concat([.Drop, .I32Const(0), .RefI31, .LocalSet(result_idx)])
    },
    .Never => out,
    _ => {
      out = if is_sum_mono(result_mono, ctx.env) {
        out.append(.RefCast(true, .Named("rt_types__Variant")))
          .append(.Call(variant_to_sum_helper_sym(result_mono)))
      } else {
        emit_unbox_from_anyref(result_mono, ctx.env, out)
      }
      out.append(.LocalSet(result_idx))
    },
  }
}

// ── Trampoline emission ────────────────────────────────────────────────

fn emit_trampolines_for_func(func: PreparedFunc, ctx: EmitCtx) Vector<FuncDef> {
  // Only generate trampolines for functions that are used as closures.
  case ctx.registry.concrete_func_sigs[func.func_id.id] {
    .Some(sig) => [emit_universal_trampoline(func, sig, ctx)],
    .None => {
      if func.captures.len() > 0 {
        sig := FuncSigEntry.{
          param_types: collect sid in func.params { slot_info(func, sid).mono },
          return_type: func.return_mono,
        }
        [emit_universal_trampoline(func, sig, ctx)]
      } else {
        []
      }
    },
  }
}

fn emit_builtin_trampolines(ctx: EmitCtx) Vector<FuncDef> {
  out: Vector<FuncDef> = []
  for fid in ctx.registry.concrete_func_sigs.keys() {
    if ctx.prepared_funcs.has(fid) { continue }
    func_id := FuncId.{ id: fid }
    target := case callable_targets.callable_target(func_id, ctx.prepared_funcs, ctx.builtins, ctx.env) {
      .Some(info) => info,
      .None => { continue },
    }
    if !target.closure_materializable { continue }
    entry := case bi.entry(ctx.builtins, func_id) {
      .Some(e) => e,
      .None => { continue },
    }
    sig := case ctx.registry.concrete_func_sigs[fid] {
      .Some(s) => s,
      .None => { continue },
    }
    out = out.append(emit_builtin_universal_trampoline(entry, sig, target.wrapper_kind, ctx))
  }
  out
}


fn builtin_import_sym(info: RuntimeInfo) String {
  "${info.wasm_module}__${info.wasm_name}"
}

fn emit_builtin_universal_trampoline(entry: BuiltinEntry, sig: FuncSigEntry, wrapper_kind: callable_targets.WrapperKind?, ctx: EmitCtx) FuncDef {
  case wrapper_kind {
    .Some(.CellUpdate) => emit_builtin_cell_update_universal_trampoline(entry, sig, ctx),
    .Some(.IteratorUnfold) => emit_builtin_iterator_unfold_universal_trampoline(entry, sig, ctx),
    .Some(.HostWriteBytes) => emit_builtin_host_write_bytes_universal_trampoline(entry, sig, ctx),
    _ => {
      tramp_sym := "$tramp_${entry.func_id.id}"
      body: Vector<Instr> = []
      for mono,i in sig.param_types {
        body = body.append(.LocalGet(1))
          .append(.RefCast(true, .Named("rt_types__Array")))
          .append(.I32Const(i))
          .append(.ArrayGet("rt_types__Array"))
        body = emit_unbox_from_anyref(mono, ctx.env, body)
      }
      body = emit_builtin_trampoline_target(entry, wrapper_kind, body)
      case sig.return_type {
        .Void => {
          body = body.append(.I32Const(0)).append(.RefI31)
        },
        .Never => {},
        _ => {
          if is_sum_mono(sig.return_type, ctx.env) {
            body = body.append(.Call(sum_to_variant_helper_sym(sig.return_type)))
          } else {
            body = emit_box_to_anyref(sig.return_type, ctx.env, body)
          }
        },
      }
      FuncDef.{ name: tramp_sym, params: [.Anyref, .Anyref], results: [.Anyref], locals: [], body: body }
    },
  }
}

fn emit_builtin_cell_update_universal_trampoline(entry: BuiltinEntry, sig: FuncSigEntry, ctx: EmitCtx) FuncDef {
  tramp_sym := "$tramp_${entry.func_id.id}"
  cell_mono := sig.param_types[0]
  closure_mono := sig.param_types[1]
  inner_mono := cell_inner_mono(cell_mono)
  sym := cell_struct_sym(inner_mono, ctx.env)
  cell_vt := val_type_of_mono(cell_mono, ctx.env)
  closure_vt := val_type_of_mono(closure_mono, ctx.env)
  body: Vector<Instr> = []

  body = body.append(.LocalGet(1))
    .append(.RefCast(true, .Named("rt_types__Array")))
    .append(.I32Const(0))
    .append(.ArrayGet("rt_types__Array"))
  body = emit_unbox_from_anyref(cell_mono, ctx.env, body)
  body = body.append(.LocalSet(2))

  body = body.append(.LocalGet(1))
    .append(.RefCast(true, .Named("rt_types__Array")))
    .append(.I32Const(1))
    .append(.ArrayGet("rt_types__Array"))
  body = emit_unbox_from_anyref(closure_mono, ctx.env, body)
  body = body.append(.LocalSet(3))

  body = body.append(.LocalGet(2))
  body = body.append(.LocalGet(3)).append(.StructGet("rt_types__Closure", 1))
  body = body.append(.LocalGet(2)).append(.StructGet(sym, 0))
  body = if sym != "$Cell_anyref" { emit_box_to_anyref(inner_mono, ctx.env, body) } else { body }
  body = body.append(.ArrayNewFixed("rt_types__Array", 1))
  body = body.append(.LocalGet(3)).append(.StructGet("rt_types__Closure", 0)).append(.CallRef("rt_types__ClosureFunc"))
  body = if sym != "$Cell_anyref" { emit_unbox_from_anyref(inner_mono, ctx.env, body) } else { body }
  body = body.append(.StructSet(sym, 0))
  body = body.append(.I32Const(0)).append(.RefI31)

  FuncDef.{
    name: tramp_sym,
    params: [.Anyref, .Anyref],
    results: [.Anyref],
    locals: [cell_vt, closure_vt],
    body: body,
  }
}

fn emit_builtin_iterator_unfold_universal_trampoline(entry: BuiltinEntry, sig: FuncSigEntry, ctx: EmitCtx) FuncDef {
  tramp_sym := "$tramp_${entry.func_id.id}"
  seed_mono := sig.param_types[0]
  step_mono := sig.param_types[1]
  body: Vector<Instr> = []

  body = body.append(.LocalGet(1))
    .append(.RefCast(true, .Named("rt_types__Array")))
    .append(.I32Const(0))
    .append(.ArrayGet("rt_types__Array"))
  body = emit_unbox_from_anyref(seed_mono, ctx.env, body)
  body = emit_box_to_anyref(seed_mono, ctx.env, body)

  body = body.append(.LocalGet(1))
    .append(.RefCast(true, .Named("rt_types__Array")))
    .append(.I32Const(1))
    .append(.ArrayGet("rt_types__Array"))
  body = emit_unbox_from_anyref(step_mono, ctx.env, body)
    .append(.StructNew("rt_types__IterState"))

  FuncDef.{ name: tramp_sym, params: [.Anyref, .Anyref], results: [.Anyref], locals: [], body: body }
}

fn emit_builtin_host_write_bytes_universal_trampoline(entry: BuiltinEntry, sig: FuncSigEntry, ctx: EmitCtx) FuncDef {
  tramp_sym := "$tramp_${entry.func_id.id}"
  path_mono := sig.param_types[0]
  bytes_mono := sig.param_types[1]
  body: Vector<Instr> = []

  body = body.append(.LocalGet(1))
    .append(.RefCast(true, .Named("rt_types__Array")))
    .append(.I32Const(0))
    .append(.ArrayGet("rt_types__Array"))
  body = emit_unbox_from_anyref(path_mono, ctx.env, body)

  body = body.append(.LocalGet(1))
    .append(.RefCast(true, .Named("rt_types__Array")))
    .append(.I32Const(1))
    .append(.ArrayGet("rt_types__Array"))
  body = emit_unbox_from_anyref(bytes_mono, ctx.env, body)
    .append(.Call("rt_arr__to_array"))

  body = emit_builtin_trampoline_target(entry, .Some(.HostWriteBytes), body)
  body = body.append(.I32Const(0)).append(.RefI31)

  FuncDef.{ name: tramp_sym, params: [.Anyref, .Anyref], results: [.Anyref], locals: [], body: body }
}

fn emit_builtin_trampoline_target(entry: BuiltinEntry, wrapper_kind: callable_targets.WrapperKind?, body: Vector<Instr>) Vector<Instr> {
  case entry.kind {
    .Runtime(info) => body.append(.Call(builtin_import_sym(info))),
    .Intrinsic => case wrapper_kind {
      .Some(.ByteToString) => body.append(.I64ExtendI32U).append(.Call("rt_str__from_i64")),
      _ => case entry.name {
        "string_to_string" => body,
        _ => error("emit_builtin_trampoline_target: unsupported builtin trampoline target ${entry.name}"),
      },
    },
  }
}

fn emit_universal_trampoline(func: PreparedFunc, sig: FuncSigEntry, ctx: EmitCtx) FuncDef {
  // Universal trampoline: (env: anyref, args: anyref) → anyref
  tramp_sym := "$tramp_${func.func_id.id}"
  func_sym := lookup_func_sym(ctx.func_sym_map, func.func_id)

  body: Vector<Instr> = []
  locals: Vector<ValType> = []

  // Extract captures from env (param 0)
  for sid,i in func.captures {
    cap := slot_info(func, sid)
    body = body.append(.LocalGet(0))
    body = body.append(.RefCast(true, .Named("rt_types__ClosureEnv")))
    body = body.append(.I32Const(i))
    body = body.append(.ArrayGet("rt_types__ClosureEnv"))
    body = emit_unbox_from_anyref(cap.mono, ctx.env, body)
  }

  // Extract args from args array (param 1)
  for sid,i in func.params {
    p := slot_info(func, sid)
    body = body.append(.LocalGet(1))
    body = body.append(.RefCast(true, .Named("rt_types__Array")))
    body = body.append(.I32Const(i))
    body = body.append(.ArrayGet("rt_types__Array"))
    body = emit_unbox_from_anyref(p.mono, ctx.env, body)
  }

  body = body.append(.Call(func_sym))

  case func.return_mono {
    .Void => {
      body = body.append(.I32Const(0))
      body = body.append(.RefI31)
    },
    .Never => {},
    _ => {
      if is_sum_mono(func.return_mono, ctx.env) {
        body = body.append(.Call(sum_to_variant_helper_sym(func.return_mono)))
      } else {
        body = emit_box_to_anyref(func.return_mono, ctx.env, body)
      }
    },
  }

  FuncDef.{
    name: tramp_sym,
    params: [.Anyref, .Anyref],
    results: [.Anyref],
    locals: locals,
    body: body,
  }
}

// ── Boxing / unboxing (AWrapAnyref / AUnwrapAnyref) ────────────────────

fn emit_wrap_anyref(atom: PreparedAtom, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf = emit_atom(atom, ctx, buf)
  emit_box_to_anyref(mono, ctx.env, buf)
}

fn emit_unwrap_anyref(atom: PreparedAtom, mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  buf = emit_atom(atom, ctx, buf)
  emit_unbox_from_anyref(mono, ctx.env, buf)
}

fn emit_box_to_anyref(mono: MonoType, env: ResolvedEnv, buf: Vector<Instr>) Vector<Instr> {
  case mono {
    .Never => { return buf },
    .Void => { return buf },  // void is already i31ref → anyref
    _ => {},
  }
  layout := layout_of(mono, env)
  case layout {
    .Scalar(.WI64) => buf.append(.StructNew("rt_types__BoxedInt")),
    .Scalar(.WF64) => buf.append(.StructNew("rt_types__BoxedFloat")),
    .Scalar(.WI32) => buf.append(.RefI31),
    .Scalar(.WAnyref) => buf,  // already anyref
    // Reference types: struct refs are subtypes of anyref (implicit upcast)
    .Record(_) => buf,
    .Sum(_) => buf,
    .Closure(_) => buf,
    .Vector_(_) => buf,
    .Dict_(_, _) => buf,
    .Iterator_(_) => buf,
    .Cell_(_) => buf,
  }
}

fn emit_unbox_from_anyref(mono: MonoType, env: ResolvedEnv, buf: Vector<Instr>) Vector<Instr> {
  case mono {
    .Never => { return buf.append(.Unreachable) },
    .Void => { return buf.append(.Drop).append(.I32Const(0)).append(.RefI31) },
    .String => { return buf.append(.RefCast(true, .Named("rt_types__String"))) },
    _ => {},
  }
  layout := layout_of(mono, env)
  case layout {
    .Scalar(.WI64) => buf.append(.RefCast(false, .Named("rt_types__BoxedInt"))).append(.StructGet("rt_types__BoxedInt", 0)),
    .Scalar(.WF64) => buf.append(.RefCast(false, .Named("rt_types__BoxedFloat"))).append(.StructGet("rt_types__BoxedFloat", 0)),
    .Scalar(.WI32) => {
      // Could be Bool or Byte — both use i31ref
      out := buf.append(.RefCast(false, .I31))
      // Use I31GetU for unsigned (Byte uses unsigned)
      case mono {
        .Byte => out.append(.I31GetU),
        _ => out.append(.I31GetS),
      }
    },
    .Scalar(.WAnyref) => buf,  // already anyref
    .Record(r) => buf.append(.RefCast(false, .Named(r.sym))),
    .Sum(s) => buf.append(.RefCast(false, .Named(s.sym))),
    .Closure(_) => buf.append(.RefCast(false, .Named("rt_types__Closure"))),
    .Vector_(_) => buf.append(.RefCast(false, .Named("rt_types__PVec"))),
    .Dict_(_, _) => buf.append(.RefCast(false, .Named("rt_types__PDict"))),
    .Iterator_(it) => buf.append(.RefCast(false, .Named(it.state_sym))),
    .Cell_(inner) => {
      key := case inner {
        .Scalar(.WI32) => "i32",
        .Scalar(.WI64) => "i64",
        .Scalar(.WF64) => "f64",
        _ => "anyref",
      }
      buf.append(.RefCast(false, .Named("$Cell_${key}")))
    },
  }
}

// ── String pool emission ───────────────────────────────────────────────

fn collect_iterator_next_helpers(funcs: Vector<PreparedFunc>, builtins: BuiltinRegistry) Vector<MonoType> {
  want_fid := bi.id(builtins, "iterator_next")
  seen: Dict<String, MonoType> = Dict.new()
  order: Vector<String> = []
  for func in funcs {
    result := collect_iterator_next_helpers_expr(func.body, func, want_fid)
    for mono in result {
      key := mono_to_key(mono)
      if !seen.has(key) {
        seen[key] = mono
        order = order.append(key)
      }
    }
  }
  collect key in order {
    case seen[key] {
      .Some(mono) => mono,
      .None => error("collect_iterator_next_helpers: missing mono for ${key}"),
    }
  }
}

fn collect_iterator_next_helpers_expr(expr: PreparedExpr, func: PreparedFunc, want_fid: FuncId) Vector<MonoType> {
  // Iterative Let-chain traversal avoids O(N) recursive calls for deep ANF bodies.
  out: Vector<MonoType> = []
  cur_expr := expr
  for true {
    case cur_expr {
      .Let(sid, op, body) => {
        from_op := collect_iterator_next_helpers_op(op, func, want_fid)
        for mono in from_op { out = out.append(mono) }
        case func.slots[sid.id] {
          .Some(info) => {
            case op {
              .ACall(.AGlobalFunc(fid), _) => {
                if fid.id == want_fid.id {
                  out = out.append(info.mono)
                }
              },
              _ => {},
            }
          },
          .None => {},
        }
        cur_expr = body
      },
      _ => { return out },
    }
  }
  out
}

fn collect_iterator_next_helpers_op(op: PreparedOp, func: PreparedFunc, want_fid: FuncId) Vector<MonoType> {
  case op {
    .AIf(_, then_e, else_e) => {
      out := collect_iterator_next_helpers_expr(then_e, func, want_fid)
      more := collect_iterator_next_helpers_expr(else_e, func, want_fid)
      for mono in more { out = out.append(mono) }
      out
    },
    .AMatch(_, arms) => {
      out: Vector<MonoType> = []
      for arm in arms {
        more := collect_iterator_next_helpers_expr(arm.body, func, want_fid)
        for mono in more { out = out.append(mono) }
      }
      out
    },
    .ALoop(body) => collect_iterator_next_helpers_expr(body, func, want_fid),
    .ADefer(body) => collect_iterator_next_helpers_expr(body, func, want_fid),
    _ => [],
  }
}

fn is_sum_mono(mono: MonoType, env: ResolvedEnv) Bool {
  case mono {
    .Never => false,
    _ => {
      case layout_of(mono, env) {
        .Sum(_) => true,
        _ => false,
      }
    },
  }
}

fn sum_to_variant_helper_sym(sum_mono: MonoType) String {
  "sum_to_variant_helper_${mono_to_key(sum_mono)}"
}

fn variant_to_sum_helper_sym(sum_mono: MonoType) String {
  "variant_to_sum_helper_${mono_to_key(sum_mono)}"
}

fn collect_sum_variant_helpers(funcs: Vector<PreparedFunc>, env: ResolvedEnv) Vector<MonoType> {
  seen: Dict<String, MonoType> = Dict.new()
  // Cache is_sum_mono results per mono_to_key to avoid repeated layout_of calls
  // (layout_of → find_type_entry does a linear scan of env.types per call).
  // Most functions share the same MonoTypes across slots, so this reduces
  // ~N_total_slots calls down to ~N_unique_types calls.
  is_sum: Dict<String, Bool> = Dict.new()
  order: Vector<String> = []
  for func in funcs {
    key := mono_to_key(func.return_mono)
    cached := case is_sum[key] {
      .Some(b) => b,
      .None => {
        b := is_sum_mono(func.return_mono, env)
        is_sum[key] = b
        b
      },
    }
    if cached and !seen.has(key) {
      seen[key] = func.return_mono
      order = order.append(key)
    }
    for sid in func.slots.keys() {
      case func.slots[sid] {
        .Some(info) => {
          k := mono_to_key(info.mono)
          cached2 := case is_sum[k] {
            .Some(b) => b,
            .None => {
              b := is_sum_mono(info.mono, env)
              is_sum[k] = b
              b
            },
          }
          if cached2 and !seen.has(k) {
            seen[k] = info.mono
            order = order.append(k)
          }
        },
        .None => {},
      }
    }
  }
  collect key in order {
    case seen[key] {
      .Some(mono) => mono,
      .None => error("collect_sum_variant_helpers: missing mono for ${key}"),
    }
  }
}

fn emit_sum_to_variant_helper(sum_mono: MonoType, env: ResolvedEnv) FuncDef {
  sum_layout := get_sum_layout(sum_mono, env)
  sum_ref := ValType.Ref(true, .Named(sum_layout.sym))
  variant_ref := ValType.Ref(true, .Named("rt_types__Variant"))

  else_body: Vector<Instr> = [.Unreachable]
  for variant in sum_layout.variants.reverse() {
    then_body: Vector<Instr> = [.I32Const(0), .I32Const(variant.variant_id.id)]
    for i in range(variant.payload_types.len()) {
      field_mono := variant_field_mono(sum_mono, variant.variant_id, i, env)
      then_body = then_body.concat([
        .LocalGet(0),
        .StructGet(sum_layout.sym, variant.struct_field_offset + i),
      ])
      then_body = emit_box_to_anyref(field_mono, env, then_body)
    }
    then_body = then_body.append(.ArrayNewFixed("rt_types__Array", variant.payload_types.len()))
    then_body = then_body.append(.StructNew("rt_types__Variant"))

    else_body = [
      .LocalGet(1),
      .I32Const(variant.variant_id.id),
      .I32Eq,
      .If(.Some(variant_ref), then_body, else_body),
    ]
  }

  body: Vector<Instr> = [
    .LocalGet(0),
    .StructGet(sum_layout.sym, 0),
    .LocalSet(1),
  ]
  body = body.concat(else_body)

  FuncDef.{
    name: sum_to_variant_helper_sym(sum_mono),
    params: [sum_ref],
    results: [variant_ref],
    locals: [.I32],
    body: body,
  }
}

fn emit_variant_to_sum_helper(sum_mono: MonoType, env: ResolvedEnv) FuncDef {
  sum_layout := get_sum_layout(sum_mono, env)
  sum_ref := ValType.Ref(true, .Named(sum_layout.sym))

  else_body: Vector<Instr> = [.Unreachable]
  for variant in sum_layout.variants.reverse() {
    then_body: Vector<Instr> = [.I32Const(variant.variant_id.id)]
    for sum_variant in sum_layout.variants {
      if sum_variant.variant_id.id == variant.variant_id.id {
        for i in range(sum_variant.payload_types.len()) {
          field_mono := variant_field_mono(sum_mono, sum_variant.variant_id, i, env)
          then_body = then_body.concat([
            .LocalGet(2),
            .I32Const(i),
            .ArrayGet("rt_types__Array"),
          ])
          then_body = emit_erased_container_egress(field_mono, env, then_body)
        }
      } else {
        for pt in sum_variant.payload_types {
          then_body = emit_default_value(pt, then_body)
        }
      }
    }
    then_body = then_body.append(.StructNew(sum_layout.sym))

    else_body = [
      .LocalGet(1),
      .I32Const(variant.variant_id.id),
      .I32Eq,
      .If(.Some(sum_ref), then_body, else_body),
    ]
  }

  body: Vector<Instr> = [
    .LocalGet(0),
    .StructGet("rt_types__Variant", 1),
    .LocalSet(1),
    .LocalGet(0),
    .StructGet("rt_types__Variant", 2),
    .RefCast(true, .Named("rt_types__Array")),
    .LocalSet(2),
  ]
  body = body.concat(else_body)

  FuncDef.{
    name: variant_to_sum_helper_sym(sum_mono),
    params: [ValType.Ref(true, .Named("rt_types__Variant"))],
    results: [sum_ref],
    locals: [.I32, ValType.Ref(true, .Named("rt_types__Array"))],
    body: body,
  }
}

fn option_from_variant_helper_sym(inner_mono: MonoType) String {
  "option_from_variant_helper_${mono_to_key(inner_mono)}"
}

fn emit_option_from_variant_helper(inner_mono: MonoType, env: ResolvedEnv) FuncDef {
  result_mono := MonoType.Optional(inner_mono)
  result_layout := get_sum_layout(result_mono, env)
  payload_vt := val_type_of_mono(inner_mono, env)

  none_body: Vector<Instr> = [.I32Const(0)]
  some_variant := result_layout.variants[1]
  if some_variant.payload_types.len() > 0 {
    none_body = emit_default_value(some_variant.payload_types[0], none_body)
  }
  none_body = none_body.append(.StructNew(result_layout.sym))

  some_body: Vector<Instr> = [
    .I32Const(1),
    .LocalGet(0),
    .StructGet("rt_types__Variant", 2),
    .RefCast(true, .Named("rt_types__Array")),
    .I32Const(0),
    .ArrayGet("rt_types__Array"),
  ]
  some_body = emit_erased_container_egress(inner_mono, env, some_body)
  some_body = some_body.append(.StructNew(result_layout.sym))

  FuncDef.{
    name: option_from_variant_helper_sym(inner_mono),
    params: [ValType.Ref(true, .Named("rt_types__Variant"))],
    results: [ValType.Ref(true, .Named(result_layout.sym))],
    locals: [],
    body: [
      .LocalGet(0),
      .StructGet("rt_types__Variant", 1),
      .I32Eqz,
      .If(.Some(ValType.Ref(true, .Named(result_layout.sym))), none_body, some_body),
    ],
  }
}

fn emit_host_read_file_result_helper(env: ResolvedEnv) FuncDef {
  result_mono := MonoType.Result(MonoType.Vector(MonoType.Byte), MonoType.String)
  result_layout := get_sum_layout(result_mono, env)
  pvec_ref := ValType.Ref(true, .Named("rt_types__PVec"))
  str_ref := ValType.Ref(true, .Named("rt_types__String"))
  variant_ref := ValType.Ref(true, .Named("rt_types__Variant"))

  ok_body: Vector<Instr> = [
    .I32Const(0),
    .LocalGet(0),
    .StructGet("rt_types__Variant", 2),
    .RefCast(true, .Named("rt_types__Array")),
    .I32Const(0),
    .ArrayGet("rt_types__Array"),
    .RefCast(true, .Named("rt_types__PVec")),
    .RefNull(.Named("rt_types__String")),
    .StructNew(result_layout.sym),
  ]

  err_body: Vector<Instr> = [
    .I32Const(1),
    .RefNull(.Named("rt_types__PVec")),
    .LocalGet(0),
    .StructGet("rt_types__Variant", 2),
    .RefCast(true, .Named("rt_types__Array")),
    .I32Const(0),
    .ArrayGet("rt_types__Array"),
    .RefCast(true, .Named("rt_types__String")),
    .StructNew(result_layout.sym),
  ]

  FuncDef.{
    name: host_read_file_result_helper_sym(),
    params: [variant_ref],
    results: [ValType.Ref(true, .Named(result_layout.sym))],
    locals: [],
    body: [
      .LocalGet(0),
      .RefCast(true, .Named("rt_types__Variant")),
      .StructGet("rt_types__Variant", 1),
      .I32Eqz,
      .If(.Some(ValType.Ref(true, .Named(result_layout.sym))), ok_body, err_body),
    ],
  }
}

fn emit_iterator_next_helper(result_mono: MonoType, env: ResolvedEnv) FuncDef {
  iter_item_mono := case result_mono {
    .Optional(inner) => inner,
    _ => error("emit_iterator_next_helper: expected Option<IterItem>, got ${mono_to_key(result_mono)}"),
  }
  option_layout := case layout_of(result_mono, env) {
    .Sum(s) => s,
    _ => error("emit_iterator_next_helper: expected Option sum layout"),
  }
  option_sym := option_layout.sym
  iter_item_layout := case layout_of(iter_item_mono, env) {
    .Record(r) => r,
    _ => error("emit_iterator_next_helper: expected IterItem record layout"),
  }
  value_mono := case iter_item_mono {
    .Named(_, args) => if args.len() > 0 { args[0] } else { .Void },
    _ => .Void,
  }
  some_payload_vt := if option_layout.variants.len() > 1 and option_layout.variants[1].payload_types.len() > 0 {
    option_layout.variants[1].payload_types[0]
  } else {
    .Anyref
  }

  none_body: Vector<Instr> = [.I32Const(0)]
  none_body = emit_default_value(some_payload_vt, none_body)
  none_body = none_body.append(.StructNew(option_sym))

  some_body: Vector<Instr> = [
    .LocalGet(1),
    .StructGet("rt_types__Variant", 2),
    .RefCast(true, .Named("rt_types__Array")),
    .LocalSet(3),
    .I32Const(1),
    .LocalGet(3),
    .I32Const(0),
    .ArrayGet("rt_types__Array"),
  ]
  some_body = emit_erased_container_egress(value_mono, env, some_body)
  some_body = some_body.concat([
    .LocalGet(3),
    .I32Const(1),
    .ArrayGet("rt_types__Array"),
    .LocalGet(4),
    .StructGet("rt_types__IterState", 1),
    .StructNew("rt_types__IterState"),
    .StructNew(iter_item_layout.sym),
    .StructNew(option_sym),
  ])

  FuncDef.{
    name: iterator_next_helper_sym(result_mono),
    params: [.Ref(true, .Named("rt_types__IterState"))],
    results: [.Ref(true, .Named(option_sym))],
    locals: [
      .Ref(true, .Named("rt_types__Variant")),
      .I32,
      .Ref(true, .Named("rt_types__Array")),
      .Ref(true, .Named("rt_types__IterState")),
    ],
    body: [
      .LocalGet(0),
      .RefCast(true, .Named("rt_types__IterState")),
      .LocalSet(4),
      .LocalGet(4),
      .StructGet("rt_types__IterState", 1),
      .RefCast(false, .Named("rt_types__Closure")),
      .StructGet("rt_types__Closure", 1),
      .LocalGet(4),
      .StructGet("rt_types__IterState", 0),
      .ArrayNewFixed("rt_types__Array", 1),
      .LocalGet(4),
      .StructGet("rt_types__IterState", 1),
      .RefCast(false, .Named("rt_types__Closure")),
      .StructGet("rt_types__Closure", 0),
      .CallRef("rt_types__ClosureFunc"),
      .RefCast(false, .Named("rt_types__Variant")),
      .LocalSet(1),
      .LocalGet(1),
      .StructGet("rt_types__Variant", 1),
      .LocalSet(2),
      .LocalGet(2),
      .I32Eqz,
      .If(.Some(.Ref(true, .Named(option_sym))), none_body, some_body),
    ],
  }
}

fn emit_string_pool_globals(reg: WasmTypeRegistry) Vector<GlobalDef> {
  globals: Vector<GlobalDef> = []
  for k in reg.string_pool_order {
    case reg.string_pool[k] {
      .Some(entry) => {
        globals = globals.append(GlobalDef.{
          name: entry.global_sym,
          mutable: true,
          ty: .Ref(true, .Named("rt_types__String")),
          init: [.RefNull(.Named("rt_types__String"))],
        })
      },
      .None => {},
    }
  }
  globals
}

fn emit_string_pool_getters(reg: WasmTypeRegistry) Vector<FuncDef> {
  funcs: Vector<FuncDef> = []
  for k in reg.string_pool_order {
    case reg.string_pool[k] {
      .Some(entry) => {
        // Getter: check global, if null → create from data segment, cache.
        // Build the instruction vectors directly as literals here. Repeated
        // append() construction of these Instr vectors currently miscompiles in
        // the boot compiler and can produce empty function bodies.
        then_body: Vector<Instr> = [
          .I32Const(entry.byte_offset),
          .I32Const(entry.byte_len),
          .ArrayNewData("rt_types__String", entry.data_segment_name),
          .GlobalSet(entry.global_sym),
        ]
        body: Vector<Instr> = [
          .GlobalGet(entry.global_sym),
          .RefIsNull,
          .If(.None, then_body, []),
          .GlobalGet(entry.global_sym),
          .RefAsNonNull,
        ]

        funcs = funcs.append(FuncDef.{
          name: entry.getter_sym,
          params: [],
          results: [.Ref(false, .Named("rt_types__String"))],
          locals: [],
          body: body,
        })
      },
      .None => {},
    }
  }
  funcs
}

fn emit_string_data_segment(reg: WasmTypeRegistry) DataSegment? {
  if reg.string_pool_order.len() == 0 { return .None }

  // Collect all string bytes in insertion order
  all_bytes: Vector<Byte> = []
  for k in reg.string_pool_order {
    for b in k { all_bytes = all_bytes.append(b) }
  }

  .Some(DataSegment.{
    name: "$data_strings",
    offset: [],  // passive data segment (no offset)
    bytes: all_bytes,
  })
}

// ── Module globals emission ────────────────────────────────────────────

fn emit_module_globals(reg: WasmTypeRegistry, anf: AnfModule, env: ResolvedEnv) Vector<GlobalDef> {
  globals: Vector<GlobalDef> = []
  for k in reg.module_globals_order {
    case reg.module_globals[k] {
      .Some(gentry) => {
        vt := val_type_of_mono(gentry.mono, env)
        globals = globals.append(GlobalDef.{
          name: gentry.sym,
          mutable: true,
          ty: vt,
          init: emit_default_value(vt, []),
        })
      },
      .None => {},
    }
  }
  globals
}

// ── Checked i32 narrowing ──────────────────────────────────────────────

fn emit_checked_i32_narrow(atom: PreparedAtom, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  // Safe i64→i32: trap if < 0 or > i32::MAX (2147483647).
  // Emits the atom three times: twice for the range check, once for the wrap.
  // Atoms are cheap (local.get / const), so re-emission is fine.
  buf = emit_atom(atom, ctx, buf)
  buf = buf.concat([.I64Const(0), .I64GeS])  // value >= 0
  buf = emit_atom(atom, ctx, buf)
  buf = buf.concat([.I64Const(2147483647), .I64LeS])  // value <= i32::MAX
  buf = buf.concat([.I32And, .I32Eqz, .If(.None, [.Unreachable], [])])
  buf = emit_atom(atom, ctx, buf)
  buf.append(.I32WrapI64)
}

// ── Default values ─────────────────────────────────────────────────────

fn emit_default_value(vt: ValType, buf: Vector<Instr>) Vector<Instr> {
  case vt {
    .I32 => buf.append(.I32Const(0)),
    .I64 => buf.append(.I64Const(0)),
    .F64 => buf.append(.F64Const(0.0)),
    .Anyref => buf.append(.RefNull(.None_)),
    .I31ref => buf.append(.I32Const(0)).append(.RefI31),
    .Funcref => buf.append(.RefNull(.Func)),
    .Ref(nullable, heap) => {
      if nullable { buf.append(.RefNull(heap)) }
      else {
        // Non-nullable ref: can't produce a default. Use ref.null + cast
        // (This will trap at runtime if actually used — only valid for dead code paths)
        buf.append(.RefNull(heap)).append(.RefAsNonNull)
      }
    },
    .I8 => buf.append(.I32Const(0)),
  }
}

// ── Helper utilities ───────────────────────────────────────────────────

fn slot_info(func: PreparedFunc, sid: SlotId) SlotInfo {
  case func.slots[sid.id] {
    .Some(info) => info,
    .None => error("emit: missing SlotInfo for S${sid.id} in F${func.func_id.id}"),
  }
}

fn lookup_slot(ctx: EmitCtx, sid: SlotId) LocalEntry {
  case ctx.local_map[sid.id] {
    .Some(entry) => entry,
    .None => error("lookup_slot: unknown SlotId S${sid.id}"),
  }
}

fn repr_name(repr: ReprKind) String {
  case repr {
    .I64 => "I64",
    .F64 => "F64",
    .I32 => "I32",
    .TypedRef(_) => "TypedRef",
    .TypedSum(_) => "TypedSum",
    .ClosureRef => "ClosureRef",
    .ErasedSum => "ErasedSum",
    .OpaqueAnyref => "OpaqueAnyref",
    .DeadValue => "DeadValue",
  }
}

fn expr_always_diverges(expr: PreparedExpr) Bool {
  case expr {
    .Return(_) => true,
    .Break(_) => true,
    .Continue => true,
    .Atom(_) => false,
    .Let(_, _, body) => expr_always_diverges(body),
  }
}

fn all_arms_diverge(arms: Vector<PreparedMatchArm>) Bool {
  if arms.len() == 0 { return true }
  for arm in arms {
    if !expr_always_diverges(arm.body) { return false }
  }
  true
}

fn pattern_is_trivial(p: PreparedPattern) Bool {
  case p {
    .Wildcard => true,
    .Var(_) => true,
    _ => false,
  }
}

fn get_sum_layout(mono: MonoType, env: ResolvedEnv) WasmSumLayout {
  layout := layout_of(mono, env)
  case layout {
    .Sum(s) => s,
    _ => error("get_sum_layout: expected Sum, got other for ${mono_to_key(mono)}"),
  }
}

fn find_variant_layout(sum: WasmSumLayout, vid: VariantId) WasmVariantLayout {
  for v in sum.variants {
    if v.variant_id.id == vid.id { return v }
  }
  error("find_variant_layout: VariantId ${vid.id} not found in ${sum.sym}")
}

fn variant_field_mono(scrutinee_mono: MonoType, vid: VariantId, field_idx: Int, env: ResolvedEnv) MonoType {
  case scrutinee_mono {
    .Optional(inner) => {
      if vid.id == 1 and field_idx == 0 { return inner }
      .Void
    },
    .Result(ok, err) => {
      if vid.id == 0 and field_idx == 0 { return ok }
      if vid.id == 1 and field_idx == 0 { return err }
      .Void
    },
    .Named(tid, args) => {
      case env.lookup_type_def(tid) {
        .Some(.Alias(_, type_params, target)) => {
          variant_field_mono(subst_type_params(target, type_params, args), vid, field_idx, env)
        },
        _ => resolve_named_variant_field(tid, args, vid, field_idx, env),
      }
    },
    .Void => .Void,
    _ => error("variant_field_mono: unexpected scrutinee type ${mono_to_key(scrutinee_mono)} for variant ${vid.id} field ${field_idx}"),
  }
}

fn resolve_named_variant_field(tid: TypeId, args: Vector<MonoType>, vid: VariantId, field_idx: Int, env: ResolvedEnv) MonoType {
  def := case env.lookup_type_def(tid) {
    .Some(d) => d,
    .None => { return .Void },
  }
  case def {
    .Sum(_, type_params, variants) => {
      v := variants[vid.id]
      field_ty := v.fields[field_idx]
      subst_type_params(field_ty, type_params, args)
    },
    _ => .Void,
  }
}

fn subst_type_params(ty: MonoType, type_params: Vector<String>, args: Vector<MonoType>) MonoType {
  case ty {
    .Var(name) => {
      for p,i in type_params {
        if p == name { return args[i] }
      }
      ty
    },
    .Named(tid, inner_args) => {
      new_args := collect a in inner_args { subst_type_params(a, type_params, args) }
      .Named(tid, new_args)
    },
    .Vector(elem) => .Vector(subst_type_params(elem, type_params, args)),
    .Dict(k, v) => .Dict(subst_type_params(k, type_params, args), subst_type_params(v, type_params, args)),
    .Function(ps, r) => {
      new_ps := collect p in ps { subst_type_params(p, type_params, args) }
      .Function(new_ps, subst_type_params(r, type_params, args))
    },
    .Optional(inner) => .Optional(subst_type_params(inner, type_params, args)),
    .Result(ok, err) => .Result(subst_type_params(ok, type_params, args), subst_type_params(err, type_params, args)),
    _ => ty,
  }
}

fn combine_and_checks(checks: Vector<Vector<Instr>>) Vector<Instr> {
  if checks.len() == 0 { return [.I32Const(1)] }
  if checks.len() == 1 { return checks[0] }
  out := checks[0]
  idx := 1
  for idx < checks.len() {
    out = out.append(.If(.Some(.I32), checks[idx], [.I32Const(0)]))
    idx = idx + 1
  }
  out
}

