// ── Match emission ─────────────────────────────────────────────────────
fn emit_match_op(
  scrutinee: PreparedAtom,
  arms: Vector<PreparedMatchArm>,
  result_idx: Int,
  result_vt: ValType?,
  result_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  match_emit.emit_match_op(
    scrutinee,
    arms,
    result_idx,
    result_vt,
    result_mono,
    ctx,
    buf,
    match_emit.MatchEmitFns.{
      emit_atom,
      emit_expr,
      match_scrutinee_mono,
      emit_pattern_condition,
      emit_pattern_bindings,
    },
  )
}

fn can_match_variant_pattern(scrutinee_mono: MonoType, env: ResolvedEnv) Bool {
  case scrutinee_mono {
    .Optional(_) => true,
    .Result(_, _) => true,
    .Named(tid, args) => case env.lookup_type_def(tid) {
      .Some(.Sum(_, _, _)) => true,
      .Some(.Alias(_, type_params, target)) => can_match_variant_pattern(
        subst_type_params(target, type_params, args),
        env,
      ),
      _ => false,
    },
    _ => false,
  }
}

fn emit_pattern_condition(
  pattern: PreparedPattern,
  scrutinee_instrs: Vector<Instr>,
  scrutinee_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  case pattern {
    .Wildcard => buf.append(.I32Const(1)),
    .Var(_) => buf.append(.I32Const(1)),
    .LitInt(n) => if scrutinee_mono == .Byte {
      buf.concat(scrutinee_instrs).append(.I32Const(n)).append(.I32Eq)
    } else {
      buf.concat(scrutinee_instrs).append(.I64Const(n)).append(.I64Eq)
    },
    .LitBool(b) => buf
      .concat(scrutinee_instrs)
      .append(
        .I32Const(
          if b {
            1
          } else {
            0
          },
        ),
      )
      .append(.I32Eq),
    .LitStr(s) => {
      // String comparison via rt_str__eq
      out := buf.concat(scrutinee_instrs)

      case ctx.registry.string_pool[s] {
        .Some(entry) => out.append(.Call(entry.getter_sym)).append(.Call("rt_str__eq")),
        .None => error("emit_pattern_condition: string not in pool"),
      }
    },
    .Variant(tid, vid, fields) => if !can_match_variant_pattern(scrutinee_mono, ctx.env) {
      buf.append(.I32Const(0))
    } else {
      emit_variant_pattern_condition(tid, vid, fields, scrutinee_instrs, scrutinee_mono, ctx, buf)
    },
  }
}

fn emit_variant_pattern_condition(
  tid: TypeId,
  vid: VariantId,
  fields: Vector<PreparedPattern>,
  scrutinee_instrs: Vector<Instr>,
  scrutinee_mono: MonoType,
  ctx: EmitCtx,
  buf: Vector<Instr>,
) Vector<Instr> {
  // Option<ExternRef> → null check instead of tag check
  if variant_emit.is_nullable_extern_option(scrutinee_mono) {
    if vid.id == 0 {
      // None: ref.is_null
      return buf.concat(scrutinee_instrs).append(.RefIsNull)
    } else {
      // Some: not null
      tag_check := scrutinee_instrs.append(.RefIsNull).append(.I32Eqz)

      // Check for non-trivial sub-patterns on the Some payload
      has_inner := false

      for fp in fields {
        if !pattern_is_trivial(fp) {
          has_inner = true
        }
      }

      if !has_inner {
        return buf.concat(tag_check)
      }

      // Sub-pattern on the payload (the scrutinee itself, cast to non-null)
      inner_checks: Vector<Vector<Instr>> = []

      for fp, i in fields {
        if !pattern_is_trivial(fp) {
          field_instrs := scrutinee_instrs.append(.RefAsNonNull)
          field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
          inner_checks = .append(emit_pattern_condition(fp, field_instrs, field_mono, ctx, []))
        }
      }

      inner_cond := combine_and_checks(inner_checks)

      return buf.concat(tag_check).append(.If(.Some(.I32), inner_cond, [.I32Const(0)]))
    }
  }

  sum_layout := get_sum_layout_ctx(scrutinee_mono, ctx)

  // Tag check — build as a separate small vector, then prepend to buf
  tag_check := scrutinee_instrs
    .append(.StructGet(sum_layout.sym, 0))
    .append(.I32Const(vid.id))
    .append(.I32Eq)

  // Check for non-trivial sub-patterns
  has_inner := false

  for fp in fields {
    if !pattern_is_trivial(fp) {
      has_inner = true
    }
  }

  if !has_inner {
    return buf.concat(tag_check)
  }

  // Short-circuit inner checks
  variant_layout := find_variant_layout(sum_layout, vid)
  inner_checks: Vector<Vector<Instr>> = []

  for fp, i in fields {
    if !pattern_is_trivial(fp) {
      offset := variant_layout.struct_field_offset + i
      field_instrs := scrutinee_instrs
      field_instrs = .append(.StructGet(sum_layout.sym, offset))
      field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)

      case field_mono {
        .Void => case fp {
          .Variant(_, nested_vid, _) => {
            fid_text := case ctx.current_func_id {
              .Some(fid) => fid.id.to_string(),
              .None => "?",
            }
            error(
              "emit_variant_pattern_condition: nested variant pattern on void field in FuncId(${fid_text}), scrutinee=${mono_to_key(
                scrutinee_mono,
              )}, variant=${vid.id}, field=${i}, nested_variant=${nested_vid.id}",
            )
          },
          _ => {},
        },
        _ => {},
      }

      inner_checks = .append(emit_pattern_condition(fp, field_instrs, field_mono, ctx, []))
    }
  }

  inner_cond := combine_and_checks(inner_checks)
  buf.concat(tag_check).append(.If(.Some(.I32), inner_cond, [.I32Const(0)]))
}

fn emit_pattern_bindings(
  pattern: PreparedPattern,
  scrutinee_instrs: Vector<Instr>,
  scrutinee_mono: MonoType,
  ctx: EmitCtx,
) Vector<Instr> {
  case pattern {
    .Wildcard => [],
    .LitInt(_) => [],
    .LitBool(_) => [],
    .LitStr(_) => [],
    .Var(sid) => {
      entry := lookup_slot(ctx, sid)
      out := scrutinee_instrs
      out.append(.LocalSet(entry.index))
    },
    .Variant(tid, vid, fields) => if !can_match_variant_pattern(scrutinee_mono, ctx.env) {
      []
    } else if variant_emit.is_nullable_extern_option(scrutinee_mono) {
      // Option<ExternRef>: payload is the scrutinee itself (non-null for Some)
      if vid.id == 0 {
        // None — no bindings
        []
      } else {
        out: Vector<Instr> = []

        for fp, i in fields {
          // The Some payload is the scrutinee cast to non-null
          field_instrs := scrutinee_instrs.append(.RefAsNonNull)
          field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
          out = .concat(emit_pattern_bindings(fp, field_instrs, field_mono, ctx))
        }

        out
      }
    } else {
      sum_layout := get_sum_layout_ctx(scrutinee_mono, ctx)
      variant_layout := find_variant_layout(sum_layout, vid)
      out: Vector<Instr> = []

      for fp, i in fields {
        offset := variant_layout.struct_field_offset + i
        field_instrs := scrutinee_instrs
        field_instrs = .append(.StructGet(sum_layout.sym, offset))
        field_mono := variant_field_mono(scrutinee_mono, vid, i, ctx.env)
        out = .concat(emit_pattern_bindings(fp, field_instrs, field_mono, ctx))
      }

      out
    },
  }
}

