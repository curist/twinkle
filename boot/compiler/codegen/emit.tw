// ── Array operations ───────────────────────────────────────────────────

fn emit_array_literal(items: Vector<PreparedAtom>, result_mono: MonoType, ctx: EmitCtx, buf: Vector<Instr>) Vector<Instr> {
  array_emit.emit_array_literal(items, result_mono, ctx, buf, array_emit.ArrayEmitFns.{
