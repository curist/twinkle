//! Type checker: bidirectional inference with Damas-Milner unification.
//!
//! Consumes ResolvedEnv + Module AST, produces TypeMap + diagnostics.
//! InferCtx is threaded functionally through every call; updates use COW field mutation.

use lib.source.diagnostics.{DiagKind, MissingVariant}
use lib.source.rewrite
use lib.source.rewrite.{Rewrite}
use lib.source.span.{Span}

use .ast.{
  BinOp, Block, BreakStmt, CaseArm, CollectExpr, CondArm, ContinueStmt, Expr, ForStmt, FunctionDecl,
  LetStmt, Module, Param, Pattern, RecordEntry, ReturnStmt, Stmt, StringPart, TypeExpr, UnOp,
}
use .contracts.{BuiltinContract, ContractMethodRequirement, ContractReturnShape}
use .lint.{LintFinding}
use .mono_type.{MonoType, TypeId}
use .resolver.{
  FunctionSig, ResolvedEnv, ResolvedField, ResolvedTypeParam, plain_resolved_type_params,
  resolved_type_param_names,
}
use .type_util.{subst_type_params}

// ── Types ───────────────────────────────────────────────────────────
pub type InferCtx = .{
  env: ResolvedEnv,
  module_aliases: Dict<String, Bool>,
  locals: Vector<Dict<String, MonoType>>,
  subst: Dict<Int, MonoType>,
  next_meta: Int,
  current_ret: MonoType?,
  loop_depth: Int,
  type_var_scope: Vector<ResolvedTypeParam>,
  type_map: Dict<Int, MonoType>,
  expr_spans: Dict<Int, Int>,
  call_expected_ret: MonoType?,
  pub_names: Dict<String, Bool>,
  method_calls: Dict<Int, MethodCallInfo>,
  contract_cache: Dict<String, Bool>,
  iterable_lowering: Dict<Int, IterableLoweringInfo>,
  // Review (twk lint): only populated when lint_mode is on (off for build/check).
  lint_mode: Bool,
  rewrites: Vector<Rewrite>,
  lints: Vector<LintFinding>,
}

pub type MethodCallInfo = .{
  func_name: String,
  has_receiver: Bool,
  contract: BuiltinContract?,
  method_name: String,
}

// How a `for`/`collect` iterable should be lowered. The checker already knows
// the iteration mode after type-checking, so it records that decision once here
// (keyed by the iterable expression id) instead of leaving lowering to re-derive
// it from the receiver's `Var(_)` shape and the `method_calls` side channel.
pub type IterableLoweringKind = {
  ConcreteIndexed,
  Dict,
  Range,
  Iterator,
  IndexReadContract,
  IntoIteratorContract,
}

pub type IterableLoweringInfo = .{ elem_ty: MonoType, kind: IterableLoweringKind }

type SynthOut = .{ ty: MonoType, ctx: InferCtx, diags: Vector<DiagKind> }

type CheckOut = .{ ctx: InferCtx, diags: Vector<DiagKind> }

type UnifyOut = .{ ctx: InferCtx, diags: Vector<DiagKind> }

pub type CheckResult = .{
  type_map: Dict<Int, MonoType>,
  expr_spans: Dict<Int, Int>,
  env: ResolvedEnv,
  diagnostics: Vector<DiagKind>,
  method_calls: Dict<Int, MethodCallInfo>,
  pub_values: Dict<String, MonoType>,
  iterable_lowering: Dict<Int, IterableLoweringInfo>,
  rewrites: Vector<Rewrite>,
  lints: Vector<LintFinding>,
}

// ── Context helpers ─────────────────────────────────────────────────
fn empty_ctx(env: ResolvedEnv, module_aliases: Dict<String, Bool>, lint_mode: Bool) InferCtx {
  .{
    env,
    module_aliases,
    locals: [Dict.new()],
    subst: Dict.new(),
    next_meta: 0,
    current_ret: .None,
    loop_depth: 0,
    type_var_scope: [],
    type_map: Dict.new(),
    expr_spans: Dict.new(),
    call_expected_ret: .None,
    pub_names: Dict.new(),
    method_calls: Dict.new(),
    contract_cache: Dict.new(),
    iterable_lowering: Dict.new(),
    lint_mode,
    rewrites: [],
    lints: [],
  }
}

fn push_scope(ctx: InferCtx) InferCtx {
  ctx.locals = .append(Dict.new())
  ctx
}

fn pop_scope(ctx: InferCtx) InferCtx {
  ctx.locals = .drop_last()
  ctx
}

fn bind_optional(ctx: InferCtx, name: String?, ty: MonoType) InferCtx {
  case name {
    .Some(n) => ctx.bind_local(n, ty),
    .None => ctx,
  }
}

fn bind_local(ctx: InferCtx, name: String, ty: MonoType) InferCtx {
  last := ctx.locals.len() - 1
  frame := ctx.locals[last]
  frame[name] = ty

  case ctx.locals.set(last, frame) {
    .Some(new_locals) => ctx.locals = new_locals,
    .None => {},
  }

  ctx
}

fn lookup_local(ctx: InferCtx, name: String) MonoType? {
  i := ctx.locals.len() - 1

  for i >= 0 {
    case ctx.locals[i][name] {
      .Some(ty) => return .Some(ty),
      .None => {},
    }

    i = i - 1
  }

  .None
}

fn set_type_map(ctx: InferCtx, id: Int, ty: MonoType) InferCtx {
  ctx.type_map[id] = ty
  ctx
}

fn set_type_map_span(ctx: InferCtx, id: Int, span_start: Int, ty: MonoType) InferCtx {
  ctx.type_map[id] = ty
  ctx.expr_spans[id] = span_start
  ctx
}

fn set_subst(ctx: InferCtx, id: Int, ty: MonoType) InferCtx {
  ctx.subst[id] = ty
  ctx
}

// ── Type annotation resolution ──────────────────────────────────────
fn resolve_annotation(ty_expr: TypeExpr, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  r := ctx.env.resolve_type_expr(ty_expr, resolved_type_param_names(ctx.type_var_scope))
  result_diags := diags.concat(r.diagnostics)

  case r.ty {
    .Some(ty) => {
      bounds_r := check_type_instantiation_bounds(ty, ty_expr.span, ctx, result_diags)
      .{ ty, ctx: bounds_r.ctx, diags: bounds_r.diags }
    },
    .None => {
      m := ctx.fresh_meta()
      .{ ty: m.ty, ctx: m.ctx, diags: result_diags }
    },
  }
}

// ── Core engine ─────────────────────────────────────────────────────
fn fresh_meta(ctx: InferCtx) SynthOut {
  ty := MonoType.MetaVar(ctx.next_meta)
  ctx.next_meta = ctx.next_meta + 1
  .{ ty, ctx, diags: [] }
}

type ZonkMetaOut = .{ ty: MonoType, has_meta: Bool }

fn zonk(ty: MonoType, subst: Dict<Int, MonoType>) MonoType {
  zonk_with_meta(ty, subst).ty
}

fn zonk_with_meta(ty: MonoType, subst: Dict<Int, MonoType>) ZonkMetaOut {
  case ty {
    .MetaVar(id) => case subst[id] {
      .Some(resolved) => zonk_with_meta(resolved, subst),
      .None => .{ ty, has_meta: true },
    },
    .Vector(inner) => {
      r := zonk_with_meta(inner, subst)
      .{ ty: MonoType.Vector(r.ty), has_meta: r.has_meta }
    },
    .Dict(k, v) => {
      kr := zonk_with_meta(k, subst)
      vr := zonk_with_meta(v, subst)
      .{ ty: MonoType.Dict(kr.ty, vr.ty), has_meta: kr.has_meta or vr.has_meta }
    },
    .Function(params, ret) => {
      zonked_params: Vector<MonoType> = []
      has_meta := false

      for p in params {
        pr := zonk_with_meta(p, subst)
        zonked_params = .append(pr.ty)

        if pr.has_meta {
          has_meta = true
        }
      }

      rr := zonk_with_meta(ret, subst)
      .{ ty: MonoType.Function(zonked_params, rr.ty), has_meta: has_meta or rr.has_meta }
    },
    .Optional(inner) => {
      r := zonk_with_meta(inner, subst)
      .{ ty: MonoType.Optional(r.ty), has_meta: r.has_meta }
    },
    .Result(ok, err) => {
      ok_r := zonk_with_meta(ok, subst)
      err_r := zonk_with_meta(err, subst)
      .{ ty: MonoType.Result(ok_r.ty, err_r.ty), has_meta: ok_r.has_meta or err_r.has_meta }
    },
    .Named(tid, args) => {
      zonked_args: Vector<MonoType> = []
      has_meta := false

      for a in args {
        ar := zonk_with_meta(a, subst)
        zonked_args = .append(ar.ty)

        if ar.has_meta {
          has_meta = true
        }
      }

      .{ ty: MonoType.Named(tid, zonked_args), has_meta }
    },
    _ => .{ ty, has_meta: false },
  }
}

fn occurs(id: Int, ty: MonoType, subst: Dict<Int, MonoType>) Bool {
  case ty {
    .MetaVar(other) => {
      if id == other {
        return true
      }

      case subst[other] {
        .Some(resolved) => occurs(id, resolved, subst),
        .None => false,
      }
    },
    .Vector(inner) => occurs(id, inner, subst),
    .Dict(k, v) => occurs(id, k, subst) or occurs(id, v, subst),
    .Function(params, ret) => {
      for p in params {
        if occurs(id, p, subst) {
          return true
        }
      }

      occurs(id, ret, subst)
    },
    .Optional(inner) => occurs(id, inner, subst),
    .Result(ok, err) => occurs(id, ok, subst) or occurs(id, err, subst),
    .Named(_, args) => {
      for a in args {
        if occurs(id, a, subst) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

fn contains_meta(ty: MonoType) Bool {
  case ty {
    .MetaVar(_) => true,
    .Vector(inner) => contains_meta(inner),
    .Dict(k, v) => contains_meta(k) or contains_meta(v),
    .Function(params, ret) => {
      for p in params {
        if contains_meta(p) {
          return true
        }
      }

      contains_meta(ret)
    },
    .Optional(inner) => contains_meta(inner),
    .Result(ok, err) => contains_meta(ok) or contains_meta(err),
    .Named(_, args) => {
      for a in args {
        if contains_meta(a) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

fn unify(ctx: InferCtx, a: MonoType, b: MonoType, s: Span, diags: Vector<DiagKind>) UnifyOut {
  za := expand_alias(zonk(a, ctx.subst), ctx.env, 0)
  zb := expand_alias(zonk(b, ctx.subst), ctx.env, 0)

  // Never unifies with anything
  case za {
    .Never => return .{ ctx, diags },
    _ => {},
  }

  case zb {
    .Never => return .{ ctx, diags },
    _ => {},
  }

  // MetaVar binding
  case za {
    .MetaVar(id) => {
      case zb {
        .MetaVar(other) => if id == other {
          return .{ ctx, diags }
        },
        _ => {},
      }

      if occurs(id, zb, ctx.subst) {
        return .{ ctx, diags: diags.append(.Error(.InfiniteType(.{ span: s }))) }
      }

      return .{ ctx: ctx.set_subst(id, zb), diags }
    },
    _ => {},
  }

  case zb {
    .MetaVar(id) => {
      if occurs(id, za, ctx.subst) {
        return .{ ctx, diags: diags.append(.Error(.InfiniteType(.{ span: s }))) }
      }

      return .{ ctx: ctx.set_subst(id, za), diags }
    },
    _ => {},
  }

  // Structural matching
  case za {
    .Int => case zb {
      .Int => return .{ ctx, diags },
      _ => {},
    },
    .Float => case zb {
      .Float => return .{ ctx, diags },
      _ => {},
    },
    .Bool => case zb {
      .Bool => return .{ ctx, diags },
      _ => {},
    },
    .Byte => case zb {
      .Byte => return .{ ctx, diags },
      _ => {},
    },
    .String => case zb {
      .String => return .{ ctx, diags },
      _ => {},
    },
    .Void => case zb {
      .Void => return .{ ctx, diags },
      _ => {},
    },
    .Anyref_ => case zb {
      .Anyref_ => return .{ ctx, diags },
      _ => {},
    },
    .Vector(ia) => case zb {
      .Vector(ib) => return ctx.unify(ia, ib, s, diags),
      _ => {},
    },
    .Dict(ka, va) => case zb {
      .Dict(kb, vb) => {
        r := ctx.unify(ka, kb, s, diags)
        return r.ctx.unify(va, vb, s, r.diags)
      },
      _ => {},
    },
    .Optional(ia) => case zb {
      .Optional(ib) => return ctx.unify(ia, ib, s, diags),
      _ => {},
    },
    .Result(oa, ea) => case zb {
      .Result(ob, eb) => {
        r := ctx.unify(oa, ob, s, diags)
        return r.ctx.unify(ea, eb, s, r.diags)
      },
      _ => {},
    },
    .Named(ta, aa) => case zb {
      .Named(tb, ab) => if ta.id == tb.id and aa.len() == ab.len() {
        cur_ctx := ctx
        cur_diags := diags

        for i in 0..aa.len() {
          r := cur_ctx.unify(aa[i], ab[i], s, cur_diags)
          cur_ctx = r.ctx
          cur_diags = r.diags
        }

        return .{ ctx: cur_ctx, diags: cur_diags }
      },
      _ => {},
    },
    .Function(pa, ra) => case zb {
      .Function(pb, rb) => if pa.len() == pb.len() {
        cur_ctx := ctx
        cur_diags := diags

        for i in 0..pa.len() {
          r := cur_ctx.unify(pa[i], pb[i], s, cur_diags)
          cur_ctx = r.ctx
          cur_diags = r.diags
        }

        return cur_ctx.unify(ra, rb, s, cur_diags)
      },
      _ => {},
    },
    .ExternRef(ta) => case zb {
      .ExternRef(tb) => if ta.id == tb.id {
        return .{ ctx, diags }
      },
      _ => {},
    },
    .Var(na) => case zb {
      .Var(nb) => if na == nb {
        return .{ ctx, diags }
      },
      _ => return .{
        ctx,
        diags: diags.append(
          .Error(
            .CompilerBug(
              .{ span: s, message: "uninstantiated type variable '${na}' reached unification" },
            ),
          ),
        ),
      },
    },
    _ => {},
  }

  // Mismatch
  .{ ctx, diags: diags.append(.Error(.TypeMismatch(.{ span: s, expected: za, found: zb }))) }
}

fn subst_vars(ty: MonoType, var_map: Dict<String, MonoType>) MonoType {
  if var_map.len() == 0 {
    return ty
  }

  case ty {
    .Var(name) => case var_map[name] {
      .Some(replacement) => replacement,
      .None => ty,
    },
    .Vector(inner) => .Vector(subst_vars(inner, var_map)),
    .Dict(k, v) => .Dict(subst_vars(k, var_map), subst_vars(v, var_map)),
    .Function(params, ret) => {
      inst_params := collect p in params {
        subst_vars(p, var_map)
      }
      .Function(inst_params, subst_vars(ret, var_map))
    },
    .Optional(inner) => .Optional(subst_vars(inner, var_map)),
    .Result(ok, err) => .Result(subst_vars(ok, var_map), subst_vars(err, var_map)),
    .Named(tid, args) => {
      inst_args := collect a in args {
        subst_vars(a, var_map)
      }
      MonoType.Named(tid, inst_args)
    },
    _ => ty,
  }
}

fn build_var_map(type_params: Vector<ResolvedTypeParam>, type_args: Vector<MonoType>) Dict<
  String,
  MonoType,
> {
  m: Dict<String, MonoType> = Dict.new()

  for i in 0..type_params.len() {
    if i < type_args.len() {
      m[type_params[i].name] = type_args[i]
    }
  }

  m
}

fn find_record_field_type(
  fields: Vector<ResolvedField>,
  type_params: Vector<ResolvedTypeParam>,
  type_args: Vector<MonoType>,
  name: String,
) MonoType? {
  var_map := build_var_map(type_params, type_args)

  for f in fields {
    if f.name == name {
      return .Some(subst_vars(f.ty, var_map))
    }
  }

  .None
}

// Best-effort, silent constraint step: attempt to solve MetaVars introduced by
// instantiation by unifying the instantiated return type with the expected
// return type from context.  Any mismatch diagnostics from this unification are
// intentionally discarded — the real error will be reported later by the
// outer call-site or type-check pass.  This matches the stage0 policy.
fn pre_unify_return(
  ctx: InferCtx,
  inst_ret: MonoType,
  call_expected: MonoType?,
  s: Span,
  diags: Vector<DiagKind>,
) CheckOut {
  case call_expected {
    .Some(expected_ret) => {
      pre_u := ctx.unify(inst_ret, expected_ret, s, diags)

      // Keep the updated substitution (MetaVars may now be solved) but drop
      // pre_u.diags — mismatch errors here are noise; the real error surfaces
      // later.
      .{ ctx: pre_u.ctx, diags }
    },
    .None => .{ ctx, diags },
  }
}

fn same_builtin_contract(a: BuiltinContract, b: BuiltinContract) Bool {
  case a {
    .Stringify => case b {
      .Stringify => true,
      _ => false,
    },
    .Eq => case b {
      .Eq => true,
      _ => false,
    },
    .Ord => case b {
      .Ord => true,
      _ => false,
    },
    .IndexRead => case b {
      .IndexRead => true,
      _ => false,
    },
    .IndexWrite => case b {
      .IndexWrite => true,
      _ => false,
    },
    .IntoIterator => case b {
      .IntoIterator => true,
      _ => false,
    },
    .Sliceable => case b {
      .Sliceable => true,
      _ => false,
    },
  }
}

fn contract_name(contract: BuiltinContract) String {
  contract.spec().name
}

fn contract_return_type(shape: ContractReturnShape, recv_ty: MonoType, elem_ty: MonoType) MonoType {
  case shape {
    .String => .String,
    .Bool => .Bool,
    .Order => MonoType.Named(TypeId.{ id: 7 }, []),
    .Int => .Int,
    .Receiver => recv_ty,
    .Elem => elem_ty,
    // `Iterator<Elem>` — the builtin `Iterator` is TypeId 4 (see base_env).
    .IteratorElem => MonoType.Named(TypeId.{ id: 4 }, [elem_ty]),
  }
}

fn contract_requirement_summary(req: ContractMethodRequirement) String {
  ret_name := case req.ret {
    .String => "String",
    .Bool => "Bool",
    .Order => "Order",
    .Int => "Int",
    .Receiver => "Self",
    .Elem => "Elem",
    .IteratorElem => "Iterator<Elem>",
  }

  if req.arg_shapes.len() == 0 {
    return "${req.method_name}(self) -> ${ret_name}"
  }

  "${req.method_name}(self, ...) -> ${ret_name}"
}

fn lookup_scoped_type_param(scope: Vector<ResolvedTypeParam>, name: String) ResolvedTypeParam? {
  for tp in scope {
    if tp.name == name {
      return .Some(tp)
    }
  }

  .None
}

// If the type variable `name` carries `contract` via an in-scope bound, return
// that bound's type arguments (e.g. `[E]` for `C: IndexRead<E>`, or `[]` for an
// unparameterized bound like `T: Eq`). `.None` means the variable has no such
// bound in scope.
fn scoped_bound_for_contract(
  name: String,
  contract: BuiltinContract,
  scope: Vector<ResolvedTypeParam>,
) Vector<MonoType>? {
  tp := case lookup_scoped_type_param(scope, name) {
    .Some(found) => found,
    .None => return .None,
  }

  for bound in tp.bounds {
    case bound {
      .Builtin(found, type_args) => if same_builtin_contract(found, contract) {
        return .Some(type_args)
      },
    }
  }

  .None
}

// When proving that a type variable satisfies a parameterized contract via its
// in-scope bound, tie the proof's element hint to the bound's declared element
// type. This propagates the functional dependency `Self -> Elem` across a call:
// proving `C: IndexRead<E_callee>` for a caller's `C` (bounded `IndexRead<E>`)
// binds `E_callee` to the caller's `E`, so a sibling `E_callee: Eq` then resolves
// against the caller's `E` instead of an unbound meta.
fn bind_elem_hint_to_scoped_bound(ctx: InferCtx, elem_hint: MonoType?, bound_args: Vector<MonoType>) InferCtx {
  case elem_hint {
    .Some(hint) => if bound_args.len() > 0 {
      case ctx.silent_unify(hint, bound_args[0]) {
        .Some(u) => u,
        .None => ctx,
      }
    } else {
      ctx
    },
    .None => ctx,
  }
}

type ScopedContractMatch = .{
  contract: BuiltinContract,
  req: ContractMethodRequirement,
  type_args: Vector<MonoType>,
}

// A type variable's in-scope bound for a specific contract: the contract itself
// plus its declared type arguments (e.g. `[E]` for `C: IndexRead<E>`). Unlike
// `lookup_scoped_contract_method`, this keys on contract identity rather than a
// method name, so contract-backed decisions (indexing, iteration) do not depend
// on which method names a contract happens to expose.
type ScopedContractBound = .{ contract: BuiltinContract, type_args: Vector<MonoType> }

fn lookup_scoped_contract_bound(
  base_ty: MonoType,
  contract: BuiltinContract,
  scope: Vector<ResolvedTypeParam>,
) ScopedContractBound? {
  name := case base_ty {
    .Var(n) => n,
    _ => return .None,
  }

  case scoped_bound_for_contract(name, contract, scope) {
    .Some(type_args) => .Some(.{ contract, type_args }),
    .None => .None,
  }
}

fn lookup_scoped_contract_method(
  base_ty: MonoType,
  method_name: String,
  scope: Vector<ResolvedTypeParam>,
) ScopedContractMatch? {
  name := case base_ty {
    .Var(n) => n,
    _ => return .None,
  }
  tp := case lookup_scoped_type_param(scope, name) {
    .Some(found) => found,
    .None => return .None,
  }

  for bound in tp.bounds {
    case bound {
      .Builtin(contract, type_args) => {
        for req in contract.methods() {
          if req.method_name == method_name {
            return .Some(.{ contract, req, type_args })
          }
        }
      },
    }
  }

  .None
}

fn builtin_contract_satisfied_by_primitive(ty: MonoType, contract: BuiltinContract) Bool {
  case contract {
    .Stringify => case ty {
      .Int => true,
      .Float => true,
      .Bool => true,
      .Byte => true,
      .String => true,
      _ => false,
    },
    .Eq => case ty {
      .Int => true,
      .Float => true,
      .Bool => true,
      .Byte => true,
      .String => true,
      .Void => true,
      _ => false,
    },
    .Ord => case ty {
      .Int => true,
      .Float => true,
      .Byte => true,
      .String => true,
      _ => false,
    },
    // IndexRead/IndexWrite/IntoIterator/Sliceable are satisfied via inherent
    // methods, not a primitive shortcut.
    .IndexRead => false,
    .IndexWrite => false,
    .IntoIterator => false,
    .Sliceable => false,
  }
}

fn silent_unify(ctx: InferCtx, a: MonoType, b: MonoType) InferCtx? {
  u := ctx.unify(a, b, .{ file_id: 0, start: 0, end: 0 }, [])

  if u.diags.len() > 0 {
    return .None
  }

  .Some(u.ctx)
}

fn prove_contract_method(
  ty: MonoType,
  contract: BuiltinContract,
  req: ContractMethodRequirement,
  ctx: InferCtx,
  active: Dict<String, Bool>,
  elem_hint: MonoType?,
) Result<InferCtx, String> {
  fn_name := try resolve_method_func_name(ty, req.method_name, ctx.env).ok_or(
    "missing ${contract_requirement_summary(req)}",
  )
  sig := try ctx.env
    .lookup_registered_function(fn_name)
    .ok_or("missing ${contract_requirement_summary(req)}")
  inst := instantiate(sig, ctx)
  expected_param_count := req.receiver_param_count + req.arg_shapes.len()

  if inst.params.len() != expected_param_count {
    return .Err(
      "${req.method_name} has the wrong receiver-only shape for ${contract_name(contract)}",
    )
  }

  if req.receiver_param_count != 1 {
    return .Err("unsupported contract receiver shape for ${contract_name(contract)}")
  }

  recv_ctx := try inst.ctx
    .silent_unify(ty, inst.params[0])
    .ok_or("${req.method_name} does not apply to ${ctx.env.ty_to_string_env(ty)}")

  // The receiver-determined element type (functional dependency Self -> Elem).
  // When the proof is triggered from a parameterized bound (`C: IndexRead<E>`),
  // the caller threads the declared `E` as the hint so this proof binds it
  // directly — that's what makes the FD recover `E` for downstream bounds
  // (e.g. a sibling `E: Eq`). Absent a hint, a fresh meta gets bound by
  // whichever requirement mentions `Elem`; determinacy guarantees agreement.
  elem_ty := case elem_hint {
    .Some(hint) => hint,
    .None => {
      em := recv_ctx.fresh_meta()
      recv_ctx = em.ctx
      em.ty
    },
  }

  // Validate non-receiver parameters match their declared shape.
  for i in 0..req.arg_shapes.len() {
    param_idx := req.receiver_param_count + i
    expected_arg := case req.arg_shapes[i] {
      .Receiver => ty,
      .Int => MonoType.Int,
      .Elem => elem_ty,
    }
    recv_ctx = try recv_ctx
      .silent_unify(expected_arg, inst.params[param_idx])
      .ok_or(
        "${req.method_name} parameter ${param_idx} does not match ${ctx.env.ty_to_string_env(ty)}",
      )
  }

  ret_ty := zonk(inst.ret, recv_ctx.subst)
  expected_ret := contract_return_type(req.ret, ty, elem_ty)

  // Unify (not compare) so an `Elem`/`Receiver` return binds against the
  // satisfier's actual return type; for concrete shapes this is an equality check.
  recv_ctx = try recv_ctx
    .silent_unify(expected_ret, ret_ty)
    .ok_or(
      "${req.method_name} returns ${recv_ctx.env.ty_to_string_env(ret_ty)}, expected ${recv_ctx.env.ty_to_string_env(
        expected_ret,
      )}",
    )

  cur_ctx := recv_ctx

  for i in 0..sig.type_params.len() {
    if i >= inst.type_args.len() {
      continue
    }

    arg_ty := expand_alias(zonk(inst.type_args[i], cur_ctx.subst), cur_ctx.env, 0)
    tp := sig.type_params[i]

    for bound in tp.bounds {
      case bound {
        .Builtin(bound_contract, bound_type_args) => {
          // Thread the bound's declared element type (e.g. `E2` in
          // `C2: IndexRead<E2>`) as the proof hint. Without this, proving a
          // satisfier method's own bound binds a fresh meta, so a satisfier
          // whose element comes *through* that bound (e.g. `View<C2>`, whose
          // `at` returns the bound-only `E2`) never connects its concrete
          // element back to the outer element meta — and a sibling `E: Eq`
          // fails. The hint binds the functional dependency one level deeper.
          elem_hint := bound_elem_hint(bound_type_args, sig.type_params, inst.type_args)
          proof := prove_contract(arg_ty, bound_contract, cur_ctx, active, elem_hint)

          case proof {
            .Ok(next_ctx) => {
              cur_ctx = next_ctx
            },
            .Err(reason) => return .Err(reason),
          }
        },
      }
    }
  }

  .Ok(cur_ctx)
}

fn contract_supports_auto_derive(contract: BuiltinContract) Bool {
  case contract {
    .Eq => true,
    .Stringify => false,
    .Ord => false,
    .IndexRead => false,
    .IndexWrite => false,
    .IntoIterator => false,
    .Sliceable => false,
  }
}

fn try_builtin_container_contract(
  ty: MonoType,
  contract: BuiltinContract,
  ctx: InferCtx,
  active: Dict<String, Bool>,
) Result<InferCtx, String>? {
  case contract {
    .Eq => case ty {
      .Optional(inner) => .Some(prove_contract(inner, .Eq, ctx, active, .None)),
      .Result(ok, err) => case prove_contract(ok, .Eq, ctx, active, .None) {
        .Ok(ctx2) => .Some(prove_contract(err, .Eq, ctx2, active, .None)),
        .Err(e) => .Some(.Err(e)),
      },
      .Vector(elem) => .Some(prove_contract(elem, .Eq, ctx, active, .None)),
      .Dict(k, v) => case prove_contract(k, .Eq, ctx, active, .None) {
        .Ok(ctx2) => .Some(prove_contract(v, .Eq, ctx2, active, .None)),
        .Err(e) => .Some(.Err(e)),
      },
      _ => .None,
    },
    .Stringify => .None,
    .Ord => case ty {
      .Vector(elem) => .Some(prove_contract(elem, .Ord, ctx, active, .None)),
      _ => .None,
    },
    // IndexRead/IndexWrite/IntoIterator/Sliceable have no structural container
    // rule; they prove via inherent methods.
    .IndexRead => .None,
    .IndexWrite => .None,
    .IntoIterator => .None,
    .Sliceable => .None,
  }
}

fn try_auto_derive_eq(ty: MonoType, ctx: InferCtx, active: Dict<String, Bool>) Result<
  InferCtx,
  String,
>? {
  case ty {
    .Named(tid, type_args) => case ctx.env.lookup_type_def(tid) {
      .Some(def) => case def {
        .Record(_, type_params, fields) => {
          cur_ctx := ctx

          for field in fields {
            field_ty := subst_type_params(field.ty, type_params, type_args)

            case prove_contract(field_ty, .Eq, cur_ctx, active, .None) {
              .Ok(next_ctx) => {
                cur_ctx = next_ctx
              },
              .Err(reason) => return .Some(.Err(reason)),
            }
          }

          .Some(.Ok(cur_ctx))
        },
        .Sum(_, type_params, variants) => {
          cur_ctx := ctx

          for variant in variants {
            for payload_ty in variant.fields {
              concrete_ty := subst_type_params(payload_ty, type_params, type_args)

              case prove_contract(concrete_ty, .Eq, cur_ctx, active, .None) {
                .Ok(next_ctx) => {
                  cur_ctx = next_ctx
                },
                .Err(reason) => return .Some(.Err(reason)),
              }
            }
          }

          .Some(.Ok(cur_ctx))
        },
        .Alias(_, _, _) => .None,
      },
      .None => .None,
    },
    _ => .None,
  }
}

fn prove_contract(
  ty: MonoType,
  contract: BuiltinContract,
  ctx: InferCtx,
  active: Dict<String, Bool>,
  elem_hint: MonoType?,
) Result<InferCtx, String> {
  zonked := expand_alias(zonk(ty, ctx.subst), ctx.env, 0)
  base_key := "${ctx.env.ty_to_string_env(zonked)}::${contract_name(contract)}"

  // Parameterized contracts (IndexRead<E> / IndexWrite<E> / IntoIterator<E>)
  // must cache per element type: a bare `ty::contract` key cannot tell
  // IndexRead<Int> from IndexRead<String>, so a hinted proof would otherwise
  // poison later checks for a different element. When the hinted element is
  // still an unresolved meta, skip the cache entirely — the boolean ignores the
  // element, the meta is local to this inference session, and the proof's FD
  // unification side-effect (binding the declared `E`) must run every time.
  elem_zonked: MonoType? = if contract.type_arg_count() > 0 {
    case elem_hint {
      .Some(h) => .Some(expand_alias(zonk(h, ctx.subst), ctx.env, 0)),
      .None => .None,
    }
  } else {
    .None
  }
  cache_enabled := case elem_zonked {
    .Some(zh) => !contains_meta(zh),
    .None => true,
  }
  cache_key := case elem_zonked {
    .Some(zh) => "${base_key}::${ctx.env.ty_to_string_env(zh)}",
    .None => base_key,
  }

  // Check proof cache first (only when the key is precise enough to read).
  if cache_enabled {
    case ctx.contract_cache.get(cache_key) {
      .Some(satisfied) => if satisfied {
        return .Ok(ctx)
      } else {
        return .Err(
          "type ${ctx.env.ty_to_string_env(zonked)} does not satisfy ${contract_name(contract)}",
        )
      },
      .None => {},
    }
  }

  if active.has(base_key) {
    // Coinductive: for auto-derivable contracts, assume satisfaction holds
    // for recursive types (structural equality on recursive types is well-defined)
    if contract_supports_auto_derive(contract) {
      return .Ok(ctx)
    }

    return .Err("cyclic proof for ${ctx.env.ty_to_string_env(zonked)}: ${contract_name(contract)}")
  }

  active[base_key] = true

  case zonked {
    .Var(name) => case scoped_bound_for_contract(name, contract, ctx.type_var_scope) {
      .Some(bound_args) => return .Ok(ctx.bind_elem_hint_to_scoped_bound(elem_hint, bound_args)),
      .None => {},
    },
    _ => {},
  }

  if builtin_contract_satisfied_by_primitive(zonked, contract) {
    if cache_enabled {
      ctx.contract_cache[cache_key] = true
    }

    return .Ok(ctx)
  }

  // Conditional satisfaction for builtin container types
  case try_builtin_container_contract(zonked, contract, ctx, active) {
    .Some(result) => case result {
      .Ok(ok_ctx) => {
        if cache_enabled {
          ok_ctx.contract_cache[cache_key] = true
        }

        return .Ok(ok_ctx)
      },
      .Err(e) => {
        if cache_enabled {
          ctx.contract_cache[cache_key] = false
        }

        return .Err(e)
      },
    },
    .None => {},
  }

  // Try explicit method lookup first (user-defined eq takes priority)
  cur_ctx := ctx
  method_ok := true

  for req in contract.methods() {
    proof := prove_contract_method(zonked, contract, req, cur_ctx, active, elem_hint)

    case proof {
      .Ok(next_ctx) => {
        cur_ctx = next_ctx
      },
      .Err(_) => {
        method_ok = false
      },
    }
  }

  if method_ok {
    if cache_enabled {
      cur_ctx.contract_cache[cache_key] = true
    }

    return .Ok(cur_ctx)
  }

  // Fall back to auto-derive for contracts that support it (currently Eq only)
  if contract_supports_auto_derive(contract) {
    case try_auto_derive_eq(zonked, ctx, active) {
      .Some(result) => case result {
        .Ok(ok_ctx) => {
          if cache_enabled {
            ok_ctx.contract_cache[cache_key] = true
          }

          return .Ok(ok_ctx)
        },
        .Err(e) => {
          if cache_enabled {
            ctx.contract_cache[cache_key] = false
          }

          return .Err(e)
        },
      },
      .None => {},
    }
  }

  // Neither explicit method nor auto-derive succeeded
  if cache_enabled {
    ctx.contract_cache[cache_key] = false
  }

  .Err("type ${ctx.env.ty_to_string_env(zonked)} does not satisfy ${contract_name(contract)}")
}

fn satisfies_contract(ty: MonoType, contract: BuiltinContract, ctx: InferCtx) Result<
  InferCtx,
  String,
> {
  prove_contract(ty, contract, ctx, Dict.new(), .None)
}

// Like `satisfies_contract`, but for a parameterized bound (`C: IndexRead<E>`):
// `elem_hint` carries the bound's declared element type so the functional
// dependency binds it during the proof. Sibling bounds (e.g. `E: Eq`) then see
// the resolved element type instead of an unbound meta.
fn satisfies_contract_with_elem(
  ty: MonoType,
  contract: BuiltinContract,
  elem_hint: MonoType?,
  ctx: InferCtx,
) Result<InferCtx, String> {
  prove_contract(ty, contract, ctx, Dict.new(), elem_hint)
}

fn check_instantiated_bounds(
  sig: FunctionSig,
  type_args: Vector<MonoType>,
  error_span: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  cur_ctx := ctx
  cur_diags := diags

  for i in 0..sig.type_params.len() {
    if i >= type_args.len() {
      continue
    }

    tp := sig.type_params[i]
    arg_ty := expand_alias(zonk(type_args[i], cur_ctx.subst), cur_ctx.env, 0)

    for bound in tp.bounds {
      case bound {
        .Builtin(contract, bound_type_args) => {
          // Map the bound's declared element type (e.g. `E` in `IndexRead<E>`)
          // to the instantiated meta so the FD binds it during the proof.
          elem_hint := bound_elem_hint(bound_type_args, sig.type_params, type_args)
          proof := satisfies_contract_with_elem(arg_ty, contract, elem_hint, cur_ctx)

          case proof {
            .Ok(next_ctx) => {
              cur_ctx = next_ctx
            },
            .Err(reason) => {
              cur_diags = .append(
                .Error(
                  .ContractViolation(
                    .{
                      span: error_span,
                      ty: arg_ty,
                      contract: contract_name(contract),
                      owner: "${sig.name}<${tp.name}: ${contract_name(contract)}>",
                      reason,
                    },
                  ),
                ),
              )
            },
          }
        },
      }
    }
  }

  .{ ctx: cur_ctx, diags: cur_diags }
}

// Resolve a parameterized bound's declared element type arg against the owner's
// instantiated type args. `IndexRead<E>` stores `E` as a `Var`; substituting the
// owner's params -> args turns it into the call-site meta the FD must bind.
fn bound_elem_hint(
  bound_type_args: Vector<MonoType>,
  type_params: Vector<ResolvedTypeParam>,
  type_args: Vector<MonoType>,
) MonoType? {
  if bound_type_args.len() == 0 {
    return .None
  }

  .Some(subst_vars(bound_type_args[0], build_var_map(type_params, type_args)))
}

fn check_resolved_type_param_bounds(
  owner_name: String,
  params: Vector<ResolvedTypeParam>,
  type_args: Vector<MonoType>,
  error_span: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  cur_ctx := ctx
  cur_diags := diags

  for i in 0..params.len() {
    if i >= type_args.len() {
      continue
    }

    tp := params[i]
    arg_ty := expand_alias(zonk(type_args[i], cur_ctx.subst), cur_ctx.env, 0)

    for bound in tp.bounds {
      case bound {
        .Builtin(contract, bound_type_args) => {
          elem_hint := bound_elem_hint(bound_type_args, params, type_args)
          proof := satisfies_contract_with_elem(arg_ty, contract, elem_hint, cur_ctx)

          case proof {
            .Ok(next_ctx) => {
              cur_ctx = next_ctx
            },
            .Err(reason) => {
              cur_diags = .append(
                .Error(
                  .ContractViolation(
                    .{
                      span: error_span,
                      ty: arg_ty,
                      contract: contract_name(contract),
                      owner: "${owner_name}<${tp.name}: ${contract_name(contract)}>",
                      reason,
                    },
                  ),
                ),
              )
            },
          }
        },
      }
    }
  }

  .{ ctx: cur_ctx, diags: cur_diags }
}

fn check_type_instantiation_bounds(
  ty: MonoType,
  error_span: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  zonked := expand_alias(zonk(ty, ctx.subst), ctx.env, 0)

  case zonked {
    .Vector(elem) => check_type_instantiation_bounds(elem, error_span, ctx, diags),
    .Dict(k, v) => {
      kr := check_type_instantiation_bounds(k, error_span, ctx, diags)
      check_type_instantiation_bounds(v, error_span, kr.ctx, kr.diags)
    },
    .Function(params, ret) => {
      cur_ctx := ctx
      cur_diags := diags

      for p in params {
        pr := check_type_instantiation_bounds(p, error_span, cur_ctx, cur_diags)
        cur_ctx = pr.ctx
        cur_diags = pr.diags
      }

      check_type_instantiation_bounds(ret, error_span, cur_ctx, cur_diags)
    },
    .Optional(inner) => check_type_instantiation_bounds(inner, error_span, ctx, diags),
    .Result(ok, err) => {
      ok_r := check_type_instantiation_bounds(ok, error_span, ctx, diags)
      check_type_instantiation_bounds(err, error_span, ok_r.ctx, ok_r.diags)
    },
    .Named(tid, type_args) => {
      cur_ctx := ctx
      cur_diags := diags

      for arg in type_args {
        ar := check_type_instantiation_bounds(arg, error_span, cur_ctx, cur_diags)
        cur_ctx = ar.ctx
        cur_diags = ar.diags
      }

      def := case cur_ctx.env.lookup_type_def(tid) {
        .Some(found) => found,
        .None => return .{ ctx: cur_ctx, diags: cur_diags },
      }

      case def {
        .Record(name, type_params, _) => check_resolved_type_param_bounds(
          name,
          type_params,
          type_args,
          error_span,
          cur_ctx,
          cur_diags,
        ),
        .Sum(name, type_params, _) => check_resolved_type_param_bounds(
          name,
          type_params,
          type_args,
          error_span,
          cur_ctx,
          cur_diags,
        ),
        .Alias(name, type_params, target) => {
          own_r := check_resolved_type_param_bounds(
            name,
            type_params,
            type_args,
            error_span,
            cur_ctx,
            cur_diags,
          )
          expanded_target := subst_vars(target, build_var_map(type_params, type_args))
          check_type_instantiation_bounds(expanded_target, error_span, own_r.ctx, own_r.diags)
        },
      }
    },
    _ => .{ ctx, diags },
  }
}

fn check_args(
  ctx: InferCtx,
  args: Vector<Expr>,
  param_tys: Vector<MonoType>,
  diags: Vector<DiagKind>,
) CheckOut {
  cur_ctx := ctx
  cur_diags := diags

  for i in 0..args.len() {
    ar := cur_ctx.check_expr(args[i], param_tys[i], cur_diags)
    cur_ctx = ar.ctx
    cur_diags = ar.diags
  }

  .{ ctx: cur_ctx, diags: cur_diags }
}

// Shared post-instantiation pipeline: arity check → check args → record callee
// type and optional method metadata.  Callers are responsible for instantiation
// and pre_unify_return before calling this.
fn check_instantiated_call(
  ctx: InferCtx,
  diags: Vector<DiagKind>,
  params: Vector<MonoType>,
  ret: MonoType,
  args: Vector<Expr>,
  error_span: Span,
  callee_id: Int,
  callee_span_start: Int,
  method_meta: MethodCallInfo?,
) SynthOut {
  if args.len() != params.len() {
    return .{
      ty: ret,
      ctx: ctx.set_type_map_span(callee_id, callee_span_start, MonoType.Function(params, ret)),
      diags: diags.append(
        .Error(.WrongArity(.{ span: error_span, expected: params.len(), found: args.len() })),
      ),
    }
  }

  ar := ctx.check_args(args, params, diags)
  callee_ty := MonoType.Function(params, ret)
  final_ctx := ar.ctx.set_type_map_span(callee_id, callee_span_start, callee_ty)

  case method_meta {
    .Some(meta) => final_ctx.method_calls[callee_id] = meta,
    .None => {},
  }

  .{ ty: ret, ctx: final_ctx, diags: ar.diags }
}

type InstOut = .{
  params: Vector<MonoType>,
  ret: MonoType,
  type_args: Vector<MonoType>,
  ctx: InferCtx,
}

fn instantiate(sig: FunctionSig, ctx: InferCtx) InstOut {
  // Fast path: non-generic functions need no substitution — avoid allocating
  // var_map and copying params (the common case: almost all compiler functions
  // are non-generic).
  if sig.type_params.len() == 0 {
    inst_ret := case sig.ret {
      .Some(r) => r,
      .None => MonoType.Void,
    }

    return .{ params: sig.params, ret: inst_ret, type_args: [], ctx }
  }

  var_map: Dict<String, MonoType> = Dict.new()
  cur_ctx := ctx
  inst_type_args: Vector<MonoType> = []

  for tp in sig.type_params {
    m := cur_ctx.fresh_meta()
    cur_ctx = m.ctx
    var_map[tp.name] = m.ty
    inst_type_args = .append(m.ty)
  }

  inst_params := collect p in sig.params {
    subst_vars(p, var_map)
  }
  inst_ret := case sig.ret {
    .Some(r) => subst_vars(r, var_map),
    .None => MonoType.Void,
  }
  .{ params: inst_params, ret: inst_ret, type_args: inst_type_args, ctx: cur_ctx }
}

// Expand type aliases: if ty is Named(tid, args) and the def is an Alias,
// substitute type params and return the target type. Recurses up to depth 10.
fn expand_alias(ty: MonoType, env: ResolvedEnv, depth: Int) MonoType {
  if depth > 10 {
    return ty
  }

  case ty {
    .Named(tid, type_args) => {
      def := case env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => return ty,
      }

      case def {
        .Alias(_, type_params, target) => {
          expanded := subst_vars(target, build_var_map(type_params, type_args))
          expand_alias(expanded, env, depth + 1)
        },
        _ => ty,
      }
    },
    _ => ty,
  }
}

// ── Synthesis ───────────────────────────────────────────────────────
fn synth(ctx: InferCtx, expr: Expr, diags: Vector<DiagKind>) SynthOut {
  r := ctx.synth_inner(expr, diags)
  .{ ty: r.ty, ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, r.ty), diags: r.diags }
}

fn synth_inner(ctx: InferCtx, expr: Expr, diags: Vector<DiagKind>) SynthOut {
  case expr.kind {
    .IntLit(_) => .{ ty: .Int, ctx, diags },
    .FloatLit(_) => .{ ty: .Float, ctx, diags },
    .BoolLit(_) => .{ ty: .Bool, ctx, diags },
    .StringLit(_) => .{ ty: .String, ctx, diags },
    .Ident(name) => synth_ident(name, expr.span, ctx, diags),
    .Call(callee, args) => synth_call(callee, args, expr.id, expr.span.start, expr.span, ctx, diags),
    .BlockExpr(block) => synth_block(block, ctx, diags),
    .Binary(op, lhs, rhs) => synth_binary(op, lhs, rhs, expr.span, ctx, diags),
    .Unary(op, operand) => synth_unary(op, operand, expr.span, ctx, diags),
    .Index(base, idx) => synth_index(base, idx, expr.id, expr.span, ctx, diags),
    .StringInterp(parts) => synth_string_interp(parts, ctx, diags),
    .Field(base, field_name) => synth_field(base, field_name, expr.span, ctx, diags),
    .Array(elems) => synth_array(elems, expr.span, ctx, diags),
    .If(cond_e, then_block, else_expr) => synth_if(
      cond_e,
      then_block,
      else_expr,
      expr.span,
      ctx,
      diags,
    ),
    .Case(scrut, arms) => synth_case(scrut, arms, expr.span, ctx, diags),
    .Cond(arms) => synth_cond(arms, expr.span, ctx, diags),
    .Closure(params, ret_ty, body) => synth_closure(params, ret_ty, body, expr.span, ctx, diags),
    .Collect(ce) => synth_collect(ce, expr.span, ctx, diags),
    .NamedRecord(type_name, entries) => synth_named_record(
      type_name,
      entries,
      expr.id,
      expr.span.start,
      expr.span,
      ctx,
      diags,
    ),
    _ => {
      m := ctx.fresh_meta()
      .{
        ty: m.ty,
        ctx: m.ctx,
        diags: diags.append(.Error(.CannotSynthesize(.{ span: expr.span }))),
      }
    },
  }
}

fn synth_ident(name: String, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  // Try local first
  case ctx.lookup_local(name) {
    .Some(ty) => .{ ty, ctx, diags },
    .None => {
      // Try function
      case ctx.env.lookup_function(name) {
        .Some(sig) => {
          inst := instantiate(sig, ctx)

          // For zero-arg functions looked up as values, return Function type
          ty := MonoType.Function(inst.params, inst.ret)
          .{ ty, ctx: inst.ctx, diags }
        },
        .None => {
          // Try imported value binding (selective import of pub let)
          case ctx.env.value_bindings[name] {
            .Some(ty) => .{ ty, ctx, diags },
            .None => {
              m := ctx.fresh_meta()
              .{
                ty: m.ty,
                ctx: m.ctx,
                diags: diags.append(.Error(.UndefinedVar(.{ span: s, name }))),
              }
            },
          }
        },
      }
    },
  }
}

fn synth_call(
  callee: Expr,
  args: Vector<Expr>,
  call_id: Int,
  call_span_start: Int,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut {
  // Capture and clear call_expected_ret so it doesn't leak into nested
  // synth_expr calls (e.g. synthesising the callee/base). The value is
  // used once for pre-unification at the right level.
  call_expected := ctx.call_expected_ret
  clean_ctx := ctx
  clean_ctx.call_expected_ret = .None

  // Special case: direct function call by name
  case callee.kind {
    .Field(base, method_name) => {
      // Module-qualified call form: Alias.func(...)
      case base.kind {
        .Ident(alias) => if clean_ctx.is_module_alias(alias) {
          module_call := try_synth_module_qualified_call(
            alias,
            method_name,
            args,
            callee.id,
            callee.span.start,
            callee.span,
            s,
            clean_ctx,
            diags,
            call_expected,
          )

          case module_call {
            .Some(r) => return r,
            // Fall through on miss: a name that is both a module alias and a
            // type (Option, Result) may instead be a qualified variant
            // constructor, handled just below.
            .None => {},
          }
        },
        _ => {},
      }

      // Qualified variant constructor form: TypeName.Variant(args)
      case try_resolve_type_from_expr(base, clean_ctx) {
        .Some(resolved) => {
          named_ty := canonical_named_type(resolved.tid, resolved.type_args, resolved.ctx.env)

          case resolve_variant_info(method_name, named_ty, resolved.ctx.env) {
            .Some(.Ok(info)) => {
              if args.len() != info.field_types.len() {
                return .{
                  ty: named_ty,
                  ctx: resolved.ctx,
                  diags: diags.append(
                    .Error(
                      .WrongArity(.{ span: s, expected: info.field_types.len(), found: args.len() }),
                    ),
                  ),
                }
              }

              // Pre-unify the result type with the call-site expected type so
              // MetaVars in the type args get solved before we check arguments.
              pu := resolved.ctx.pre_unify_return(named_ty, call_expected, s, diags)
              cur_ctx := pu.ctx
              cur_diags := pu.diags

              for i in 0..args.len() {
                ar := cur_ctx.check_expr(args[i], info.field_types[i], cur_diags)
                cur_ctx = ar.ctx
                cur_diags = ar.diags
              }

              bounds_r := check_type_instantiation_bounds(named_ty, s, cur_ctx, cur_diags)
              cur_ctx = bounds_r.ctx
              cur_diags = bounds_r.diags
              callee_ty := MonoType.Function(info.field_types, named_ty)
              cur_ctx = .set_type_map(base.id, named_ty)
              cur_ctx = .set_type_map_span(callee.id, callee.span.start, callee_ty)
              return .{ ty: named_ty, ctx: cur_ctx, diags: cur_diags }
            },
            _ => {},
          }
        },
        .None => {},
      }

      // Receiver method call form: receiver.method(...)
      method_call := try_synth_method_call(
        base,
        method_name,
        args,
        callee.id,
        callee.span.start,
        callee.span,
        clean_ctx,
        diags,
        call_expected,
      )

      case method_call {
        .Some(r) => r,
        .None => synth_call_general(
          callee,
          args,
          call_id,
          s.start,
          s,
          clean_ctx,
          diags,
          call_expected,
        ),
      }
    },
    .Ident(name) => case clean_ctx.lookup_local(name) {
      .Some(_) => synth_call_general(
        callee,
        args,
        call_id,
        s.start,
        s,
        clean_ctx,
        diags,
        call_expected,
      ),
      .None => case clean_ctx.env.lookup_function(name) {
        .Some(sig) => {
          inst := instantiate(sig, clean_ctx)

          // Pre-unify return type to solve MetaVars before checking arguments
          pu := inst.ctx.pre_unify_return(inst.ret, call_expected, s, diags)
          call_r := pu.ctx.check_instantiated_call(
            pu.diags,
            inst.params,
            inst.ret,
            args,
            s,
            callee.id,
            callee.span.start,
            .None,
          )
          bounds_r := check_instantiated_bounds(sig, inst.type_args, s, call_r.ctx, call_r.diags)
          out_ctx := bounds_r.ctx.maybe_inherent_rewrite(s, name, name, inst.params, args)
          .{ ty: call_r.ty, ctx: out_ctx, diags: bounds_r.diags }
        },
        .None => synth_call_general(
          callee,
          args,
          call_id,
          s.start,
          s,
          clean_ctx,
          diags,
          call_expected,
        ),
      },
    },
    _ => synth_call_general(callee, args, call_id, s.start, s, clean_ctx, diags, call_expected),
  }
}

fn synth_call_general(
  callee: Expr,
  args: Vector<Expr>,
  call_id: Int,
  call_span_start: Int,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
  call_expected: MonoType?,
) SynthOut {
  // Synth the callee
  callee_r := ctx.synth(callee, diags)
  cur_ctx := callee_r.ctx
  cur_diags := callee_r.diags

  // If callee type is Function(param_tys, ret), check args against param types
  callee_ty := zonk(callee_r.ty, cur_ctx.subst)

  case callee_ty {
    .Function(param_tys, ret_ty) => if param_tys.len() == args.len() {
      // Pre-unify return type with the call-site expected type so MetaVars in
      // the callee's return get solved before checking arguments.
      pu := cur_ctx.pre_unify_return(ret_ty, call_expected, s, cur_diags)
      cur_ctx = pu.ctx
      cur_diags = pu.diags

      for i in 0..args.len() {
        cr := cur_ctx.check_expr(args[i], param_tys[i], cur_diags)
        cur_ctx = cr.ctx
        cur_diags = cr.diags
      }

      return .{
        ty: ret_ty,
        ctx: cur_ctx.set_type_map_span(call_id, call_span_start, ret_ty),
        diags: cur_diags,
      }
    },
    _ => {},
  }

  // Fallback: synth all args and unify callee with fn(arg_tys) -> ?ret
  arg_tys: Vector<MonoType> = []

  for arg in args {
    ar := cur_ctx.synth(arg, cur_diags)
    cur_ctx = ar.ctx
    cur_diags = ar.diags
    arg_tys = .append(ar.ty)
  }

  ret_m := cur_ctx.fresh_meta()
  cur_ctx = ret_m.ctx
  expected_fn := MonoType.Function(arg_tys, ret_m.ty)
  u := cur_ctx.unify(callee_r.ty, expected_fn, s, cur_diags)
  .{ ty: ret_m.ty, ctx: u.ctx, diags: u.diags }
}

fn is_module_alias(ctx: InferCtx, name: String) Bool {
  if ctx.module_aliases.has(name) {
    return true
  }

  ctx.env.extern_namespaces.has(name)
}

fn method_owner_name(base_ty: MonoType, env: ResolvedEnv) String? {
  case base_ty {
    .Int => .Some("Int"),
    .Float => .Some("Float"),
    .Bool => .Some("Bool"),
    .Byte => .Some("Byte"),
    .String => .Some("String"),
    .Vector(_) => .Some("Vector"),
    .Dict(_, _) => .Some("Dict"),
    .Optional(_) => .Some("Option"),
    .Result(_, _) => .Some("Result"),
    .Named(tid, _) => env.find_type_name(tid),
    .ExternRef(tid) => env.find_type_name(tid),
    _ => .None,
  }
}

/// Rewrite R1: if `ctx.lint_mode` and the free-function call could be written in
/// receiver-method form resolving to the *same* function, record a rewrite.
/// `params`/`args` are the resolved call's parameters and argument expressions;
/// `call_span` covers the whole call. Fails closed — no rewrite unless the
/// inherent form provably maps to `fn_name` and the receiver is postfix-atomic.
fn maybe_inherent_rewrite(
  ctx: InferCtx,
  call_span: Span,
  method: String,
  fn_name: String,
  params: Vector<MonoType>,
  args: Vector<Expr>,
) InferCtx {
  if !ctx.lint_mode or args.len() < 1 or params.len() < 1 {
    return ctx
  }

  resolves := case resolve_method_func_name(params[0], method, ctx.env) {
    .Some(n) => n == fn_name,
    .None => false,
  }

  if !resolves {
    return ctx
  }

  arg0 := args[0]

  if !rewrite.is_postfix_atomic(arg0.kind) {
    return ctx
  }

  // The checker re-checks some expressions across passes; dedup by call span so
  // one call site yields at most one rewrite.
  for existing in ctx.rewrites {
    case existing {
      .InherentMethodCall(e) => if e.span.start == call_span.start and e.span.end == call_span.end {
        return ctx
      },
    }
  }
  second_start: Int? = if args.len() >= 2 {
    .Some(args[1].span.start)
  } else {
    .None
  }
  rw := Rewrite.InherentMethodCall(.{
    span: call_span,
    method,
    arg0_start: arg0.span.start,
    arg0_end: arg0.span.end,
    second_start,
  })
  ctx.rewrites = .append(rw)
  ctx
}

/// Lint L2: flag a statement-position expression whose value is a `Result` or
/// `Option` that is silently dropped (in `lint_mode`). `try`/`case`/binding all
/// change the type away from Result/Option, so they never reach here.
///
/// (L1 "unused pure result" — discarding any non-Void value — is deliberately
/// NOT done here: without effect analysis it can't tell a forgotten rebinding
/// from an effectful call whose value is legitimately ignored, e.g. a
/// `Cell`-mutating `registry.add_file(...)`. It needs a purity flag first.)
fn maybe_unused_value(ctx: InferCtx, span: Span, ty: MonoType) InferCtx {
  if !ctx.lint_mode {
    return ctx
  }

  message := case zonk(ty, ctx.subst) {
    .Result(_, _) => "ignored `Result`: a possible error is discarded — handle it (`try`, `case`, `.ok_or`) or bind it",
    .Optional(_) => "ignored `Option`: a possible `None` is discarded — handle it (`try`, `case`) or bind it",
    _ => return ctx,
  }

  // Dedup by span across the checker's multiple passes.
  for existing in ctx.lints {
    if existing.span.start == span.start
      and existing.span.end == span.end and existing.rule == "unused-must-use" {
      return ctx
    }
  }
  ctx.lints = .append(.{ span, message, rule: "unused-must-use" })
  ctx
}

fn resolve_method_func_name(base_ty: MonoType, method_name: String, env: ResolvedEnv) String? {
  case base_ty {
    .Int => env.lookup_method("Int", method_name),
    .Float => env.lookup_method("Float", method_name),
    .Bool => env.lookup_method("Bool", method_name),
    .Byte => env.lookup_method("Byte", method_name),
    .String => env.lookup_method("String", method_name),
    .Vector(_) => env.lookup_method("Vector", method_name),
    .Dict(_, _) => env.lookup_method("Dict", method_name),
    .Optional(_) => env.lookup_method("Option", method_name),
    .Result(_, _) => env.lookup_method("Result", method_name),
    .Named(tid, _) => env.lookup_type_method(tid, method_name),
    .ExternRef(tid) => env.lookup_type_method(tid, method_name),
    _ => .None,
  }
}

fn builtin_sig(
  name: String,
  type_params: Vector<String>,
  param_names: Vector<String>,
  params: Vector<MonoType>,
  ret: MonoType,
) FunctionSig {
  .{
    name,
    type_params: plain_resolved_type_params(type_params),
    param_names,
    params,
    ret: .Some(ret),
    doc: .None,
    extern_module: .None,
  }
}

fn builtin_method_sig(base_ty: MonoType, method_name: String) FunctionSig? {
  t := MonoType.Var("T")
  k := MonoType.Var("K")
  v := MonoType.Var("V")

  case base_ty {
    .Int => if method_name == "to_string" {
      return .Some(builtin_sig("int$to_string", [], ["n"], [.Int], .String))
    },
    .Bool => if method_name == "to_string" {
      return .Some(builtin_sig("bool$to_string", [], ["b"], [.Bool], .String))
    },
    .Byte => if method_name == "to_int" {
      return .Some(builtin_sig("byte$to_int", [], ["b"], [.Byte], .Int))
    } else if method_name == "to_string" {
      return .Some(builtin_sig("byte$to_string", [], ["b"], [.Byte], .String))
    },
    .Vector(_) => if method_name == "len" {
      return .Some(builtin_sig("vector$len", ["T"], ["xs"], [.Vector(t)], .Int))
    },
    .Dict(_, _) => if method_name == "len" {
      return .Some(builtin_sig("dict$len", ["K", "V"], ["d"], [.Dict(k, v)], .Int))
    },
    _ => {},
  }

  .None
}

fn builtin_type_method_sig(type_name: String, method_name: String) FunctionSig? {
  k := MonoType.Var("K")
  v := MonoType.Var("V")

  if type_name == "Dict" and method_name == "new" {
    return .Some(builtin_sig("dict$new", ["K", "V"], [], [], .Dict(k, v)))
  }

  .None
}

fn lookup_method_sig(base_ty: MonoType, method_name: String, env: ResolvedEnv) FunctionSig? {
  case builtin_method_sig(base_ty, method_name) {
    .Some(sig) => return .Some(sig),
    .None => {},
  }

  fn_name := case resolve_method_func_name(base_ty, method_name, env) {
    .Some(name) => name,
    .None => return .None,
  }
  env.lookup_registered_function(fn_name)
}

fn named_function_field_exists(base_ty: MonoType, field_name: String, env: ResolvedEnv) Bool {
  case base_ty {
    .Named(tid, type_args) => {
      def := case env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => return false,
      }

      case def {
        .Record(_, type_params, fields) => {
          var_map := build_var_map(type_params, type_args)

          for f in fields {
            if f.name != field_name {
              continue
            }

            field_ty := subst_vars(f.ty, var_map)

            case field_ty {
              .Function(_, _) => return true,
              _ => return false,
            }
          }

          false
        },
        _ => false,
      }
    },
    _ => false,
  }
}

fn type_def_name(env: ResolvedEnv, tid: TypeId) String? {
  case env.lookup_type_def(tid) {
    .Some(.Record(name, _, _)) => .Some(name),
    .Some(.Sum(name, _, _)) => .Some(name),
    .Some(.Alias(name, _, _)) => .Some(name),
    .None => .None,
  }
}

fn resolve_named_type_id(env: ResolvedEnv, name: String) TypeId? {
  entry := case env.lookup_type(name) {
    .Some(found) => found,
    .None => return .None,
  }

  case entry.def {
    .Some(.Alias(_, _, target)) => case expand_alias(target, env, 0) {
      .Named(tid, _) => .Some(tid),
      _ => .Some(entry.id),
    },
    .Some(_) => .Some(entry.id),
    .None => .Some(entry.id),
  }
}

fn try_synth_module_qualified_value(
  type_name: String,
  method_name: String,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut? {
  fn_name := case ctx.env.lookup_method(type_name, method_name) {
    .Some(name) => name,
    .None => {
      qualified := "${type_name}.${method_name}"

      case ctx.env.lookup_function(qualified) {
        .Some(_) => qualified,
        .None => {
          // Check for an imported module-level value binding.
          case ctx.env.value_bindings[qualified] {
            .Some(ty) => return .Some(.{ ty, ctx, diags }),
            .None => return .None,
          }
        },
      }
    },
  }
  sig := case builtin_type_method_sig(type_name, method_name) {
    .Some(s) => s,
    .None => case ctx.env.lookup_registered_function(fn_name) {
      .Some(s) => s,
      .None => return .None,
    },
  }
  inst := instantiate(sig, ctx)
  .Some(.{ ty: MonoType.Function(inst.params, inst.ret), ctx: inst.ctx, diags })
}

fn try_synth_module_qualified_call(
  type_name: String,
  method_name: String,
  args: Vector<Expr>,
  callee_id: Int,
  callee_span_start: Int,
  callee_span: Span,
  call_span: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
  call_expected: MonoType?,
) SynthOut? {
  fn_name := case ctx.env.lookup_method(type_name, method_name) {
    .Some(name) => name,
    .None => {
      // For extern namespaces, look up directly as qualified name
      qualified := "${type_name}.${method_name}"

      case ctx.env.lookup_function(qualified) {
        .Some(_) => qualified,
        .None => return .None,
      }
    },
  }
  sig := case builtin_type_method_sig(type_name, method_name) {
    .Some(s) => s,
    .None => case ctx.env.lookup_registered_function(fn_name) {
      .Some(s) => s,
      .None => return .None,
    },
  }
  inst := instantiate(sig, ctx)
  pu := inst.ctx.pre_unify_return(inst.ret, call_expected, callee_span, diags)
  meta := MethodCallInfo.{ func_name: fn_name, has_receiver: false, contract: .None, method_name }
  call_r := pu.ctx.check_instantiated_call(
    pu.diags,
    inst.params,
    inst.ret,
    args,
    callee_span,
    callee_id,
    callee_span_start,
    .Some(meta),
  )
  bounds_r := check_instantiated_bounds(sig, inst.type_args, callee_span, call_r.ctx, call_r.diags)
  out_ctx := bounds_r.ctx.maybe_inherent_rewrite(call_span, method_name, fn_name, inst.params, args)
  .Some(.{ ty: call_r.ty, ctx: out_ctx, diags: bounds_r.diags })
}

fn try_synth_method_call(
  base: Expr,
  method_name: String,
  args: Vector<Expr>,
  callee_id: Int,
  callee_span_start: Int,
  callee_span: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
  call_expected: MonoType?,
) SynthOut? {
  br := ctx.synth(base, diags)
  base_ty := expand_alias(zonk(br.ty, br.ctx.subst), br.ctx.env, 0)
  contract_match := lookup_scoped_contract_method(base_ty, method_name, br.ctx.type_var_scope)

  case contract_match {
    .Some(m) => {
      // `Elem` slots resolve to the bound's declared element type arg (e.g. `E`
      // in `C: IndexRead<E>`); fall back to the receiver if the bound is nullary.
      elem_ty := if m.type_args.len() > 0 {
        m.type_args[0]
      } else {
        base_ty
      }
      ret_ty := contract_return_type(m.req.ret, base_ty, elem_ty)

      extra_params: Vector<MonoType> = []

      for shape in m.req.arg_shapes {
        case shape {
          .Receiver => extra_params = .append(base_ty),
          .Int => extra_params = .append(MonoType.Int),
          .Elem => extra_params = .append(elem_ty),
        }
      }

      pu := br.ctx.pre_unify_return(ret_ty, call_expected, callee_span, br.diags)
      meta := MethodCallInfo.{
        func_name: "",
        has_receiver: true,
        contract: .Some(m.contract),
        method_name,
      }

      return .Some(
        pu.ctx.check_instantiated_call(
          pu.diags,
          extra_params,
          ret_ty,
          args,
          callee_span,
          callee_id,
          callee_span_start,
          .Some(meta),
        ),
      )
    },
    .None => {},
  }

  sig := case lookup_method_sig(base_ty, method_name, br.ctx.env) {
    .Some(s) => s,
    .None => {
      owner := method_owner_name(base_ty, br.ctx.env)

      case owner {
        .None => return .None,
        .Some(_) => {
          if named_function_field_exists(base_ty, method_name, br.ctx.env) {
            return .None
          }

          return .Some(
            .{
              ty: .Void,
              ctx: br.ctx,
              diags: br.diags.append(
                .Error(.NoMethod(.{ span: callee_span, ty: base_ty, name: method_name })),
              ),
            },
          )
        },
      }
    },
  }
  inst := instantiate(sig, br.ctx)
  pu := inst.ctx.pre_unify_return(inst.ret, call_expected, callee_span, br.diags)
  cur_ctx := pu.ctx
  cur_diags := pu.diags

  if inst.params.len() == 0 {
    return .Some(
      .{
        ty: inst.ret,
        ctx: cur_ctx,
        diags: cur_diags.append(
          .Error(.InvalidMethodSig(.{ span: callee_span, name: method_name })),
        ),
      },
    )
  }

  recv_u := cur_ctx.unify(base_ty, inst.params[0], base.span, cur_diags)
  expected_args := inst.params.slice(1, inst.params.len())
  resolved_fn := case resolve_method_func_name(base_ty, method_name, recv_u.ctx.env) {
    .Some(name) => name,
    .None => method_name,
  }
  meta := MethodCallInfo.{
    func_name: resolved_fn,
    has_receiver: true,
    contract: .None,
    method_name,
  }
  call_r := recv_u.ctx.check_instantiated_call(
    recv_u.diags,
    expected_args,
    inst.ret,
    args,
    callee_span,
    callee_id,
    callee_span_start,
    .Some(meta),
  )
  bounds_r := check_instantiated_bounds(sig, inst.type_args, callee_span, call_r.ctx, call_r.diags)
  .Some(.{ ty: call_r.ty, ctx: bounds_r.ctx, diags: bounds_r.diags })
}

fn try_synth_method_value(
  base_ty: MonoType,
  method_name: String,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut? {
  scoped_match := lookup_scoped_contract_method(base_ty, method_name, ctx.type_var_scope)

  case scoped_match {
    .Some(m) => {
      elem_ty := if m.type_args.len() > 0 {
        m.type_args[0]
      } else {
        base_ty
      }
      extra_params: Vector<MonoType> = []

      for shape in m.req.arg_shapes {
        case shape {
          .Receiver => extra_params = .append(base_ty),
          .Int => extra_params = .append(MonoType.Int),
          .Elem => extra_params = .append(elem_ty),
        }
      }

      return .Some(
        .{
          ty: .Function(extra_params, contract_return_type(m.req.ret, base_ty, elem_ty)),
          ctx,
          diags,
        },
      )
    },
    .None => {},
  }

  sig := case lookup_method_sig(base_ty, method_name, ctx.env) {
    .Some(found) => found,
    .None => return .None,
  }
  inst := instantiate(sig, ctx)
  cur_ctx := inst.ctx
  cur_diags := diags

  if inst.params.len() == 0 {
    return .Some(
      .{
        ty: .Function([], inst.ret),
        ctx: cur_ctx,
        diags: cur_diags.append(.Error(.InvalidMethodSig(.{ span: s, name: method_name }))),
      },
    )
  }

  recv_u := cur_ctx.unify(base_ty, inst.params[0], s, cur_diags)
  cur_ctx = recv_u.ctx
  cur_diags = recv_u.diags
  remaining := inst.params.slice(1, inst.params.len())
  .Some(.{ ty: .Function(remaining, inst.ret), ctx: cur_ctx, diags: cur_diags })
}

// ── Records, Fields, Variants ───────────────────────────────────────
type VariantInfo = .{ field_types: Vector<MonoType> }

type ResolvedTypeExpr = .{ tid: TypeId, type_args: Vector<MonoType>, ctx: InferCtx }

// Resolve a variant name against a zonked type, returning substituted field types.
// Returns .Ok(info) if found, .Err(message) on error, .None if not a sum type.
fn resolve_variant_info(name: String, zonked: MonoType, env: ResolvedEnv) Result<
  VariantInfo,
  String,
>? {
  case zonked {
    .Optional(inner) => {
      if name == "Some" {
        return .Some(.Ok(.{ field_types: [inner] }))
      }

      if name == "None" {
        return .Some(.Ok(.{ field_types: [] }))
      }

      .Some(.Err("unknown variant .${name} for Optional"))
    },
    .Result(ok_ty, err_ty) => {
      if name == "Ok" {
        return .Some(.Ok(.{ field_types: [ok_ty] }))
      }

      if name == "Err" {
        return .Some(.Ok(.{ field_types: [err_ty] }))
      }

      .Some(.Err("unknown variant .${name} for Result"))
    },
    .Named(tid, type_args) => {
      def := try env.lookup_type_def(tid)

      case def {
        .Sum(_, type_params, variants) => {
          var_map := build_var_map(type_params, type_args)

          for v in variants {
            if v.name == name {
              field_types := collect ft in v.fields {
                subst_vars(ft, var_map)
              }

              return .Some(.Ok(.{ field_types }))
            }
          }

          .Some(.Err("unknown variant .${name}"))
        },
        _ => .None,
      }
    },
    _ => .None,
  }
}

fn extract_type_name_expr(expr: Expr) String? {
  case expr.kind {
    .Ident(name) => .Some(name),
    .Field(base, field) => {
      prefix := try extract_type_name_expr(base)
      .Some("${prefix}.${field}")
    },
    _ => .None,
  }
}

// Try to resolve an expression as a type name, returning a named type plus fresh meta args.
fn try_resolve_type_from_expr(expr: Expr, ctx: InferCtx) ResolvedTypeExpr? {
  type_name := try extract_type_name_expr(expr)

  case ctx.env.lookup_type(type_name) {
    .Some(entry) => {
      // Build fresh meta type args for generic types
      cur_ctx := ctx
      type_args: Vector<MonoType> = []

      case entry.def {
        .Some(.Sum(_, type_params, _)) => {
          for _ in type_params {
            m := cur_ctx.fresh_meta()
            cur_ctx = m.ctx
            type_args = .append(m.ty)
          }
        },
        .Some(.Record(_, type_params, _)) => {
          for _ in type_params {
            m := cur_ctx.fresh_meta()
            cur_ctx = m.ctx
            type_args = .append(m.ty)
          }
        },
        _ => {},
      }

      .Some(.{ tid: entry.id, type_args, ctx: cur_ctx })
    },
    .None => .None,
  }
}

// Builtin Option/Result are represented by dedicated MonoType kinds, not Named,
// so a qualified constructor (Option.Some, Result.Ok) must produce the canonical
// kind — otherwise the result type is `Named(0/1, …)` and won't unify with `T?`
// or `Result<T, E>`. resolve_variant_info already understands both kinds.
fn canonical_named_type(tid: TypeId, type_args: Vector<MonoType>, env: ResolvedEnv) MonoType {
  name := case env.find_type_name(tid) {
    .Some(n) => n,
    .None => "",
  }

  if name == "Option" and type_args.len() == 1 {
    .Optional(type_args[0])
  } else if name == "Result" and type_args.len() == 2 {
    .Result(type_args[0], type_args[1])
  } else {
    .Named(tid, type_args)
  }
}

fn synth_field(base: Expr, field_name: String, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  // Check if base is a type name with a variant (TypeName.VariantName)
  case try_resolve_type_from_expr(base, ctx) {
    .Some(resolved) => {
      named_ty := canonical_named_type(resolved.tid, resolved.type_args, resolved.ctx.env)

      case resolve_variant_info(field_name, named_ty, resolved.ctx.env) {
        .Some(.Ok(info)) => {
          // Zero-arg variant: value of the named type; otherwise: constructor function
          new_ctx := resolved.ctx.set_type_map(base.id, named_ty)

          if info.field_types.len() == 0 {
            return .{ ty: named_ty, ctx: new_ctx, diags }
          } else {
            return .{ ty: .Function(info.field_types, named_ty), ctx: new_ctx, diags }
          }
        },
        _ => {},
      }
    },
    .None => {},
  }

  case base.kind {
    .Ident(alias) => if ctx.is_module_alias(alias) {
      module_value := try_synth_module_qualified_value(alias, field_name, ctx, diags)

      case module_value {
        .Some(r) => return r,
        .None => {},
      }
    },
    _ => {},
  }

  br := ctx.synth(base, diags)
  zonked_base := expand_alias(zonk(br.ty, br.ctx.subst), br.ctx.env, 0)

  case zonked_base {
    .Named(tid, type_args) => {
      def := case br.ctx.env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => return .{
          ty: .Void,
          ctx: br.ctx,
          diags: br.diags.append(.Error(.NotARecord(.{ span: s, ty: zonked_base }))),
        },
      }

      case def {
        .Record(_, type_params, fields) => {
          case find_record_field_type(fields, type_params, type_args, field_name) {
            .Some(fty) => return .{ ty: fty, ctx: br.ctx, diags: br.diags },
            .None => {},
          }

          method_r := try_synth_method_value(zonked_base, field_name, s, br.ctx, br.diags)

          case method_r {
            .Some(r) => r,
            .None => {
              err: DiagKind = .Error(.NoField(.{ span: s, name: field_name, ty: zonked_base }))
              .{ ty: .Void, ctx: br.ctx, diags: br.diags.append(err) }
            },
          }
        },
        _ => {
          method_r := try_synth_method_value(zonked_base, field_name, s, br.ctx, br.diags)

          case method_r {
            .Some(r) => r,
            .None => .{
              ty: .Void,
              ctx: br.ctx,
              diags: br.diags.append(.Error(.NotARecord(.{ span: s, ty: zonked_base }))),
            },
          }
        },
      }
    },
    _ => {
      method_r := try_synth_method_value(zonked_base, field_name, s, br.ctx, br.diags)

      case method_r {
        .Some(r) => r,
        .None => {
          m := br.ctx.fresh_meta()
          err: DiagKind = .Error(.NoField(.{ span: s, name: field_name, ty: zonked_base }))
          .{ ty: m.ty, ctx: m.ctx, diags: br.diags.append(err) }
        },
      }
    },
  }
}

fn synth_named_record(
  type_name: String,
  entries: Vector<RecordEntry>,
  record_id: Int,
  record_span_start: Int,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut {
  entry := case ctx.env.lookup_type(type_name) {
    .Some(e) => e,
    .None => {
      m := ctx.fresh_meta()

      return .{
        ty: m.ty,
        ctx: m.ctx,
        diags: diags.append(.Error(.UndefinedType(.{ span: s, name: type_name }))),
      }
    },
  }

  // Build type args: fresh MetaVars for generic record types
  cur_ctx := ctx
  type_args: Vector<MonoType> = []

  case entry.def {
    .Some(def) => case def {
      .Record(_, type_params, _) => {
        for _ in type_params {
          m := cur_ctx.fresh_meta()
          cur_ctx = m.ctx
          type_args = .append(m.ty)
        }
      },
      _ => {},
    },
    .None => {},
  }

  expected := MonoType.Named(entry.id, type_args)
  cr := check_record_lit(entries, expected, s, cur_ctx, diags)
  bounds_r := check_type_instantiation_bounds(expected, s, cr.ctx, cr.diags)
  .{
    ty: expected,
    ctx: bounds_r.ctx.set_type_map_span(record_id, record_span_start, expected),
    diags: bounds_r.diags,
  }
}

fn check_record_lit(
  entries: Vector<RecordEntry>,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  zonked := expand_alias(zonk(expected, ctx.subst), ctx.env, 0)

  case zonked {
    .Named(tid, type_args) => {
      def := case ctx.env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => return .{ ctx, diags: diags.append(.Error(.NotARecord(.{ span: s, ty: zonked }))) },
      }

      case def {
        .Record(_, type_params, fields) => {
          cur_ctx := ctx
          cur_diags := diags

          // Detect duplicate fields before checking values
          seen_fields: Dict<String, Span> = Dict.new()

          for entry in entries {
            case seen_fields[entry.name] {
              .Some(first) => {
                cur_diags = .append(
                  .Error(.DuplicateField(.{ span: entry.span, name: entry.name, first })),
                )
              },
              .None => seen_fields[entry.name] = entry.span,
            }
          }

          // Check each provided field
          for entry in entries {
            case find_record_field_type(fields, type_params, type_args, entry.name) {
              .Some(field_ty) => case entry.value {
                .Some(val) => {
                  vr := cur_ctx.check_expr(val, field_ty, cur_diags)
                  cur_ctx = vr.ctx
                  cur_diags = vr.diags
                },
                .None => {
                  // Punning: .{ name } means .{ name: name }
                  ir := synth_ident(entry.name, entry.span, cur_ctx, cur_diags)
                  u := ir.ctx.unify(ir.ty, field_ty, entry.span, ir.diags)
                  cur_ctx = u.ctx
                  cur_diags = u.diags
                },
              },
              .None => {
                cur_diags = .append(
                  .Error(.NoField(.{ span: entry.span, name: entry.name, ty: zonked })),
                )
              },
            }
          }

          // Check missing fields
          for f in fields {
            if !entries.any(fn(e) { e.name == f.name }) {
              cur_diags = .append(.Error(.MissingField(.{ span: s, name: f.name, ty: zonked })))
            }
          }

          .{ ctx: cur_ctx, diags: cur_diags }
        },
        _ => .{ ctx, diags: diags.append(.Error(.NotARecord(.{ span: s, ty: zonked }))) },
      }
    },
    _ => .{ ctx, diags: diags.append(.Error(.NotARecord(.{ span: s, ty: zonked }))) },
  }
}

fn check_variant_lit(
  name: String,
  args: Vector<Expr>,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  zonked := expand_alias(zonk(expected, ctx.subst), ctx.env, 0)

  case resolve_variant_info(name, zonked, ctx.env) {
    .Some(.Ok(info)) => {
      if args.len() != info.field_types.len() {
        return .{
          ctx,
          diags: diags.append(
            .Error(.WrongArity(.{ span: s, expected: info.field_types.len(), found: args.len() })),
          ),
        }
      }

      cur_ctx := ctx
      cur_diags := diags

      for i in 0..args.len() {
        ar := cur_ctx.check_expr(args[i], info.field_types[i], cur_diags)
        cur_ctx = ar.ctx
        cur_diags = ar.diags
      }

      .{ ctx: cur_ctx, diags: cur_diags }
    },
    .Some(.Err(msg)) => .{
      ctx,
      diags: diags.append(.Error(.ParseError(.{ span: s, message: msg, help_lines: [] }))),
    },
    .None => .{
      ctx,
      diags: diags.append(.Error(.VariantTypeMismatch(.{ span: s, name, ty: zonked }))),
    },
  }
}

fn block_needs_expected_type(block: Block) Bool {
  case block.tail {
    .Some(tail) => expr_needs_expected_type(tail),
    .None => false,
  }
}

fn expr_needs_expected_type(expr: Expr) Bool {
  case expr.kind {
    .Variant(_, _) => true,
    .Record(_) => true,
    .BlockExpr(block) => block_needs_expected_type(block),
    _ => false,
  }
}

fn synth_array(elems: Vector<Expr>, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  if elems.len() == 0 {
    m := ctx.fresh_meta()
    return .{ ty: MonoType.Vector(m.ty), ctx: m.ctx, diags }
  }

  // Synth first element, unify rest against it
  first := ctx.synth(elems[0], diags)
  cur_ctx := first.ctx
  cur_diags := first.diags

  for i in 1..elems.len() {
    r := cur_ctx.synth(elems[i], cur_diags)
    u := r.ctx.unify(r.ty, first.ty, elems[i].span, r.diags)
    cur_ctx = u.ctx
    cur_diags = u.diags
  }

  .{ ty: .Vector(first.ty), ctx: cur_ctx, diags: cur_diags }
}

// ── Check mode ──────────────────────────────────────────────────────
fn int_literal_fits_byte(n: Int) Bool {
  n >= 0 and n <= 255
}

fn check_expr(ctx: InferCtx, expr: Expr, expected: MonoType, diags: Vector<DiagKind>) CheckOut {
  // Check-mode dispatch: certain expression forms benefit from pushing the expected type down
  case expr.kind {
    .IntLit(n) => case zonk(expected, ctx.subst) {
      .Byte => {
        if int_literal_fits_byte(n) {
          return .{ ctx: ctx.set_type_map_span(expr.id, expr.span.start, MonoType.Byte), diags }
        }

        return .{
          ctx,
          diags: diags.append(.Error(.ByteOutOfRange(.{ span: expr.span, value: n }))),
        }
      },
      _ => {},
    },
    _ => {},
  }

  case expr.kind {
    .BlockExpr(block) => {
      r := check_block(block, expected, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .If(cond_e, then_block, else_expr) => {
      r := check_if(cond_e, then_block, else_expr, expected, expr.span, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .Case(scrut, arms) => {
      r := check_case(scrut, arms, expected, expr.span, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .Cond(arms) => {
      r := check_cond(arms, expected, expr.span, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .Record(entries) => {
      r := check_record_lit(entries, expected, expr.span, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .Variant(name, args) => {
      r := check_variant_lit(name, args, expected, expr.span, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .Closure(params, ret_ty, body) => {
      r := check_closure(params, ret_ty, body, expected, expr.span, ctx, diags)
      return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
    },
    .Array(elems) => {
      // Push expected element type into array check
      case expand_alias(zonk(expected, ctx.subst), ctx.env, 0) {
        .Vector(elem_ty) => {
          cur_ctx := ctx
          cur_diags := diags

          for e in elems {
            er := cur_ctx.check_expr(e, elem_ty, cur_diags)
            cur_ctx = er.ctx
            cur_diags = er.diags
          }

          return .{
            ctx: cur_ctx.set_type_map_span(expr.id, expr.span.start, expected),
            diags: cur_diags,
          }
        },
        _ => {},
      }
    },
    .Collect(ce) => case expand_alias(zonk(expected, ctx.subst), ctx.env, 0) {
      .Vector(elem_ty) => {
        r := check_collect(ce, elem_ty, expr.span, ctx, diags)
        return .{ ctx: r.ctx.set_type_map_span(expr.id, expr.span.start, expected), diags: r.diags }
      },
      _ => {},
    },
    .Call(_, _) => {
      // Propagate expected return type into generic call instantiation.
      // synth_call captures and clears call_expected_ret at the top.
      call_ctx := ctx
      call_ctx.call_expected_ret = .Some(expected)
      r := call_ctx.synth(expr, diags)
      u := r.ctx.unify(r.ty, expected, expr.span, r.diags)
      return .{ ctx: u.ctx, diags: u.diags }
    },
    _ => {},
  }

  // Fallback: synth then unify
  r := ctx.synth(expr, diags)
  u := r.ctx.unify(r.ty, expected, expr.span, r.diags)
  .{ ctx: u.ctx, diags: u.diags }
}

// ── Closures ────────────────────────────────────────────────────────
fn synth_closure(
  params: Vector<Param>,
  ret_ty_expr: TypeExpr?,
  body: Block,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut {
  cur_ctx := ctx.push_scope()
  cur_diags := diags
  prev_ret := cur_ctx.current_ret
  prev_loop_depth := cur_ctx.loop_depth
  cur_ctx.loop_depth = 0

  // Resolve param types (annotated or fresh meta)
  param_tys: Vector<MonoType> = []

  for p in params {
    case p.ty {
      .Some(ty_expr) => {
        ann := resolve_annotation(ty_expr, cur_ctx, cur_diags)
        cur_ctx = ann.ctx
        cur_diags = ann.diags
        param_tys = .append(ann.ty)
        cur_ctx = .bind_local(p.name, ann.ty)
      },
      .None => {
        m := cur_ctx.fresh_meta()
        cur_ctx = m.ctx
        cur_diags = m.diags
        param_tys = .append(m.ty)
        cur_ctx = .bind_local(p.name, m.ty)
      },
    }
  }

  // Resolve return type or synth body
  case ret_ty_expr {
    .Some(rte) => {
      ann := resolve_annotation(rte, cur_ctx, cur_diags)
      cur_ctx = ann.ctx
      cur_diags = ann.diags
      cur_ctx.current_ret = .Some(ann.ty)
      body_r := check_block(body, ann.ty, cur_ctx, cur_diags)
      cur_ctx = body_r.ctx.pop_scope()
      cur_ctx.current_ret = prev_ret
      cur_ctx.loop_depth = prev_loop_depth
      .{ ty: .Function(param_tys, ann.ty), ctx: cur_ctx, diags: body_r.diags }
    },
    .None => {
      body_r := synth_block(body, cur_ctx, cur_diags)
      cur_ctx = body_r.ctx.pop_scope()
      cur_ctx.current_ret = prev_ret
      cur_ctx.loop_depth = prev_loop_depth
      .{ ty: .Function(param_tys, body_r.ty), ctx: cur_ctx, diags: body_r.diags }
    },
  }
}

fn check_closure(
  params: Vector<Param>,
  ret_ty_expr: TypeExpr?,
  body: Block,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  // Push expected param types into unannotated closure params
  zonked := expand_alias(zonk(expected, ctx.subst), ctx.env, 0)

  case zonked {
    .Function(exp_params, exp_ret) => {
      cur_ctx := ctx.push_scope()
      cur_diags := diags
      prev_ret := cur_ctx.current_ret
      prev_loop_depth := cur_ctx.loop_depth
      cur_ctx.current_ret = .Some(exp_ret)
      cur_ctx.loop_depth = 0
      param_tys: Vector<MonoType> = []

      for i in 0..params.len() {
        p := params[i]

        case p.ty {
          .Some(ty_expr) => {
            ann := resolve_annotation(ty_expr, cur_ctx, cur_diags)
            cur_ctx = ann.ctx
            cur_diags = ann.diags
            param_tys = .append(ann.ty)

            // Unify with expected param
            if i < exp_params.len() {
              u := cur_ctx.unify(ann.ty, exp_params[i], p.span, cur_diags)
              cur_ctx = u.ctx
              cur_diags = u.diags
            }

            cur_ctx = .bind_local(p.name, ann.ty)
          },
          .None => {
            // Use expected param type
            pty := if i < exp_params.len() {
              exp_params[i]
            } else {
              fm := cur_ctx.fresh_meta()
              cur_ctx = fm.ctx
              fm.ty
            }
            param_tys = .append(pty)
            cur_ctx = .bind_local(p.name, pty)
          },
        }
      }

      // If the closure has an explicit return annotation, it must agree with
      // the expected return type so generic call-site type variables can be
      // solved from the annotation itself.
      body_expected := case ret_ty_expr {
        .Some(rte) => {
          ann := resolve_annotation(rte, cur_ctx, cur_diags)
          cur_ctx = ann.ctx
          cur_diags = ann.diags
          u := cur_ctx.unify(ann.ty, exp_ret, rte.span, cur_diags)
          cur_ctx = u.ctx
          cur_diags = u.diags
          ann.ty
        },
        .None => exp_ret,
      }

      // Check body against the resolved return type.
      body_r := check_block(body, body_expected, cur_ctx, cur_diags)
      out_ctx := body_r.ctx.pop_scope()
      out_ctx.current_ret = prev_ret
      out_ctx.loop_depth = prev_loop_depth
      .{ ctx: out_ctx, diags: body_r.diags }
    },
    _ => {
      // Fallback: synth then unify
      r := synth_closure(params, ret_ty_expr, body, s, ctx, diags)
      u := r.ctx.unify(r.ty, expected, s, r.diags)
      .{ ctx: u.ctx, diags: u.diags }
    },
  }
}

// ── If, Case, For ──────────────────────────────────────────────────
fn synth_if(
  cond_e: Expr,
  then_block: Block,
  else_expr: Expr?,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut {
  // Check condition is Bool
  cr := ctx.synth(cond_e, diags)
  u := cr.ctx.unify(cr.ty, MonoType.Bool, cond_e.span, cr.diags)

  // Synth then branch
  then_r := synth_block(then_block, u.ctx, u.diags)

  case else_expr {
    .Some(else_e) => {
      if then_r.ty == .Never {
        // Then diverges — synth else freely
        else_r := then_r.ctx.synth(else_e, then_r.diags)
        return .{ ty: else_r.ty, ctx: else_r.ctx, diags: else_r.diags }
      }

      then_zonked := zonk(then_r.ty, then_r.ctx.subst)

      if contains_meta(then_zonked) {
        // Then type still ambiguous — synth else and unify
        else_r := then_r.ctx.synth(else_e, then_r.diags)

        if else_r.ty == .Never {
          return .{ ty: then_zonked, ctx: else_r.ctx, diags: else_r.diags }
        }

        u2 := else_r.ctx.unify(then_zonked, else_r.ty, s, else_r.diags)
        .{ ty: then_zonked, ctx: u2.ctx, diags: u2.diags }
      } else {
        // Then type is concrete — check else against it for variant shorthand resolution
        else_r := then_r.ctx.check_expr(else_e, then_zonked, then_r.diags)
        .{ ty: then_zonked, ctx: else_r.ctx, diags: else_r.diags }
      }
    },
    .None => {
      // No else — result is Void
      .{ ty: MonoType.Void, ctx: then_r.ctx, diags: then_r.diags }
    },
  }
}

fn check_if(
  cond_e: Expr,
  then_block: Block,
  else_expr: Expr?,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  cr := ctx.synth(cond_e, diags)
  u := cr.ctx.unify(cr.ty, .Bool, cond_e.span, cr.diags)

  case else_expr {
    .Some(else_e) => {
      then_r := check_block(then_block, expected, u.ctx, u.diags)

      case else_e.kind {
        .BlockExpr(block) => {
          else_r := check_block(block, expected, then_r.ctx, then_r.diags)
          .{ ctx: else_r.ctx, diags: else_r.diags }
        },
        _ => {
          else_r := then_r.ctx.check_expr(else_e, expected, then_r.diags)
          .{ ctx: else_r.ctx, diags: else_r.diags }
        },
      }
    },
    .None => {
      then_r := synth_block(then_block, u.ctx, u.diags)
      u2 := then_r.ctx.unify(.Void, expected, s, then_r.diags)
      .{ ctx: u2.ctx, diags: u2.diags }
    },
  }
}

fn has_cond_default(arms: Vector<CondArm>) Bool {
  if arms.len() == 0 {
    return false
  }

  arms[arms.len() - 1].condition.is_none()
}

fn synth_cond(arms: Vector<CondArm>, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  cur_ctx := ctx
  cur_diags := diags
  result_ty: MonoType? = .None
  deferred_arms: Vector<CondArm> = []
  has_default := has_cond_default(arms)

  for arm in arms {
    // Check condition is Bool (if not wildcard)
    case arm.condition {
      .Some(cond_expr) => {
        cr := cur_ctx.synth(cond_expr, cur_diags)
        u := cr.ctx.unify(cr.ty, MonoType.Bool, cond_expr.span, cr.diags)
        cur_ctx = u.ctx
        cur_diags = u.diags
      },
      .None => {},
    }

    if expr_needs_expected_type(arm.body) {
      deferred_arms = .append(arm)
      continue
    }

    body_r := cur_ctx.synth(arm.body, cur_diags)
    cur_ctx = body_r.ctx
    cur_diags = body_r.diags
    arm_ty := zonk(body_r.ty, cur_ctx.subst)

    case arm_ty {
      .Never => {},
      _ => case result_ty {
        .Some(rt) => {
          u := cur_ctx.unify(arm_ty, rt, arm.span, cur_diags)
          cur_ctx = u.ctx
          cur_diags = u.diags
        },
        .None => {
          result_ty = .Some(arm_ty)
        },
      },
    }
  }

  case result_ty {
    .Some(join_ty) => {
      zonked_join := zonk(join_ty, cur_ctx.subst)

      if deferred_arms.len() > 0 and !contains_meta(zonked_join) {
        for arm in deferred_arms {
          body_r := cur_ctx.check_expr(arm.body, zonked_join, cur_diags)
          cur_ctx = body_r.ctx
          cur_diags = body_r.diags
        }
      } else {
        for arm in deferred_arms {
          body_r := cur_ctx.synth(arm.body, cur_diags)
          cur_ctx = body_r.ctx
          cur_diags = body_r.diags
        }
      }

      if !has_default {
        // No default arm — result is Void (like if without else)
        .{ ty: MonoType.Void, ctx: cur_ctx, diags: cur_diags }
      } else {
        .{ ty: zonked_join, ctx: cur_ctx, diags: cur_diags }
      }
    },
    .None => {
      if deferred_arms.len() > 0 {
        for arm in deferred_arms {
          body_r := cur_ctx.synth(arm.body, cur_diags)
          cur_ctx = body_r.ctx
          cur_diags = body_r.diags
        }

        return .{ ty: MonoType.Void, ctx: cur_ctx, diags: cur_diags }
      }

      .{ ty: MonoType.Void, ctx: cur_ctx, diags: cur_diags }
    },
  }
}

fn check_cond(
  arms: Vector<CondArm>,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  cur_ctx := ctx
  cur_diags := diags
  has_default := has_cond_default(arms)

  for arm in arms {
    case arm.condition {
      .Some(cond_expr) => {
        cr := cur_ctx.synth(cond_expr, cur_diags)
        u := cr.ctx.unify(cr.ty, MonoType.Bool, cond_expr.span, cr.diags)
        cur_ctx = u.ctx
        cur_diags = u.diags
      },
      .None => {},
    }

    body_r := cur_ctx.check_expr(arm.body, expected, cur_diags)
    cur_ctx = body_r.ctx
    cur_diags = body_r.diags
  }

  if !has_default and expected != .Void {
    cur_diags = .append(.Error(.MissingCondDefault(.{ span: s })))
  }

  .{ ctx: cur_ctx, diags: cur_diags }
}

fn is_case_scrutinee_supported(ty: MonoType, ctx: InferCtx) Bool {
  zonked := expand_alias(zonk(ty, ctx.subst), ctx.env, 0)

  case zonked {
    .Int => true,
    .Bool => true,
    .String => true,
    .Byte => true,
    .Optional(_) => true,
    .Result(_, _) => true,
    .Named(tid, _) => {
      def := case ctx.env.lookup_type_def(tid) {
        .Some(d) => d,
        .None => return false,
      }

      case def {
        .Sum(_, _, _) => true,
        _ => false,
      }
    },
    _ => false,
  }
}

fn synth_case_arm(arm: CaseArm, scrut_ty: MonoType, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  arm_ctx := ctx.push_scope()
  pr := check_pattern(arm.pattern, scrut_ty, arm_ctx, diags)
  body_r := pr.ctx.synth(arm.expr, pr.diags)
  .{ ty: body_r.ty, ctx: body_r.ctx.pop_scope(), diags: body_r.diags }
}

fn check_case_arm(
  arm: CaseArm,
  scrut_ty: MonoType,
  expected: MonoType,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  arm_ctx := ctx.push_scope()
  pr := check_pattern(arm.pattern, scrut_ty, arm_ctx, diags)
  body_r := pr.ctx.check_expr(arm.expr, expected, pr.diags)
  .{ ctx: body_r.ctx.pop_scope(), diags: body_r.diags }
}

fn synth_case(scrut: Expr, arms: Vector<CaseArm>, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  sr := ctx.synth(scrut, diags)
  cur_ctx := sr.ctx
  cur_diags := sr.diags

  if !is_case_scrutinee_supported(sr.ty, cur_ctx) {
    return .{
      ty: .Void,
      ctx: cur_ctx,
      diags: cur_diags.append(
        .Error(.InvalidScrutinee(.{ span: scrut.span, ty: zonk(sr.ty, cur_ctx.subst) })),
      ),
    }
  }

  result_ty: MonoType? = .None
  deferred_arms: Vector<CaseArm> = []

  for arm in arms {
    if expr_needs_expected_type(arm.expr) {
      deferred_arms = .append(arm)
      continue
    }

    arm_r := synth_case_arm(arm, sr.ty, cur_ctx, cur_diags)
    cur_ctx = arm_r.ctx
    cur_diags = arm_r.diags
    arm_ty := zonk(arm_r.ty, cur_ctx.subst)

    case arm_ty {
      .Never => {},
      _ => case result_ty {
        .Some(rt) => {
          u := cur_ctx.unify(arm_ty, rt, arm.span, cur_diags)
          cur_ctx = u.ctx
          cur_diags = u.diags
        },
        .None => {
          result_ty = .Some(arm_ty)
        },
      },
    }
  }

  cur_diags = check_unreachable_arms(sr.ty, arms, cur_ctx, cur_diags)
  cur_diags = check_exhaustiveness(sr.ty, arms, s, cur_ctx, cur_diags)

  case result_ty {
    .Some(join_ty) => {
      zonked_join := zonk(join_ty, cur_ctx.subst)

      if deferred_arms.len() > 0 and !contains_meta(zonked_join) {
        for arm in deferred_arms {
          arm_r := check_case_arm(arm, sr.ty, zonked_join, cur_ctx, cur_diags)
          cur_ctx = arm_r.ctx
          cur_diags = arm_r.diags
        }
      } else {
        for arm in deferred_arms {
          arm_r := synth_case_arm(arm, sr.ty, cur_ctx, cur_diags)
          cur_ctx = arm_r.ctx
          cur_diags = arm_r.diags
        }
      }

      .{ ty: zonked_join, ctx: cur_ctx, diags: cur_diags }
    },
    .None => {
      if deferred_arms.len() > 0 {
        for arm in deferred_arms {
          arm_r := synth_case_arm(arm, sr.ty, cur_ctx, cur_diags)
          cur_ctx = arm_r.ctx
          cur_diags = arm_r.diags
        }

        return .{ ty: MonoType.Void, ctx: cur_ctx, diags: cur_diags }
      }

      .{ ty: MonoType.Never, ctx: cur_ctx, diags: cur_diags }
    },
  }
}

fn check_case(
  scrut: Expr,
  arms: Vector<CaseArm>,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  sr := ctx.synth(scrut, diags)
  cur_ctx := sr.ctx
  cur_diags := sr.diags

  if !is_case_scrutinee_supported(sr.ty, cur_ctx) {
    return .{
      ctx: cur_ctx,
      diags: cur_diags.append(
        .Error(.InvalidScrutinee(.{ span: scrut.span, ty: zonk(sr.ty, cur_ctx.subst) })),
      ),
    }
  }

  for arm in arms {
    arm_r := check_case_arm(arm, sr.ty, expected, cur_ctx, cur_diags)
    cur_ctx = arm_r.ctx
    cur_diags = arm_r.diags
  }

  cur_diags = check_unreachable_arms(sr.ty, arms, cur_ctx, cur_diags)
  .{ ctx: cur_ctx, diags: check_exhaustiveness(sr.ty, arms, s, cur_ctx, cur_diags) }
}

fn check_pattern(pat: Pattern, expected: MonoType, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  case pat.kind {
    .Wildcard => .{ ctx, diags },
    .Ident(name) => .{ ctx: ctx.bind_local(name, expected), diags },
    .Literal(expr) => if expected == .Byte {
      // Route through check_expr so ByteOutOfRange fires for out-of-range literals
      ctx.check_expr(expr, .Byte, diags)
    } else {
      r := ctx.synth(expr, diags)
      u := r.ctx.unify(r.ty, expected, pat.span, r.diags)
      .{ ctx: u.ctx, diags: u.diags }
    },
    .Variant(name, sub_pats) => check_variant_pattern(
      name,
      sub_pats,
      expected,
      pat.span,
      ctx,
      diags,
    ),
    .QualifiedVariant(path, name, sub_pats) => {
      // Validate that the qualifier matches the scrutinee type
      diags = .concat(validate_qualifier(path, expected, pat.span, ctx))
      check_variant_pattern(name, sub_pats, expected, pat.span, ctx, diags)
    },
    .ErrorPattern => .{ ctx, diags },
  }
}

// Returns a display name for a scrutinee type, if it's a named/sum type.
fn scrutinee_type_name(ty: MonoType, ctx: InferCtx) String? {
  zonked := expand_alias(zonk(ty, ctx.subst), ctx.env, 0)

  case zonked {
    .Optional(_) => .Some("Option"),
    .Result(_, _) => .Some("Result"),
    .Named(tid, _) => ctx.env.find_type_name(tid),
    _ => .None,
  }
}

fn qualifier_matches_scrutinee(path: Vector<String>, expected: MonoType, ctx: InferCtx) Bool {
  qualifier := path.join(".")
  zonked := expand_alias(zonk(expected, ctx.subst), ctx.env, 0)

  case zonked {
    .Optional(_) => qualifier == "Option",
    .Result(_, _) => qualifier == "Result",
    .Named(tid, _) => case resolve_named_type_id(ctx.env, qualifier) {
      .Some(qid) => qid.id == tid.id,
      .None => false,
    },
    _ => false,
  }
}

// Validate that a qualified variant path (e.g., Color in Color.Red) matches the scrutinee type.
fn validate_qualifier(path: Vector<String>, expected: MonoType, s: Span, ctx: InferCtx) Vector<
  DiagKind,
> {
  if path.len() == 0 {
    return []
  }

  qualifier := path.join(".")

  if qualifier_matches_scrutinee(path, expected, ctx) {
    return []
  }

  case scrutinee_type_name(expected, ctx) {
    .Some(type_name) => [
      .Error(.QualifierMismatch(.{ span: s, qualifier, scrutinee_type: type_name })),
    ],
    .None => [],
  }
}

fn check_variant_pattern(
  name: String,
  sub_pats: Vector<Pattern>,
  expected: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  zonked := expand_alias(zonk(expected, ctx.subst), ctx.env, 0)

  case resolve_variant_info(name, zonked, ctx.env) {
    .Some(.Ok(info)) => {
      if sub_pats.len() != info.field_types.len() {
        return .{
          ctx,
          diags: diags.append(
            .Error(
              .WrongArity(.{ span: s, expected: info.field_types.len(), found: sub_pats.len() }),
            ),
          ),
        }
      }

      cur_ctx := ctx
      cur_diags := diags

      for i in 0..sub_pats.len() {
        pr := check_pattern(sub_pats[i], info.field_types[i], cur_ctx, cur_diags)
        cur_ctx = pr.ctx
        cur_diags = pr.diags
      }

      .{ ctx: cur_ctx, diags: cur_diags }
    },
    .Some(.Err(msg)) => .{
      ctx,
      diags: diags.append(.Error(.ParseError(.{ span: s, message: msg, help_lines: [] }))),
    },
    .None => .{
      ctx,
      diags: diags.append(.Error(.VariantTypeMismatch(.{ span: s, name, ty: zonked }))),
    },
  }
}

// ── Unreachable arm detection ────────────────────────────────────────
type ArmCoverage = { CatchAll(Span), Literal(String, Span), Variant(String, Span) }

fn pattern_is_irrefutable(pat: Pattern) Bool {
  case pat.kind {
    .Wildcard => true,
    .Ident(_) => true,
    _ => false,
  }
}

fn literal_key(pat: Pattern) String? {
  case pat.kind {
    .Literal(expr) => case expr.kind {
      .IntLit(v) => .Some("int:${v}"),
      .FloatLit(v) => .Some("float:${v}"),
      .StringLit(v) => .Some("str:${v}"),
      .BoolLit(v) => .Some("bool:${v}"),
      _ => .None,
    },
    _ => .None,
  }
}

fn variant_name_from_pattern(pat: Pattern, scrut_ty: MonoType, ctx: InferCtx) String? {
  case pat.kind {
    .Variant(name, _) => .Some(name),
    .QualifiedVariant(path, name, _) => if qualifier_matches_scrutinee(path, scrut_ty, ctx) {
      .Some(name)
    } else {
      .None
    },
    _ => .None,
  }
}

fn coverage_from_pattern(pat: Pattern, scrut_ty: MonoType, ctx: InferCtx) ArmCoverage? {
  case pat.kind {
    .Wildcard => .Some(.CatchAll(pat.span)),
    .Ident(_) => .Some(.CatchAll(pat.span)),
    .Literal(_) => case literal_key(pat) {
      .Some(key) => .Some(.Literal(key, pat.span)),
      .None => .None,
    },
    .Variant(name, sub_pats) => if sub_pats.all(pattern_is_irrefutable) {
      .Some(.Variant(name, pat.span))
    } else {
      .None
    },
    .QualifiedVariant(path, name, sub_pats) => {
      if !qualifier_matches_scrutinee(path, scrut_ty, ctx) {
        return .None
      }

      if sub_pats.all(pattern_is_irrefutable) {
        .Some(.Variant(name, pat.span))
      } else {
        .None
      }
    },
    .ErrorPattern => .None,
  }
}

fn coverage_covers_pattern(cov: ArmCoverage, pat: Pattern, scrut_ty: MonoType, ctx: InferCtx) Bool {
  case cov {
    .CatchAll(_) => case pat.kind {
      .ErrorPattern => false,
      _ => true,
    },
    .Literal(key, _) => case literal_key(pat) {
      .Some(pat_key) => key == pat_key,
      .None => false,
    },
    .Variant(name, _) => case variant_name_from_pattern(pat, scrut_ty, ctx) {
      .Some(pat_name) => name == pat_name,
      .None => false,
    },
  }
}

fn check_unreachable_arms(
  scrut_ty: MonoType,
  arms: Vector<CaseArm>,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) Vector<DiagKind> {
  covered: Vector<ArmCoverage> = []

  for arm in arms {
    // Skip error patterns to avoid cascading diagnostics
    case arm.pattern.kind {
      .ErrorPattern => continue,
      _ => {},
    }

    // Check if this arm is covered by any previous coverage item
    covered_by: Span? = .None

    for cov in covered {
      if cov.coverage_covers_pattern(arm.pattern, scrut_ty, ctx) {
        covered_by = .Some(
          case cov {
            .CatchAll(s) => s,
            .Literal(_, s) => s,
            .Variant(_, s) => s,
          },
        )
        break
      }
    }

    case covered_by {
      .Some(covered_by_span) => {
        diags = .append(
          .Error(.UnreachableCaseArm(.{ span: arm.pattern.span, covered_by: covered_by_span })),
        )
      },
      .None => {
        // Only add coverage from reachable arms
        case coverage_from_pattern(arm.pattern, scrut_ty, ctx) {
          .Some(cov) => {
            covered = .append(cov)
          },
          .None => {},
        }
      },
    }
  }

  diags
}

fn check_exhaustiveness(
  scrut_ty: MonoType,
  arms: Vector<CaseArm>,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) Vector<DiagKind> {
  // Check if any arm is a wildcard or ident (covers all)
  for arm in arms {
    case arm.pattern.kind {
      .Wildcard => return diags,
      .Ident(_) => return diags,
      _ => {},
    }
  }

  variant_specs := get_variant_specs(scrut_ty, ctx)

  case variant_specs {
    .None => diags,
    .Some(specs) => {
      // Collect covered variant names from arm patterns
      covered := collect arm in arms {
        case arm.pattern.kind {
          .Variant(name, _) => name,
          .QualifiedVariant(path, name, _) => {
            // Only count as covered if qualifier matches scrutinee type
            if !qualifier_matches_scrutinee(path, scrut_ty, ctx) {
              continue
            }

            name
          },
          .Literal(lit_expr) => case lit_expr.kind {
            .BoolLit(val) => if val {
              "true"
            } else {
              "false"
            },
            _ => continue,
          },
          _ => continue,
        }
      }

      // Find uncovered variants, preserving their arities
      missing := collect spec in specs {
        if covered.any(fn(c) { c == spec.name }) {
          continue
        }

        spec
      }

      if missing.len() > 0 {
        diags.append(
          .Error(
            .MissingVariants(
              .{ span: s, scrutinee_ty: zonk(scrut_ty, ctx.subst), missing, insert_at: s.end - 1 },
            ),
          ),
        )
      } else {
        diags
      }
    },
  }
}

fn get_variant_specs(scrut_ty: MonoType, ctx: InferCtx) Vector<MissingVariant>? {
  zonked := zonk(scrut_ty, ctx.subst)

  case zonked {
    .Optional(_) => .Some([.{ name: "Some", arity: 1 }, .{ name: "None", arity: 0 }]),
    .Result(_, _) => .Some([.{ name: "Ok", arity: 1 }, .{ name: "Err", arity: 1 }]),
    .Bool => .Some([.{ name: "true", arity: 0 }, .{ name: "false", arity: 0 }]),
    .Named(tid, _) => {
      def := try ctx.env.lookup_type_def(tid)

      case def {
        .Sum(_, _, variants) => .Some(
          collect v in variants {
            .{ name: v.name, arity: v.fields.len() }
          },
        ),
        _ => .None,
      }
    },
    _ => .None,
  }
}

fn check_for(for_stmt: ForStmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  cur_ctx := ctx.push_scope()
  cur_diags := diags
  cond_r := check_optional_condition(for_stmt.condition, cur_ctx, cur_diags)
  cur_ctx = cond_r.ctx
  cur_diags = cond_r.diags

  case for_stmt.iter {
    .Some(iter_expr) => {
      ib := cur_ctx.bind_iterable_vars(
        iter_expr,
        for_stmt.pattern,
        for_stmt.index,
        "for-loop",
        cur_diags,
      )
      cur_ctx = ib.ctx
      cur_diags = ib.diags
    },
    .None => {},
  }

  // Check the body with break/continue enabled only for the loop body.
  body_ctx := cur_ctx
  body_ctx.loop_depth = body_ctx.loop_depth + 1
  body_stmts := synth_block(for_stmt.body, body_ctx, cur_diags)
  out_ctx := body_stmts.ctx.pop_scope()
  out_ctx.loop_depth = ctx.loop_depth
  .{ ctx: out_ctx, diags: body_stmts.diags }
}

type IterBindResult = .{ ctx: InferCtx, diags: Vector<DiagKind>, elem_ty: MonoType }

fn bind_iterable_vars(
  ctx: InferCtx,
  iter_expr: Expr,
  pattern: String?,
  index: String?,
  index_err_label: String,
  diags: Vector<DiagKind>,
) IterBindResult {
  ir := ctx.synth(iter_expr, diags)
  cur_ctx := ir.ctx
  cur_diags := ir.diags
  info := iterable_binding_info_of(ir.ty, iter_expr.span, cur_ctx, cur_diags)
  cur_diags = info.diags

  // Record the single iteration decision (element type + lowering mode) for this
  // iterable. Lowering consumes it directly instead of re-deriving the mode from
  // the receiver's `Var(_)` shape or a separate `method_calls` entry.
  cur_ctx.iterable_lowering[iter_expr.id] = .{ elem_ty: info.elem_ty, kind: info.kind }
  cur_ctx = .bind_optional(pattern, info.elem_ty)

  case index {
    .Some(idx_name) => if info.secondary_allowed {
      case info.secondary_ty {
        .Some(ty) => {
          cur_ctx = .bind_local(idx_name, ty)
        },
        .None => {
          cur_ctx = .bind_local(idx_name, MonoType.Int)
        },
      }
    } else {
      cur_diags = .append(.Error(.IteratorNoIndex(.{ span: iter_expr.span })))
    },
    .None => {},
  }

  .{ ctx: cur_ctx, diags: cur_diags, elem_ty: info.elem_ty }
}

fn check_optional_condition(cond_e: Expr?, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  case cond_e {
    .Some(c) => {
      cr := ctx.synth(c, diags)
      u := cr.ctx.unify(cr.ty, MonoType.Bool, c.span, cr.diags)
      .{ ctx: u.ctx, diags: u.diags }
    },
    .None => .{ ctx, diags },
  }
}

type IterableBindingInfo = .{
  elem_ty: MonoType,
  secondary_ty: MonoType?,
  secondary_allowed: Bool,
  kind: IterableLoweringKind,
  diags: Vector<DiagKind>,
}

fn single_arg_named_iterable_info(
  args: Vector<MonoType>,
  kind: IterableLoweringKind,
  s: Span,
  zonked: MonoType,
  diags: Vector<DiagKind>,
) IterableBindingInfo {
  if args.len() > 0 {
    .{ elem_ty: args[0], secondary_ty: .Some(MonoType.Int), secondary_allowed: true, kind, diags }
  } else {
    .{
      elem_ty: MonoType.Int,
      secondary_ty: .Some(MonoType.Int),
      secondary_allowed: true,
      kind,
      diags: diags.append(.Error(.NotIterable(.{ span: s, ty: zonked }))),
    }
  }
}

// Which access contract makes a type variable iterable: `IndexRead` (by index)
// takes precedence over `IntoIterator` (by `iter()`). `.None` means neither.
fn iterable_var_match(ty: MonoType, scope: Vector<ResolvedTypeParam>) ScopedContractBound? {
  case lookup_scoped_contract_bound(ty, .IndexRead, scope) {
    .Some(m) => .Some(m),
    .None => lookup_scoped_contract_bound(ty, .IntoIterator, scope),
  }
}

fn iterable_binding_info_of(ty: MonoType, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) IterableBindingInfo {
  zonked := expand_alias(zonk(ty, ctx.subst), ctx.env, 0)

  case zonked {
    .Vector(elem) => .{
      elem_ty: elem,
      secondary_ty: .Some(MonoType.Int),
      secondary_allowed: true,
      kind: .ConcreteIndexed,
      diags,
    },
    .String => .{
      elem_ty: MonoType.Byte,
      secondary_ty: .Some(MonoType.Int),
      secondary_allowed: true,
      kind: .ConcreteIndexed,
      diags,
    },
    .Dict(k, v) => .{
      elem_ty: k,
      secondary_ty: .Some(v),
      secondary_allowed: true,
      kind: .Dict,
      diags,
    },
    // A type variable iterates via an in-scope access contract: `IndexRead<E>`
    // (preferred — by index, no allocation) or, failing that, `IntoIterator<E>`
    // (driven through `iter()`). The element is the matching bound's declared `E`.
    .Var(_) => case iterable_var_match(zonked, ctx.type_var_scope) {
      .Some(m) => {
        elem_ty := if m.type_args.len() > 0 {
          m.type_args[0]
        } else {
          zonked
        }
        kind: IterableLoweringKind = case m.contract {
          .IntoIterator => .IntoIteratorContract,
          _ => .IndexReadContract,
        }
        .{ elem_ty, secondary_ty: .Some(MonoType.Int), secondary_allowed: true, kind, diags }
      },
      .None => .{
        elem_ty: MonoType.Int,
        secondary_ty: .Some(MonoType.Int),
        secondary_allowed: true,
        kind: .ConcreteIndexed,
        diags: diags.append(.Error(.NotIterable(.{ span: s, ty: zonked }))),
      },
    },
    .Named(tid, args) => case type_def_name(ctx.env, tid) {
      .Some("Range") => .{
        elem_ty: MonoType.Int,
        secondary_ty: .Some(MonoType.Int),
        secondary_allowed: true,
        kind: .Range,
        diags,
      },
      .Some("Iterator") => single_arg_named_iterable_info(args, .Iterator, s, zonked, diags),
      .Some("Set") => single_arg_named_iterable_info(args, .IntoIteratorContract, s, zonked, diags),
      .Some("Channel") => single_arg_named_iterable_info(
        args,
        .IntoIteratorContract,
        s,
        zonked,
        diags,
      ),
      _ => .{
        elem_ty: MonoType.Int,
        secondary_ty: .Some(MonoType.Int),
        secondary_allowed: true,
        kind: .ConcreteIndexed,
        diags: diags.append(.Error(.NotIterable(.{ span: s, ty: zonked }))),
      },
    },
    _ => .{
      elem_ty: MonoType.Int,
      secondary_ty: .Some(MonoType.Int),
      secondary_allowed: true,
      kind: .ConcreteIndexed,
      diags: diags.append(.Error(.NotIterable(.{ span: s, ty: zonked }))),
    },
  }
}

fn synth_collect(ce: CollectExpr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  cur_ctx := ctx.push_scope()
  cur_diags := diags

  case ce.iter {
    .Some(iter_expr) => {
      ib := cur_ctx.bind_iterable_vars(iter_expr, ce.pattern, ce.index, "collect", cur_diags)
      cur_ctx = ib.ctx
      cur_diags = ib.diags
    },
    .None => {},
  }

  cond_r := check_optional_condition(ce.condition, cur_ctx, cur_diags)
  cur_ctx = cond_r.ctx
  cur_diags = cond_r.diags
  body_ctx := cur_ctx
  body_ctx.loop_depth = body_ctx.loop_depth + 1
  body_r := synth_block(ce.body, body_ctx, cur_diags)
  out_ctx := body_r.ctx.pop_scope()
  out_ctx.loop_depth = ctx.loop_depth
  .{ ty: MonoType.Vector(body_r.ty), ctx: out_ctx, diags: body_r.diags }
}

fn check_collect(
  ce: CollectExpr,
  expected_elem: MonoType,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) CheckOut {
  cur_ctx := ctx.push_scope()
  cur_diags := diags

  case ce.iter {
    .Some(iter_expr) => {
      ib := cur_ctx.bind_iterable_vars(iter_expr, ce.pattern, ce.index, "collect", cur_diags)
      cur_ctx = ib.ctx
      cur_diags = ib.diags
    },
    .None => {},
  }

  cond_r := check_optional_condition(ce.condition, cur_ctx, cur_diags)
  cur_ctx = cond_r.ctx
  cur_diags = cond_r.diags
  body_ctx := cur_ctx
  body_ctx.loop_depth = body_ctx.loop_depth + 1
  body_r := check_block(ce.body, expected_elem, body_ctx, cur_diags)
  out_ctx := body_r.ctx.pop_scope()
  out_ctx.loop_depth = ctx.loop_depth
  .{ ctx: out_ctx, diags: body_r.diags }
}

// ── Operators ───────────────────────────────────────────────────────
fn is_numeric(ty: MonoType) Bool {
  case ty {
    .Int => true,
    .Float => true,
    .Byte => true,
    _ => false,
  }
}

fn is_string(ty: MonoType) Bool {
  case ty {
    .String => true,
    _ => false,
  }
}

fn is_int(ty: MonoType) Bool {
  case ty {
    .Int => true,
    _ => false,
  }
}

fn is_float(ty: MonoType) Bool {
  case ty {
    .Float => true,
    _ => false,
  }
}

fn is_meta_var(ty: MonoType) Bool {
  case ty {
    .MetaVar(_) => true,
    _ => false,
  }
}

fn synth_binary(op: BinOp, lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  case op {
    .Assign => synth_assign_op(lhs, rhs, s, ctx, diags),
    .LogicalAnd => synth_bool_op(lhs, rhs, s, ctx, diags),
    .LogicalOr => synth_bool_op(lhs, rhs, s, ctx, diags),
    .Eq => synth_eq_op(lhs, rhs, s, ctx, diags),
    .Ne => synth_eq_op(lhs, rhs, s, ctx, diags),
    .Range => synth_range_op(lhs, rhs, s, ctx, diags),
    .Lt => synth_cmp_op(op, lhs, rhs, s, ctx, diags),
    .Le => synth_cmp_op(op, lhs, rhs, s, ctx, diags),
    .Gt => synth_cmp_op(op, lhs, rhs, s, ctx, diags),
    .Ge => synth_cmp_op(op, lhs, rhs, s, ctx, diags),
    .BitAnd => synth_bitwise_op(lhs, rhs, s, ctx, diags),
    .BitOr => synth_bitwise_op(lhs, rhs, s, ctx, diags),
    .BitXor => synth_bitwise_op(lhs, rhs, s, ctx, diags),
    .Shl => synth_bitwise_op(lhs, rhs, s, ctx, diags),
    .Shr => synth_bitwise_op(lhs, rhs, s, ctx, diags),
    _ => synth_arith_op(op, lhs, rhs, s, ctx, diags),
  }
}

fn synth_assign_op(lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  case lhs.kind {
    .Ident(name) => {
      if ctx.pub_names.has(name) {
        return .{
          ty: MonoType.Void,
          ctx,
          diags: diags.append(.Error(.PublicRebind(.{ span: lhs.span, name }))),
        }
      }

      case ctx.lookup_local(name) {
        .Some(existing_ty) => {
          rr := ctx.check_expr(rhs, existing_ty, diags)
          .{ ty: MonoType.Void, ctx: rr.ctx, diags: rr.diags }
        },
        .None => .{
          ty: MonoType.Void,
          ctx,
          diags: diags.append(.Error(.UndefinedVar(.{ span: lhs.span, name }))),
        },
      }
    },
    .Field(base, field_name) => {
      br := ctx.synth(base, diags)
      zonked_base := expand_alias(zonk(br.ty, br.ctx.subst), br.ctx.env, 0)

      case zonked_base {
        .Named(tid, type_args) => {
          def := case br.ctx.env.lookup_type_def(tid) {
            .Some(d) => d,
            .None => return .{
              ty: MonoType.Void,
              ctx: br.ctx,
              diags: br.diags.append(.Error(.NotARecord(.{ span: lhs.span, ty: zonked_base }))),
            },
          }

          case def {
            .Record(_, type_params, fields) => case find_record_field_type(
              fields,
              type_params,
              type_args,
              field_name,
            ) {
              .Some(fty) => {
                rr := br.ctx.check_expr(rhs, fty, br.diags)
                .{ ty: MonoType.Void, ctx: rr.ctx, diags: rr.diags }
              },
              .None => .{
                ty: MonoType.Void,
                ctx: br.ctx,
                diags: br.diags.append(
                  .Error(.NoField(.{ span: lhs.span, name: field_name, ty: zonked_base })),
                ),
              },
            },
            _ => .{
              ty: MonoType.Void,
              ctx: br.ctx,
              diags: br.diags.append(.Error(.NotARecord(.{ span: lhs.span, ty: zonked_base }))),
            },
          }
        },
        _ => .{
          ty: MonoType.Void,
          ctx: br.ctx,
          diags: br.diags.append(.Error(.NotARecord(.{ span: lhs.span, ty: zonked_base }))),
        },
      }
    },
    .Index(base, idx) => {
      br := ctx.synth(base, diags)
      zonked_base := expand_alias(zonk(br.ty, br.ctx.subst), br.ctx.env, 0)

      case zonked_base {
        .Vector(elem_ty) => {
          ir := br.ctx.check_expr(idx, MonoType.Int, br.diags)
          rr := ir.ctx.check_expr(rhs, elem_ty, ir.diags)
          .{ ty: MonoType.Void, ctx: rr.ctx, diags: rr.diags }
        },
        .Dict(k_ty, v_ty) => {
          ir := br.ctx.check_expr(idx, k_ty, br.diags)
          rr := ir.ctx.check_expr(rhs, v_ty, ir.diags)
          .{ ty: MonoType.Void, ctx: rr.ctx, diags: rr.diags }
        },
        _ => .{
          ty: MonoType.Void,
          ctx: br.ctx,
          diags: br.diags.append(.Error(.NotIndexable(.{ span: base.span, ty: zonked_base }))),
        },
      }
    },
    _ => .{
      ty: MonoType.Void,
      ctx,
      diags: diags.append(.Error(.InvalidAssignTarget(.{ span: lhs.span }))),
    },
  }
}

fn synth_range_op(lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  lr := ctx.synth(lhs, diags)
  u1 := lr.ctx.unify(lr.ty, MonoType.Int, lhs.span, lr.diags)
  rr := u1.ctx.synth(rhs, u1.diags)
  u2 := rr.ctx.unify(rr.ty, MonoType.Int, rhs.span, rr.diags)
  .{ ty: MonoType.Named(TypeId.{ id: 3 }, []), ctx: u2.ctx, diags: u2.diags }
}

fn is_int_or_byte(ty: MonoType) Bool {
  case ty {
    .Int => true,
    .Byte => true,
    _ => false,
  }
}

fn synth_bitwise_op(lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  lr := ctx.synth(lhs, diags)
  rr := lr.ctx.synth(rhs, lr.diags)
  cur_ctx := rr.ctx
  cur_diags := rr.diags
  left_z := zonk(lr.ty, cur_ctx.subst)
  right_z := zonk(rr.ty, cur_ctx.subst)

  case left_z {
    .MetaVar(_) => {
      u := cur_ctx.unify(lr.ty, MonoType.Int, lhs.span, cur_diags)
      cur_ctx = u.ctx
      cur_diags = u.diags
    },
    _ => {},
  }

  case right_z {
    .MetaVar(_) => {
      u := cur_ctx.unify(rr.ty, MonoType.Int, rhs.span, cur_diags)
      cur_ctx = u.ctx
      cur_diags = u.diags
    },
    _ => {},
  }

  left_final := zonk(lr.ty, cur_ctx.subst)
  right_final := zonk(rr.ty, cur_ctx.subst)

  if is_int_or_byte(left_final) and is_int_or_byte(right_final) {
    return .{ ty: MonoType.Int, ctx: cur_ctx, diags: cur_diags }
  }

  bad_ty := if !is_int_or_byte(left_final) {
    left_final
  } else {
    right_final
  }
  .{
    ty: MonoType.Int,
    ctx: cur_ctx,
    diags: cur_diags.append(
      .Error(.InvalidOperand(.{ span: s, ty: bad_ty, operation: "bitwise operator" })),
    ),
  }
}

fn cmp_op_name(op: BinOp) String {
  case op {
    .Lt => "<",
    .Gt => ">",
    .Le => "<=",
    .Ge => ">=",
    _ => "comparison",
  }
}

fn synth_cmp_op(op: BinOp, lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  lr := ctx.synth(lhs, diags)
  rr := lr.ctx.synth(rhs, lr.diags)
  cur_ctx := rr.ctx
  cur_diags := rr.diags
  left_z := zonk(lr.ty, cur_ctx.subst)
  right_z := zonk(rr.ty, cur_ctx.subst)

  // Byte/Int cross-comparison: skip unify, just check both are numeric
  if is_int_or_byte(left_z) and is_int_or_byte(right_z) {
    return .{ ty: MonoType.Bool, ctx: cur_ctx, diags: cur_diags }
  }

  u := cur_ctx.unify(lr.ty, rr.ty, s, cur_diags)
  unified_ty := zonk(lr.ty, u.ctx.subst)
  check_ord_contract(unified_ty, op, u.ctx, u.diags, s)
}

fn check_ord_contract(
  operand_ty: MonoType,
  op: BinOp,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
  s: Span,
) SynthOut {
  zonked := expand_alias(zonk(operand_ty, ctx.subst), ctx.env, 0)

  // Defer while inference is incomplete
  if contains_meta(zonked) {
    return .{ ty: MonoType.Bool, ctx, diags }
  }

  proof := satisfies_contract(zonked, .Ord, ctx)

  case proof {
    .Ok(next_ctx) => .{ ty: MonoType.Bool, ctx: next_ctx, diags },
    .Err(reason) => .{
      ty: MonoType.Bool,
      ctx,
      diags: diags.append(
        .Error(
          .ContractViolation(
            .{ span: s, ty: zonked, contract: "Ord", owner: cmp_op_name(op), reason },
          ),
        ),
      ),
    },
  }
}

fn synth_arith_op(op: BinOp, lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  lr := ctx.synth(lhs, diags)
  rr := lr.ctx.synth(rhs, lr.diags)
  cur_ctx := rr.ctx
  cur_diags := rr.diags
  left_z := zonk(lr.ty, cur_ctx.subst)
  right_z := zonk(rr.ty, cur_ctx.subst)

  if op == .Add and (is_string(left_z) or is_string(right_z)) {
    return .{
      ty: MonoType.String,
      ctx: cur_ctx,
      diags: cur_diags.append(.Error(.StringConcatOperator(.{ span: s }))),
    }
  }

  // Int × Int → Int
  if is_int(left_z) and is_int(right_z) {
    return .{ ty: MonoType.Int, ctx: cur_ctx, diags: cur_diags }
  }

  // Float × Float → Float
  if is_float(left_z) and is_float(right_z) {
    return .{ ty: MonoType.Float, ctx: cur_ctx, diags: cur_diags }
  }

  // Byte × Byte → Int, Int × Byte → Int, Byte × Int → Int
  if is_int_or_byte(left_z) and is_int_or_byte(right_z) {
    return .{ ty: MonoType.Int, ctx: cur_ctx, diags: cur_diags }
  }

  // MetaVar × concrete: solve meta, then determine result
  case left_z {
    .MetaVar(_) => case right_z {
      .Int => {
        u := cur_ctx.unify(lr.ty, MonoType.Int, lhs.span, cur_diags)
        return .{ ty: MonoType.Int, ctx: u.ctx, diags: u.diags }
      },
      .Float => {
        u := cur_ctx.unify(lr.ty, MonoType.Float, lhs.span, cur_diags)
        return .{ ty: MonoType.Float, ctx: u.ctx, diags: u.diags }
      },
      .Byte => {
        u := cur_ctx.unify(lr.ty, MonoType.Int, lhs.span, cur_diags)
        return .{ ty: MonoType.Int, ctx: u.ctx, diags: u.diags }
      },
      _ => {},
    },
    _ => {},
  }

  case right_z {
    .MetaVar(_) => case left_z {
      .Int => {
        u := cur_ctx.unify(rr.ty, MonoType.Int, rhs.span, cur_diags)
        return .{ ty: MonoType.Int, ctx: u.ctx, diags: u.diags }
      },
      .Float => {
        u := cur_ctx.unify(rr.ty, MonoType.Float, rhs.span, cur_diags)
        return .{ ty: MonoType.Float, ctx: u.ctx, diags: u.diags }
      },
      .Byte => {
        u := cur_ctx.unify(rr.ty, MonoType.Int, rhs.span, cur_diags)
        return .{ ty: MonoType.Int, ctx: u.ctx, diags: u.diags }
      },
      _ => {},
    },
    _ => {},
  }

  // MetaVar × MetaVar: unify and return left type
  if is_meta_var(left_z) and is_meta_var(right_z) {
    u := cur_ctx.unify(lr.ty, rr.ty, s, cur_diags)
    return .{ ty: lr.ty, ctx: u.ctx, diags: u.diags }
  }

  // Error: unsupported operand types
  .{
    ty: lr.ty,
    ctx: cur_ctx,
    diags: cur_diags.append(
      .Error(.InvalidOperand(.{ span: s, ty: left_z, operation: "arithmetic operator" })),
    ),
  }
}

fn synth_bool_op(lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  lr := ctx.synth(lhs, diags)
  u1 := lr.ctx.unify(lr.ty, MonoType.Bool, lhs.span, lr.diags)
  rr := u1.ctx.synth(rhs, u1.diags)
  u2 := rr.ctx.unify(rr.ty, MonoType.Bool, rhs.span, rr.diags)
  .{ ty: MonoType.Bool, ctx: u2.ctx, diags: u2.diags }
}

type EqDirectionalResult = .{ operand_ty: MonoType, ctx: InferCtx, diags: Vector<DiagKind> }

fn try_eq_directional(
  synth_side: Expr,
  check_side: Expr,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) EqDirectionalResult? {
  // Synth one side, then try check_expr on the other with the inferred type.
  // If the entire attempt introduces no new diagnostics, use that result.
  pre_len := diags.len()
  lr := ctx.synth(synth_side, diags)

  if lr.diags.len() > pre_len {
    // Synth itself failed — bail without polluting state
    return .None
  }

  cr := lr.ctx.check_expr(check_side, lr.ty, lr.diags)

  if cr.diags.len() == pre_len {
    .Some(.{ operand_ty: lr.ty, ctx: cr.ctx, diags: cr.diags })
  } else {
    .None
  }
}

fn synth_eq_op(lhs: Expr, rhs: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  // Attempt 1: synth left, check right against left's type
  r1 := try_eq_directional(lhs, rhs, s, ctx, diags)

  case r1 {
    .Some(r) => return check_eq_contract(r.operand_ty, r.ctx, r.diags, s),
    .None => {},
  }

  // Attempt 2: synth right, check left against right's type
  r2 := try_eq_directional(rhs, lhs, s, ctx, diags)

  case r2 {
    .Some(r) => return check_eq_contract(r.operand_ty, r.ctx, r.diags, s),
    .None => {},
  }

  // Fallback: synth both, unify, allow Byte/Int cross-comparison
  lr := ctx.synth(lhs, diags)
  rr := lr.ctx.synth(rhs, lr.diags)
  left_z := zonk(lr.ty, rr.ctx.subst)
  right_z := zonk(rr.ty, rr.ctx.subst)

  if is_int_or_byte(left_z) and is_int_or_byte(right_z) {
    return .{ ty: MonoType.Bool, ctx: rr.ctx, diags: rr.diags }
  }

  u := rr.ctx.unify(lr.ty, rr.ty, s, rr.diags)
  unified_ty := zonk(lr.ty, u.ctx.subst)
  check_eq_contract(unified_ty, u.ctx, u.diags, s)
}

fn check_eq_contract(operand_ty: MonoType, ctx: InferCtx, diags: Vector<DiagKind>, s: Span) SynthOut {
  zonked := expand_alias(zonk(operand_ty, ctx.subst), ctx.env, 0)

  // Skip check for meta variables (not yet resolved), primitives (always Eq),
  // and type variables (enforced at call site via bounds, not at == site)
  if is_primitive_eq(zonked) or contains_type_var(zonked) {
    return .{ ty: MonoType.Bool, ctx, diags }
  }

  case zonked {
    .MetaVar(_) => return .{ ty: MonoType.Bool, ctx, diags },
    _ => {},
  }

  proof := satisfies_contract(zonked, .Eq, ctx)

  case proof {
    .Ok(next_ctx) => .{ ty: MonoType.Bool, ctx: next_ctx, diags },
    .Err(reason) => .{
      ty: MonoType.Bool,
      ctx,
      diags: diags.append(
        .Error(.ContractViolation(.{ span: s, ty: zonked, contract: "Eq", owner: "==", reason })),
      ),
    },
  }
}

fn is_primitive_eq(ty: MonoType) Bool {
  case ty {
    .Int => true,
    .Float => true,
    .Bool => true,
    .Byte => true,
    .String => true,
    .Void => true,
    _ => false,
  }
}

fn contains_type_var(ty: MonoType) Bool {
  case ty {
    .Var(_) => true,
    .Vector(inner) => contains_type_var(inner),
    .Dict(k, v) => contains_type_var(k) or contains_type_var(v),
    .Function(params, ret) => {
      for p in params {
        if contains_type_var(p) {
          return true
        }
      }

      contains_type_var(ret)
    },
    .Optional(inner) => contains_type_var(inner),
    .Result(ok, err) => contains_type_var(ok) or contains_type_var(err),
    .Named(_, args) => {
      for a in args {
        if contains_type_var(a) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

// `try` on a control-flow operand (if/case/cond/block): push the enclosing
// function's Result/Option shape into the operand so bare variant/.Ok/.Err
// literals in its branches resolve — synth alone never reaches them. Returns
// .None when the enclosing return isn't Result/Option, so the caller falls back
// to the synth path (which keeps the precise try-misuse diagnostics).
fn try_check_cf_operand(operand: Expr, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut? {
  case ctx.current_ret {
    .Some(ret_ty) => case zonk(ret_ty, ctx.subst) {
      .Result(_, ret_err) => {
        m := ctx.fresh_meta()
        cr := m.ctx.check_expr(operand, MonoType.Result(m.ty, ret_err), diags)
        .Some(.{ ty: zonk(m.ty, cr.ctx.subst), ctx: cr.ctx, diags: cr.diags })
      },
      .Optional(_) => {
        m := ctx.fresh_meta()
        cr := m.ctx.check_expr(operand, MonoType.Optional(m.ty), diags)
        .Some(.{ ty: zonk(m.ty, cr.ctx.subst), ctx: cr.ctx, diags: cr.diags })
      },
      _ => .None,
    },
    .None => .None,
  }
}

fn synth_unary(op: UnOp, operand: Expr, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  case op {
    .Neg => {
      r := ctx.synth(operand, diags)
      zonked := zonk(r.ty, r.ctx.subst)
      result_diags := if is_numeric(zonked) or is_meta_var(zonked) {
        r.diags
      } else {
        r.diags.append(.Error(.InvalidOperand(.{ span: s, ty: zonked, operation: "negation" })))
      }
      .{ ty: r.ty, ctx: r.ctx, diags: result_diags }
    },
    .Not => {
      r := ctx.synth(operand, diags)
      u := r.ctx.unify(r.ty, MonoType.Bool, operand.span, r.diags)
      .{ ty: MonoType.Bool, ctx: u.ctx, diags: u.diags }
    },
    .BitNot => {
      r := ctx.synth(operand, diags)
      zonked := zonk(r.ty, r.ctx.subst)

      case zonked {
        .Int => .{ ty: MonoType.Int, ctx: r.ctx, diags: r.diags },
        .Byte => .{ ty: MonoType.Int, ctx: r.ctx, diags: r.diags },
        .MetaVar(_) => {
          u := r.ctx.unify(r.ty, MonoType.Int, operand.span, r.diags)
          .{ ty: MonoType.Int, ctx: u.ctx, diags: u.diags }
        },
        _ => .{
          ty: MonoType.Int,
          ctx: r.ctx,
          diags: r.diags.append(
            .Error(.InvalidOperand(.{ span: s, ty: zonked, operation: "bitwise not" })),
          ),
        },
      }
    },
    .Try => {
      // Control-flow operands (if/case/cond/block) can't resolve bare
      // variant/.Ok/.Err literals in their branches under synth — the expected
      // type never reaches them. Check them against the enclosing Result/Option
      // shape instead (same propagation that makes return-position if/case work).
      cf_out := case operand.kind {
        .If(_, _, _) => try_check_cf_operand(operand, ctx, diags),
        .Case(_, _) => try_check_cf_operand(operand, ctx, diags),
        .Cond(_) => try_check_cf_operand(operand, ctx, diags),
        .BlockExpr(_) => try_check_cf_operand(operand, ctx, diags),
        _ => .None,
      }

      case cf_out {
        .Some(out) => out,
        .None => {
          // For a call operand, propagate the enclosing function's Result/Option
          // shape so a generic call (e.g. opt.ok_or(.Variant(...))) can solve its
          // error type — and thus resolve bare variant-literal args — before its
          // arguments are checked. synth_call captures and clears call_expected_ret,
          // so this mirrors check_expr's .Call handling and cannot leak.
          try_ctx := case operand.kind {
            .Call(_, _) => case ctx.current_ret {
              .Some(ret_ty) => case zonk(ret_ty, ctx.subst) {
                .Result(_, ret_err) => {
                  m := ctx.fresh_meta()
                  cc := m.ctx
                  cc.call_expected_ret = .Some(MonoType.Result(m.ty, ret_err))
                  cc
                },
                .Optional(_) => {
                  m := ctx.fresh_meta()
                  cc := m.ctx
                  cc.call_expected_ret = .Some(MonoType.Optional(m.ty))
                  cc
                },
                _ => ctx,
              },
              .None => ctx,
            },
            _ => ctx,
          }
          r := try_ctx.synth(operand, diags)
          zonked := zonk(r.ty, r.ctx.subst)

          case zonked {
            .Optional(inner) => {
              // try on Option: function must return Option
              try_diags := case r.ctx.current_ret {
                .Some(ret_ty) => case zonk(ret_ty, r.ctx.subst) {
                  .Optional(_) => r.diags,
                  _ => r.diags.append(
                    .Error(.TryReturnMismatch(.{ span: s, expected_kind: "Option" })),
                  ),
                },
                .None => r.diags.append(
                  .Error(.TryReturnMismatch(.{ span: s, expected_kind: "Option" })),
                ),
              }
              .{ ty: inner, ctx: r.ctx, diags: try_diags }
            },
            .Result(ok_ty, err_ty) => {
              // try on Result: function must return Result with compatible error type
              try_result: SynthOut = case r.ctx.current_ret {
                .Some(ret_ty) => case zonk(ret_ty, r.ctx.subst) {
                  .Result(_, ret_err) => {
                    u := r.ctx.unify(err_ty, ret_err, s, r.diags)

                    // Thread u.ctx so MetaVar substitutions from error unification are preserved
                    .{ ty: ok_ty, ctx: u.ctx, diags: u.diags }
                  },
                  _ => .{
                    ty: ok_ty,
                    ctx: r.ctx,
                    diags: r.diags.append(
                      .Error(.TryReturnMismatch(.{ span: s, expected_kind: "Result" })),
                    ),
                  },
                },
                .None => .{
                  ty: ok_ty,
                  ctx: r.ctx,
                  diags: r.diags.append(
                    .Error(.TryReturnMismatch(.{ span: s, expected_kind: "Result" })),
                  ),
                },
              }
              try_result
            },
            _ => {
              m := r.ctx.fresh_meta()
              .{
                ty: m.ty,
                ctx: m.ctx,
                diags: r.diags.append(.Error(.TryOperandError(.{ span: s, ty: zonked }))),
              }
            },
          }
        },
      }
    },
  }
}

fn synth_index(base: Expr, idx: Expr, expr_id: Int, s: Span, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  // `foo[a..b]` — a range literal in index position is a `Sliceable` slice, not
  // an element read. Desugar to `foo.slice(a, b)`, which returns `Self`. Only the
  // literal `a..b` form reaches here; a stepped or stored `Range` in index
  // position keeps the element-read path and is rejected by the `Int` unify below.
  case idx.kind {
    .Binary(.Range, lo, hi) => return synth_slice(base, lo, hi, expr_id, s, ctx, diags),
    _ => {},
  }

  br := ctx.synth(base, diags)
  ir := br.ctx.synth(idx, br.diags)
  zonked_base := zonk(br.ty, ir.ctx.subst)

  case zonked_base {
    .Vector(elem) => {
      u := ir.ctx.unify(ir.ty, MonoType.Int, idx.span, ir.diags)
      .{ ty: elem, ctx: u.ctx, diags: u.diags }
    },
    .Dict(k, v) => {
      u := ir.ctx.unify(ir.ty, k, idx.span, ir.diags)
      .{ ty: MonoType.Optional(v), ctx: u.ctx, diags: u.diags }
    },
    .String => {
      u := ir.ctx.unify(ir.ty, MonoType.Int, idx.span, ir.diags)
      .{ ty: MonoType.Byte, ctx: u.ctx, diags: u.diags }
    },
    // A type variable bounded `IndexRead<E>`: `c[i]` desugars to the contract's
    // `at(c, i)`. Record the contract call so lowering emits a ContractCall, and
    // type the result as the bound's declared element `E`.
    .Var(_) => case lookup_scoped_contract_bound(zonked_base, .IndexRead, ir.ctx.type_var_scope) {
      .Some(m) => {
        elem_ty := if m.type_args.len() > 0 {
          m.type_args[0]
        } else {
          zonked_base
        }
        u := ir.ctx.unify(ir.ty, MonoType.Int, idx.span, ir.diags)
        result_ctx := u.ctx
        result_ctx.method_calls[expr_id] = MethodCallInfo.{
          func_name: "",
          has_receiver: true,
          contract: .Some(m.contract),
          method_name: "at",
        }
        .{ ty: elem_ty, ctx: result_ctx, diags: u.diags }
      },
      .None => {
        m := ir.ctx.fresh_meta()
        .{
          ty: m.ty,
          ctx: m.ctx,
          diags: ir.diags.append(.Error(.NotIndexable(.{ span: s, ty: zonked_base }))),
        }
      },
    },
    _ => {
      m := ir.ctx.fresh_meta()
      .{
        ty: m.ty,
        ctx: m.ctx,
        diags: ir.diags.append(.Error(.NotIndexable(.{ span: s, ty: zonked_base }))),
      }
    },
  }
}

// `foo[a..b]` over a `Sliceable` receiver. Both bounds are `Int`; the result is
// the receiver type `Self` (a subvector / substring / sub-window). Lowering emits
// a `Sliceable.slice` contract call uniformly (see `lower_index`), which
// monomorphization resolves to the satisfier's `slice` via the method table — so
// here we only validate the receiver actually exposes a `slice` satisfier: a
// concrete type with an inherent `slice` method, or a `Sliceable`-bounded type var.
fn synth_slice(
  base: Expr,
  lo: Expr,
  hi: Expr,
  expr_id: Int,
  s: Span,
  ctx: InferCtx,
  diags: Vector<DiagKind>,
) SynthOut {
  br := ctx.synth(base, diags)
  zonked_base := zonk(br.ty, br.ctx.subst)

  lor := br.ctx.check_expr(lo, MonoType.Int, br.diags)
  hir := lor.ctx.check_expr(hi, MonoType.Int, lor.diags)
  cur_ctx := hir.ctx
  cur_diags := hir.diags

  sliceable := case zonked_base {
    .Var(_) => case lookup_scoped_contract_bound(zonked_base, .Sliceable, cur_ctx.type_var_scope) {
      .Some(_) => true,
      .None => false,
    },
    _ => case resolve_method_func_name(zonked_base, "slice", cur_ctx.env) {
      .Some(_) => true,
      .None => false,
    },
  }

  if sliceable {
    .{ ty: zonked_base, ctx: cur_ctx, diags: cur_diags }
  } else {
    .{
      ty: zonked_base,
      ctx: cur_ctx,
      diags: cur_diags.append(.Error(.NotIndexable(.{ span: s, ty: zonked_base }))),
    }
  }
}

fn check_interpolation_expr(expr: Expr, expr_ty: MonoType, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  zonked := expand_alias(zonk(expr_ty, ctx.subst), ctx.env, 0)

  case zonked {
    .String => return .{ ctx, diags },
    .MetaVar(_) => return .{ ctx, diags },
    _ => {},
  }

  proof := satisfies_contract(zonked, .Stringify, ctx)

  case proof {
    .Err(reason) => .{
      ctx,
      diags: diags.append(
        .Error(.CannotInterpolate(.{ span: expr.span, ty: zonked, reason: "to_string ${reason}" })),
      ),
    },
    .Ok(proof_ctx) => {
      info := case zonked {
        .Var(_) => MethodCallInfo.{
          func_name: "",
          has_receiver: true,
          contract: .Some(.Stringify),
          method_name: "to_string",
        },
        _ => {
          fn_name := case resolve_method_func_name(zonked, "to_string", proof_ctx.env) {
            .Some(name) => name,
            .None => case zonked {
              .Int => "int$to_string",
              .Float => "float$to_string",
              .Bool => "bool$to_string",
              .Byte => "byte$to_string",
              .String => "string$to_string",
              _ => "",
            },
          }
          MethodCallInfo.{
            func_name: fn_name,
            has_receiver: true,
            contract: .None,
            method_name: "to_string",
          }
        },
      }
      proof_ctx.method_calls[expr.id] = info
      .{ ctx: proof_ctx, diags }
    },
  }
}

fn synth_string_interp(parts: Vector<StringPart>, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  cur_ctx := ctx
  cur_diags := diags

  for part in parts {
    case part {
      .Literal(_) => {},
      .Interpolation(expr) => {
        r := cur_ctx.synth(expr, cur_diags)
        cur_ctx = r.ctx
        cur_diags = r.diags
        vr := check_interpolation_expr(expr, r.ty, cur_ctx, cur_diags)
        cur_ctx = vr.ctx
        cur_diags = vr.diags
      },
    }
  }

  .{ ty: MonoType.String, ctx: cur_ctx, diags: cur_diags }
}

// ── Block / Statement handling ──────────────────────────────────────
fn synth_block(block: Block, ctx: InferCtx, diags: Vector<DiagKind>) SynthOut {
  cur_ctx := ctx.push_scope()
  cur_diags := diags

  for stmt in block.stmts {
    r := check_stmt(stmt, cur_ctx, cur_diags)
    cur_ctx = r.ctx
    cur_diags = r.diags
  }

  case block.tail {
    .Some(tail_expr) => {
      r := cur_ctx.synth(tail_expr, cur_diags)
      .{ ty: r.ty, ctx: r.ctx.pop_scope(), diags: r.diags }
    },
    .None => {
      // If the last statement diverges, the block type is Never, not Void
      block_ty := if block.stmts.len() > 0
        and stmt_diverges(block.stmts[block.stmts.len() - 1], cur_ctx) {
        MonoType.Never
      } else {
        MonoType.Void
      }
      .{ ty: block_ty, ctx: cur_ctx.pop_scope(), diags: cur_diags }
    },
  }
}

fn check_block(block: Block, expected: MonoType, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  cur_ctx := ctx.push_scope()
  cur_diags := diags

  for stmt in block.stmts {
    r := check_stmt(stmt, cur_ctx, cur_diags)
    cur_ctx = r.ctx
    cur_diags = r.diags
  }

  case block.tail {
    .Some(tail_expr) => {
      r := cur_ctx.check_expr(tail_expr, expected, cur_diags)
      .{ ctx: r.ctx.pop_scope(), diags: r.diags }
    },
    .None => {
      // If the last statement diverges, don't unify Void with expected
      diverges := if block.stmts.len() > 0 {
        stmt_diverges(block.stmts[block.stmts.len() - 1], cur_ctx)
      } else {
        false
      }

      if diverges {
        .{ ctx: cur_ctx.pop_scope(), diags: cur_diags }
      } else {
        u := cur_ctx.unify(MonoType.Void, expected, block.span, cur_diags)
        .{ ctx: u.ctx.pop_scope(), diags: u.diags }
      }
    },
  }
}

// Check if a statement definitely diverges (all control paths return/error).
fn stmt_diverges(stmt: Stmt, ctx: InferCtx) Bool {
  case stmt {
    .Return(_) => true,
    .Break(_) => true,
    .Continue(_) => true,
    .Expr(es) => expr_diverges(es.expr, ctx),
    _ => false,
  }
}

// Check if an expression definitely diverges.
fn returns_never(sig: FunctionSig) Bool {
  case sig.ret {
    .Some(.Never) => true,
    _ => false,
  }
}

// Check if an expression definitely diverges.
fn call_diverges(callee: Expr, ctx: InferCtx) Bool {
  case callee.kind {
    .Ident(name) => {
      if name == "error" {
        return true
      }

      case ctx.env.lookup_function(name) {
        .Some(sig) => returns_never(sig),
        .None => false,
      }
    },
    .Field(base, method_name) => case base.kind {
      .Ident(alias) => {
        if !ctx.is_module_alias(alias) {
          return false
        }

        fn_name := case ctx.env.lookup_method(alias, method_name) {
          .Some(found) => found,
          .None => return false,
        }

        case ctx.env.lookup_registered_function(fn_name) {
          .Some(sig) => returns_never(sig),
          .None => false,
        }
      },
      _ => false,
    },
    _ => false,
  }
}

// Check if an expression definitely diverges.
fn expr_diverges(e: Expr, ctx: InferCtx) Bool {
  case e.kind {
    .Call(callee, _) => call_diverges(callee, ctx),
    // if cond { ... } else { ... } diverges if both branches diverge
    .If(_, then_block, else_expr) => {
      then_div := block_diverges(then_block, ctx)
      else_div := case else_expr {
        .Some(eb) => expr_diverges(eb, ctx),
        .None => false,
      }
      then_div and else_div
    },
    .BlockExpr(block) => block_diverges(block, ctx),
    _ => false,
  }
}

fn block_diverges(block: Block, ctx: InferCtx) Bool {
  case block.tail {
    .Some(tail) => expr_diverges(tail, ctx),
    .None => if block.stmts.len() > 0 {
      stmt_diverges(block.stmts[block.stmts.len() - 1], ctx)
    } else {
      false
    },
  }
}

fn invalid_control_flow(span_in: Span, message: String, help_lines: Vector<String>) DiagKind {
  .Error(.InvalidControlFlow(.{ span: span_in, message, help_lines }))
}

fn check_break_stmt(bs: BreakStmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  cur_ctx := ctx
  cur_diags := diags

  if ctx.loop_depth <= 0 {
    cur_diags = .append(
      invalid_control_flow(
        bs.span,
        "break is only valid inside a loop",
        ["remove this break or wrap it in a loop"],
      ),
    )
  }

  case bs.value {
    .Some(val) => {
      r := cur_ctx.synth(val, cur_diags)
      cur_ctx = r.ctx
      cur_diags = r.diags.append(
        invalid_control_flow(
          bs.span,
          "break with a value is not supported",
          ["write `break` without a value"],
        ),
      )
    },
    .None => {},
  }

  .{ ctx: cur_ctx, diags: cur_diags }
}

fn check_continue_stmt(cs: ContinueStmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  if ctx.loop_depth <= 0 {
    return .{
      ctx,
      diags: diags.append(
        invalid_control_flow(
          cs.span,
          "continue is only valid inside a loop",
          ["remove this continue or wrap it in a loop"],
        ),
      ),
    }
  }

  .{ ctx, diags }
}

fn check_stmt(stmt: Stmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  case stmt {
    .Let(ls) => check_let(ls, ctx, diags),
    .Expr(es) => {
      r := ctx.synth(es.expr, diags)
      .{ ctx: r.ctx.maybe_unused_value(es.expr.span, r.ty), diags: r.diags }
    },
    .Return(rs) => check_return(rs, ctx, diags),
    .For(fs) => check_for(fs, ctx, diags),
    .Break(bs) => check_break_stmt(bs, ctx, diags),
    .Continue(cs) => check_continue_stmt(cs, ctx, diags),
    .Defer(ds) => {
      r := ctx.synth(ds.expr, diags)
      deferred_ty := zonk(r.ty, r.ctx.subst)
      final_diags := case deferred_ty {
        .Never => r.diags.append(.Error(.DeferDiverge(.{ span: ds.expr.span }))),
        _ => r.diags,
      }
      .{ ctx: r.ctx, diags: final_diags }
    },
    _ => .{ ctx, diags },
  }
}

fn check_top_level_stmt(stmt: Stmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  case stmt {
    .Expr(es) => {
      r := ctx.synth(es.expr, diags)
      .{ ctx: r.ctx.maybe_unused_value(es.expr.span, r.ty), diags: r.diags }
    },
    .For(fs) => check_for(fs, ctx, diags),
    .Break(bs) => check_break_stmt(bs, ctx, diags),
    .Continue(cs) => check_continue_stmt(cs, ctx, diags),
    .Return(rs) => case rs.value {
      .Some(val) => {
        r := ctx.synth(val, diags)
        .{ ctx: r.ctx, diags: r.diags }
      },
      .None => .{ ctx, diags },
    },
    .Defer(ds) => {
      r := ctx.synth(ds.expr, diags)
      deferred_ty := zonk(r.ty, r.ctx.subst)
      final_diags := case deferred_ty {
        .Never => r.diags.append(.Error(.DeferDiverge(.{ span: ds.expr.span }))),
        _ => r.diags,
      }
      .{ ctx: r.ctx, diags: final_diags }
    },
    .Let(_) => .{ ctx, diags },
    _ => .{ ctx, diags },
  }
}

fn check_let(ls: LetStmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  if ls.is_rebind {
    if ctx.locals.len() == 1 and ctx.pub_names.has(ls.name) {
      return .{ ctx, diags: diags.append(.Error(.PublicRebind(.{ span: ls.span, name: ls.name }))) }
    }

    // Assignment: x = value — check against the existing binding type
    case ctx.lookup_local(ls.name) {
      .Some(existing_ty) => {
        val_r := ctx.check_expr(ls.value, existing_ty, diags)
        return .{ ctx: val_r.ctx, diags: val_r.diags }
      },
      .None => {
        val_r := ctx.synth(ls.value, diags)

        return .{
          ctx: val_r.ctx,
          diags: val_r.diags.append(.Error(.UndefinedVar(.{ span: ls.span, name: ls.name }))),
        }
      },
    }
  }

  // Track pub bindings
  if ls.is_pub {
    ctx.pub_names[ls.name] = true
  }

  case ls.ty {
    .Some(ty_expr) => {
      // Annotated: x: T = value — use check mode to push expected type down
      ann := resolve_annotation(ty_expr, ctx, diags)
      cr := ann.ctx.check_expr(ls.value, ann.ty, ann.diags)
      .{ ctx: cr.ctx.bind_local(ls.name, ann.ty), diags: cr.diags }
    },
    .None => {
      // Inferred: x := value
      val_r := ctx.synth(ls.value, diags)
      .{ ctx: val_r.ctx.bind_local(ls.name, val_r.ty), diags: val_r.diags }
    },
  }
}

fn check_return(rs: ReturnStmt, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  result: CheckOut = case ctx.current_ret {
    .Some(ret_ty) => case rs.value {
      .Some(val) => {
        val_r := ctx.check_expr(val, ret_ty, diags)
        .{ ctx: val_r.ctx, diags: val_r.diags }
      },
      .None => {
        u := ctx.unify(MonoType.Void, ret_ty, rs.span, diags)
        .{ ctx: u.ctx, diags: u.diags }
      },
    },
    .None => .{ ctx, diags },
  }
  result
}

// ── Function checking ───────────────────────────────────────────────
fn check_function(decl: FunctionDecl, ctx: InferCtx, diags: Vector<DiagKind>) CheckOut {
  case ctx.env.lookup_function(decl.name) {
    .Some(sig) => {
      fn_ctx := ctx.push_scope()

      // Bind parameters
      for i in 0..sig.params.len() {
        fn_ctx = .bind_local(sig.param_names[i], sig.params[i])
      }

      // Set current_ret and type_var_scope
      fn_ctx.current_ret = sig.ret
      fn_ctx.type_var_scope = sig.type_params

      // Check or synth the body. An explicit annotation checks the body
      // against it; an unannotated function (whose sig.ret is a Pass-0 meta)
      // synthesizes the body's real type — including Never for diverging bodies
      // — and binds the meta to it, so every call site (forward references,
      // recursion, top-level statements) resolves to the same inferred type.
      case decl.return_type {
        .Some(_) => case sig.ret {
          .Some(ret_ty) => {
            body_r := check_block(decl.body, ret_ty, fn_ctx, diags)
            .{ ctx: body_r.ctx.pop_scope(), diags: body_r.diags }
          },
          .None => {
            body_r := check_block(decl.body, .Void, fn_ctx, diags)
            .{ ctx: body_r.ctx.pop_scope(), diags: body_r.diags }
          },
        },
        .None => {
          body_r := synth_block(decl.body, fn_ctx, diags)
          result_ctx := body_r.ctx.pop_scope()
          inferred_ret := zonk(body_r.ty, result_ctx.subst)

          // Bind the Pass-0 meta directly (unify would not bind it for a Never
          // body), then write the concrete inferred type back to the signature
          // so lowering and later source-order lookups see it.
          bound_ctx := case sig.ret {
            .Some(.MetaVar(mid)) => result_ctx.set_subst(mid, inferred_ret),
            _ => result_ctx,
          }
          updated_fns := collect f in bound_ctx.env.functions {
            if f.name == decl.name {
              f.ret = .Some(inferred_ret)
            }

            f
          }
          bound_ctx.env = .with_functions(updated_fns)
          .{ ctx: bound_ctx, diags: body_r.diags }
        },
      }
    },
    .None => .{ ctx, diags },
  }
}

// ── Public API ──────────────────────────────────────────────────────
fn collect_module_aliases(module: Module) Dict<String, Bool> {
  builtin_module_aliases: Vector<String> = [
    "Cell",
    "Channel",
    "Dict",
    "Iterator",
    "Option",
    "Result",
    "Set",
    "Task",
    "Vector",
    "String",
    "Int",
    "Float",
    "Bool",
    "Byte",
  ]
  aliases: Dict<String, Bool> = Dict.new()

  for alias in builtin_module_aliases {
    aliases[alias] = true
  }

  for item in module.items {
    case item {
      .Use(decl) => {
        case decl.items {
          .Some(_) => continue,
          .None => {},
        }

        fallback := if decl.path.len() > 0 {
          decl.path[decl.path.len() - 1]
        } else {
          ""
        }
        alias := case decl.alias {
          .Some(name) => name,
          .None => fallback,
        }

        if alias != "" {
          aliases[alias] = true
        }
      },
      _ => {},
    }
  }

  aliases
}

pub fn check(module: Module, env: ResolvedEnv, lint_mode: Bool) CheckResult {
  ctx := empty_ctx(env, collect_module_aliases(module), lint_mode)
  cur_diags: Vector<DiagKind> = []

  // Pass 0: give every unannotated function a fresh meta-var return type. Its
  // body unifies with that meta during checking, and every call site (including
  // top-level statements and forward / recursive references) instantiates the
  // same meta — so definitions and callers agree on the return type, and the
  // final zonk resolves it. Without this, an unannotated ret defaults to Void at
  // call sites while the definition emits the body's value type, leaving a stray
  // value on the stack.
  pass0_fns: Vector<FunctionSig> = []

  for f in ctx.env.functions {
    case f.ret {
      .None => {
        fm := ctx.fresh_meta()
        ctx = fm.ctx
        f.ret = .Some(fm.ty)
      },
      .Some(_) => {},
    }

    pass0_fns = .append(f)
  }

  ctx.env = .with_functions(pass0_fns)

  // Pass 1: top-level statements/lets.
  // This makes top-level bindings available to all functions regardless of
  // source order. For unannotated lets, diagnostics are suppressed because
  // function return types may not be inferred yet (ret = None defaults to
  // Void). Pass 3 re-checks these with full type information.
  for item in module.items {
    case item {
      .Stmt(stmt) => {
        r := case stmt {
          .Let(ls) => case ls.ty {
            .Some(_) => check_let(ls, ctx, cur_diags),
            .None => {
              // Suppress diagnostics — re-checked in Pass 3
              trial := check_let(ls, ctx, [])
              .{ ctx: trial.ctx, diags: cur_diags }
            },
          },
          _ => check_top_level_stmt(stmt, ctx, cur_diags),
        }
        ctx = r.ctx
        cur_diags = r.diags
      },
      _ => {},
    }
  }

  // Pass 2: function bodies.
  diags_before_pass2 := cur_diags.len()

  for item in module.items {
    case item {
      .Function(decl) => {
        r := check_function(decl, ctx, cur_diags)
        ctx = r.ctx
        cur_diags = r.diags
      },
      _ => {},
    }
  }

  // Pass 3: re-check unannotated top-level lets.
  // Now that all function return types are inferred, re-synthesize these
  // bindings to get correct types and report real errors.
  any_type_updated := false

  for item in module.items {
    case item {
      .Stmt(.Let(ls)) => case ls.ty {
        .None => {
          r := check_let(ls, ctx, cur_diags)

          // Check if the type changed from Pass 1
          case r.ctx.lookup_local(ls.name) {
            .Some(new_ty) => case ctx.lookup_local(ls.name) {
              .Some(old_ty) => if old_ty != new_ty {
                any_type_updated = true
              },
              .None => {
                any_type_updated = true
              },
            },
            .None => {},
          }

          ctx = r.ctx
          cur_diags = r.diags
        },
        _ => {},
      },
      _ => {},
    }
  }

  // Pass 4: if any top-level let type was corrected in Pass 3, re-check
  // functions that may have seen stale types.
  if any_type_updated and cur_diags.len() > diags_before_pass2 {
    cur_diags = .slice(0, diags_before_pass2)

    for item in module.items {
      case item {
        .Function(decl) => {
          r := check_function(decl, ctx, cur_diags)
          ctx = r.ctx
          cur_diags = r.diags
        },
        _ => {},
      }
    }
  }

  // Zonk all type_map entries and detect unsolved MetaVars.
  // Deduplicate by span_start so one root ambiguity emits at most one diagnostic.
  final_map: Dict<Int, MonoType> = Dict.new()
  reported_spans: Dict<Int, Bool> = Dict.new()

  for key, ty in ctx.type_map {
    zonked := zonk_with_meta(ty, ctx.subst)
    final_map[key] = zonked.ty

    if zonked.has_meta {
      // Only report for entries with a known source position.  Entries
      // written via set_type_map (no span) are internal type-name nodes;
      // they rarely stay ambiguous and must not share bucket 0 with real
      // offset-0 expressions.
      case ctx.expr_spans[key] {
        .Some(span_start) => if !reported_spans.has(span_start) {
          reported_spans[span_start] = true
          cur_diags = .append(
            .Error(.AmbiguousType(.{ span: .{ file_id: 0, start: span_start, end: span_start } })),
          )
        },
        .None => {},
      }
    }
  }

  // Resolve inferred (meta-var) function return types so lowering reads
  // concrete signatures, consistent with the zonked call-site types above.
  zonked_fns := collect f in ctx.env.functions {
    f.ret = case f.ret {
      .Some(r) => .Some(zonk(r, ctx.subst)),
      .None => .None,
    }
    f
  }
  ctx.env = .with_functions(zonked_fns)

  // Collect pub value types from module-level scope.
  pub_values: Dict<String, MonoType> = Dict.new()

  if ctx.locals.len() > 0 {
    module_scope := ctx.locals[0]

    for name in ctx.pub_names.keys() {
      case module_scope[name] {
        .Some(ty) => pub_values[name] = zonk(ty, ctx.subst),
        .None => {},
      }
    }
  }

  .{
    type_map: final_map,
    expr_spans: ctx.expr_spans,
    env: ctx.env,
    diagnostics: cur_diags,
    method_calls: ctx.method_calls,
    pub_values,
    iterable_lowering: ctx.iterable_lowering,
    rewrites: ctx.rewrites,
    lints: ctx.lints,
  }
}
