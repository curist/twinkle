//! Core monomorphic type representation for the Twinkle compiler.
//!
//! Extracted from resolver.tw so that both lib/source/diagnostics.tw and
//! compiler/resolver.tw can import MonoType without circular dependency.

pub type TypeId = .{ id: Int }

pub type MonoType = {
  Int,
  Float,
  Bool,
  Byte,
  String,
  Void,
  Anyref_,
  ExternRef(TypeId),
  Var(String),
  Named(TypeId, Vector<MonoType>),
  Vector(MonoType),
  Dict(MonoType, MonoType),
  Function(Vector<MonoType>, MonoType),
  Optional(MonoType),
  Result(MonoType, MonoType),
  MetaVar(Int),
  Never,
  ErrorType,
}

// Build a method table key for contract resolution keyed by receiver type.
// Returns e.g. "Int::to_string", "t42::eq", "Vector::to_string".
pub fn method_table_key(receiver_ty: MonoType, method_name: String) String? {
  receiver_key: String? = case receiver_ty {
    .Int => .Some("Int"),
    .Float => .Some("Float"),
    .Bool => .Some("Bool"),
    .Byte => .Some("Byte"),
    .String => .Some("String"),
    .Vector(_) => .Some("Vector"),
    .Dict(_, _) => .Some("Dict"),
    .Optional(_) => .Some("Option"),
    .Result(_, _) => .Some("Result"),
    .Named(tid, _) => .Some("t${tid.id}"),
    .ExternRef(tid) => .Some("t${tid.id}"),
    _ => .None,
  }

  case receiver_key {
    .Some(k) => .Some("${k}::${method_name}"),
    .None => .None,
  }
}

// Debug-only type stringifier — Named types render as raw ids (e.g. "Named(3)").
// Prefer ty_to_string_env (in resolver) for user-facing diagnostics.
pub fn ty_to_string(ty: MonoType) String {
  case ty {
    .Int => "Int",
    .Float => "Float",
    .Bool => "Bool",
    .Byte => "Byte",
    .String => "String",
    .Void => "Void",
    .Anyref_ => "Anyref",
    .ExternRef(tid) => "ExternRef(${tid.id})",
    .Never => "Never",
    .Var(n) => n,
    .MetaVar(id) => "?${id}",
    .Vector(inner) => "Vector<${inner.ty_to_string()}>",
    .Dict(k, v) => "Dict<${k.ty_to_string()}, ${v.ty_to_string()}>",
    .Optional(inner) => "${inner.ty_to_string()}?",
    .Result(ok, err) => "Result<${ok.ty_to_string()}, ${err.ty_to_string()}>",
    .Named(tid, args) => if args.len() == 0 {
      "Named(${tid.id})"
    } else {
      joined := collect a in args {
        a.ty_to_string()
      }
      "Named(${tid.id})<${joined.join(", ")}>"
    },
    .Function(params, ret) => {
      joined := collect p in params {
        p.ty_to_string()
      }
      "fn(${joined.join(", ")}) ${ret.ty_to_string()}"
    },
    .ErrorType => "<error>",
  }
}
