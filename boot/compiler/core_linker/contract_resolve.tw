// Contract target resolution for DCE.
//
// Maps a (receiver_type, method_name) pair to the concrete function that
// implements the contract method for that type.
use compiler.core_ir.{FuncId}
use compiler.mono_type.{MonoType}

pub fn exact_contract_ref(
  receiver_ty: MonoType,
  method_name: String,
  method_table: Dict<String, FuncId>,
) FuncId? {
  case receiver_ty.method_table_key(method_name) {
    .Some(key) => method_table[key],
    .None => .None,
  }
}
