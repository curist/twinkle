use compiler.anf.{AnfModule}
use compiler.builtins.{BuiltinRegistry, make_builtin_registry}
use compiler.resolver.{ResolvedEnv}
use compiler.codegen.codegen.{codegen, runtime_modules}
use compiler.codegen.emit.{emit_module}
use compiler.codegen.wasm_plan.{plan_wasm_types}
use compiler.codegen.linker.{link, LinkedModule}
use compiler.backend.prepare.{prepare_backend}
use compiler.backend.closure_convert.{compute_closure_captures}
use compiler.pipeline

pub type CodegenInputs = .{
  anf: AnfModule,
  env: ResolvedEnv,
  builtins: BuiltinRegistry,
}

pub fn codegen_inputs(src: String) Result<CodegenInputs, String> {
  artifacts := try pipeline.compile_source(src)
  .Ok(CodegenInputs.{ anf: artifacts.opt, env: artifacts.env, builtins: artifacts.builtins })
}

pub fn codegen_src(src: String) Result<String, String> {
  inputs := try codegen_inputs(src)
  .Ok(codegen(inputs.anf, inputs.env, inputs.builtins))
}

pub fn codegen_path(path: String) Result<String, String> {
  artifacts := try pipeline.compile_entry_path(path)
  .Ok(codegen(artifacts.opt, artifacts.env, artifacts.builtins))
}

// Returns the linked module for structural inspection (before WAT emission).
pub fn codegen_linked(src: String) Result<LinkedModule, String> {
  inputs := try codegen_inputs(src)
  closure_captures := compute_closure_captures(inputs.anf)
  prepared := prepare_backend(inputs.anf, inputs.env, inputs.builtins, closure_captures)
  registry := plan_wasm_types(prepared, inputs.env, inputs.builtins)
  user_module := emit_module(prepared, registry, inputs.builtins, inputs.env)
  modules := runtime_modules().append(user_module)
  case link(modules, .None) {
    .Ok(linked) => .Ok(linked),
    .Err(_) => .Err("link failed"),
  }
}
