use @std.proc

use tests.helpers.codegen_harness

fn fail(msg: String) {
  eprintln(msg)
  proc.exit(1)
}

fn main() {
  args := proc.args()

  if args.len() < 2 { fail("usage: emit_boot_wat.tw <source.tw>") }

  case codegen_harness.codegen_path(args[1]) {
    .Ok(wat) => { print(wat) },
    .Err(msg) => { fail(msg) },
  }
}

main()
