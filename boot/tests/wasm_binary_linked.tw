use @std.fs
use tests.helpers.codegen_harness
use compiler.codegen.wasm.{emit_linked_wasm}

src := "
pub fn add(a: Int, b: Int) Int { a + b }
"

linked := case codegen_harness.codegen_linked(src) {
  .Ok(l) => l,
  .Err(e) => error("compile failed: ${e}"),
}

bytes := emit_linked_wasm(linked)
out := "boot/tests/wasm_binary_linked.wasm"
case fs.write_bytes(out, bytes) {
  .Ok(_) => println("wrote ${bytes.len()} bytes to ${out}"),
  .Err(_) => error("write failed"),
}
