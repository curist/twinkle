use tests.runner
use tests.suites.assert_helpers_suite
use tests.suites.semantic_suite
use tests.suites.equality_repro_suite
use tests.suites.equality_matrix_suite
use tests.suites.semantic_closure_rebinding_suite
use tests.suites.semantic_control_flow_suite
use tests.suites.api_option_result_suite
use tests.suites.api_cell_suite
use tests.suites.api_vector_suite
use tests.suites.api_string_suite
use tests.suites.api_dict_suite
use tests.suites.api_range_iterator_suite
use tests.suites.stdlib_path_suite
use tests.suites.stdlib_host_suite
use tests.suites.source_suite
use tests.suites.parser_suite
use tests.suites.resolver_suite
use tests.suites.checker_suite
use tests.suites.checker_coverage_suite
use tests.suites.core_ir_suite
use tests.suites.anf_suite
use tests.suites.anf_lower_suite
use tests.suites.anf_analysis_suite
use tests.suites.opt_builder_region_suite
use tests.suites.opt_dead_let_suite
use tests.suites.opt_const_fold_suite
use tests.suites.opt_analysis_suite
use tests.suites.opt_loop_builder_suite
use tests.suites.opt_pipeline_suite
use tests.suites.opt_liveness_suite
use tests.suites.opt_semantics_suite
use tests.suites.opt_uniqueness_suite
use tests.suites.opt_defer_elim_suite
use tests.suites.builtins_suite
use tests.suites.wasm_ir_suite
use tests.suites.wasm_layout_suite
use tests.suites.wasm_plan_suite
use tests.suites.insert_boundaries_suite
use tests.suites.slot_assign_suite
use tests.suites.backend_prepare_suite
use tests.suites.backend_repr_suite
use tests.suites.backend_verify_suite
use tests.suites.wat_suite
use tests.suites.linker_suite
use tests.suites.runtime_suite
use tests.suites.module_loader_suite
use tests.suites.dependency_graph_suite
use tests.suites.query_keys_suite
use tests.suites.imports_suite
use tests.suites.multi_module_suite
use tests.suites.base_env_guardrail_suite
use tests.suites.signature_loader_suite
use tests.suites.builtins_canonical_suite
use tests.suites.signature_drift_suite

suites := [
  assert_helpers_suite.suite(),
  semantic_suite.suite(),
  equality_repro_suite.suite(),
  equality_matrix_suite.suite(),
  semantic_closure_rebinding_suite.suite(),
  semantic_control_flow_suite.suite(),
  api_option_result_suite.suite(),
  api_cell_suite.suite(),
  api_vector_suite.suite(),
  api_string_suite.suite(),
  api_dict_suite.suite(),
  api_range_iterator_suite.suite(),
  stdlib_path_suite.suite(),
  stdlib_host_suite.suite(),
  source_suite.suite(),
  parser_suite.suite(),
  resolver_suite.suite(),
  checker_suite.suite(),
  checker_coverage_suite.suite(),
  core_ir_suite.suite(),
  anf_suite.suite(),
  anf_lower_suite.suite(),
  anf_analysis_suite.suite(),
  opt_builder_region_suite.suite(),
  opt_dead_let_suite.suite(),
  opt_const_fold_suite.suite(),
  opt_analysis_suite.suite(),
  opt_loop_builder_suite.suite(),
  opt_pipeline_suite.suite(),
  opt_liveness_suite.suite(),
  opt_semantics_suite.suite(),
  opt_uniqueness_suite.suite(),
  opt_defer_elim_suite.suite(),
  builtins_suite.suite(),
  wasm_ir_suite.suite(),
  wasm_layout_suite.suite(),
]
// Using append here avoids a current boot-compiler cast failure when a
// cross-module populated Suite value appears directly inside a vector literal.
suites = suites.append(wasm_plan_suite.suite())
suites = suites.append(backend_prepare_suite.suite())
suites = suites.append(backend_repr_suite.suite())
suites = suites.append(backend_verify_suite.suite())
// Keep extending the suite list one item at a time. This avoids backend cast
// hazards around large cross-module Suite vector literals/concat chains.
suites = suites.append(insert_boundaries_suite.suite())
suites = suites.append(slot_assign_suite.suite())
suites = suites.append(wat_suite.suite())
suites = suites.append(linker_suite.suite())
suites = suites.append(runtime_suite.suite())
suites = suites.append(module_loader_suite.suite())
suites = suites.append(dependency_graph_suite.suite())
suites = suites.append(query_keys_suite.suite())
suites = suites.append(imports_suite.suite())
suites = suites.append(multi_module_suite.suite())
suites = suites.append(base_env_guardrail_suite.suite())
suites = suites.append(signature_loader_suite.suite())
suites = suites.append(builtins_canonical_suite.suite())
suites = suites.append(signature_drift_suite.suite())

runner.run_all(suites)
