fn run_batch(suites: Vector<runner.Suite>) Void {
  runner.run_all(suites)
}

batch1: Vector<runner.Suite> = []
batch1 = batch1.append(assert_helpers_suite.suite())
batch1 = batch1.append(semantic_suite.suite())
run_batch(batch1)

