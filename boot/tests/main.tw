  api_string_suite.suite(),
  api_dict_suite.suite(),
  api_range_iterator_suite.suite(),
  stdlib_path_suite.suite(),
  stdlib_host_suite.suite(),
  source_suite.suite(),
  parser_suite.suite(),
  resolver_suite.suite(),
  checker_suite.suite(),
  checker_coverage_suite.suite(),
  core_ir_suite.suite(),
  anf_suite.suite(),
  anf_lower_suite.suite(),
  anf_analysis_suite.suite(),
  opt_builder_region_suite.suite(),
  opt_dead_let_suite.suite(),
  opt_const_fold_suite.suite(),
  opt_analysis_suite.suite(),
  opt_loop_builder_suite.suite(),
  opt_pipeline_suite.suite(),
