use tests.runner
use tests.suites.wasm_ir_suite
use tests.suites.wasm_layout_suite
use tests.suites.wasm_plan_suite
use tests.suites.insert_boundaries_suite

suites := [
  wasm_ir_suite.suite(),
  wasm_layout_suite.suite(),
]
// Using append here avoids a current boot-compiler cast failure when a
// cross-module populated Suite value appears directly inside a vector literal.
suites = suites.append(wasm_plan_suite.suite())
suites = suites.append(insert_boundaries_suite.suite())

runner.run_all(suites)
