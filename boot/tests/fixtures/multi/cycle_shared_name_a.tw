//! Cycle whose members both have a private local type named Entry.

use .cycle_shared_name_b

type Entry = .{ id: Int }

fn entry_id(entry: Entry) Int {
  entry.id
}

pub fn ping(n: Int) Int {
  local := entry_id(Entry.{ id: n })
  if n == 0 {
    local
  } else {
    cycle_shared_name_b.pong(n - 1) + local
  }
}
