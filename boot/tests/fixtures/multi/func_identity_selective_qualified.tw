/// Test: selective import and qualified import of same function converge.
/// Both "add" (selective) and "math_lib.add" (qualified) should resolve
/// to the same imported function identity.

use tests.fixtures.multi.math_lib
use tests.fixtures.multi.math_lib.{add}

fn main() {
  a := add(1, 2)
  b := math_lib.add(3, 4)
  println(Int.to_string(a + b))
}
