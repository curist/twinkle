use @std.testing.assert as assert
use @std.testing as runner

use compiler.base_env
use compiler.query.cache
use compiler.query.stage_runner
use lib.query.keys

pub fn suite() runner.Suite {
  runner
    .suite("query stage runner")
    .test(
      "parse uses cache on second run",
      fn() {
        path := "/virtual/main.tw"
        source := "x := 1\n"
        r := stage_runner.new(path, keys.hash_text(source), 0, 0, false)
        first := r.parse(cache.empty(), source, 0)
        second := r.parse(first.store, source, 0)
        try assert.is_false(first.cache_hit)
        try assert.is_true(second.cache_hit)
        try assert.equal(second.value.diagnostics.len(), 0)
        st := second.store.get_stats()
        try assert.equal(st.parse_hits, 1)
        try assert.equal(st.parse_misses, 1)
        .Ok({})
      },
    )
    .test(
      "resolve and typecheck use cache on second run",
      fn() {
        path := "/virtual/main.tw"
        source := "x := 1\n"
        r := stage_runner.new(path, keys.hash_text(source), 0, 0, false)
        parsed := r.parse(cache.empty(), source, 0)
        env := base_env.builtin_env()
        resolved1 := r.resolve(parsed.store, parsed.value, env)
        resolved2 := r.resolve(resolved1.store, parsed.value, env)
        try assert.is_false(resolved1.cache_hit)
        try assert.is_true(resolved2.cache_hit)
        try assert.equal(resolved2.value.diagnostics.len(), 0)
        typed1 := r.typecheck(resolved2.store, parsed.value, resolved2.value, false)
        typed2 := r.typecheck(typed1.store, parsed.value, resolved2.value, false)
        try assert.is_false(typed1.cache_hit)
        try assert.is_true(typed2.cache_hit)
        try assert.equal(typed2.value.diagnostics.len(), 0)
        st := typed2.store.get_stats()
        try assert.equal(st.resolve_hits, 1)
        try assert.equal(st.typecheck_hits, 1)
        .Ok({})
      },
    )
}
