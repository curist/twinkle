use tests.assert
use tests.runner

type Point = .{ x: Int, y: Int }

pub fn suite() runner.Suite {
  runner.suite("equality repros").test(
    "vector structural equality repro",
    fn() {
      a: Vector<Int> = [1, 2, 3]
      b: Vector<Int> = [1, 2, 3]
      c: Vector<Int> = [1, 2, 4]
      try assert.is_true(a == b)
      try assert.is_false(a == c)
      .Ok({})
    },
  ).test(
    "dict order-insensitive equality repro",
    fn() {
      a: Dict<String, Int> = Dict.new()
      a["left"] = 1
      a["right"] = 2
      b: Dict<String, Int> = Dict.new()
      b["right"] = 2
      b["left"] = 1
      c: Dict<String, Int> = Dict.new()
      c["left"] = 1
      c["right"] = 3
      try assert.is_true(a == b)
      try assert.is_false(a == c)
      .Ok({})
    },
  ).test(
    "typed-sum nested collection repro",
    fn() {
      a: Vector<Option<Vector<Int>>> = [.Some([1, 2]), .None, .Some([3])]
      b: Vector<Option<Vector<Int>>> = [.Some([1, 2]), .None, .Some([3])]
      c: Vector<Option<Vector<Int>>> = [.Some([1, 2]), .None, .Some([4])]
      try assert.is_true(a == b)
      try assert.is_false(a == c)
      .Ok({})
    },
  ).test(
    "record structural equality repro",
    fn() {
      same := Point.{ x: 1, y: 2 }
      other := Point.{ x: 1, y: 2 }
      same_opt_a: Option<Point> = .Some(same)
      same_opt_b: Option<Point> = .Some(same)
      other_opt: Option<Point> = .Some(other)
      try assert.is_true([same] == [same])
      try assert.is_true([same] == [other])
      try assert.is_true(same_opt_a == same_opt_b)
      try assert.is_true(same_opt_a == other_opt)
      .Ok({})
    },
  )
}
