use tests.assert
use tests.runner

type Foo = .{ x: Int }

fn hello(f: Foo) String {
  "hello foo"
}

fn double_x(f: Foo) Int {
  f.x * 2
}

type Point = .{ x: Int, y: Int }

fn translate(p: Point, dx: Int, dy: Int) Int {
  p.x + dx + p.y + dy
}

type Adder = .{ base: Int }

fn add(a: Adder, n: Int) Int {
  a.base + n
}

pub fn suite() runner.Suite {
  runner.suite("first-class method")
    .test(
      "extract and call method value",
      fn() {
        foo := Foo.{ x: 15 }
        try assert.equal(foo.hello(), "hello foo")
        f := foo.hello
        try assert.equal(f(), "hello foo")
        .Ok({})
      },
    )
    .test(
      "method value with return value",
      fn() {
        foo := Foo.{ x: 15 }
        g := foo.double_x
        try assert.equal(g(), 30)
        .Ok({})
      },
    )
    .test(
      "method value with multiple args",
      fn() {
        p := Point.{ x: 1, y: 2 }
        f := p.translate
        try assert.equal(f(1, 2), 6)
        p2 := Point.{ x: 5, y: 5 }
        g := p2.translate
        try assert.equal(g(2, 3), 15)
        .Ok({})
      },
    )
    .test(
      "builtin method values",
      fn() {
        xs := [1, 2, 3]
        f := xs.len
        try assert.equal(f(), 3)
        n := 42
        g := n.to_string
        try assert.equal(g(), "42")
        b := true
        h := b.to_string
        try assert.equal(h(), "true")
        s := "hello "
        c := s.concat
        try assert.equal(c("world"), "hello world")
        .Ok({})
      },
    )
    .test(
      "method value passed to higher-order function",
      fn() {
        adder := Adder.{ base: 10 }
        f := adder.add
        results := [1, 2, 3].map(f)
        try assert.equal(results.map(Int.to_string).join(","), "11,12,13")
        .Ok({})
      },
    )
    .test(
      "receiver evaluated exactly once",
      fn() {
        count := Cell.new(0)
        f := make_foo(count).hello
        try assert.equal(count.get(), 1)
        try assert.equal(f(), "hello foo")
        try assert.equal(count.get(), 1)
        .Ok({})
      },
    )
    .test(
      "registered method value (Vector.map)",
      fn() {
        xs := [1, 2, 3]
        f: fn(fn(Int) Int) Vector<Int> = xs.map
        doubled := f(fn(n: Int) Int { n * 2 })
        try assert.equal(doubled.map(Int.to_string).join(","), "2,4,6")
        .Ok({})
      },
    )
    .test(
      "registered method value (Vector.join)",
      fn() {
        strs := [1, 2, 3].map(Int.to_string)
        h := strs.join
        try assert.equal(h(","), "1,2,3")
        .Ok({})
      },
    )
}

fn make_foo(count: Cell<Int>) Foo {
  count.update(fn(n) { n + 1 })
  Foo.{ x: 1 }
}
