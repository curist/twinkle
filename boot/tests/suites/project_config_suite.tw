use @std.testing.assert as assert
use @std.testing as runner

use lib.project.config

pub fn suite() runner.Suite {
  runner
    .suite("project config")
    .test(
      "empty content yields defaults",
      fn() {
        cfg := try config.parse("")
        try assert.equal(cfg.name, .None)
        try assert.equal(cfg.project_entries.len(), 0)
        try assert.equal(cfg.test_entries.len(), 0)
        try assert.equal(cfg.lib_entries.len(), 0)
        .Ok({})
      },
    )
    .test(
      "legacy top-level name is accepted",
      fn() {
        cfg := try config.parse("name = \"twinkle-boot\"")
        try assert.equal(cfg.name, .Some("twinkle-boot"))
        .Ok({})
      },
    )
    .test(
      "project section name and entries parse",
      fn() {
        cfg := try config.parse(
          "[project]\nname = \"demo\"\nentries = [\"cmd/app.tw\", \"cmd/server.tw\"]\n",
        )
        try assert.equal(cfg.name, .Some("demo"))
        try assert.equal(cfg.project_entries.len(), 2)
        try assert.equal(cfg.project_entries[0], "cmd/app.tw")
        try assert.equal(cfg.project_entries[1], "cmd/server.tw")
        .Ok({})
      },
    )
    .test(
      "test section entries parse",
      fn() {
        cfg := try config.parse("[test]\nentries = [\"tests/main.tw\"]\n")
        try assert.equal(cfg.test_entries.len(), 1)
        try assert.equal(cfg.test_entries[0], "tests/main.tw")
        .Ok({})
      },
    )
    .test(
      "lib section entry shorthand parses to a one-element list",
      fn() {
        cfg := try config.parse("[lib]\nentry = \"demo.tw\"\n")
        try assert.equal(cfg.lib_entries.len(), 1)
        try assert.equal(cfg.lib_entries[0], "demo.tw")
        .Ok({})
      },
    )
    .test(
      "lib section entries list parses",
      fn() {
        cfg := try config.parse("[lib]\nentries = [\"math.tw\", \"text.tw\"]\n")
        try assert.equal(cfg.lib_entries.len(), 2)
        try assert.equal(cfg.lib_entries[0], "math.tw")
        try assert.equal(cfg.lib_entries[1], "text.tw")
        .Ok({})
      },
    )
    .test(
      "comments and blank lines are ignored",
      fn() {
        cfg := try config.parse("# a comment\n\n[project]\n  # indented comment\nname = \"x\"\n")
        try assert.equal(cfg.name, .Some("x"))
        .Ok({})
      },
    )
    .test(
      "unknown key reports an error",
      fn() {
        case config.parse("[project]\nbogus = \"y\"\n") {
          .Ok(_) => .Err("expected unknown-key error"),
          .Err(_) => .Ok({}),
        }
      },
    )
    .test(
      "malformed line reports an error",
      fn() {
        case config.parse("not a valid line") {
          .Ok(_) => .Err("expected malformed-line error"),
          .Err(_) => .Ok({}),
        }
      },
    )
    .test(
      "validate accepts project-local .tw entries",
      fn() {
        cfg := try config.parse("[test]\nentries = [\"tests/main.tw\"]\n")
        try cfg.validate()
        .Ok({})
      },
    )
    .test(
      "validate rejects non-.tw entry",
      fn() {
        cfg := try config.parse("[test]\nentries = [\"tests/main.txt\"]\n")
        case cfg.validate() {
          .Ok(_) => .Err("expected non-.tw rejection"),
          .Err(_) => .Ok({}),
        }
      },
    )
    .test(
      "validate rejects path escaping the project root",
      fn() {
        cfg := try config.parse("[project]\nentries = [\"../outside.tw\"]\n")
        case cfg.validate() {
          .Ok(_) => .Err("expected escaping-path rejection"),
          .Err(_) => .Ok({}),
        }
      },
    )
    .test(
      "load returns defaults when no twinkle.toml is present",
      fn() {
        cfg := try config.load("/nonexistent-twinkle-dir-xyz")
        try assert.equal(cfg.name, .None)
        try assert.equal(cfg.project_entries.len(), 0)
        .Ok({})
      },
    )
    .test(
      "entries unions project then test then lib entries",
      fn() {
        cfg := try config.parse(
          "[project]\nentries = [\"cmd/app.tw\"]\n[test]\nentries = [\"tests/main.tw\"]\n[lib]\nentry = \"demo.tw\"\n",
        )
        all := cfg.entries()
        try assert.equal(all.len(), 3)
        try assert.equal(all[0], "cmd/app.tw")
        try assert.equal(all[1], "tests/main.tw")
        try assert.equal(all[2], "demo.tw")
        .Ok({})
      },
    )
    .test(
      "entry_paths resolves entries against the project root",
      fn() {
        cfg := try config.parse("[test]\nentries = [\"tests/main.tw\"]\n")
        paths := cfg.entry_paths("/proj")
        try assert.equal(paths.len(), 1)
        try assert.equal(paths[0], "/proj/tests/main.tw")
        .Ok({})
      },
    )
    .test(
      "entry_paths is empty when no entries are configured",
      fn() {
        cfg := config.empty()
        try assert.equal(cfg.entry_paths("/proj").len(), 0)
        .Ok({})
      },
    )
}
