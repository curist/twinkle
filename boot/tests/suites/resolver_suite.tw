    .test(
      "user function shadows prelude function",
      fn() {
        // Pre-populate env with a "map" function (simulating prelude)
        prelude_sig := resolver.FunctionSig.{
          name: "map",
          type_params: plain_resolved_type_params(["A", "B"]),
          param_names: ["xs", "f"],
          params: [
            mono_type.MonoType.Vector(mono_type.MonoType.Var("A")),
            mono_type.MonoType.Function([mono_type.MonoType.Var("A")], mono_type.MonoType.Var("B")),
          ],
          ret: .Some(mono_type.MonoType.Vector(mono_type.MonoType.Var("B"))),
          doc: .None,
          extern_module: .None,
        }
        env := resolver.empty_env().with_functions([prelude_sig])

        // User defines their own "map" — should shadow prelude's
        src := "fn map(x: Int) Int { x }"
        result_env := try resolve_ok_with_env(src, env)

        // Lookup should find user's map (1 param of Int), not prelude's (2 params)
        case result_env.lookup_function("map") {
          .Some(sig) => {
            try assert.equal(sig.params.len(), 1)
            try assert.equal(mono_to_string(sig.params[0]), "Int")
            .Ok({})
          },
          .None => .Err("user-defined map should exist"),
        }
      },
    )
