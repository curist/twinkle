      // Should have method entry so mymod.greet(...) works via checker
      case env.methods["mymod"] {
        .Some(methods) => {
          found := false
          for m in methods { if m.method_name == "greet" { found = true } }
          try assert.is_true(found)
          .Ok({})
        },
        .None => .Err("mymod should have method entries"),
      }
    })

    .test("merge_selective_imports adds unqualified bindings", fn() {
      src := "pub fn add(a: Int, b: Int) Int { a + b }\npub fn sub(a: Int, b: Int) Int { a - b }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      items: Vector<ast.ImportItem> = [
        .Value(ast.ImportValueItem.{ name: "add", alias: .None, span: span.Span.{ file_id: 0, start: 0, end: 0 } }),
      ]

      env := resolver.empty_env()
      env = env.merge_selective_imports("math", "", exports, items)

      // "add" should be available unqualified
      try assert.is_true(resolver.has_function(env, "add"))
      // Selective imports should not expose the parent module namespace.
      try assert.is_true(!resolver.has_function(env, "sub"))
      try assert.is_true(!resolver.has_function(env, "math.add"))
      try assert.is_true(!resolver.has_function(env, "math.sub"))
      try assert.is_true(!resolver.has_function(env, "$import$.math.add"))
      .Ok({})
    })

    .test("mixed selective and aliased full import of same module reuses type id", fn() {
      src := "pub type Diagnostic = .{ message: String }\npub fn error(message: String) Diagnostic { Diagnostic.{ message } }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports_for_module(r.env, parsed.value, "test://diagnostic")

      items: Vector<ast.ImportItem> = [
        .Type(ast.ImportTypeItem.{ name: "Diagnostic", alias: .None, span: span.Span.{ file_id: 0, start: 0, end: 0 } }),
      ]

      env := resolver.empty_env()
      env = env.merge_selective_imports("diagnostic", "", exports, items)
      env = env.merge_module_exports("diag", "", exports)

      bare := try resolver.lookup_type(env, "Diagnostic").ok_or("missing selective type binding")
      aliased := try resolver.lookup_type(env, "diag.Diagnostic").ok_or("missing aliased module type binding")

      try assert.int_eq(bare.id.id, aliased.id.id)
      .Ok({})
    })

    .test("same module imported under two full aliases reuses type id", fn() {
      src := "pub type Diagnostic = .{ message: String }\npub fn error(message: String) Diagnostic { Diagnostic.{ message } }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports_for_module(r.env, parsed.value, "test://diagnostic")

      env := resolver.empty_env()
      env = env.merge_module_exports("diag_a", "", exports)
      env = env.merge_module_exports("diag_b", "", exports)

      first := try resolver.lookup_type(env, "diag_a.Diagnostic").ok_or("missing first aliased module type binding")
      second := try resolver.lookup_type(env, "diag_b.Diagnostic").ok_or("missing second aliased module type binding")

      try assert.int_eq(first.id.id, second.id.id)
      .Ok({})
    })

    .test("merge_selective_imports with alias renames", fn() {
      src := "pub fn calculate(x: Int) Int { x }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      items: Vector<ast.ImportItem> = [
        .Value(ast.ImportValueItem.{ name: "calculate", alias: .Some("calc"), span: span.Span.{ file_id: 0, start: 0, end: 0 } }),
      ]

      env := resolver.empty_env()
      env = env.merge_selective_imports("mod", "", exports, items)

      // Should be available as "calc", not "calculate"
      try assert.is_true(resolver.has_function(env, "calc"))
      try assert.is_true(!resolver.has_function(env, "calculate"))
      .Ok({})
    })

    .test("standalone selective value import does not retain hidden function bindings", fn() {
      src := "pub fn add(a: Int, b: Int) Int { a + b }\npub fn sub(a: Int, b: Int) Int { a - b }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      items: Vector<ast.ImportItem> = [
        .Value(ast.ImportValueItem.{ name: "add", alias: .None, span: span.Span.{ file_id: 0, start: 0, end: 0 } }),
      ]

      env := resolver.empty_env().merge_selective_imports("math", "", exports, items)

      try assert.is_true(resolver.has_function(env, "add"))
      try assert.is_true(!resolver.has_function(env, "math.add"))
      try assert.is_true(!resolver.has_function(env, "$import$.math.add"))

      found_registered := false
      for sig in env.functions {
        if sig.name == "math.add" {
          found_registered = true
        }
        if sig.name.starts_with("$import$.math.") {
          return .Err("unexpected hidden selective-import function retained: ${sig.name}")
        }
      }
      try assert.is_true(found_registered)

      for name in env.function_bindings.keys() {
        if name.starts_with("$import$.math.") {
          return .Err("unexpected hidden selective-import function binding retained: ${name}")
        }
      }

      .Ok({})
    })

    .test("standalone selective type import does not retain hidden import bindings", fn() {
      src := "pub type Point = .{ x: Int }\npub type Line = .{ p: Point }\npub fn id(p: Point) Point { p }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      items: Vector<ast.ImportItem> = [
        .Type(ast.ImportTypeItem.{ name: "Point", alias: .None, span: span.Span.{ file_id: 0, start: 0, end: 0 } }),
      ]

      env := resolver.empty_env()
      env = env.merge_selective_imports("geom", "", exports, items)

      try assert.is_true(resolver.has_type(env, "Point"))
      try assert.is_true(!resolver.has_type(env, "$import$.geom.Point"))
      try assert.is_true(!resolver.has_type(env, "geom.Point"))
      try assert.is_true(!resolver.has_type(env, "Line"))
      try assert.is_true(!resolver.has_type(env, "geom.Line"))
      try assert.str_eq(try resolver.find_type_name(env, resolver.TypeId.{ id: 1 }).ok_or("stored unselected type missing"), "geom.Line")

      for name in env.type_names {
        if name.starts_with("$import$.geom.") {
          return .Err("unexpected hidden selective-import stored type retained: ${name}")
        }
      }

      for name in env.type_bindings.keys() {
        if name.starts_with("$import$.geom.") {
          return .Err("unexpected hidden selective-import binding retained: ${name}")
        }
      }

      .Ok({})
    })

    .test("merge_prelude_exports adds unqualified without alias", fn() {
      src := "pub fn helper(x: Int) Int { x }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      env := resolver.empty_env()
      env = env.merge_prelude_exports("", "", exports)

      // Should be available as unqualified "helper"
      try assert.is_true(resolver.has_function(env, "helper"))
      .Ok({})
    })

    .test("merge_prelude_exports does not shadow builtins", fn() {
      // Pre-populate with a builtin "len"
      builtin_sig := resolver.FunctionSig.{
        name: "len", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.String], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      env := resolver.empty_env().with_functions([builtin_sig])

      // Create prelude export with a different "len"
      src := "pub fn len(x: Int) Int { x }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      env = env.merge_prelude_exports("", "", exports)

      // Should still have the builtin version (String param, not Int)
      case resolver.lookup_function(env, "len") {
        .Some(sig) => {
          try assert.str_eq(mono_to_string(sig.params[0]), "String")
          .Ok({})
        },
        .None => .Err("len should exist"),
      }
    })

    .test("qualified type path resolves after merge", fn() {
      // Create a module with a public type
      src := "pub type Color = .{ r: Int, g: Int, b: Int }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      // Merge into env
      env := resolver.empty_env()
      env = env.merge_module_exports("gfx", "", exports)

      // Now resolve a module that uses gfx.Color
      src2 := "type Canvas = .{ bg: gfx.Color }"
      r2 := env.resolve(parser.parse(src2, 0).value)
      try assert.int_eq(r2.diagnostics.len(), 0)
      .Ok({})
    })

    .test("merge_module_exports sets canonical function origins", fn() {
      src := "pub fn greet(name: String) String { name }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      env := resolver.empty_env()
      env = env.merge_module_exports("mymod", "test/mymod.tw", exports)

      // The registered function "mymod.greet" should have an origin
      case resolver.lookup_function_origin(env, "mymod.greet") {
        .Some(origin) => {
          try assert.str_eq(origin.module_path, "test/mymod.tw")
          try assert.str_eq(origin.func_name, "greet")
          .Ok({})
        },
        .None => .Err("expected function origin for mymod.greet"),
      }
    })

    .test("merge_selective_imports sets canonical function origins", fn() {
