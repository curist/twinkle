    .test(
      "unresolved param type is not Void",
      fn() {
        // fn foo(x: Nonexistent) Void {} — the error placeholder should not be Void
        src := "fn foo(x: Nonexistent) Void { }"
        r := resolve_src(src)

        case r.env.lookup_function("foo") {
          .Some(sig) => {
            param_str := mono_to_string(sig.params[0])

            // param should be an error placeholder, NOT "Void"
            if param_str == "Void" {
              return .Err(
                "error placeholder should not be Void (indistinguishable from real Void return)",
              )
            }

            // return type SHOULD be actual Void
            ret_str := case sig.ret {
              .Some(ty) => mono_to_string(ty),
              .None => "(none)",
            }
            try assert.equal(ret_str, "Void")
            .Ok({})
          },
          .None => .Err("function foo should be registered"),
        }
      },
    )
