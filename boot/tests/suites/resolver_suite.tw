    // ── Module exports & merging ──

    .test("extract_exports finds pub types", fn() {
      src := "pub type Foo = .{ x: Int }\ntype Bar = .{ y: Bool }\npub type Baz = .{ z: String }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)
      try assert.int_eq(exports.visible_types.len(), 2)
      try assert.int_eq(exports.support_types.len(), 0)
      // Should have Foo and Baz, not Bar
      names: Vector<String> = collect et in exports.visible_types { et.name }
      try assert.vec_contains(names, "Foo")
      try assert.vec_contains(names, "Baz")
      .Ok({})
    })

    .test("extract_exports separates support-only imported types", fn() {
      tid := resolver.TypeId.{ id: 11 }
      entry := resolver.TypeEntry.{
        id: tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Alias("dep.Support", [], resolver.MonoType.Int)),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      sig := resolver.FunctionSig.{
        name: "expose", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Named(tid, [])], ret: .Some(resolver.MonoType.Named(tid, [])),
        doc: .None,
    extern_module: .None,
}
      parsed := parser.parse("pub fn expose(x: Int) Int { x }", 0)
      env := resolver.empty_env().register_type_entry(entry, "dep.Support").with_functions([sig])

      exports := resolver.extract_exports(env, parsed.value)

      try assert.int_eq(exports.visible_types.len(), 0)
      try assert.int_eq(exports.support_types.len(), 1)
      try assert.str_eq(exports.support_types[0].name, "dep.Support")
      .Ok({})
    })

    .test("extract_exports includes transitive support-only imported types", fn() {
      inner_tid := resolver.TypeId.{ id: 21 }
      outer_tid := resolver.TypeId.{ id: 22 }
      inner_entry := resolver.TypeEntry.{
        id: inner_tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Record("dep.Inner", [], [
          resolver.ResolvedField.{ name: "value", ty: resolver.MonoType.Int },
        ])),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      outer_entry := resolver.TypeEntry.{
        id: outer_tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Record("dep.Outer", [], [
          resolver.ResolvedField.{ name: "inner", ty: resolver.MonoType.Named(inner_tid, []) },
        ])),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      sig := resolver.FunctionSig.{
        name: "expose", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Named(outer_tid, [])], ret: .Some(resolver.MonoType.Named(outer_tid, [])),
        doc: .None,
    extern_module: .None,
}
      parsed := parser.parse("pub fn expose(x: Int) Int { x }", 0)
      env := resolver.empty_env()
        .register_type_entry(inner_entry, "dep.Inner")
        .register_type_entry(outer_entry, "dep.Outer")
        .with_functions([sig])

      exports := resolver.extract_exports(env, parsed.value)

      try assert.int_eq(exports.visible_types.len(), 0)
      try assert.int_eq(exports.support_types.len(), 2)
      names: Vector<String> = collect et in exports.support_types { et.name }
      try assert.vec_contains(names, "dep.Inner")
      try assert.vec_contains(names, "dep.Outer")
      .Ok({})
    })

    .test("extract_exports includes support types referenced by visible exported type definitions", fn() {
      support_tid := resolver.TypeId.{ id: 23 }
      wrapper_tid := resolver.TypeId.{ id: 24 }
      support_entry := resolver.TypeEntry.{
        id: support_tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Record("dep.Support", [], [
          resolver.ResolvedField.{ name: "value", ty: resolver.MonoType.Int },
        ])),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      wrapper_entry := resolver.TypeEntry.{
        id: wrapper_tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Record("Wrapper", [], [
          resolver.ResolvedField.{ name: "inner", ty: resolver.MonoType.Named(support_tid, []) },
        ])),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      parsed := parser.parse("pub type Wrapper = .{ inner: Int }", 0)
      env := resolver.empty_env()
        .register_type_entry(support_entry, "dep.Support")
        .add_type(wrapper_entry, "Wrapper")

      exports := resolver.extract_exports(env, parsed.value)

      try assert.int_eq(exports.visible_types.len(), 1)
      try assert.str_eq(exports.visible_types[0].name, "Wrapper")
      try assert.int_eq(exports.support_types.len(), 1)
      try assert.str_eq(exports.support_types[0].name, "dep.Support")
      .Ok({})
    })

