    .test(
      "H3 record with bad field preserves field count",
      fn() {
        src := "type Foo = .{ x: Int, y: Nonexistent, z: Bool }"
        r := resolve_src(src)

        // Should have a diagnostic for the bad type
        try assert.is_true(r.diagnostics.len() > 0)

        // The record should still have 3 fields (y with ErrorType, not skipped)
        case r.env.lookup_type("Foo") {
          .Some(entry) => case entry.def {
            .Some(def) => case def {
              .Record(_, _, fields) => {
                try assert.equal(fields.len(), 3)
                try assert.equal(mono_to_string(fields[0].ty), "Int")
                try assert.equal(mono_to_string(fields[1].ty), "<error>")
                try assert.equal(mono_to_string(fields[2].ty), "Bool")
                .Ok({})
              },
              _ => .Err("expected Record"),
            },
            .None => .Err("expected def to be populated"),
          },
          .None => .Err("Foo not found"),
        }
      },
    )
    .test(
      "H3 sum variant with bad field preserves field count",
      fn() {
        src := "type Shape = { Circle(Nonexistent), Rect(Float, Float) }"
        r := resolve_src(src)
        try assert.is_true(r.diagnostics.len() > 0)

        case r.env.lookup_type("Shape") {
          .Some(entry) => case entry.def {
            .Some(def) => case def {
              .Sum(_, _, variants) => {
                // Circle should have 1 field (ErrorType), not 0
                try assert.equal(variants[0].fields.len(), 1)
                try assert.equal(mono_to_string(variants[0].fields[0]), "<error>")

                // Rect should still have 2 fields
                try assert.equal(variants[1].fields.len(), 2)
                .Ok({})
              },
              _ => .Err("expected Sum"),
            },
            .None => .Err("expected def to be populated"),
          },
          .None => .Err("Shape not found"),
        }
      },
    )
