    .test(
      "merge_selective_imports adds unqualified bindings",
      fn() {
        src := "pub fn add(a: Int, b: Int) Int { a + b }\npub fn sub(a: Int, b: Int) Int { a - b }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports(parsed.value)
        items: Vector<ast.ImportItem> = [
          .Value(
            ast.ImportValueItem.{
              name: "add",
              alias: .None,
              span: span.Span.{ file_id: 0, start: 0, end: 0 },
            },
          ),
        ]
        env := resolver.empty_env()
        env = .merge_selective_imports("math", "", exports, items)

        // "add" should be available unqualified
        try assert.is_true(env.has_function("add"))

        // Selective imports should not expose the parent module namespace.
        try assert.is_true(!env.has_function("sub"))
        try assert.is_true(!env.has_function("math.add"))
        try assert.is_true(!env.has_function("math.sub"))
        try assert.is_true(!env.has_function("$import$.math.add"))
        .Ok({})
      },
    )
    .test(
      "mixed selective and aliased full import of same module reuses type id",
      fn() {
        src := "pub type Diagnostic = .{ message: String }\npub fn error(message: String) Diagnostic { Diagnostic.{ message } }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports_for_module(parsed.value, "test://diagnostic", Dict.new())
        items: Vector<ast.ImportItem> = [
          .Type(
            ast.ImportTypeItem.{
              name: "Diagnostic",
              alias: .None,
              span: span.Span.{ file_id: 0, start: 0, end: 0 },
            },
          ),
        ]
        env := resolver.empty_env()
        env = .merge_selective_imports("diagnostic", "", exports, items)
        env = .merge_module_exports("diag", "", exports)
        bare := try env.lookup_type("Diagnostic").ok_or("missing selective type binding")
        aliased := try env
          .lookup_type("diag.Diagnostic")
          .ok_or("missing aliased module type binding")
        try assert.equal(bare.id.id, aliased.id.id)
        .Ok({})
      },
    )
    .test(
      "same module imported under two full aliases reuses type id",
      fn() {
        src := "pub type Diagnostic = .{ message: String }\npub fn error(message: String) Diagnostic { Diagnostic.{ message } }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports_for_module(parsed.value, "test://diagnostic", Dict.new())
        env := resolver.empty_env()
        env = .merge_module_exports("diag_a", "", exports)
        env = .merge_module_exports("diag_b", "", exports)
        first := try env
          .lookup_type("diag_a.Diagnostic")
          .ok_or("missing first aliased module type binding")
        second := try env
          .lookup_type("diag_b.Diagnostic")
          .ok_or("missing second aliased module type binding")
        try assert.equal(first.id.id, second.id.id)
        .Ok({})
      },
    )
