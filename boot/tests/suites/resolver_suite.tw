          try assert.is_true(found)
          .Ok({})
        },
        .None => .Err("Point should have methods"),
      }
    })

    .test("extract_exports includes support method functions for exported support types", fn() {
      env_tid := resolver.TypeId.{ id: 31 }
      env_entry := resolver.TypeEntry.{
        id: env_tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Record("dep.Env", [], [
          resolver.ResolvedField.{ name: "value", ty: resolver.MonoType.Int },
        ])),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      make_sig := resolver.FunctionSig.{
        name: "make_env", type_params: [], param_names: [],
        params: [], ret: .Some(resolver.MonoType.Named(env_tid, [])),
        doc: .None,
    extern_module: .None,
}
      resolve_sig := resolver.FunctionSig.{
        name: "dep.resolve", type_params: [], param_names: ["env"],
        params: [resolver.MonoType.Named(env_tid, [])], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      env := resolver.empty_env()
        .register_type_entry(env_entry, "dep.Env")
        .add_function(make_sig)
        .register_function(resolve_sig)
        .register_bound_methods("dep.Env", [resolver.MethodEntry.{ method_name: "resolve", function_name: "dep.resolve" }])
        .register_receiver_methods(env_tid, [resolver.MethodEntry.{ method_name: "resolve", function_name: "dep.resolve" }])

      parsed := parser.parse("pub fn make_env() Int { 0 }", 0)
      exports := resolver.extract_exports(env, parsed.value)

      try assert.int_eq(exports.support_types.len(), 1)
      try assert.str_eq(exports.support_types[0].name, "dep.Env")
      try assert.int_eq(exports.support_functions.len(), 1)
      try assert.str_eq(exports.support_functions[0].name, "dep.resolve")
      case exports.methods["dep.Env"] {
        .Some(methods) => {
          found := false
          for m in methods {
            if m.method_name == "resolve" and m.function_name == "dep.resolve" { found = true }
          }
          try assert.is_true(found)
          .Ok({})
        },
        .None => .Err("dep.Env should have support methods"),
      }
    })

    .test("merge_module_exports adds qualified types", fn() {
      // Create exports with a type
      src := "pub type Foo = .{ x: Int }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      // Merge into a fresh env under alias "m"
      env := resolver.empty_env()
      env = env.merge_module_exports("m", "", exports)

      // Should be able to look up "m.Foo"
      try assert.is_true(resolver.has_type(env, "m.Foo"))
      // But not bare "Foo"
      try assert.is_true(!resolver.has_type(env, "Foo"))
      .Ok({})
    })

    .test("merge_module_exports registers support types without binding them", fn() {
      tid := resolver.TypeId.{ id: 13 }
      entry := resolver.TypeEntry.{
        id: tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Alias("dep.Support", [], resolver.MonoType.Int)),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }
      sig := resolver.FunctionSig.{
        name: "expose", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Named(tid, [])], ret: .Some(resolver.MonoType.Named(tid, [])),
        doc: .None,
    extern_module: .None,
}
      exports := resolver.ModuleExports.{
        visible_types: [],
        support_types: [resolver.ExportedType.{ name: "dep.Support", entry, origin: .Some("dep::Support") }],
        functions: [resolver.ExportedFunction.{ name: "expose", sig, source_name: "expose", origin: .None }],
        support_functions: [],
        methods: Dict.new(),
      }

      env := resolver.empty_env().merge_module_exports("mod", "", exports)

      try assert.is_true(!resolver.has_type(env, "dep.Support"))
      try assert.is_true(resolver.has_function(env, "mod.expose"))
      try assert.str_eq(try resolver.find_type_name(env, resolver.TypeId.{ id: 0 }).ok_or("support type missing"), "dep.Support")
      .Ok({})
    })

    .test("merge_module_exports adds qualified functions to method table", fn() {
      src := "pub fn greet(name: String) String { name }"
      parsed := parser.parse(src, 0)
