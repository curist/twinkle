    .test(
      "standalone selective value import does not retain hidden function bindings",
      fn() {
        src := "pub fn add(a: Int, b: Int) Int { a + b }\npub fn sub(a: Int, b: Int) Int { a - b }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports(parsed.value)
        items: Vector<ast.ImportItem> = [
          .Value(
            ast.ImportValueItem.{
              name: "add",
              alias: .None,
              span: span.Span.{ file_id: 0, start: 0, end: 0 },
            },
          ),
        ]
        env := resolver.empty_env().merge_selective_imports("math", "", exports, items)
        try assert.is_true(env.has_function("add"))
        try assert.is_true(!env.has_function("math.add"))
        try assert.is_true(!env.has_function("$import$.math.add"))
        found_registered := false

        for sig in env.functions {
          if sig.name == "math.add" {
            found_registered = true
          }

          if sig.name.starts_with("$import$.math.") {
            return .Err("unexpected hidden selective-import function retained: ${sig.name}")
          }
        }

        try assert.is_true(found_registered)

        for name in env.function_bindings.keys() {
          if name.starts_with("$import$.math.") {
            return .Err("unexpected hidden selective-import function binding retained: ${name}")
          }
        }

        .Ok({})
      },
    )
    .test(
      "standalone selective type import does not retain hidden import bindings",
      fn() {
        src := "pub type Point = .{ x: Int }\npub type Line = .{ p: Point }\npub fn id(p: Point) Point { p }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports(parsed.value)
        items: Vector<ast.ImportItem> = [
          .Type(
            ast.ImportTypeItem.{
              name: "Point",
              alias: .None,
              span: span.Span.{ file_id: 0, start: 0, end: 0 },
            },
          ),
        ]
        env := resolver.empty_env()
        env = .merge_selective_imports("geom", "", exports, items)
        try assert.is_true(env.has_type("Point"))
        try assert.is_true(!env.has_type("$import$.geom.Point"))
        try assert.is_true(!env.has_type("geom.Point"))
        try assert.is_true(!env.has_type("Line"))
        try assert.is_true(!env.has_type("geom.Line"))
        try assert.equal(
          try env.find_type_name(mono_type.TypeId.{ id: 1 }).ok_or("stored unselected type missing"),
          "geom.Line",
        )

        for name in env.type_names {
          if name.starts_with("$import$.geom.") {
            return .Err("unexpected hidden selective-import stored type retained: ${name}")
          }
        }

        for name in env.type_bindings.keys() {
          if name.starts_with("$import$.geom.") {
            return .Err("unexpected hidden selective-import binding retained: ${name}")
          }
        }

        .Ok({})
      },
    )
