    // ── Issue 6: Duplicate method deduplication ──
    .test("duplicate builtin methods are deduplicated", fn() {
      env := resolver.empty_env().register_builtin_methods()
      env = env.register_builtin_methods()
      // String.len should exist exactly once, not duplicated
      case env.methods["String"] {
        .Some(entries) => {
          count := 0
          for e in entries {
            if e.method_name == "len" { count = count + 1 }
