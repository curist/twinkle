          span: span.Span.{ file_id: 0, start: 0, end: 0 },
          is_extern: false,
        }
        make_sig := resolver.FunctionSig.{
          name: "make_env",
          type_params: [],
          param_names: [],
          params: [],
          ret: .Some(mono_type.MonoType.Named(env_tid, [])),
          doc: .None,
          extern_module: .None,
        }
        resolve_sig := resolver.FunctionSig.{
          name: "dep.resolve",
          type_params: [],
          param_names: ["env"],
          params: [mono_type.MonoType.Named(env_tid, [])],
          ret: .Some(mono_type.MonoType.Int),
          doc: .None,
          extern_module: .None,
        }
