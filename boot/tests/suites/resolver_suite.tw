    .test("extract_exports includes inherent methods", fn() {
      src := "pub type Point = .{ x: Int, y: Int }\npub fn translate(p: Point, dx: Int) Point { Point.{ x: p.x + dx, y: p.y } }"
      parsed := parser.parse(src, 0)
