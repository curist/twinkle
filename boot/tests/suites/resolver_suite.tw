              name: "add",
              alias: .None,
              span: span.Span.{ file_id: 0, start: 0, end: 0 },
            },
          ),
        ]
        env := resolver.empty_env()
        env = .merge_selective_imports("math", "test/math.tw", exports, items)

        // The registered function "math.add" should have an origin
        case env.lookup_function_origin("math.add") {
          .Some(origin) => {
            try assert.equal(origin.module_path, "test/math.tw")
            try assert.equal(origin.func_name, "add")
            .Ok({})
          },
          .None => .Err("expected function origin for math.add"),
        }
      },
    )
    .test(
      "merge_prelude_exports sets canonical function origins",
      fn() {
        src := "pub fn filter(v: Vector<Int>) Vector<Int> { v }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports(parsed.value)
        root := loader.find_project_root("boot")
        roots := imports.make_canonical_roots(root)
        prelude_vector := imports.canonical_module_path(
          "${loader.resolve_prelude_root()}/vector.tw",
          roots,
        )
        env := resolver.empty_env()
        env = .merge_prelude_exports("__prelude_vector", prelude_vector, exports)

        case env.lookup_function_origin("filter") {
          .Some(origin) => {
            try assert.equal(origin.module_path, prelude_vector)
            try assert.equal(origin.func_name, "filter")
            .Ok({})
          },
          .None => .Err("expected function origin for prelude filter"),
        }
      },
    )
    .test(
      "local function shadows prelude origin",
      fn() {
        src := "pub fn filter(v: Vector<Int>) Vector<Int> { v }"
        parsed := parser.parse(src, 0)
        r := resolver.empty_env().resolve(parsed.value)
        exports := r.env.extract_exports(parsed.value)
        env := resolver.empty_env()
        env = .merge_prelude_exports("__prelude_vector", "prelude/vector.tw", exports)

        // Verify origin exists
        try assert.is_some(env.lookup_function_origin("filter"))

        // Now add a local function that shadows it
        env = .add_function(
          resolver.FunctionSig.{
            name: "filter",
            type_params: [],
            param_names: ["x"],
            params: [mono_type.MonoType.Int],
            ret: .Some(mono_type.MonoType.Int),
            doc: .None,
            extern_module: .None,
          },
        )

        // Origin should be cleared for the now-local function
        case env.lookup_function_origin("filter") {
          .Some(_) => .Err("expected stale origin to be cleared after local shadow"),
          .None => .Ok({}),
        }
      },
    )
    .test(
      "with_functions drops origins for removed registered targets",
      fn() {
        imported := resolver.FunctionSig.{
          name: "filter",
          type_params: [],
          param_names: ["x"],
          params: [mono_type.MonoType.Int],
          ret: .Some(mono_type.MonoType.Int),
          doc: .None,
          extern_module: .None,
        }
        local := resolver.FunctionSig.{
          name: "local_only",
          type_params: [],
          param_names: [],
          params: [],
          ret: .Some(mono_type.MonoType.Void),
          doc: .None,
          extern_module: .None,
        }
        env := resolver
          .empty_env()
          .with_functions([imported, local])
          .set_function_origin("filter", .{ module_path: "prelude/vector.tw", func_name: "filter" })
        try assert.is_some(env.lookup_function_origin("filter"))
        env = .with_functions([local])

        case env.lookup_function_origin("filter") {
          .Some(_) => .Err("expected removed function origin to be dropped by with_functions"),
          .None => .Ok({}),
        }
      },
    )
    .test(
      "merge_module_exports preserves original defining origin across re-export metadata",
      fn() {
        sig := resolver.FunctionSig.{
          name: "foo",
          type_params: [],
          param_names: ["x"],
          params: [mono_type.MonoType.Int],
          ret: .Some(mono_type.MonoType.Int),
          doc: .None,
          extern_module: .None,
        }
        exports := resolver.ModuleExports.{
          doc: .None,
          visible_types: [],
          support_types: [],
          functions: [
            resolver.ExportedFunction.{
              name: "foo",
              sig,
              source_name: "foo",
              origin: .Some(.{ module_path: "test/a.tw", func_name: "foo" }),
            },
          ],
          support_functions: [],
          methods: Dict.new(),
          values: [],
        }
        env := resolver.empty_env().merge_module_exports("bridge", "test/b.tw", exports)

        case env.lookup_function_origin("bridge.foo") {
          .Some(origin) => {
            try assert.equal(origin.module_path, "test/a.tw")
            try assert.equal(origin.func_name, "foo")
            .Ok({})
          },
          .None => .Err("expected re-exported function to preserve original defining origin"),
        }
      },
    )
    .test(
      "merge_module_exports preserves support function origins",
      fn() {
        helper_sig := resolver.FunctionSig.{
          name: "helper",
          type_params: [],
          param_names: ["x"],
          params: [mono_type.MonoType.Int],
          ret: .Some(mono_type.MonoType.Int),
          doc: .None,
          extern_module: .None,
        }
        exports := resolver.ModuleExports.{
          doc: .None,
          visible_types: [],
          support_types: [],
          functions: [],
          support_functions: [
            resolver.ExportedFunction.{
              name: "helper",
              sig: helper_sig,
              source_name: "helper",
              origin: .Some(.{ module_path: "test/support.tw", func_name: "helper" }),
            },
          ],
          methods: Dict.new(),
          values: [],
        }
        env := resolver.empty_env().merge_module_exports("support_mod", "test/bridge.tw", exports)

        case env.lookup_function_origin("support_mod.helper") {
          .Some(origin) => {
            try assert.equal(origin.module_path, "test/support.tw")
            try assert.equal(origin.func_name, "helper")
            .Ok({})
          },
          .None => .Err("expected support function to preserve canonical origin"),
        }
      },
    )
    .test(
      "extern type resolves in extern function signatures",
      fn() {
        src := "extern dom type Element\nextern dom { fn get_element(id: String) Element fn set_text(el: Element, text: String) }"
        env := try resolve_ok(src)
        try assert.is_true(env.has_type("Element"))
        try assert.equal(
          try get_return_type(env, "dom.get_element"),
          "ExternRef(${try type_id_of(env, "Element")})",
        )
        try assert.equal(
          try get_param_type(env, "dom.set_text", 0),
          "ExternRef(${try type_id_of(env, "Element")})",
        )
        .Ok({})
      },
    )
    .test(
      "Option of extern type is accepted",
      fn() {
        env := try resolve_ok("extern dom type Element\ntype MaybeElement = Element?")
        try assert.is_true(env.has_type("MaybeElement"))
        .Ok({})
      },
    )
    .test(
      "anon record variant synthesizes record type",
      fn() {
        src := "type Foo = { Bar(.{ x: Int, y: String }) }"
        env := try resolve_ok(src)

        // The parent enum should exist
        try assert.is_true(env.has_type("Foo"))

        // The synthesized record type should be findable by display name
        try assert.equal(try get_field_type(env, "Foo.Bar", "x"), "Int")
        try assert.equal(try get_field_type(env, "Foo.Bar", "y"), "String")
        .Ok({})
      },
    )
    .test(
      "anon record variant payload is Named(synth_tid)",
      fn() {
        src := "type Foo = { Bar(.{ x: Int }), Baz(Int) }"
        env := try resolve_ok(src)
        count := try get_variant_count(env, "Foo")
        try assert.equal(count, 2)
        .Ok({})
      },
    )
    .test(
      "two enums with same variant name coexist",
      fn() {
        src := "type A = { X(.{ a: Int }) } type B = { X(.{ b: String }) }"
        env := try resolve_ok(src)
        try assert.equal(try get_field_type(env, "A.X", "a"), "Int")
        try assert.equal(try get_field_type(env, "B.X", "b"), "String")
        .Ok({})
      },
    )
    .test(
      "anon record variant not in type_bindings",
      fn() {
        src := "type Foo = { Bar(.{ x: Int }) }"
        env := try resolve_ok(src)

        // "Bar" should NOT be a user-accessible type name
        try assert.is_true(!env.has_type("Bar"))
        .Ok({})
      },
    )
    .test(
      "generic enum with anon record variant",
      fn() {
        src := "type Wrap<T> = { Item(.{ value: T }) }"
        env := try resolve_ok(src)
        try assert.is_true(env.has_type("Wrap"))
        try assert.equal(try get_field_type(env, "Wrap.Item", "value"), "Var(T)")
        .Ok({})
      },
    )
}
