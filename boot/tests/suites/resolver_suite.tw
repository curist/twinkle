    // ── Issue 1: User functions shadow prelude functions ──
    .test("user function shadows prelude function", fn() {
      // Pre-populate env with a "map" function (simulating prelude)
      prelude_sig := resolver.FunctionSig.{
        name: "map",
        type_params: plain_resolved_type_params(["A", "B"]),
        param_names: ["xs", "f"],
        params: [
          resolver.MonoType.Vector(resolver.MonoType.Var("A")),
          resolver.MonoType.Function([resolver.MonoType.Var("A")], resolver.MonoType.Var("B")),
        ],
        ret: .Some(resolver.MonoType.Vector(resolver.MonoType.Var("B"))),
        doc: .None,
    extern_module: .None,
}
      env := resolver.empty_env().with_functions([prelude_sig])

      // User defines their own "map" — should shadow prelude's
      src := "fn map(x: Int) Int { x }"
      result_env := try resolve_ok_with_env(src, env)

      // Lookup should find user's map (1 param of Int), not prelude's (2 params)
      case resolver.lookup_function(result_env, "map") {
        .Some(sig) => {
          try assert.int_eq(sig.params.len(), 1)
          try assert.str_eq(mono_to_string(sig.params[0]), "Int")
          .Ok({})
        },
        .None => .Err("user-defined map should exist"),
      }
    })
    .test("user function shadows prelude without diagnostic", fn() {
      prelude_sig := resolver.FunctionSig.{
        name: "to_string",
        type_params: [],
        param_names: ["x"],
        params: [resolver.MonoType.Int],
        ret: .Some(resolver.MonoType.String),
        doc: .None,
    extern_module: .None,
}
      env := resolver.empty_env().with_functions([prelude_sig])

      // User redefines to_string — should NOT produce a "duplicate" diagnostic
      src := "fn to_string(x: Float) String { \"\" }"
      r := resolve_src_with_env(src, env)
      try assert.int_eq(r.diagnostics.len(), 0)
      .Ok({})
    })
    // ── Issue 2: Missing param annotation alignment ──
    .test("missing param annotation keeps param vectors aligned", fn() {
      src := "fn foo(x, y: Int) Int { 0 }"
      r := resolve_src(src)
      // Should have a diagnostic for missing annotation
      try assert.is_true(r.diagnostics.len() > 0)
      // The function should have aligned param_names and params vectors
      case resolver.lookup_function(r.env, "foo") {
        .Some(sig) => {
          try assert.int_eq(sig.param_names.len(), sig.params.len())
          .Ok({})
        },
        .None => .Err("function foo should be registered"),
      }
    })
    // ── Issue 3: Error sentinel not Void ──
    .test("unresolved param type is not Void", fn() {
      // fn foo(x: Nonexistent) Void {} — the error placeholder should not be Void
      src := "fn foo(x: Nonexistent) Void { }"
      r := resolve_src(src)
      case resolver.lookup_function(r.env, "foo") {
        .Some(sig) => {
          param_str := mono_to_string(sig.params[0])
          // param should be an error placeholder, NOT "Void"
          if param_str == "Void" {
            return .Err("error placeholder should not be Void (indistinguishable from real Void return)")
          }
          // return type SHOULD be actual Void
          ret_str := case sig.ret {
            .Some(ty) => mono_to_string(ty),
            .None => "(none)",
          }
          try assert.str_eq(ret_str, "Void")
          .Ok({})
        },
        .None => .Err("function foo should be registered"),
      }
    })
    // ── Issue 5: Incremental add_type / add_function ──
    .test("add_type incrementally builds env", fn() {
      env := resolver.empty_env()
      e1 := resolver.TypeEntry.{ id: resolver.TypeId.{ id: 0 }, arity: 0, def: .None, span: span.Span.{ file_id: 0, start: 0, end: 0 } }
      env = env.add_type( e1, "Foo")
      e2 := resolver.TypeEntry.{ id: resolver.TypeId.{ id: 1 }, arity: 0, def: .None, span: span.Span.{ file_id: 0, start: 0, end: 0 } }
      env = env.add_type( e2, "Bar")

      try assert.is_true(resolver.has_type(env, "Foo"))
      try assert.is_true(resolver.has_type(env, "Bar"))
      try assert.int_eq(env.types.len(), 2)
      .Ok({})
    })
    .test("type entry can exist without a visible binding", fn() {
      tid := resolver.TypeId.{ id: 7 }
      entry := resolver.TypeEntry.{
        id: tid,
        arity: 0,
        def: .Some(resolver.ResolvedTypeDef.Alias("geom.Support", [], resolver.MonoType.Int)),
        span: span.Span.{ file_id: 0, start: 0, end: 0 },
      }

      env := resolver.empty_env().register_type_entry(entry, "geom.Support")

      try assert.int_eq(env.types.len(), 1)
      try assert.is_true(!resolver.has_type(env, "geom.Support"))
      try assert.str_eq(try resolver.find_type_name(env, tid).ok_or("preferred type name missing"), "geom.Support")
      case resolver.lookup_type_def(env, tid) {
        .Some(_) => .Ok({}),
        .None => .Err("stored type entry should remain addressable by TypeId"),
      }
    })
    .test("add_function incrementally builds env", fn() {
      env := resolver.empty_env()
      sig1 := resolver.FunctionSig.{
        name: "foo", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Int], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      env = env.add_function( sig1)
      sig2 := resolver.FunctionSig.{
        name: "bar", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.String], ret: .Some(resolver.MonoType.String),
        doc: .None,
    extern_module: .None,
}
      env = env.add_function( sig2)

      try assert.is_true(resolver.has_function(env, "foo"))
      try assert.is_true(resolver.has_function(env, "bar"))
      try assert.int_eq(env.functions.len(), 2)
      .Ok({})
    })
    .test("add_function shadows existing by name", fn() {
      env := resolver.empty_env()
      sig1 := resolver.FunctionSig.{
        name: "foo", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Int], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      env = env.add_function( sig1)
      // Add another "foo" — should shadow the first
      sig2 := resolver.FunctionSig.{
        name: "foo", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.String], ret: .Some(resolver.MonoType.String),
        doc: .None,
    extern_module: .None,
}
      env = env.add_function( sig2)

      case resolver.lookup_function(env, "foo") {
        .Some(sig) => {
          // Should find the second (shadowing) version
          try assert.str_eq(mono_to_string(sig.params[0]), "String")
          .Ok({})
        },
        .None => .Err("foo should exist"),
      }
    })
    // ── Hardening item 1: type arity in forward/mutual refs ──
    .test("H1 arity checked even when def is still shell", fn() {
      // Wrapper depends on nothing, Inner depends on Wrapper.
      // Topo order: Wrapper first, Inner second.
      // But Inner has wrong arity for Wrapper — and Wrapper's def IS available.
      // This test verifies the baseline works.
      src := "type Wrapper<T> = .{ value: T }\ntype Inner = .{ w: Wrapper<Int, String> }"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("expects 1 type argument") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("H1 arity checked on mutual recursion with wrong args", fn() {
      // A and B are mutually recursive. A passes wrong arity to B.
      // Topo visit: A depends on B, B depends on A.
      // Visit A → visit B → A is in-progress, skip → B done → A done.
      // Order: [B, A]. B resolved first (def populated), then A.
      // When A is resolved, B's def exists, so arity check works.
      // But reverse: B references A with correct arity, so no issue there.
      // To catch the real bug: make A depend on nothing except B (wrong arity),
      // and B depend on A. Then B is resolved after A, and when B tries
      // to check A's arity, A has def. Still works.
      //
      // The ACTUAL bug: a standalone type with wrong arity for a type
      // declared LATER that has no deps on it.
      // Topo order for independent types: declaration order.
      // type Usage = .{ x: Later<Int, String> }
      // type Later<T> = .{ value: T }
      // Usage has no recognized dep on Later (Later is resolved as Named),
      // wait — collect_type_refs DOES find Later as a dep of Usage.
      // So topo order: Later first, Usage second. Arity check works.
      //
      // Conclusion: topo sort ensures deps are resolved first, so arity
      // check via def always works for type-to-type references.
      // The real gap is types referenced from FUNCTION signatures —
      // those aren't topo-sorted but resolved after all types.
      // By then all defs are populated. So... the bug may not be
      // triggerable in practice with the current architecture.
      //
      // Still, storing arity in TypeEntry is a robustness improvement.
      // Test: verify arity is available on TypeEntry directly.
      src := "type Box<T> = .{ value: T }\ntype Pair<A, B> = .{ a: A, b: B }"
      r := resolve_src(src)
      try assert.int_eq(r.diagnostics.len(), 0)
      box_entry := case resolver.lookup_type(r.env, "Box") {
        .Some(e) => e,
        .None => { return .Err("Box not found") },
      }
      try assert.int_eq(box_entry.arity, 1)
      pair_entry := case resolver.lookup_type(r.env, "Pair") {
        .Some(e) => e,
        .None => { return .Err("Pair not found") },
      }
      try assert.int_eq(pair_entry.arity, 2)
      .Ok({})
    })
    // ── Hardening item 2: method name collision diagnostics ──
    .test("H2 user inherent method colliding with builtin emits diagnostic", fn() {
      // User type Point + builtin-registered method "show" on Point,
      // then user defines fn show(p: Point) — should conflict.
      src := "type Point = .{ x: Int }\nfn show(p: Point) String { \"\" }"
      parsed := parser.parse(src, 0)
      // Pre-register a builtin "show" method on Point
      env := resolver.empty_env()
      env.methods["Point"] = [resolver.MethodEntry.{ method_name: "show", function_name: "__builtin_show" }]
      r := env.resolve(parsed.value)
      found := false
      for d in r.diagnostics {
        if d.message.contains("show") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("H2 duplicate user inherent methods for same type emit diagnostic", fn() {
      // Two user functions with same name and same Named first-param type
      // The second should produce a diagnostic (currently silently ignored)
      src := "type Point = .{ x: Int }\nfn show(p: Point) String { \"\" }\nfn show(p: Point) String { \"\" }"
      r := resolve_src(src)
      // We expect TWO diagnostics: one for duplicate function, one for method collision
      // But at minimum the duplicate function diagnostic
      found_dup := false
      for d in r.diagnostics {
        if d.message.contains("duplicate function") { found_dup = true }
      }
      try assert.is_true(found_dup)
      .Ok({})
    })
    // ── Hardening item 3: no partial defs on field resolution failure ──
    .test("H3 record with bad field preserves field count", fn() {
      src := "type Foo = .{ x: Int, y: Nonexistent, z: Bool }"
      r := resolve_src(src)
      // Should have a diagnostic for the bad type
      try assert.is_true(r.diagnostics.len() > 0)
      // The record should still have 3 fields (y with ErrorType, not skipped)
      case resolver.lookup_type(r.env, "Foo") {
        .Some(entry) => {
          case entry.def {
            .Some(def) => {
              case def {
                .Record(_, _, fields) => {
                  try assert.int_eq(fields.len(), 3)
                  try assert.str_eq(mono_to_string(fields[0].ty), "Int")
                  try assert.str_eq(mono_to_string(fields[1].ty), "<error>")
                  try assert.str_eq(mono_to_string(fields[2].ty), "Bool")
                  .Ok({})
                },
                _ => .Err("expected Record"),
              }
            },
            .None => .Err("expected def to be populated"),
          }
        },
        .None => .Err("Foo not found"),
      }
    })
    .test("H3 sum variant with bad field preserves field count", fn() {
      src := "type Shape = { Circle(Nonexistent), Rect(Float, Float) }"
      r := resolve_src(src)
      try assert.is_true(r.diagnostics.len() > 0)
      case resolver.lookup_type(r.env, "Shape") {
        .Some(entry) => {
          case entry.def {
            .Some(def) => {
              case def {
                .Sum(_, _, variants) => {
                  // Circle should have 1 field (ErrorType), not 0
                  try assert.int_eq(variants[0].fields.len(), 1)
                  try assert.str_eq(mono_to_string(variants[0].fields[0]), "<error>")
                  // Rect should still have 2 fields
                  try assert.int_eq(variants[1].fields.len(), 2)
                  .Ok({})
                },
                _ => .Err("expected Sum"),
              }
            },
            .None => .Err("expected def to be populated"),
          }
        },
        .None => .Err("Shape not found"),
      }
    })
    // ── Hardening item 4: type params in dependency collection ──
