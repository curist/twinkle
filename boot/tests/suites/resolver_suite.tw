use tests.runner
use tests.assert
use compiler.parser
use compiler.resolver
use compiler.ast

// ── Helpers ──────────────────────────────────────────────────────────

fn resolve_src(src: String) resolver.ResolveResult {
  parsed := parser.parse(src, 0)
  resolver.resolve(parsed.value, resolver.empty_env())
}

fn resolve_ok(src: String) Result<resolver.ResolvedEnv, String> {
  r := resolve_src(src)
  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message}")
  }
  .Ok(r.env)
}

fn resolve_errs(src: String) Result<Vector<String>, String> {
  r := resolve_src(src)
  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }
  msgs: Vector<String> = []
  for d in r.diagnostics {
    msgs = msgs.push(d.message)
  }
  .Ok(msgs)
}

fn type_id_of(env: resolver.ResolvedEnv, name: String) Result<Int, String> {
  case resolver.lookup_type(env, name) {
    .Some(entry) => .Ok(entry.id.id),
    .None => .Err("type ${name} not found"),
  }
}

pub fn mono_to_string(ty: resolver.MonoType) String {
  case ty {
    .Int => "Int",
    .Float => "Float",
    .Bool => "Bool",
    .Byte => "Byte",
    .String => "String",
    .Void => "Void",
    .Var(name) => "Var(${name})",
    .Named(tid, args) => {
      if args.len() == 0 {
        "Named(${tid.id})"
      } else {
        joined := ""
        for a, i in args {
          if i > 0 { joined = "${joined}, " }
          joined = "${joined}${mono_to_string(a)}"
        }
        "Named(${tid.id})<${joined}>"
      }
    },
    .Vector(inner) => "Vector<${mono_to_string(inner)}>",
    .Dict(k, v) => "Dict<${mono_to_string(k)}, ${mono_to_string(v)}>",
    .Function(params, ret) => {
      joined := ""
      for p, i in params {
        if i > 0 { joined = "${joined}, " }
        joined = "${joined}${mono_to_string(p)}"
      }
      "fn(${joined}) ${mono_to_string(ret)}"
    },
    .Optional(inner) => "${mono_to_string(inner)}?",
    .Result(ok, err) => "Result<${mono_to_string(ok)}, ${mono_to_string(err)}>",
    .MetaVar(id) => "?${id}",
    .Never => "Never",
  }
}

fn get_field_type(env: resolver.ResolvedEnv, type_name: String, field_name: String) Result<String, String> {
  case resolver.lookup_type(env, type_name) {
    .Some(entry) => {
      case entry.def {
        .Some(def) => {
          case def {
            .Record(_, _, fields) => {
              for f in fields {
                if f.name == field_name {
                  return .Ok(mono_to_string(f.ty))
                }
              }
              .Err("field ${field_name} not found in ${type_name}")
            },
            _ => .Err("${type_name} is not a record"),
          }
        },
        .None => .Err("${type_name} has no definition"),
      }
    },
    .None => .Err("type ${type_name} not found"),
  }
}

fn get_variant_count(env: resolver.ResolvedEnv, type_name: String) Result<Int, String> {
  case resolver.lookup_type(env, type_name) {
    .Some(entry) => {
      case entry.def {
        .Some(def) => {
          case def {
            .Sum(_, _, variants) => .Ok(variants.len()),
            _ => .Err("${type_name} is not a sum type"),
          }
        },
        .None => .Err("${type_name} has no definition"),
      }
    },
    .None => .Err("type ${type_name} not found"),
  }
}

fn get_param_type(env: resolver.ResolvedEnv, fn_name: String, idx: Int) Result<String, String> {
  case resolver.lookup_function(env, fn_name) {
    .Some(sig) => {
      if idx >= sig.params.len() {
        return .Err("param index ${idx} out of range for ${fn_name}")
      }
      .Ok(mono_to_string(sig.params[idx]))
    },
    .None => .Err("function ${fn_name} not found"),
  }
}

fn get_return_type(env: resolver.ResolvedEnv, fn_name: String) Result<String, String> {
  case resolver.lookup_function(env, fn_name) {
    .Some(sig) => {
      case sig.ret {
        .Some(ty) => .Ok(mono_to_string(ty)),
        .None => .Ok("(none)"),
      }
    },
    .None => .Err("function ${fn_name} not found"),
  }
}

// ── Suite ────────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("resolver")
    // ── Type declarations ──
    .test("resolve empty module", fn() {
      env := try resolve_ok("")
      assert.int_eq(env.types.len(), 0)
    })
    .test("resolve record type", fn() {
      env := try resolve_ok("type Point = .{ x: Int, y: Int }")
      try assert.is_true(resolver.has_type(env, "Point"))
      try assert.str_eq(try get_field_type(env, "Point", "x"), "Int")
      try assert.str_eq(try get_field_type(env, "Point", "y"), "Int")
      .Ok({})
    })
    .test("resolve record with various field types", fn() {
      src := "type Foo = .{ a: Int, b: Float, c: Bool, d: String, e: Byte }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_field_type(env, "Foo", "a"), "Int")
      try assert.str_eq(try get_field_type(env, "Foo", "b"), "Float")
      try assert.str_eq(try get_field_type(env, "Foo", "c"), "Bool")
      try assert.str_eq(try get_field_type(env, "Foo", "d"), "String")
      try assert.str_eq(try get_field_type(env, "Foo", "e"), "Byte")
      .Ok({})
    })
    .test("resolve sum type", fn() {
      src := "type Shape = { Circle(Float), Rect(Float, Float), Unit }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Shape"))
      try assert.int_eq(try get_variant_count(env, "Shape"), 3)
      .Ok({})
    })
    .test("resolve type alias", fn() {
      src := "type Name = String"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Name"))
      .Ok({})
    })
    .test("resolve type with type parameters", fn() {
      src := "type Box<T> = .{ value: T }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Box"))
      try assert.str_eq(try get_field_type(env, "Box", "value"), "Var(T)")
      .Ok({})
    })
    .test("resolve type referencing another type", fn() {
      src := "type Point = .{ x: Int, y: Int }\ntype Line = .{ start: Point, end: Point }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Point"))
      try assert.is_true(resolver.has_type(env, "Line"))
      start_ty := try get_field_type(env, "Line", "start")
      try assert.str_eq(start_ty, "Named(0)")
      .Ok({})
    })
    .test("TypeIds are assigned in declaration order", fn() {
      src := "type A = .{ x: Int }\ntype B = .{ y: Float }\ntype C = .{ z: Bool }"
      env := try resolve_ok(src)
      try assert.int_eq(try type_id_of(env, "A"), 0)
      try assert.int_eq(try type_id_of(env, "B"), 1)
      try assert.int_eq(try type_id_of(env, "C"), 2)
      .Ok({})
    })
    // ── Builtin generic types ──
    .test("resolve Vector type", fn() {
      src := "type Nums = .{ items: Vector<Int> }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_field_type(env, "Nums", "items"), "Vector<Int>")
      .Ok({})
    })
    .test("resolve Dict type", fn() {
      src := "type Map = .{ data: Dict<String, Int> }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_field_type(env, "Map", "data"), "Dict<String, Int>")
      .Ok({})
    })
    .test("resolve Optional type", fn() {
      src := "type Foo = .{ value: Int? }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_field_type(env, "Foo", "value"), "Int?")
      .Ok({})
    })
    .test("resolve function type in field", fn() {
      src := "type Callback = .{ handler: fn(Int) Bool }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_field_type(env, "Callback", "handler"), "fn(Int) Bool")
      .Ok({})
    })
    // ── Function declarations ──
    .test("resolve function with typed params", fn() {
      src := "fn add(a: Int, b: Int) Int { a }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_function(env, "add"))
      try assert.str_eq(try get_param_type(env, "add", 0), "Int")
      try assert.str_eq(try get_param_type(env, "add", 1), "Int")
      try assert.str_eq(try get_return_type(env, "add"), "Int")
      .Ok({})
    })
    .test("resolve function with no return type", fn() {
      src := "fn greet(name: String) { name }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_return_type(env, "greet"), "(none)")
      .Ok({})
    })
    .test("resolve function with user type params", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn origin() Point { origin }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_return_type(env, "origin"), "Named(0)")
      .Ok({})
    })
    .test("resolve generic function", fn() {
      src := "fn identity<T>(x: T) T { x }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_param_type(env, "identity", 0), "Var(T)")
      try assert.str_eq(try get_return_type(env, "identity"), "Var(T)")
      .Ok({})
    })
    // ── Error cases ──
    .test("duplicate type names", fn() {
      src := "type Foo = .{ x: Int }\ntype Foo = .{ y: Int }"
      msgs := try resolve_errs(src)
      try assert.str_contains(msgs[0], "duplicate type")
      .Ok({})
    })
    .test("duplicate function names", fn() {
      src := "fn foo(x: Int) Int { x }\nfn foo(y: Int) Int { y }"
      msgs := try resolve_errs(src)
      try assert.str_contains(msgs[0], "duplicate function")
      .Ok({})
    })
    .test("duplicate fn produces exactly one env entry", fn() {
      r := resolve_src("fn foo(x: Int) Int { x }\nfn foo(y: Int) Int { y }")
      try assert.int_eq(r.env.functions.len(), 1)
      .Ok({})
    })
    .test("undefined type in field", fn() {
      src := "type Foo = .{ x: Nonexistent }"
      msgs := try resolve_errs(src)
      try assert.str_contains(msgs[0], "undefined type")
      .Ok({})
    })
    .test("undefined type in function param", fn() {
      src := "fn foo(x: Nonexistent) Int { 0 }"
      msgs := try resolve_errs(src)
      try assert.str_contains(msgs[0], "undefined type")
      .Ok({})
    })
    .test("multiple type-arg errors collected", fn() {
      src := "type Foo = .{ x: Dict<Bad1, Bad2> }"
      msgs := try resolve_errs(src)
      try assert.int_eq(msgs.len(), 2)
      try assert.str_contains(msgs[0], "Bad1")
      try assert.str_contains(msgs[1], "Bad2")
      .Ok({})
    })
    .test("multiple fn param type errors collected", fn() {
      src := "fn foo(a: Bad1, b: Bad2) Int { 0 }"
      msgs := try resolve_errs(src)
      try assert.int_eq(msgs.len(), 2)
      try assert.str_contains(msgs[0], "Bad1")
      try assert.str_contains(msgs[1], "Bad2")
      .Ok({})
    })
    .test("fn type errors include return type", fn() {
      src := "type Foo = .{ f: fn(Bad1) Bad2 }"
      msgs := try resolve_errs(src)
      try assert.int_eq(msgs.len(), 2)
      try assert.str_contains(msgs[0], "Bad1")
      try assert.str_contains(msgs[1], "Bad2")
      .Ok({})
    })
    .test("circular type alias", fn() {
      src := "type A = B\ntype B = A"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("circular") {
          found = true
        }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("circular alias has non-zero span", fn() {
      r := resolve_src("type A = B\ntype B = A")
      found_circular := false
      for d in r.diagnostics {
        if d.message.contains("circular") {
          has_span := d.span.start > 0
          if !has_span { has_span = d.span.end > 0 }
          if has_span {
            found_circular = true
          }
        }
      }
      try assert.is_true(found_circular)
      .Ok({})
    })
    // ── Result type ──
    .test("resolve Result type in field", fn() {
      src := "type Foo = .{ value: Result<Int, String> }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_field_type(env, "Foo", "value"), "Result<Int, String>")
      .Ok({})
    })
    // ── Sum with generic payloads ──
    .test("resolve sum with generic payload", fn() {
      src := "type Either<A, B> = { Left(A), Right(B) }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Either"))
      try assert.int_eq(try get_variant_count(env, "Either"), 2)
      .Ok({})
    })
    // ── Multiple functions ──
    .test("resolve multiple functions", fn() {
      src := "fn add(a: Int, b: Int) Int { a }\nfn sub(a: Int, b: Int) Int { a }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_function(env, "add"))
      try assert.is_true(resolver.has_function(env, "sub"))
      .Ok({})
    })
    // ── Arity checks ──
    .test("wrong arity for user-defined generic type", fn() {
      src := "type Box<T> = .{ value: T }\ntype Foo = .{ x: Box<Int, String> }"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("expects 1 type argument") {
          found = true
        }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("zero args for generic type", fn() {
      src := "type Pair<A, B> = .{ a: A, b: B }\ntype Foo = .{ x: Pair }"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("expects 2 type argument") {
          found = true
        }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("forward-ref arity check", fn() {
      // Foo references Box before it's declared — arity should still be checked
      src := "type Foo = .{ x: Box<Int, String> }\ntype Box<T> = .{ value: T }"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("expects 1 type argument") {
          found = true
        }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("forward-ref field resolves", fn() {
      // Line references Point declared after it — should resolve correctly
      src := "type Line = .{ start: Point, end: Point }\ntype Point = .{ x: Int, y: Int }"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Line"))
      start_ty := try get_field_type(env, "Line", "start")
      try assert.str_eq(start_ty, "Named(1)")
      .Ok({})
    })
    // ── Type alias chain ──
    .test("resolve alias chain", fn() {
      src := "type Name = String\ntype Alias = Name"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "Name"))
      try assert.is_true(resolver.has_type(env, "Alias"))
      .Ok({})
    })
    // ── F5: Additional coverage ──
    .test("self-alias is circular", fn() {
      src := "type A = A"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("circular") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("3-node cycle is circular", fn() {
      src := "type A = B\ntype B = C\ntype C = A"
      msgs := try resolve_errs(src)
      found := false
      for m in msgs {
        if m.contains("circular") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("forward alias chain resolves", fn() {
      src := "type A = B\ntype B = Int"
      env := try resolve_ok(src)
      try assert.is_true(resolver.has_type(env, "A"))
      try assert.is_true(resolver.has_type(env, "B"))
      .Ok({})
    })
    .test("type var shadows builtin", fn() {
      // fn f<Int>(x: Int) — the Int here should be Var("Int"), not MonoType.Int
      src := "fn f<Int>(x: Int) Int { x }"
      env := try resolve_ok(src)
      try assert.str_eq(try get_param_type(env, "f", 0), "Var(Int)")
      try assert.str_eq(try get_return_type(env, "f"), "Var(Int)")
      .Ok({})
    })
    // ── Method registry ──
    .test("lookup_method on empty env returns None", fn() {
      env := resolver.empty_env()
      case resolver.lookup_method(env, "String", "len") {
        .None => .Ok({}),
        .Some(_) => .Err("expected None"),
      }
    })
    .test("manual method registration + lookup", fn() {
      env := resolver.empty_env()
      entry := resolver.MethodEntry.{ method_name: "len", function_name: "string_len" }
      env.methods["String"] = [entry]
      case resolver.lookup_method(env, "String", "len") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "string_len")
          .Ok({})
        },
        .None => .Err("expected Some"),
      }
    })
    .test("builtin method: String.len", fn() {
      env := resolver.register_builtin_methods(resolver.empty_env())
      case resolver.lookup_method(env, "String", "len") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "string_len")
          .Ok({})
        },
        .None => .Err("expected Some"),
      }
    })
    .test("builtin method: Vector.push", fn() {
      env := resolver.register_builtin_methods(resolver.empty_env())
      case resolver.lookup_method(env, "Vector", "push") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "vector_push")
          .Ok({})
        },
        .None => .Err("expected Some"),
      }
    })
    .test("builtin method: Int.to_string", fn() {
      env := resolver.register_builtin_methods(resolver.empty_env())
      case resolver.lookup_method(env, "Int", "to_string") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "int_to_string")
          .Ok({})
        },
        .None => .Err("expected Some"),
      }
    })
    .test("builtin method: Dict.keys", fn() {
      env := resolver.register_builtin_methods(resolver.empty_env())
      case resolver.lookup_method(env, "Dict", "keys") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "dict_keys")
          .Ok({})
        },
        .None => .Err("expected Some"),
      }
    })
    // ── Auto-detected inherent methods ──
    .test("auto-detect inherent method: to_string on Point", fn() {
      src := "type Point = .{ x: Int }\nfn to_string(p: Point) String { \"\" }"
      env := try resolve_ok(src)
      case resolver.lookup_method(env, "Point", "to_string") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "to_string")
          .Ok({})
        },
        .None => .Err("expected to_string to be registered on Point"),
      }
    })
    .test("no inherent method if first param not Named", fn() {
      src := "type Point = .{ x: Int }\nfn format(s: String) String { s }"
      env := try resolve_ok(src)
      case resolver.lookup_method(env, "Point", "format") {
        .Some(_) => .Err("format should not be registered on Point"),
        .None => .Ok({}),
      }
    })
    .test("auto-detect method on sum type", fn() {
      src := "type Shape = { Circle(Float), Rect(Float, Float) }\nfn area(s: Shape) Float { 0.0 }"
      env := try resolve_ok(src)
      case resolver.lookup_method(env, "Shape", "area") {
        .Some(fn_name) => {
          try assert.str_eq(fn_name, "area")
          .Ok({})
        },
        .None => .Err("expected area to be registered on Shape"),
      }
    })
}
