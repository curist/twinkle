    .test("merge_prelude_exports sets canonical function origins", fn() {
      src := "pub fn filter(v: Vector<Int>) Vector<Int> { v }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      root := loader.find_project_root("boot")
      roots := imports.make_canonical_roots(root)
      prelude_vector := imports.canonical_module_path("${loader.resolve_prelude_root(root)}/vector.tw", roots)

      env := resolver.empty_env()
      env = env.merge_prelude_exports("__prelude_vector", prelude_vector, exports)

      case resolver.lookup_function_origin(env, "filter") {
        .Some(origin) => {
          try assert.str_eq(origin.module_path, prelude_vector)
          try assert.str_eq(origin.func_name, "filter")
          .Ok({})
        },
        .None => .Err("expected function origin for prelude filter"),
      }
    })

    .test("local function shadows prelude origin", fn() {
      src := "pub fn filter(v: Vector<Int>) Vector<Int> { v }"
      parsed := parser.parse(src, 0)
      r := resolver.empty_env().resolve(parsed.value)
      exports := resolver.extract_exports(r.env, parsed.value)

      env := resolver.empty_env()
      env = env.merge_prelude_exports("__prelude_vector", "prelude/vector.tw", exports)

      // Verify origin exists
      try assert.is_some(resolver.lookup_function_origin(env, "filter"))

      // Now add a local function that shadows it
      env = env.add_function(resolver.FunctionSig.{
        name: "filter", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Int], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
})

      // Origin should be cleared for the now-local function
      case resolver.lookup_function_origin(env, "filter") {
        .Some(_) => .Err("expected stale origin to be cleared after local shadow"),
        .None => .Ok({}),
      }
    })

    .test("with_functions drops origins for removed registered targets", fn() {
      imported := resolver.FunctionSig.{
        name: "filter", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Int], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      local := resolver.FunctionSig.{
        name: "local_only", type_params: [], param_names: [],
        params: [], ret: .Some(resolver.MonoType.Void),
        doc: .None,
    extern_module: .None,
}

      env := resolver.empty_env()
        .with_functions([imported, local])
        .set_function_origin("filter", .{ module_path: "prelude/vector.tw", func_name: "filter" })

      try assert.is_some(resolver.lookup_function_origin(env, "filter"))

      env = env.with_functions([local])

      case resolver.lookup_function_origin(env, "filter") {
        .Some(_) => .Err("expected removed function origin to be dropped by with_functions"),
        .None => .Ok({}),
      }
    })

    .test("merge_module_exports preserves original defining origin across re-export metadata", fn() {
      sig := resolver.FunctionSig.{
        name: "foo", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Int], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      exports := resolver.ModuleExports.{
        visible_types: [],
        support_types: [],
        functions: [resolver.ExportedFunction.{
          name: "foo",
          sig,
          source_name: "foo",
          origin: .Some(.{ module_path: "test/a.tw", func_name: "foo" }),
        }],
        support_functions: [],
        methods: Dict.new(),
      }

      env := resolver.empty_env().merge_module_exports("bridge", "test/b.tw", exports)

      case resolver.lookup_function_origin(env, "bridge.foo") {
        .Some(origin) => {
          try assert.str_eq(origin.module_path, "test/a.tw")
          try assert.str_eq(origin.func_name, "foo")
          .Ok({})
        },
        .None => .Err("expected re-exported function to preserve original defining origin"),
      }
    })

    .test("merge_module_exports preserves support function origins", fn() {
      helper_sig := resolver.FunctionSig.{
        name: "helper", type_params: [], param_names: ["x"],
        params: [resolver.MonoType.Int], ret: .Some(resolver.MonoType.Int),
        doc: .None,
    extern_module: .None,
}
      exports := resolver.ModuleExports.{
        visible_types: [],
        support_types: [],
        functions: [],
        support_functions: [resolver.ExportedFunction.{
          name: "helper",
          sig: helper_sig,
          source_name: "helper",
          origin: .Some(.{ module_path: "test/support.tw", func_name: "helper" }),
        }],
        methods: Dict.new(),
      }

      env := resolver.empty_env().merge_module_exports("support_mod", "test/bridge.tw", exports)

      case resolver.lookup_function_origin(env, "support_mod.helper") {
        .Some(origin) => {
          try assert.str_eq(origin.module_path, "test/support.tw")
          try assert.str_eq(origin.func_name, "helper")
          .Ok({})
        },
        .None => .Err("expected support function to preserve canonical origin"),
      }
    })
}
