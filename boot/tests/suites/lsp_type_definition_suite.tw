use compiler.query.cache as query_cache
use lib.json
use lib.lsp.document_store
use lib.lsp.protocol
use lib.lsp.server_core
use @std.testing.assert as assert
use @std.testing as runner

fn state_with_doc(uri: String, text: String) server_core.State {
  docs := document_store.empty().open(uri, text, .Some(1))
  server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: false,
    diagnostics_deadline_ms: 0.0,
    last_published: Dict.new(),
    diagnostics_tier: .Full,
    parse_dirty_uris: Dict.new(),
    full_dirty: false,
    closure_snapshot: .None,
  }
}

fn state_with_two_docs(uri_a: String, text_a: String, uri_b: String, text_b: String) server_core.State {
  docs0 := document_store.empty().open(uri_a, text_a, .Some(1))
  docs := docs0.open(uri_b, text_b, .Some(1))
  server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: false,
    diagnostics_deadline_ms: 0.0,
    last_published: Dict.new(),
    diagnostics_tier: .Full,
    parse_dirty_uris: Dict.new(),
    full_dirty: false,
    closure_snapshot: .None,
  }
}

fn typedef_request(id: Int, uri: String, line: Int, character: Int) protocol.Message {
  params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri))])),
    json.kv(
      "position",
      json.object([json.kv("line", .Int(line)), json.kv("character", .Int(character))]),
    ),
  ])
  protocol.Message.Request(.{
    id: .IntId(id),
    method: "textDocument/typeDefinition",
    params: .Some(params),
  })
}

type RangeInfo = .{ start_line: Int, start_char: Int, end_line: Int, end_char: Int }

fn result_range(step: server_core.Step) RangeInfo!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))
  range := try result.decode(json.field("range", json.raw()))
  start := try range.decode(json.field("start", json.raw()))
  end := try range.decode(json.field("end", json.raw()))
  start_line := try start.decode(json.field("line", json.int()))
  start_char := try start.decode(json.field("character", json.int()))
  end_line := try end.decode(json.field("line", json.int()))
  end_char := try end.decode(json.field("character", json.int()))
  .Ok(.{ start_line, start_char, end_line, end_char })
}

fn is_null_result(step: server_core.Step) Bool!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))

  case result {
    .Null => .Ok(true),
    _ => .Ok(false),
  }
}

fn result_uri(step: server_core.Step) String!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))
  result.decode(json.field("uri", json.string()))
}

pub fn suite() runner.Suite {
  runner
    .suite("lsp type definition")
    .test(
      "initialize advertises typeDefinitionProvider",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)
        out := step.outgoing[0]
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        try assert.is_true(try caps.decode(json.field("typeDefinitionProvider", json.bool())))
        .Ok({})
      },
    )
    .test(
      "local binding with record type jumps to type decl",
      fn() {
        // type Point = .{ x: Int, y: Int }
        // fn main() Int {
        //   p := Point.{ x: 1, y: 2 }
        //   p.x
        //   ^  cursor on p
        // }
        src := "type Point = .{ x: Int, y: Int }\nfn main() Int {\n  p := Point.{ x: 1, y: 2 }\n  p.x\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 3, 2))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 10)
        .Ok({})
      },
    )
    .test(
      "function call result jumps to return type",
      fn() {
        // type Msg = .{ text: String }
        // fn make() Msg { .{ text: "hi" } }
        // fn main() String {
        //   m := make()
        //   m.text
        //   ^  cursor on m
        // }
        src := "type Msg = .{ text: String }\nfn make() Msg { .{ text: \"hi\" } }\nfn main() String {\n  m := make()\n  m.text\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 4, 2))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 8)
        .Ok({})
      },
    )
    .test(
      "let binding name jumps to type of the value",
      fn() {
        // type Point = .{ x: Int, y: Int }
        // fn main() Int {
        //   p := Point.{ x: 1, y: 2 }
        //   ^  cursor on p at binding site
        //   p.x
        // }
        src := "type Point = .{ x: Int, y: Int }\nfn main() Int {\n  p := Point.{ x: 1, y: 2 }\n  p.x\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 2, 2))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 10)
        .Ok({})
      },
    )
    .test(
      "top-level let binding name jumps to type",
      fn() {
        // type Config = .{ debug: Bool }
        // cfg := Config.{ debug: false }
        // ^  cursor on cfg
        src := "type Config = .{ debug: Bool }\ncfg := Config.{ debug: false }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 1, 0))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 11)
        .Ok({})
      },
    )
    .test(
      "enum variant expression jumps to parent enum type",
      fn() {
        // type Color = { Red, Green, Blue }
        // c := Color.Red
        // fn main() Int {
        //   case c { .Red => 1, .Green => 2, .Blue => 3 }
        // }
        // cursor on c in case
        src := "type Color = { Red, Green, Blue }\nc := Color.Red\nfn main() Int {\n  case c { .Red => 1, .Green => 2, .Blue => 3 }\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 3, 7))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 10)
        .Ok({})
      },
    )
    .test(
      "field access expression jumps to type of the field",
      fn() {
        // type Inner = .{ value: Int }
        // type Outer = .{ inner: Inner }
        // fn main() Int {
        //   o := Outer.{ inner: Inner.{ value: 1 } }
        //   o.inner.value
        //     ^^^^^  cursor on .inner — the expression o.inner has type Inner
        // }
        src := "type Inner = .{ value: Int }\ntype Outer = .{ inner: Inner }\nfn main() Int {\n  o := Outer.{ inner: Inner.{ value: 1 } }\n  o.inner.value\n}\n"
        state := state_with_doc("file:///a.tw", src)

        // cursor on "inner" in o.inner — at char 4
        step := state.handle_message(typedef_request(1, "file:///a.tw", 4, 4))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 10)
        .Ok({})
      },
    )
    .test(
      "type annotation falls through to type definition",
      fn() {
        // type Msg = .{ text: String }
        // fn send(m: Msg) Void { }
        //            ^^^  cursor on Msg type annotation
        src := "type Msg = .{ text: String }\nfn send(m: Msg) Void { }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 1, 11))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 8)
        .Ok({})
      },
    )
    .test(
      "parameter jumps to type of parameter",
      fn() {
        // type Point = .{ x: Int, y: Int }
        // fn get_x(p: Point) Int { p.x }
        //                          ^  cursor on p in body
        src := "type Point = .{ x: Int, y: Int }\nfn get_x(p: Point) Int { p.x }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 1, 25))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 10)
        .Ok({})
      },
    )
    .test(
      "imported type jumps to defining module",
      fn() {
        dep := "pub type Widget = .{ id: Int }\n"
        main := "use dep\nfn main() Int {\n  w := dep.Widget.{ id: 1 }\n  w.id\n}\n"
        state := state_with_two_docs(
          "file:///tmp/lsp-typedef/dep.tw",
          dep,
          "file:///tmp/lsp-typedef/main.tw",
          main,
        )

        // cursor on w in w.id
        step := state.handle_message(typedef_request(1, "file:///tmp/lsp-typedef/main.tw", 3, 2))
        uri := try result_uri(step)
        try assert.equal(uri, "file:///tmp/lsp-typedef/dep.tw")
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 9)
        try assert.equal(r.end_char, 15)
        .Ok({})
      },
    )
    .test(
      "primitive-typed binding returns null",
      fn() {
        // fn main() Int {
        //   x := 42
        //   x
        //   ^  cursor on x — type is Int (primitive, no definition site)
        // }
        src := "fn main() Int {\n  x := 42\n  x\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 2, 2))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
    .test(
      "string-typed binding returns null",
      fn() {
        src := "fn main() String {\n  s := \"hello\"\n  s\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 2, 2))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
    .test(
      "integer literal returns null",
      fn() {
        src := "x := 42\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 0, 5))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
    .test(
      "unknown document returns null",
      fn() {
        state := state_with_doc("file:///a.tw", "x := 1\n")
        step := state.handle_message(typedef_request(1, "file:///other.tw", 0, 0))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
    .test(
      "method call result jumps to return type",
      fn() {
        // type Counter = .{ n: Int }
        // fn inc(c: Counter) Counter { .{ n: c.n + 1 } }
        // fn main() Int {
        //   c := Counter.{ n: 0 }
        //   d := c.inc()
        //   d.n
        //   ^  cursor on d — type is Counter
        // }
        src := "type Counter = .{ n: Int }\nfn inc(c: Counter) Counter { .{ n: c.n + 1 } }\nfn main() Int {\n  c := Counter.{ n: 0 }\n  d := c.inc()\n  d.n\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 5, 2))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 12)
        .Ok({})
      },
    )
    .test(
      "case arm binding jumps to matched type",
      fn() {
        // type Payload = .{ data: String }
        // type Event = { Click(Payload), Close }
        // fn handle(e: Event) String {
        //   case e {
        //     .Click(p) => p.data,
        //                  ^  cursor on p — type is Payload
        //     .Close => "",
        //   }
        // }
        src := "type Payload = .{ data: String }\ntype Event = { Click(Payload), Close }\nfn handle(e: Event) String {\n  case e {\n    .Click(p) => p.data,\n    .Close => \"\",\n  }\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 4, 17))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 12)
        .Ok({})
      },
    )
    .test(
      "generic Vector<T> outer type returns null",
      fn() {
        // fn main() Int {
        //   xs := [1, 2, 3]
        //   xs
        //   ^^ cursor on xs — type is Vector<Int>, which is a builtin
        // }
        src := "fn main() Int {\n  xs := [1, 2, 3]\n  xs.len()\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 2, 2))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
    .test(
      "let binding in nested block",
      fn() {
        // type Item = .{ id: Int }
        // fn main() Int {
        //   items := [Item.{ id: 1 }]
        //   for item in items {
        //     item.id
        //     ^^^^  cursor on item
        //   }
        //   0
        // }
        src := "type Item = .{ id: Int }\nfn main() Int {\n  items := [Item.{ id: 1 }]\n  for item in items {\n    item.id\n  }\n  0\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 4, 4))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 9)
        .Ok({})
      },
    )
    .test(
      "optional type unwraps to inner named type",
      fn() {
        // type Config = .{ debug: Bool }
        // fn find() Config? { .None }
        // fn main() Int {
        //   c := find()
        //   ^  cursor on c — type is Config?
        //   0
        // }
        src := "type Config = .{ debug: Bool }\nfn find() Config? { .None }\nfn main() Int {\n  c := find()\n  0\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 3, 2))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 11)
        .Ok({})
      },
    )
    .test(
      "result type unwraps to ok named type",
      fn() {
        // type Token = .{ kind: String }
        // fn parse(s: String) Result<Token, String> { .Err("nope") }
        // fn main() Int {
        //   r := parse("x")
        //   ^  cursor on r — type is Result<Token, String>
        //   0
        // }
        src := "type Token = .{ kind: String }\nfn parse(s: String) Result<Token, String> { .Err(\"nope\") }\nfn main() Int {\n  r := parse(\"x\")\n  0\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 3, 2))
        r := try result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 10)
        .Ok({})
      },
    )
    .test(
      "optional primitive still returns null",
      fn() {
        src := "fn find() Int? { .None }\nfn main() Int {\n  x := find()\n  0\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(typedef_request(1, "file:///a.tw", 2, 2))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
}
