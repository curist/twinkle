use compiler.query.type_registry as registry
use @std.testing.assert as assert
use @std.testing as runner

pub fn suite() runner.Suite {
  runner
    .suite("type registry")
    .test(
      "empty registry starts at given id",
      fn() {
        reg := registry.empty(8)
        try assert.equal(reg.next_id, 8)
        .Ok({})
      },
    )
    .test(
      "assign allocates sequential ids",
      fn() {
        reg := registry.empty(8)
        out1 := reg.assign("/a.tw", "Foo")
        out2 := out1.registry.assign("/a.tw", "Bar")
        try assert.equal(out1.id.id, 8)
        try assert.equal(out2.id.id, 9)
        try assert.equal(out2.registry.next_id, 10)
        .Ok({})
      },
    )
    .test(
      "assign returns same id on repeated call",
      fn() {
        reg := registry.empty(8)
        out1 := reg.assign("/a.tw", "Point")
        out2 := out1.registry.assign("/a.tw", "Point")
        try assert.equal(out1.id.id, out2.id.id)
        try assert.equal(out2.registry.next_id, 9)
        .Ok({})
      },
    )
    .test(
      "same name in different modules gets different ids",
      fn() {
        reg := registry.empty(8)
        out1 := reg.assign("/a.tw", "Point")
        out2 := out1.registry.assign("/b.tw", "Point")
        try assert.is_true(out1.id.id != out2.id.id)
        .Ok({})
      },
    )
    .test(
      "lookup finds assigned id",
      fn() {
        reg := registry.empty(8)
        out := reg.assign("/a.tw", "Foo")
        found := out.registry.lookup("/a.tw", "Foo")
        try assert.is_some(found)

        case found {
          .Some(tid) => try assert.equal(tid.id, 8),
          .None => {},
        }

        .Ok({})
      },
    )
    .test(
      "lookup returns None for unregistered type",
      fn() {
        reg := registry.empty(8)
        found := reg.lookup("/a.tw", "Missing")
        try assert.is_none(found)
        .Ok({})
      },
    )
    .test(
      "recompile scenario: same types get same ids regardless of order",
      fn() {
        // First compile: A then B
        reg := registry.empty(8)
        out_a1 := reg.assign("/a.tw", "TypeA")
        out_b1 := out_a1.registry.assign("/b.tw", "TypeB")

        // Second compile: B then A (different order, same registry)
        out_b2 := out_b1.registry.assign("/b.tw", "TypeB")
        out_a2 := out_b2.registry.assign("/a.tw", "TypeA")

        // Same ids regardless of access order
        try assert.equal(out_a1.id.id, out_a2.id.id)
        try assert.equal(out_b1.id.id, out_b2.id.id)
        .Ok({})
      },
    )
}
