use @std.testing.assert as assert
use @std.testing as runner

// Generic access over the IndexRead contract; String must satisfy IndexRead<Byte>.
fn first_via_index_read<C: IndexRead<E>, E>(c: C) E {
  c.at(0)
}

fn count_via_index_read<C: IndexRead<E>, E>(c: C) Int {
  c.len()
}

pub fn suite() runner.Suite {
  runner
    .suite("string")
    .test(
      "String satisfies IndexRead<Byte> (generic at/len over the bound)",
      fn() {
        s := "abc"
        try assert.equal(first_via_index_read(s).to_int(), 97)
        try assert.equal(count_via_index_read(s), 3)
        .Ok({})
      },
    )
    .test(
      "len returns byte length",
      fn() {
        try assert.equal("hello".len(), 5)
        try assert.equal("".len(), 0)
        .Ok({})
      },
    )
    .test(
      "is_empty detects empty and non-empty strings",
      fn() {
        try assert.is_true("".is_empty())
        try assert.is_false("hello".is_empty())
        .Ok({})
      },
    )
    .test(
      "indexing returns byte",
      fn() {
        s := "abc"
        try assert.equal(s[0].to_int(), 97)
        try assert.equal(s[1].to_int(), 98)
        try assert.equal(s[2].to_int(), 99)
        .Ok({})
      },
    )
    .test(
      "byte character predicates work as methods",
      fn() {
        upper := "A"[0]
        lower := "z"[0]
        digit := "9"[0]
        hex := "f"[0]
        space := " "[0]
        newline := "\n"[0]
        try assert.is_true(upper.is_upper())
        try assert.is_true(lower.is_lower())
        try assert.is_true(digit.is_digit())
        try assert.is_true(hex.is_hex_digit())
        try assert.is_true(upper.is_alpha())
        try assert.is_true(digit.is_alnum())
        try assert.is_false(space.is_alnum())
        try assert.is_true(space.is_space())
        try assert.is_true(newline.is_newline())
        try assert.is_true(upper.in_range(0x41, 0x5A))
        .Ok({})
      },
    )
    .test(
      "string get returns option byte",
      fn() {
        s := "hi"
        try assert.is_some(s.get(0))
        try assert.is_some(s.get(1))
        try assert.is_none(s.get(2))
        try assert.is_none(s.get(-1))
        .Ok({})
      },
    )
    .test(
      "concat joins strings",
      fn() {
        try assert.equal("hello".concat(" world"), "hello world")
        try assert.equal("".concat("x"), "x")
        .Ok({})
      },
    )
    .test(
      "contains finds substringing",
      fn() {
        try assert.is_true("hello world".contains("world"))
        try assert.is_true("hello world".contains("hello"))
        try assert.is_false("hello world".contains("xyz"))
        try assert.is_true("abc".contains(""))
        .Ok({})
      },
    )
    .test(
      "starts_with and ends_with",
      fn() {
        s := "twinkle"
        try assert.is_true(s.starts_with("twin"))
        try assert.is_false(s.starts_with("wink"))
        try assert.is_true(s.ends_with("kle"))
        try assert.is_false(s.ends_with("ink"))
        .Ok({})
      },
    )
    .test(
      "index_of finds position",
      fn() {
        s := "hello world"
        idx := s.index_of("world")
        try assert.is_some(idx)
        val := case idx {
          .Some(v) => v,
          .None => -1,
        }
        try assert.equal(val, 6)
        try assert.is_none(s.index_of("xyz"))
        .Ok({})
      },
    )
    .test(
      "split divides string",
      fn() {
        parts := "a,b,c".split(",")
        try assert.equal(parts.len(), 3)
        try assert.equal(parts[0], "a")
        try assert.equal(parts[1], "b")
        try assert.equal(parts[2], "c")
        .Ok({})
      },
    )
    .test(
      "split with no match returns whole string",
      fn() {
        parts := "hello".split(",")
        try assert.equal(parts.len(), 1)
        try assert.equal(parts[0], "hello")
        .Ok({})
      },
    )
    .test(
      "trim strips whitespace",
      fn() {
        try assert.equal("  hello  ".trim(), "hello")
        try assert.equal("hello".trim(), "hello")
        try assert.equal("   ".trim(), "")
        .Ok({})
      },
    )
    .test(
      "slice extracts byte range",
      fn() {
        s := "hello"
        try assert.equal(s.slice(1, 4), "ell")
        try assert.equal(s.slice(0, 5), "hello")
        .Ok({})
      },
    )
    .test(
      "range-index slices a string",
      fn() {
        s := "hello"
        try assert.equal(s[1..4], "ell")
        try assert.equal(s[0..5], "hello")
        try assert.equal(s[2..2], "")
        .Ok({})
      },
    )
    .test(
      "slice clamps out-of-range indices",
      fn() {
        try assert.equal("abc".slice(0, 100), "abc")
        try assert.equal("abc".slice(-5, 3), "abc")
        try assert.equal("abc".slice(1, 3), "bc")
        try assert.equal("abc".slice(5, 10), "")
        .Ok({})
      },
    )
    .test(
      "substring extracts by character index",
      fn() {
        try assert.equal("hello world".substring(0, 5), "hello")
        try assert.equal("hello world".substring(6, 11), "world")
        .Ok({})
      },
    )
    .test(
      "substring handles multibyte characters",
      fn() {
        try assert.equal("héllo".substring(0, 3), "hél")
        try assert.equal("日本語".substring(1, 3), "本語")
        try assert.equal("日本語".substring(0, 1), "日")
        .Ok({})
      },
    )
    .test(
      "substring clamps indices",
      fn() {
        try assert.equal("abc".substring(0, 100), "abc")
        try assert.equal("abc".substring(-1, 2), "ab")
        try assert.equal("abc".substring(5, 10), "")
        try assert.equal("abc".substring(2, 2), "")
        try assert.equal("abc".substring(3, 1), "")
        .Ok({})
      },
    )
    .test(
      "interpolation embeds values",
      fn() {
        name := "world"
        n := 42
        try assert.equal("hello ${name}", "hello world")
        try assert.equal("n=${n}", "n=42")
        .Ok({})
      },
    )
    .test(
      "for iterates bytes",
      fn() {
        s := "abc"
        bytes := Cell.new("")

        for b in s {
          bytes.update(fn(acc) {
            "${acc}${b.to_int()} "
          })
        }

        try assert.equal(bytes.get(), "97 98 99 ")
        .Ok({})
      },
    )
    .test(
      "chars iterates unicode scalars",
      fn() {
        ascii_count := "hello".char_len()
        try assert.equal(ascii_count, 5)
        .Ok({})
      },
    )
    .test(
      "equality and comparison",
      fn() {
        try assert.is_true("abc" == "abc")
        try assert.is_false("abc" == "def")
        try assert.is_true("abc" < "abd")
        try assert.is_true("abc" < "b")
        .Ok({})
      },
    )
    .test(
      "to_string on primitives",
      fn() {
        try assert.equal(42.to_string(), "42")
        try assert.equal(true.to_string(), "true")
        try assert.equal(false.to_string(), "false")
        .Ok({})
      },
    )
}
