use commands.lint
use compiler.base_env
use compiler.query.analyze
use compiler.query.cache
use lib.source.identity
use lib.source.overlay
use lib.source.report.{FixEdit}
use lib.source.rewrite
use tests.assert
use tests.runner

fn analyze_src(text: String, lint_mode: Bool) analyze.ModuleResult {
  ov := overlay.from_documents([
    .{ identity: identity.from_path("/tmp/lintan/main.tw"), text, version: .Some(1) },
  ])
  state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/lintan")
  state.lint_mode = lint_mode
  id := identity.from_path("/tmp/lintan/main.tw")
  analyze.analyze_module(id, "__entry", base_env.builtin_env(), state, [])
}

pub fn suite() runner.Suite {
  runner.suite("lint_command")
    .test(
      "apply_edits: single range replacement",
      fn() {
        out := lint.apply_edits("abcdef", [FixEdit.{ start: 1, end: 3, replacement: "X" }])
        try assert.equal(out, "aXdef")
        .Ok({})
      },
    )
    .test(
      "apply_edits: multiple non-overlapping edits, given ascending, applied end-to-start",
      fn() {
        edits := [
          FixEdit.{ start: 0, end: 1, replacement: "" },
          FixEdit.{ start: 4, end: 6, replacement: "Z" },
        ]
        out := lint.apply_edits("abcdef", edits)
        try assert.equal(out, "bcdZ")
        .Ok({})
      },
    )
    .test(
      "apply_edits: insertion (start == end)",
      fn() {
        out := lint.apply_edits("ac", [FixEdit.{ start: 1, end: 1, replacement: "b" }])
        try assert.equal(out, "abc")
        .Ok({})
      },
    )
    .test(
      "R1 detection: Vector.map(xs, f) yields an inherent-method rewrite in review mode",
      fn() {
        result := analyze_src("xs := [1]\nys := Vector.map(xs, fn(n) { n })\n", true)
        try assert.is_true(result.ok)
        try assert.equal(result.rewrites.len(), 1)
        hit := result.rewrites[0]
        try assert.str_contains(hit.path, "main.tw")
        try assert.equal(rewrite.rule(hit.rewrite), "inherent-calls")

        // delete `Vector.map(` prefix + replace `, ` with `.map(`
        try assert.equal(rewrite.fixes(hit.rewrite)[0].edits.len(), 2)
        .Ok({})
      },
    )
    .test(
      "R1 detection: no rewrites when review mode is off",
      fn() {
        result := analyze_src("xs := [1]\nys := Vector.map(xs, fn(n) { n })\n", false)
        try assert.is_true(result.ok)
        try assert.equal(result.rewrites.len(), 0)
        .Ok({})
      },
    )
    .test(
      "R1 detection: already-inherent xs.map(f) yields no rewrite",
      fn() {
        result := analyze_src("xs := [1]\nys := xs.map(fn(n) { n })\n", true)
        try assert.is_true(result.ok)
        try assert.equal(result.rewrites.len(), 0)
        .Ok({})
      },
    )
}
