use commands.lint
use compiler.base_env
use compiler.lint_rules
use compiler.query.analyze
use compiler.query.cache
use lib.source.identity
use lib.source.overlay
use lib.source.report.{FixEdit}
use lib.source.rewrite
use tests.assert
use tests.runner

fn analyze_src(text: String, lint_mode: Bool) analyze.ModuleResult {
  ov := overlay.from_documents([
    .{ identity: identity.from_path("/tmp/lintan/main.tw"), text, version: .Some(1) },
  ])
  state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/lintan")
  state.lint_mode = lint_mode
  id := identity.from_path("/tmp/lintan/main.tw")
  analyze.analyze_module(id, "__entry", base_env.builtin_env(), state, [])
}

pub fn suite() runner.Suite {
  runner.suite("lint_command")
    .test(
      "apply_edits: single range replacement",
      fn() {
        out := lint.apply_edits("abcdef", [FixEdit.{ start: 1, end: 3, replacement: "X" }])
        try assert.equal(out, "aXdef")
        .Ok({})
      },
    )
    .test(
      "apply_edits: multiple non-overlapping edits, given ascending, applied end-to-start",
      fn() {
        edits := [
          FixEdit.{ start: 0, end: 1, replacement: "" },
          FixEdit.{ start: 4, end: 6, replacement: "Z" },
        ]
        out := lint.apply_edits("abcdef", edits)
        try assert.equal(out, "bcdZ")
        .Ok({})
      },
    )
    .test(
      "apply_edits: insertion (start == end)",
      fn() {
        out := lint.apply_edits("ac", [FixEdit.{ start: 1, end: 1, replacement: "b" }])
        try assert.equal(out, "abc")
        .Ok({})
      },
    )
    .test(
      "R1 detection: Vector.map(xs, f) yields an inherent-method rewrite in review mode",
      fn() {
        result := analyze_src("xs := [1]\nys := Vector.map(xs, fn(n) { n })\n", true)
        try assert.is_true(result.ok)
        try assert.equal(result.rewrites.len(), 1)
        hit := result.rewrites[0]
        try assert.str_contains(hit.path, "main.tw")
        try assert.equal(rewrite.rule(hit.rewrite), "inherent-calls")

        // delete `Vector.map(` prefix + replace `, ` with `.map(`
        try assert.equal(rewrite.fixes(hit.rewrite)[0].edits.len(), 2)
        .Ok({})
      },
    )
    .test(
      "R1 detection: no rewrites when review mode is off",
      fn() {
        result := analyze_src("xs := [1]\nys := Vector.map(xs, fn(n) { n })\n", false)
        try assert.is_true(result.ok)
        try assert.equal(result.rewrites.len(), 0)
        .Ok({})
      },
    )
    .test(
      "R1 detection: already-inherent xs.map(f) yields no rewrite",
      fn() {
        result := analyze_src("xs := [1]\nys := xs.map(fn(n) { n })\n", true)
        try assert.is_true(result.ok)
        try assert.equal(result.rewrites.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L2 detection: an ignored Result yields a unused-must-use lint",
      fn() {
        src := "fn risky() Result<Int, String> {\n  .Ok(1)\n}\nfn run() {\n  risky()\n  println(\"x\")\n}\n"
        result := analyze_src(src, true)
        try assert.is_true(result.ok)
        found := false

        for h in result.lints {
          if h.finding.rule == "unused-must-use" {
            found = true
          }
        }
        try assert.is_true(found)
        .Ok({})
      },
    )
    .test(
      "L2 detection: no lint when review mode is off",
      fn() {
        src := "fn risky() Result<Int, String> {\n  .Ok(1)\n}\nfn run() {\n  risky()\n  println(\"x\")\n}\n"
        result := analyze_src(src, false)
        try assert.is_true(result.ok)
        try assert.equal(result.lints.len(), 0)
        .Ok({})
      },
    )
    .test(
      "lint_rules: describe returns brief for a known rule",
      fn() {
        info := try lint_rules.describe("direct-rebinding").ok_or("expected Some")
        try assert.equal(
          info.brief,
          "the temporary only aliases a value; rebind the field/index path directly",
        )
        .Ok({})
      },
    )
    .test(
      "lint_rules: describe returns None for an unknown rule",
      fn() {
        case lint_rules.describe("no-such-rule") {
          .Some(_) => .Err("expected None"),
          .None => .Ok({}),
        }
      },
    )
    .test(
      "lint_rules: every emitted rule id has a description",
      fn() {
        ids := [
          "direct-rebinding",
          "record-copy-helper",
          "unreachable-code",
          "unused-must-use",
          "unused-imports",
          "inherent-calls",
        ]

        for id in ids {
          case lint_rules.describe(id) {
            .Some(info) => {
              try assert.is_true(info.brief.len() > 0)
              try assert.is_true(info.detailed.len() > 0)
            },
            .None => { return .Err("no description for rule: ${id}") },
          }
        }
        .Ok({})
      },
    )
    .test(
      "render_report: groups findings by rule with brief headers, alphabetical",
      fn() {
        findings := [
          lint.Finding.{
            path: "z.tw", start: 0, message: "code after a return never runs",
            rule: "unreachable-code", edits: [],
          },
          lint.Finding.{
            path: "a.tw", start: 5, message: "`cur` is only an alias for `env`",
            rule: "direct-rebinding", edits: [],
          },
        ]
        out := lint.render_report(findings, Dict.new(), false)
        // direct-rebinding sorts before unreachable-code (index_of returns Int?)
        dr := try out.index_of("direct-rebinding").ok_or("direct-rebinding missing")
        uc := try out.index_of("unreachable-code").ok_or("unreachable-code missing")
        try assert.is_true(dr < uc)
        // brief appears in the header
        try assert.is_true(out.contains("rebind the field/index path directly"))
        // the finding line is present and indented
        try assert.is_true(out.contains("\n  a.tw:"))
        // default mode does not include the detailed block
        try assert.is_true(!out.contains("// Avoid"))
        .Ok({})
      },
    )
}
