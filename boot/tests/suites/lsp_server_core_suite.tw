use compiler.query.cache as query_cache
use lib.json
use lib.lsp.document_store
use lib.lsp.protocol
use lib.lsp.server_core
use tests.assert
use tests.runner

fn only_out(step: server_core.Step) json.Json!String {
  if step.outgoing.len() != 1 {
    .Err("expected one outgoing message")
  } else {
    .Ok(step.outgoing[0])
  }
}

fn published_for(step: server_core.Step, uri: String) json.Json!String {
  for out in step.outgoing {
    params := try out.decode(json.field("params", json.raw()))
    out_uri := try params.decode(json.field("uri", json.string()))

    if out_uri == uri {
      return .Ok(out)
    }
  }

  .Err("missing diagnostics for ${uri}")
}

fn diagnostic_count(out: json.Json) Int!String {
  params := try out.decode(json.field("params", json.raw()))
  diagnostics := try params.decode(json.field("diagnostics", json.raw().list()))
  .Ok(diagnostics.len())
}

fn publish_due_now(step: server_core.Step) server_core.Step {
  state := step.state
  state.diagnostics_deadline_ms = 0.0
  state.publish_due_diagnostics()
}

pub fn suite() runner.Suite {
  runner
    .suite("lsp server core")
    .test(
      "initialize returns minimal capabilities",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)
        out := try only_out(step)
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        try assert.equal(try caps.decode(json.field("positionEncoding", json.string())), "utf-16")
        try assert.equal(try caps.decode(json.field("textDocumentSync", json.int())), 2)
        info := try result.decode(json.field("serverInfo", json.raw()))
        try assert.equal(try info.decode(json.field("name", json.string())), "twinkle-lsp")
        .Ok({})
      },
    )
    .test(
      "initialized notification updates state without response",
      fn() {
        msg := protocol.Message.Notification(.{ method: "initialized", params: .None })
        step := server_core.initial_state().handle_message(msg)
        try assert.is_true(step.state.initialized)
        try assert.equal(step.outgoing.len(), 0)
        .Ok({})
      },
    )
    .test(
      "shutdown responds null and marks state",
      fn() {
        msg := protocol.Message.Request(.{ id: .StringId("s"), method: "shutdown", params: .None })
        step := server_core.initial_state().handle_message(msg)
        try assert.is_true(step.state.shutdown_requested)
        out := try only_out(step)

        case try out.decode(json.field("result", json.raw())) {
          .Null => .Ok({}),
          _ => assert.fail("expected null result"),
        }
      },
    )
    .test(
      "exit notification requests exit",
      fn() {
        msg := protocol.Message.Notification(.{ method: "exit", params: .None })
        step := server_core.initial_state().handle_message(msg)
        try assert.is_true(step.state.should_exit)
        try assert.equal(step.outgoing.len(), 0)
        .Ok({})
      },
    )
    .test(
      "unknown request returns method not found",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(9), method: "twinkle/nope", params: .None })
        step := server_core.initial_state().handle_message(msg)
        out := try only_out(step)
        err := try out.decode(json.field("error", json.raw()))
        try assert.equal(try err.decode(json.field("code", json.int())), -32601)
        try assert.equal(try err.decode(json.field("message", json.string())), "method not found")
        .Ok({})
      },
    )
    .test(
      "didOpen stores the document",
      fn() {
        params := json.object([
          json.kv(
            "textDocument",
            json.object([
              json.kv("uri", .Str("file:///a.tw")),
              json.kv("languageId", .Str("twinkle")),
              json.kv("version", .Int(1)),
              json.kv("text", .Str("x := 1\n")),
            ]),
          ),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didOpen",
          params: .Some(params),
        })
        step := server_core.initial_state().handle_message(msg)
        doc := try step.state.documents.get("file:///a.tw").ok_or("missing document")
        try assert.equal(doc.text, "x := 1\n")
        try assert.equal(try doc.version.ok_or("missing version"), 1)
        out := try only_out(step)
        try assert.equal(
          try out.decode(json.field("method", json.string())),
          "textDocument/publishDiagnostics",
        )
        params_out := try out.decode(json.field("params", json.raw()))
        try assert.equal(try params_out.decode(json.field("uri", json.string())), "file:///a.tw")
        try assert.equal(try params_out.decode(json.field("version", json.int())), 1)
        .Ok({})
      },
    )
    .test(
      "didChange replaces full document text",
      fn() {
        opened := document_store.empty().open("file:///a.tw", "old", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: opened,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }
        params := json.object([
          json.kv(
            "textDocument",
            json.object([json.kv("uri", .Str("file:///a.tw")), json.kv("version", .Int(2))]),
          ),
          json.kv("contentChanges", json.array([json.object([json.kv("text", .Str("new"))])])),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didChange",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        doc := try step.state.documents.get("file:///a.tw").ok_or("missing document")
        try assert.equal(doc.text, "new")
        try assert.equal(try doc.version.ok_or("missing version"), 2)
        try assert.is_true(step.state.diagnostics_pending)
        try assert.equal(step.outgoing.len(), 0)
        .Ok({})
      },
    )
    .test(
      "didChange applies incremental text change",
      fn() {
        // "hello world" — insert " beautiful" at offset 5 (line 0, char 5)
        opened := document_store.empty().open("file:///a.tw", "hello world", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: opened,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }
        change_event := json.object([
          json.kv("text", .Str(" beautiful")),
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(5))]),
              ),
              json.kv("end", json.object([json.kv("line", .Int(0)), json.kv("character", .Int(5))])),
            ]),
          ),
        ])
        params := json.object([
          json.kv(
            "textDocument",
            json.object([json.kv("uri", .Str("file:///a.tw")), json.kv("version", .Int(2))]),
          ),
          json.kv("contentChanges", json.array([change_event])),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didChange",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        doc := try step.state.documents.get("file:///a.tw").ok_or("missing document")
        try assert.equal(doc.text, "hello beautiful world")
        try assert.equal(try doc.version.ok_or("missing version"), 2)
        try assert.is_true(step.state.diagnostics_pending)
        .Ok({})
      },
    )
    .test(
      "didChange applies multiple incremental changes in order",
      fn() {
        // "aaa\nbbb" — two changes: replace "bbb" with "ccc", then insert "X" at start
        opened := document_store.empty().open("file:///a.tw", "aaa\nbbb", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: opened,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }

        // First change: replace "bbb" (line 1, char 0..3) with "ccc"
        change1 := json.object([
          json.kv("text", .Str("ccc")),
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(1)), json.kv("character", .Int(0))]),
              ),
              json.kv("end", json.object([json.kv("line", .Int(1)), json.kv("character", .Int(3))])),
            ]),
          ),
        ])

        // Second change: insert "X" at line 0, char 0
        change2 := json.object([
          json.kv("text", .Str("X")),
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(0))]),
              ),
              json.kv("end", json.object([json.kv("line", .Int(0)), json.kv("character", .Int(0))])),
            ]),
          ),
        ])
        params := json.object([
          json.kv(
            "textDocument",
            json.object([json.kv("uri", .Str("file:///a.tw")), json.kv("version", .Int(2))]),
          ),
          json.kv("contentChanges", json.array([change1, change2])),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didChange",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        doc := try step.state.documents.get("file:///a.tw").ok_or("missing document")
        try assert.equal(doc.text, "Xaaa\nccc")
        .Ok({})
      },
    )
    .test(
      "didChange publishes diagnostics for open importers",
      fn() {
        docs := document_store
          .empty()
          .open("file:///tmp/a.tw", "use dep\nx: Int = dep.answer()\n", .Some(1))
          .open("file:///tmp/dep.tw", "pub fn answer() Int { 1 }\n", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: docs,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }
        params := json.object([
          json.kv(
            "textDocument",
            json.object([json.kv("uri", .Str("file:///tmp/dep.tw")), json.kv("version", .Int(2))]),
          ),
          json.kv(
            "contentChanges",
            json.array([
              json.object([json.kv("text", .Str("pub fn answer() String { \"nope\" }\n"))]),
            ]),
          ),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didChange",
          params: .Some(params),
        })
        step := publish_due_now(state.handle_message(msg))
        try assert.equal(step.outgoing.len(), 2)
        importer_out := try published_for(step, "file:///tmp/a.tw")
        try assert.is_true(try diagnostic_count(importer_out) > 0)
        dep_out := try published_for(step, "file:///tmp/dep.tw")
        try assert.equal(try diagnostic_count(dep_out), 0)
        .Ok({})
      },
    )
    .test(
      "missing import publishes diagnostics without breaking state",
      fn() {
        params := json.object([
          json.kv(
            "textDocument",
            json.object([
              json.kv("uri", .Str("file:///tmp/missing_import.tw")),
              json.kv("languageId", .Str("twinkle")),
              json.kv("version", .Int(1)),
              json.kv("text", .Str("use missing\nx := 1\n")),
            ]),
          ),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didOpen",
          params: .Some(params),
        })
        step := server_core.initial_state().handle_message(msg)
        try assert.is_false(step.state.should_exit)
        out := try published_for(step, "file:///tmp/missing_import.tw")
        try assert.is_true(try diagnostic_count(out) > 0)
        .Ok({})
      },
    )
    .test(
      "supports repeated open change close cycles for same uri",
      fn() {
        uri := "file:///tmp/reopen.tw"
        open_params := json.object([
          json.kv(
            "textDocument",
            json.object([
              json.kv("uri", .Str(uri)),
              json.kv("languageId", .Str("twinkle")),
              json.kv("version", .Int(1)),
              json.kv("text", .Str("x := 1\n")),
            ]),
          ),
        ])
        open_step := server_core
          .initial_state()
          .handle_message(
            protocol.Message.Notification(.{
              method: "textDocument/didOpen",
              params: .Some(open_params),
            }),
          )
        try assert.is_some(open_step.state.documents.get(uri))
        close_params := json.object([
          json.kv("textDocument", json.object([json.kv("uri", .Str(uri))])),
        ])
        close_step := open_step.state.handle_message(
          protocol.Message.Notification(.{
            method: "textDocument/didClose",
            params: .Some(close_params),
          }),
        )
        try assert.is_none(close_step.state.documents.get(uri))
        reopen_params := json.object([
          json.kv(
            "textDocument",
            json.object([
              json.kv("uri", .Str(uri)),
              json.kv("languageId", .Str("twinkle")),
              json.kv("version", .Int(2)),
              json.kv("text", .Str("x := 2\n")),
            ]),
          ),
        ])
        reopen_step := close_step.state.handle_message(
          protocol.Message.Notification(.{
            method: "textDocument/didOpen",
            params: .Some(reopen_params),
          }),
        )
        doc := try reopen_step.state.documents.get(uri).ok_or("missing reopened document")
        try assert.equal(try doc.version.ok_or("missing version"), 2)
        change_params := json.object([
          json.kv(
            "textDocument",
            json.object([json.kv("uri", .Str(uri)), json.kv("version", .Int(3))]),
          ),
          json.kv("contentChanges", json.array([json.object([json.kv("text", .Str("x := 3\n"))])])),
        ])
        change_step := reopen_step.state.handle_message(
          protocol.Message.Notification(.{
            method: "textDocument/didChange",
            params: .Some(change_params),
          }),
        )
        changed := try change_step.state.documents.get(uri).ok_or("missing changed document")
        try assert.equal(changed.text, "x := 3\n")
        try assert.equal(try changed.version.ok_or("missing version"), 3)
        try assert.is_false(change_step.state.should_exit)
        .Ok({})
      },
    )
    .test(
      "didChange clears stale importer diagnostics",
      fn() {
        docs := document_store
          .empty()
          .open("file:///tmp/a.tw", "use dep\nx: Int = dep.answer()\n", .Some(1))
          .open("file:///tmp/dep.tw", "pub fn answer() String { \"nope\" }\n", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: docs,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }
        params := json.object([
          json.kv(
            "textDocument",
            json.object([json.kv("uri", .Str("file:///tmp/dep.tw")), json.kv("version", .Int(2))]),
          ),
          json.kv(
            "contentChanges",
            json.array([json.object([json.kv("text", .Str("pub fn answer() Int { 1 }\n"))])]),
          ),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didChange",
          params: .Some(params),
        })
        step := publish_due_now(state.handle_message(msg))
        try assert.equal(step.outgoing.len(), 2)
        importer_out := try published_for(step, "file:///tmp/a.tw")
        try assert.equal(try diagnostic_count(importer_out), 0)
        .Ok({})
      },
    )
    .test(
      "didClose removes the document",
      fn() {
        opened := document_store.empty().open("file:///a.tw", "old", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: opened,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }
        params := json.object([
          json.kv("textDocument", json.object([json.kv("uri", .Str("file:///a.tw"))])),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didClose",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        try assert.is_none(step.state.documents.get("file:///a.tw"))
        out := try only_out(step)
        try assert.equal(
          try out.decode(json.field("method", json.string())),
          "textDocument/publishDiagnostics",
        )
        params_out := try out.decode(json.field("params", json.raw()))
        diagnostics := try params_out.decode(json.field("diagnostics", json.raw().list()))
        try assert.equal(diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "malformed document notification is ignored",
      fn() {
        msg := protocol.Message.Notification(.{ method: "textDocument/didOpen", params: .None })
        step := server_core.initial_state().handle_message(msg)
        try assert.equal(step.outgoing.len(), 0)
        try assert.is_false(step.state.should_exit)
        try assert.is_none(step.state.documents.get("file:///a.tw"))
        .Ok({})
      },
    )
    .test(
      "unknown notification is ignored",
      fn() {
        msg := protocol.Message.Notification(.{ method: "twinkle/nope", params: .None })
        step := server_core.initial_state().handle_message(msg)
        try assert.equal(step.outgoing.len(), 0)
        try assert.is_false(step.state.should_exit)
        .Ok({})
      },
    )
    .test(
      "initialize advertises codeActionProvider",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)
        out := try only_out(step)
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        try assert.is_true(try caps.decode(json.field("codeActionProvider", json.bool())))
        .Ok({})
      },
    )
    .test(
      "initialize advertises documentFormattingProvider",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)
        out := try only_out(step)
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        try assert.is_true(try caps.decode(json.field("documentFormattingProvider", json.bool())))
        .Ok({})
      },
    )
    .test(
      "formatting returns a full-document edit",
      fn() {
        docs := document_store
          .empty()
          .open("file:///tmp/format.tw", "fn f() String { \"\\u{0065}\" }", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: docs,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }
        params := json.object([
          json.kv("textDocument", json.object([json.kv("uri", .Str("file:///tmp/format.tw"))])),
          json.kv(
            "options",
            json.object([json.kv("tabSize", .Int(2)), json.kv("insertSpaces", .Bool(true))]),
          ),
        ])
        msg := protocol.Message.Request(.{
          id: .IntId(4),
          method: "textDocument/formatting",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        out := try only_out(step)
        result := try out.decode(json.field("result", json.raw()))
        edits := try result.decode(json.raw().list())
        try assert.equal(edits.len(), 1)
        edit := edits[0]
        try assert.equal(
          try edit.decode(json.field("newText", json.string())),
          "fn f() String {\n  \"e\"\n}\n",
        )
        .Ok({})
      },
    )
    .test(
      "codeAction returns quickfix for unused import diagnostic data",
      fn() {
        // Set up a document with an unused import
        docs := document_store
          .empty()
          .open("file:///tmp/action.tw", "use foo.{A, B}\nx := A\n", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: docs,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }

        // Build a codeAction request with a diagnostic carrying fix data
        diag_data := json.object([
          json.kv(
            "fixes",
            json.array([
              json.object([
                json.kv("title", .Str("remove unused import `B`")),
                json.kv(
                  "edits",
                  json.array([
                    json.object([
                      json.kv("start", .Int(0)),
                      json.kv("end", .Int(15)),
                      json.kv("replacement", .Str("use foo.{A}\n")),
                    ]),
                  ]),
                ),
              ]),
            ]),
          ),
        ])
        diag_json := json.object([
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(12))]),
              ),
              json.kv(
                "end",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(13))]),
              ),
            ]),
          ),
          json.kv("severity", .Int(2)),
          json.kv("source", .Str("twinkle")),
          json.kv("message", .Str("unused import: B")),
          json.kv("data", diag_data),
        ])
        params := json.object([
          json.kv("textDocument", json.object([json.kv("uri", .Str("file:///tmp/action.tw"))])),
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(12))]),
              ),
              json.kv(
                "end",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(13))]),
              ),
            ]),
          ),
          json.kv("context", json.object([json.kv("diagnostics", json.array([diag_json]))])),
        ])
        msg := protocol.Message.Request(.{
          id: .IntId(2),
          method: "textDocument/codeAction",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        out := try only_out(step)
        result := try out.decode(json.field("result", json.raw()))

        // Should return an array of code actions
        actions := try result.decode(json.raw().list())
        try assert.is_true(actions.len() > 0)
        action := actions[0]
        try assert.equal(try action.decode(json.field("kind", json.string())), "quickfix")
        try assert.equal(
          try action.decode(json.field("title", json.string())),
          "remove unused import `B`",
        )

        // Should have a workspace edit
        edit := try action.decode(json.field("edit", json.raw()))
        changes := try edit.decode(json.field("changes", json.raw()))
        file_edits := try changes.decode(json.field("file:///tmp/action.tw", json.raw().list()))
        try assert.is_true(file_edits.len() > 0)
        text_edit := file_edits[0]
        try assert.equal(
          try text_edit.decode(json.field("newText", json.string())),
          "use foo.{A}\n",
        )
        .Ok({})
      },
    )
    .test(
      "didOpen publishes unused import diagnostics with data for code actions",
      fn() {
        // Open two files: dep defines something, main imports but doesn't use one
        docs := document_store
          .empty()
          .open(
            "file:///tmp/dep.tw",
            "pub fn used_fn() Int { 1 }\npub fn unused_fn() Int { 2 }\n",
            .Some(1),
          )
          .open(
            "file:///tmp/main_import.tw",
            "use dep.{used_fn, unused_fn}\nx := used_fn()\n",
            .Some(1),
          )
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: docs,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }

        // Trigger diagnostics via didChange on the main file
        change_params := json.object([
          json.kv(
            "textDocument",
            json.object([
              json.kv("uri", .Str("file:///tmp/main_import.tw")),
              json.kv("version", .Int(2)),
            ]),
          ),
          json.kv(
            "contentChanges",
            json.array([
              json.object([json.kv("text", .Str("use dep.{used_fn, unused_fn}\nx := used_fn()\n"))]),
            ]),
          ),
        ])
        msg := protocol.Message.Notification(.{
          method: "textDocument/didChange",
          params: .Some(change_params),
        })
        step := publish_due_now(state.handle_message(msg))

        // Find diagnostics for main_import.tw
        main_out := try published_for(step, "file:///tmp/main_import.tw")
        params_out := try main_out.decode(json.field("params", json.raw()))
        items := try params_out.decode(json.field("diagnostics", json.raw().list()))

        // Should have an unused import warning for unused_fn
        found_unused := false

        for item in items {
          msg_str := case item.decode(json.field("message", json.string())) {
            .Ok(m) => m,
            .Err(_) => { continue },
          }

          if msg_str.contains("unused_fn") {
            found_unused = true

            // Should have data with a uniform fix payload.
            data := try item.decode(json.field("data", json.raw()))
            fixes := try data.decode(json.field("fixes", json.raw().list()))
            fix := fixes[0]
            edits := try fix.decode(json.field("edits", json.raw().list()))
            edit := edits[0]

            // Should have replacement that keeps only used_fn
            replacement := try edit.decode(json.field("replacement", json.string()))
            try assert.str_contains(replacement, "used_fn")
            try assert.is_false(replacement.contains("unused_fn"))
          }
        }

        try assert.is_true(found_unused)
        .Ok({})
      },
    )
    .test(
      "codeAction ignores diagnostics without unused_import data",
      fn() {
        docs := document_store.empty().open("file:///tmp/noaction.tw", "x := 1\n", .Some(1))
        state := server_core.State.{
          initialized: true,
          shutdown_requested: false,
          should_exit: false,
          documents: docs,
          query_cache: query_cache.empty(),
          diagnostics_pending: false,
          diagnostics_deadline_ms: 0.0,
          last_published_versions: Dict.new(),
        }

        // Diagnostic without data
        diag_json := json.object([
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(0))]),
              ),
              json.kv("end", json.object([json.kv("line", .Int(0)), json.kv("character", .Int(1))])),
            ]),
          ),
          json.kv("severity", .Int(1)),
          json.kv("message", .Str("some error")),
        ])
        params := json.object([
          json.kv("textDocument", json.object([json.kv("uri", .Str("file:///tmp/noaction.tw"))])),
          json.kv(
            "range",
            json.object([
              json.kv(
                "start",
                json.object([json.kv("line", .Int(0)), json.kv("character", .Int(0))]),
              ),
              json.kv("end", json.object([json.kv("line", .Int(0)), json.kv("character", .Int(1))])),
            ]),
          ),
          json.kv("context", json.object([json.kv("diagnostics", json.array([diag_json]))])),
        ])
        msg := protocol.Message.Request(.{
          id: .IntId(3),
          method: "textDocument/codeAction",
          params: .Some(params),
        })
        step := state.handle_message(msg)
        out := try only_out(step)
        result := try out.decode(json.field("result", json.raw()))
        actions := try result.decode(json.raw().list())
        try assert.equal(actions.len(), 0)
        .Ok({})
      },
    )
}
