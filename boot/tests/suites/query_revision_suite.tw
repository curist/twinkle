use compiler.base_env
use compiler.checker
use compiler.parser
use compiler.query.cache
use lib.query.keys
use tests.assert
use tests.runner

pub fn suite() runner.Suite {
  runner.suite("query revision")
    .test(
      "empty store starts at revision 0",
      fn() {
        store := cache.empty()
        try assert.equal(store.revision, 0)
        .Ok({})
      },
    )
    .test(
      "note_source_hash bumps revision on new source",
      fn() {
        store := cache.empty()
        hash := keys.hash_text("fn main() {}")
        store = cache.note_source_hash(store, "/a.tw", hash)
        try assert.equal(store.revision, 1)
        .Ok({})
      },
    )
    .test(
      "note_source_hash does not bump revision on same hash",
      fn() {
        store := cache.empty()
        hash := keys.hash_text("fn main() {}")
        store = cache.note_source_hash(store, "/a.tw", hash)
        store = cache.note_source_hash(store, "/a.tw", hash)
        try assert.equal(store.revision, 1)
        .Ok({})
      },
    )
    .test(
      "note_source_hash bumps revision on changed hash",
      fn() {
        store := cache.empty()
        h1 := keys.hash_text("fn main() { 1 }")
        h2 := keys.hash_text("fn main() { 2 }")
        store = cache.note_source_hash(store, "/a.tw", h1)
        store = cache.note_source_hash(store, "/a.tw", h2)
        try assert.equal(store.revision, 2)
        .Ok({})
      },
    )
    .test(
      "different modules each bump revision independently",
      fn() {
        store := cache.empty()
        ha := keys.hash_text("mod a")
        hb := keys.hash_text("mod b")
        store = cache.note_source_hash(store, "/a.tw", ha)
        store = cache.note_source_hash(store, "/b.tw", hb)
        try assert.equal(store.revision, 2)
        .Ok({})
      },
    )
    .test(
      "put_parsed stamps changed_at to current revision",
      fn() {
        store := cache.empty()
        hash := keys.hash_text("x := 1")
        store = cache.note_source_hash(store, "/a.tw", hash)
        // revision is now 1
        key := keys.parse_key("/a.tw", hash)
        parsed := make_parsed("x := 1")
        store = cache.put_parsed(store, "/a.tw", key, parsed)
        try assert.equal(cache.changed_at(store, "/a.tw", .Parsed), 1)
        .Ok({})
      },
    )
    .test(
      "cache hit updates verified_at to current revision",
      fn() {
        store := cache.empty()
        h1 := keys.hash_text("x := 1")
        store = cache.note_source_hash(store, "/a.tw", h1)
        // revision = 1
        key := keys.parse_key("/a.tw", h1)
        parsed := make_parsed("x := 1")
        store = cache.put_parsed(store, "/a.tw", key, parsed)
        // changed_at = 1, verified_at = 1
        // Simulate another module changing (bumps revision to 2)
        h2 := keys.hash_text("mod b")
        store = cache.note_source_hash(store, "/b.tw", h2)
        // revision = 2
        // Hit cache for /a.tw — verified_at should update to 2
        lookup := cache.get_parsed(store, "/a.tw", key)
        try assert.is_true(lookup.cache_hit)
        try assert.equal(cache.verified_at(lookup.store, "/a.tw", .Parsed), 2)
        .Ok({})
      },
    )
    .test(
      "invalidate_changed_module preserves downstream resolved entries",
      fn() {
        dep := "/dep.tw"
        main := "/main.tw"
        store := cache.empty()
        store = cache.note_source_hash(store, dep, keys.hash_text("pub fn x() Int { 1 }"))
        store = cache.note_source_hash(store, main, keys.hash_text("use dep\nfn run() { dep.x() }"))
        store = cache.set_dependencies(store, main, [dep])
        // Populate main's resolved entry
        key := keys.resolve_key(main, keys.hash_text("use dep\nfn run() { dep.x() }"), 0)
        env := base_env.builtin_env()
        parsed := make_parsed("use dep\nfn run() { dep.x() }")
        resolved := env.resolve(parsed.module)
        store = cache.put_resolved(store, main, key, resolved)
        // Dep changes → invalidation
        store = cache.invalidate_changed_module(store, dep)
        // Entry should still be present (not eagerly removed)
        try assert.is_some(cache.latest_resolved(store, main))
        .Ok({})
      },
    )
    .test(
      "invalidate_changed_module preserves downstream typed entries",
      fn() {
        dep := "/dep.tw"
        main := "/main.tw"
        store := cache.empty()
        store = cache.note_source_hash(store, dep, keys.hash_text("v1"))
        store = cache.note_source_hash(store, main, keys.hash_text("main"))
        store = cache.set_dependencies(store, main, [dep])
        // Populate main's typed entry with a dummy
        parsed := make_parsed("x := 1")
        env := base_env.builtin_env()
        resolved := env.resolve(parsed.module)
        typed := checker.check(parsed.module, resolved.env)
        store = cache.put_typed(store, main, 42, typed)
        // Dep changes → invalidation
        store = cache.invalidate_changed_module(store, dep)
        // Entry should still be present
        try assert.is_some(cache.latest_typed(store, main))
        .Ok({})
      },
    )
    .test(
      "invalidate_changed_module marks downstream verified_at as stale",
      fn() {
        dep := "/dep.tw"
        main := "/main.tw"
        store := cache.empty()
        store = cache.note_source_hash(store, dep, keys.hash_text("v1"))
        store = cache.note_source_hash(store, main, keys.hash_text("main"))
        // revision = 2
        store = cache.set_dependencies(store, main, [dep])
        // Put resolved at current revision (2)
        env := base_env.builtin_env()
        parsed := make_parsed("x := 1")
        resolved := env.resolve(parsed.module)
        store = cache.put_resolved(store, main, 99, resolved)
        try assert.equal(cache.verified_at(store, main, .Resolved), 2)
        // Dep changes → revision bumps to 3
        store = cache.note_source_hash(store, dep, keys.hash_text("v2"))
        store = cache.invalidate_changed_module(store, dep)
        // main's resolved verified_at should be stale (< current revision)
        try assert.is_true(cache.verified_at(store, main, .Resolved) < store.revision)
        .Ok({})
      },
    )
}

fn make_parsed(text: String) cache.ParsedModule {
  p := parser.parse(text, 0)
  .{ module: p.value, diagnostics: p.diagnostics }
}
