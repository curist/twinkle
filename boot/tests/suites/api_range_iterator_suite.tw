use tests.runner
use tests.assert

pub fn suite() runner.Suite {
  runner.suite("range and iterator")
    // Range basics
    .test("range produces 0 to n-1", fn() {
      sum := 0
      for i in range(5) {
        sum = sum + i
      }
      try assert.int_eq(sum, 10)
      .Ok({})
    })
    .test("range(0) produces empty iteration", fn() {
      count := 0
      for _ in range(0) {
        count = count + 1
      }
      try assert.int_eq(count, 0)
      .Ok({})
    })
    .test("range_from produces start to end-1", fn() {
      vals := collect i in range_from(3, 7) { i }
      try assert.int_eq(vals.len(), 4)
      try assert.int_eq(vals[0], 3)
      try assert.int_eq(vals[3], 6)
      .Ok({})
    })
    .test("range_step with custom step", fn() {
      vals := collect i in range_step(0, 10, 3) { i }
      try assert.int_eq(vals.len(), 4)
      try assert.int_eq(vals[0], 0)
      try assert.int_eq(vals[1], 3)
      try assert.int_eq(vals[2], 6)
      try assert.int_eq(vals[3], 9)
      .Ok({})
    })
    .test("range with indexed for", fn() {
      indices := collect val, idx in range_from(10, 13) { idx }
      try assert.int_eq(indices[0], 0)
      try assert.int_eq(indices[1], 1)
      try assert.int_eq(indices[2], 2)
      .Ok({})
    })
    .test("collect from range", fn() {
      squares := collect i in range(5) { i * i }
      try assert.int_eq(squares.len(), 5)
      try assert.int_eq(squares[0], 0)
      try assert.int_eq(squares[4], 16)
      .Ok({})
    })
    .test("collect with continue filters", fn() {
      evens := collect i in range(10) {
        if i % 2 == 0 { i } else { continue }
      }
      try assert.int_eq(evens.len(), 5)
      try assert.int_eq(evens[0], 0)
      try assert.int_eq(evens[4], 8)
      .Ok({})
    })
    .test("collect with break stops early", fn() {
      vals := collect i in range(100) {
        if i >= 3 { break }
        i
      }
      try assert.int_eq(vals.len(), 3)
      try assert.int_eq(vals[0], 0)
      try assert.int_eq(vals[2], 2)
      .Ok({})
    })
    // Iterator basics
    .test("iterator unfold produces sequence", fn() {
      it := Iterator.unfold(0, fn(s: Int) {
        if s >= 5 { UnfoldStep.Done } else { UnfoldStep.Yield(s, s + 1) }
      })
      vals := collect x in it { x }
      try assert.int_eq(vals.len(), 5)
      try assert.int_eq(vals[0], 0)
      try assert.int_eq(vals[4], 4)
      .Ok({})
    })
    .test("iterator next returns item with continuation", fn() {
      it := Iterator.unfold(0, fn(s: Int) {
        if s >= 3 { UnfoldStep.Done } else { UnfoldStep.Yield(s * 10, s + 1) }
      })
      item := Iterator.next(it)
      try assert.is_some(item)
      first := case item {
        .Some(i) => i.value,
        .None => -1,
      }
      try assert.int_eq(first, 0)
      .Ok({})
    })
    .test("empty iterator produces no values", fn() {
      it := Iterator.unfold(0, fn(_s: Int) UnfoldStep<Int, Int> { UnfoldStep.Done })
      vals := collect x in it { x }
      try assert.int_eq(vals.len(), 0)
      .Ok({})
    })
    .test("for over iterator consumes all", fn() {
      it := Iterator.unfold(1, fn(s: Int) {
        if s > 4 { UnfoldStep.Done } else { UnfoldStep.Yield(s, s + 1) }
      })
      sum := 0
      for x in it {
        sum = sum + x
      }
      try assert.int_eq(sum, 10)
      .Ok({})
    })
    .test("iterator is persistent (non-consuming)", fn() {
      it := Iterator.unfold(0, fn(s: Int) {
        if s >= 3 { UnfoldStep.Done } else { UnfoldStep.Yield(s, s + 1) }
      })
      first := collect x in it { x }
      second := collect x in it { x }
      try assert.int_eq(first.len(), 3)
      try assert.int_eq(second.len(), 3)
      try assert.int_eq(first[0], second[0])
      .Ok({})
    })
    .test("string chars returns iterator", fn() {
      chars := collect c in "abc".chars() { c }
      try assert.int_eq(chars.len(), 3)
      try assert.str_eq(chars[0], "a")
      try assert.str_eq(chars[1], "b")
      try assert.str_eq(chars[2], "c")
      .Ok({})
    })
}
