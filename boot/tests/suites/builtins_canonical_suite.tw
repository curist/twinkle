use compiler.builtins.{BuiltinRegistry, make_builtin_registry}
use tests.assert
use tests.runner

fn empty_registry() BuiltinRegistry {
  BuiltinRegistry.{
    by_name: Dict.new(),
    by_id: Dict.new(),
    by_canonical: Dict.new(),
    entries: [],
    next_id: 0,
  }
}

pub fn suite() runner.Suite {
  runner
    .suite("builtins canonical mapping")
    .test(
      "entry canonical_name is None after plain registration",
      fn() {
        reg := empty_registry().runtime("string$len", "rt.str", "len")
        entry := try reg.entry(reg.id("string$len")).ok_or("missing")
        try assert.is_none(entry.canonical_name)
        .Ok({})
      },
    )
    .test(
      "with_canonical sets canonical_name on entry",
      fn() {
        reg := empty_registry()
          .runtime("string$len", "rt.str", "len")
          .with_canonical("String.len", "string$len")
        entry := try reg.entry(reg.id("string$len")).ok_or("missing")
        try assert.is_some(entry.canonical_name)
        cn := try entry.canonical_name.ok_or("no canonical_name")
        try assert.equal(cn, "String.len")
        .Ok({})
      },
    )
    .test(
      "with_canonical adds entry to by_canonical index",
      fn() {
        reg := empty_registry()
          .runtime("vector$append", "rt.arr", "push")
          .with_canonical("Vector.append", "vector$append")
        entry := try reg.entry_by_canonical("Vector.append").ok_or("not in by_canonical")
        try assert.equal(entry.name, "vector$append")
        .Ok({})
      },
    )
    .test(
      "entry_by_canonical returns None for unregistered canonical name",
      fn() {
        reg := empty_registry().runtime("string$len", "rt.str", "len")
        try assert.is_none(reg.entry_by_canonical("String.len"))
        .Ok({})
      },
    )
    .test(
      "id_by_canonical returns same FuncId as internal lookup",
      fn() {
        reg := empty_registry()
          .runtime("string$len", "rt.str", "len")
          .runtime("vector$append", "rt.arr", "push")
          .with_canonical("String.len", "string$len")
          .with_canonical("Vector.append", "vector$append")
        try assert.equal(reg.id_by_canonical("String.len").id, reg.id("string$len").id)
        try assert.equal(reg.id_by_canonical("Vector.append").id, reg.id("vector$append").id)
        .Ok({})
      },
    )
    .test(
      "multiple canonical names can map to different internal names",
      fn() {
        reg := empty_registry()
          .runtime("dict$new", "rt.dict", "make")
          .intrinsic("cell$new")
          .with_canonical("Dict.new", "dict$new")
          .with_canonical("Cell.new", "cell$new")
        try assert.equal(reg.id_by_canonical("Dict.new").id, reg.id("dict$new").id)
        try assert.equal(reg.id_by_canonical("Cell.new").id, reg.id("cell$new").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for string builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("String.len").id, reg.id("string$len").id)
        try assert.equal(reg.id_by_canonical("String.concat").id, reg.id("string$concat").id)
        try assert.equal(reg.id_by_canonical("String.get").id, reg.id("string$get").id)
        try assert.equal(reg.id_by_canonical("String.slice").id, reg.id("string$slice").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for vector builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("Vector.len").id, reg.id("vector$len").id)
        try assert.equal(reg.id_by_canonical("Vector.append").id, reg.id("vector$append").id)
        try assert.equal(reg.id_by_canonical("Vector.concat").id, reg.id("vector$concat").id)
        try assert.equal(reg.id_by_canonical("Vector.get").id, reg.id("vector$get").id)
        try assert.equal(reg.id_by_canonical("Vector.set").id, reg.id("vector$set").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for dict builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("Dict.new").id, reg.id("dict$new").id)
        try assert.equal(reg.id_by_canonical("Dict.set").id, reg.id("dict$set").id)
        try assert.equal(reg.id_by_canonical("Dict.get").id, reg.id("dict$get").id)
        try assert.equal(reg.id_by_canonical("Dict.keys").id, reg.id("dict$keys").id)
        try assert.equal(reg.id_by_canonical("Dict.len").id, reg.id("dict$len").id)
        try assert.equal(reg.id_by_canonical("Dict.has").id, reg.id("dict$has").id)
        try assert.equal(reg.id_by_canonical("Dict.remove").id, reg.id("dict$remove").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for cell builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("Cell.new").id, reg.id("cell$new").id)
        try assert.equal(reg.id_by_canonical("Cell.get").id, reg.id("cell$get").id)
        try assert.equal(reg.id_by_canonical("Cell.set").id, reg.id("cell$set").id)
        try assert.equal(reg.id_by_canonical("Cell.update").id, reg.id("cell$update").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for iterator builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("Iterator.next").id, reg.id("iterator$next").id)
        try assert.equal(reg.id_by_canonical("Iterator.unfold").id, reg.id("iterator$unfold").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for byte builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("Byte.to_int").id, reg.id("byte$to_int").id)
        try assert.equal(reg.id_by_canonical("Byte.from_int").id, reg.id("byte$from_int").id)
        try assert.equal(reg.id_by_canonical("Byte.to_string").id, reg.id("byte$to_string").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for int/float builtins",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("Int.to_string").id, reg.id("int$to_string").id)
        try assert.equal(reg.id_by_canonical("Float.to_string").id, reg.id("float$to_string").id)
        try assert.equal(reg.id_by_canonical("Bool.to_string").id, reg.id("bool$to_string").id)
        .Ok({})
      },
    )
    .test(
      "full registry has canonical names for range free functions",
      fn() {
        reg := make_builtin_registry()
        try assert.equal(reg.id_by_canonical("range_from").id, reg.id("range_from").id)
        try assert.equal(reg.id_by_canonical("range").id, reg.id("range").id)
        try assert.equal(reg.id_by_canonical("range_step").id, reg.id("range_step").id)
        .Ok({})
      },
    )
    .test(
      "entry_by_canonical returns entry with correct kind",
      fn() {
        reg := empty_registry()
          .runtime("string$len", "rt.str", "len")
          .with_canonical("String.len", "string$len")
        entry := try reg.entry_by_canonical("String.len").ok_or("missing")

        case entry.kind {
          .Runtime(info) => {
            try assert.equal(info.wasm_module, "rt.str")
            try assert.equal(info.wasm_name, "len")
            .Ok({})
          },
          .Intrinsic => .Err("expected Runtime"),
        }
      },
    )
}
