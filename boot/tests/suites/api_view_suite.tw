use @std.view
use @std.view.{View}

use tests.assert
use tests.runner

fn unwrap_or(opt: Int?, fallback: Int) Int {
  case opt {
    .Some(v) => v,
    .None => fallback,
  }
}

// View satisfies IndexRead<E> via its own len/at, so it plugs into the same
// generic algorithms as its backing. Exercising it here proves self-satisfaction.
fn count_via_index_read<C: IndexRead<E>, E>(c: C) Int {
  c.len()
}

fn index_via_bracket<C: IndexRead<E>, E>(c: C, i: Int) E {
  c[i]
}

// Generic over the IndexRead bound with a sibling `E: Eq`, reading elements
// directly through the contract (`c.at`). Driving this with a `View` backing
// forces the checker to recover the element type of a satisfier that is itself
// generic (`View<Vector<Int>>` -> element `Int`) so the sibling `E: Eq` holds.
fn is_palindrome<C: IndexRead<E>, E: Eq>(c: C) Bool {
  lo := 0
  hi := c.len() - 1

  for lo < hi {
    if c.at(lo) != c.at(hi) {
      return false
    }

    lo = lo + 1
    hi = hi - 1
  }

  true
}

// Same shape, but the bound is reached through an intermediate `View` whose own
// `at` is an inherent method returning the bound-only element type `E`. This
// forces monomorphization to recover `E` from an inherent-method return.
fn palindrome_via_view<C: IndexRead<E>, E: Eq>(c: C) Bool {
  v: View<C> = view.from(c)

  for v.len() > 1 {
    if v.at(0) != v.at(v.len() - 1) {
      return false
    }

    v = .drop_first().drop_last()
  }

  true
}

pub fn suite() runner.Suite {
  runner.suite("view")
    .test(
      "from wraps the whole backing",
      fn() {
        xs: Vector<Int> = [10, 20, 30]
        v: View<Vector<Int>> = view.from(xs)
        try assert.equal(v.len(), 3)
        try assert.is_false(v.is_empty())
        try assert.equal(v.at(0), 10)
        try assert.equal(v.at(2), 30)
        .Ok({})
      },
    )
    .test(
      "first and last peek the ends",
      fn() {
        v := view.from([10, 20, 30])
        try assert.equal(unwrap_or(v.first(), -1), 10)
        try assert.equal(unwrap_or(v.last(), -1), 30)
        .Ok({})
      },
    )
    .test(
      "first and last on an empty view return None",
      fn() {
        empty: Vector<Int> = []
        v := view.from(empty)
        try assert.is_true(v.is_empty())
        try assert.equal(v.len(), 0)
        try assert.is_none(v.first())
        try assert.is_none(v.last())
        .Ok({})
      },
    )
    .test(
      "drop_first advances the window and shares the backing",
      fn() {
        v := view.from([10, 20, 30, 40])
        v = .drop_first()
        try assert.equal(v.len(), 3)
        try assert.equal(v.at(0), 20)
        try assert.equal(unwrap_or(v.last(), -1), 40)
        .Ok({})
      },
    )
    .test(
      "drop_last shrinks the window from the end",
      fn() {
        v := view.from([10, 20, 30, 40])
        v = .drop_last()
        try assert.equal(v.len(), 3)
        try assert.equal(unwrap_or(v.last(), -1), 30)
        try assert.equal(v.at(0), 10)
        .Ok({})
      },
    )
    .test(
      "drop_first and drop_last are total on an empty view",
      fn() {
        empty: Vector<Int> = []
        v := view.from(empty)
        v = .drop_first()
        v = .drop_last()
        try assert.equal(v.len(), 0)
        try assert.is_true(v.is_empty())
        .Ok({})
      },
    )
    .test(
      "sub carves a relative window",
      fn() {
        v := view.from([10, 20, 30, 40, 50])
        w := v.sub(1, 4)
        try assert.equal(w.len(), 3)
        try assert.equal(w.at(0), 20)
        try assert.equal(w.at(2), 40)
        .Ok({})
      },
    )
    .test(
      "head/tail recursion over a view is allocation-free",
      fn() {
        // Repeated drop_first never copies the backing; it only moves start.
        v := view.from([1, 2, 3, 4, 5])
        sum := 0

        for v.len() > 0 {
          sum = sum + unwrap_or(v.first(), 0)
          v = .drop_first()
        }

        try assert.equal(sum, 15)
        .Ok({})
      },
    )
    .test(
      "to_vector materializes the window",
      fn() {
        v := view
          .from([10, 20, 30, 40])
          .drop_first()
          .drop_last()
        out := v.to_vector()
        try assert.equal(out.len(), 2)
        try assert.equal(out[0], 20)
        try assert.equal(out[1], 30)
        .Ok({})
      },
    )
    .test(
      "fold accumulates over the window",
      fn() {
        v := view
          .from([1, 2, 3, 4])
          .drop_first()
        total := v.fold(0, fn(acc, x) { acc + x })
        try assert.equal(total, 9)
        .Ok({})
      },
    )
    .test(
      "View over String windows bytes",
      fn() {
        v := view.from("hello")
        try assert.equal(v.len(), 5)
        try assert.equal(v.at(0).to_int(), 104) // 'h'
        w := v.sub(1, 4) // "ell"
        try assert.equal(w.len(), 3)
        try assert.equal(w.at(0).to_int(), 101) // 'e'
        .Ok({})
      },
    )
    .test(
      "View satisfies IndexRead through a generic bound",
      fn() {
        v := view.from([10, 20, 30])
        try assert.equal(count_via_index_read(v), 3)
        try assert.equal(index_via_bracket(v, 1), 20)
        .Ok({})
      },
    )
    .test(
      "IndexRead+Eq algorithm runs over a View backing (FD through a generic satisfier)",
      fn() {
        // Baseline: the same algorithm over the concrete backings still works.
        try assert.is_true(is_palindrome([1, 2, 1]))
        try assert.is_true(is_palindrome("aba"))

        // The fix: C = View<Vector<Int>>; E must resolve to Int so E: Eq holds.
        try assert.is_true(is_palindrome(view.from([1, 2, 3, 2, 1])))
        try assert.is_false(is_palindrome(view.from([1, 2, 3])))
        .Ok({})
      },
    )
    .test(
      "generic algorithm that wraps its bound in a View (bound-only E via inherent at)",
      fn() {
        try assert.is_true(palindrome_via_view([1, 2, 3, 2, 1]))
        try assert.is_false(palindrome_via_view([1, 2, 3]))

        // String backing too: C = String, E = Byte.
        try assert.is_true(palindrome_via_view("racecar"))
        try assert.is_false(palindrome_via_view("hello"))
        .Ok({})
      },
    )
}
