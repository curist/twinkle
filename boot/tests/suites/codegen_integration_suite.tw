fn test_wrapper_backed_builtin_first_class_function_arg_uses_wrapper_trampoline() Result<
  Void,
  String,
> {
  wat := try assert_codegen_src_compiles(
    "fn apply(f: fn(Byte) String, x: Byte) String { f(x) }\ncase Byte.from_int(42) {\n  .Some(b) => println(apply(Byte.to_string, b)),\n  .None => println(\"none\"),\n}\n",
    "wrapper-backed builtin first-class function arg",
  )
  try assert.str_contains(wat, "struct.new $rt_types__Closure")
  try assert.str_contains(wat, "i64.extend_i32_u")
  try assert.str_contains(wat, "call $rt_str__from_i64")
  .Ok({})
}

fn test_cell_update_builtin_first_class_function_arg_uses_wrapper_trampoline() Result<Void, String> {
  wat := try assert_codegen_src_compiles(
    "fn inc(x: Int) Int { x + 1 }\nfn apply_update(f: fn(Cell<Int>, fn(Int) Int) Void, c: Cell<Int>, g: fn(Int) Int) Void { f(c, g) }\nc := Cell.new(1)\napply_update(Cell.update, c, inc)\nprintln(Int.to_string(c.get()))\n",
    "cell update builtin first-class function arg",
  )
  try assert.str_contains(wat, "struct.new $rt_types__Closure")
  try assert.str_contains(wat, "call_ref $rt_types__ClosureFunc")
  try assert.str_contains(wat, "struct.set $user__$Cell_i64 0")
  .Ok({})
}

fn test_iterator_unfold_builtin_first_class_function_arg_uses_wrapper_trampoline() Result<
  Void,
  String,
> {
  wat := try assert_codegen_src_compiles(
    "fn step(i: Int) UnfoldStep<Int, Int> { if i >= 3 { UnfoldStep.Done } else { UnfoldStep.Yield(i, i + 1) } }\nfn apply_unfold(f: fn(Int, fn(Int) UnfoldStep<Int, Int>) Iterator<Int>, seed: Int, g: fn(Int) UnfoldStep<Int, Int>) Iterator<Int> { f(seed, g) }\nit := apply_unfold(Iterator.unfold, 0, step)\nprintln(Int.to_string(it.take(2).to_vector().len()))\n",
    "iterator unfold builtin first-class function arg",
  )
  try assert.str_contains(wat, "struct.new $rt_types__Closure")
  try assert.str_contains(wat, "struct.new $rt_types__IterState")
  .Ok({})
}

fn test_builtin_stored_in_local_then_called() Result<Void, String> {
  // A builtin function value stored in a local and called through that local.
  // Tests that insert_boundaries inserts AMakeClosure at the AInit boundary
  // and that the indirect call emits correctly.
  wat := try assert_codegen_src_compiles(
    "f: fn(Int) String = Int.to_string\nprintln(f(42))\n",
    "builtin stored in local then called",
  )
  try assert.str_contains(wat, "$tramp_")
  try assert.str_contains(wat, "struct.new $rt_types__Closure")
  .Ok({})
}

fn test_builtin_returned_from_function_then_called() Result<Void, String> {
  // A builtin function value returned from a function and called through the result.
  // Tests that insert_boundaries inserts AMakeClosure at the return boundary.
  wat := try assert_codegen_src_compiles(
    "fn get_converter() fn(Int) String { Int.to_string }\nf := get_converter()\nprintln(f(42))\n",
    "builtin returned from function then called",
  )
  try assert.str_contains(wat, "$tramp_")
  try assert.str_contains(wat, "struct.new $rt_types__Closure")
  .Ok({})
}

fn test_builtin_stored_in_record_field_then_called() Result<Void, String> {
  // A builtin function value stored in a record field, then extracted and called.
  // Tests closure boundaries at record construction sites.
  wat := try assert_codegen_src_compiles(
    "type Wrapper = .{ f: fn(Int) String }\nw := Wrapper.{ f: Int.to_string }\nprintln(w.f(42))\n",
    "builtin stored in record field then called",
  )
  try assert.str_contains(wat, "$tramp_")
  try assert.str_contains(wat, "struct.new $rt_types__Closure")
  .Ok({})
}

fn test_user_function_stored_in_record_field_then_called() Result<Void, String> {
  wat := try assert_codegen_src_compiles(
    "fn double(n: Int) Int { n * 2 }\ntype Wrapper = .{ f: fn(Int) Int }\nw := Wrapper.{ f: double }\nprintln(Int.to_string(w.f(21)))\n",
    "user function stored in record field then called",
  )
  try assert.str_contains(wat, "struct.new $user__$closure_")
  try assert.str_contains(wat, "call_ref $rt_types__ClosureFunc")
  .Ok({})
}

fn test_user_function_returned_from_function_then_called() Result<Void, String> {
  wat := try assert_codegen_src_compiles(
    "fn double(n: Int) Int { n * 2 }\nfn get_double() fn(Int) Int { double }\nf := get_double()\nprintln(Int.to_string(f(21)))\n",
    "user function returned from function then called",
  )
  try assert.str_contains(wat, "struct.new $user__$closure_")
  try assert.str_contains(wat, "call_ref $rt_types__ClosureFunc")
  .Ok({})
}

// ── Match emission coverage ──────────────────────────────────────────
// Ports focused match-emission cases from the former emit_pattern_suite,
// now exercising the consolidated emit.tw path end-to-end.
fn test_match_wildcard_and_var_binding() Result<Void, String> {
  // Wildcard and var-binding patterns in a case expression
  wat := try assert_codegen_src_compiles(
    "fn id(x: Int) Int { case x { y => y } }\nprintln(Int.to_string(id(42)))\n",
    "match wildcard/var",
  )

  // Var binding emits local.set for the bound variable
  try assert.str_contains(wat, "local.set")
  .Ok({})
}

fn test_match_literal_string() Result<Void, String> {
  // String literal pattern emits rt_str__eq comparison
  wat := try assert_codegen_src_compiles(
    "fn greet(s: String) String {\n  case s {\n    \"hello\" => \"hi\",\n    _ => \"huh\",\n  }\n}\nprintln(greet(\"hello\"))\n",
    "match literal string",
  )
  try assert.str_contains(wat, "rt_str__eq")
  .Ok({})
}

fn test_match_string_trie_dispatch() Result<Void, String> {
  wat := try assert_codegen_src_compiles(
    "fn classify(s: String) String {\n  case s {\n    \"alpha\" => \"a\",\n    \"bravo\" => \"b\",\n    \"gamma\" => \"g\",\n    \"delta\" => \"d\",\n    \"eagle\" => \"e\",\n    other => other,\n  }\n}\nprintln(classify(\"omega\"))\n",
    "match string trie dispatch",
  )
  try assert.str_contains(wat, "string_case")
  try assert.str_contains(wat, "array.get_u $rt_types__String")
  try assert.str_contains(wat, "rt_str__eq")
  .Ok({})
}

fn test_match_literal_int() Result<Void, String> {
  // Int literal pattern emits i64 comparison
  wat := try assert_codegen_src_compiles(
    "fn describe(n: Int) String {\n  case n {\n    0 => \"zero\",\n    1 => \"one\",\n    _ => \"other\",\n  }\n}\nprintln(describe(1))\n",
    "match literal int",
  )
  try assert.str_contains(wat, "i64.eq")
  .Ok({})
}

fn test_match_dense_int_data_table() Result<Void, String> {
  // Dense integer case with constant Int results lowers to a flat ArrayI64
  // lookup table (array.get) rather than a chain of i64.eq comparisons.
  wat := try assert_codegen_src_compiles(
    "fn classify(n: Int) Int {\n  case n {\n    0 => 10,\n    1 => 20,\n    2 => 30,\n    3 => 40,\n    4 => 50,\n    _ => 0,\n  }\n}\nprintln(Int.to_string(classify(2)))\n",
    "match dense int data table",
  )
  try assert.str_contains(wat, "array.get $rt_types__ArrayI64")
  .Ok({})
}

fn test_match_dense_byte_data_table() Result<Void, String> {
  // Dense Byte case with constant Int results lowers to a data table.
  wat := try assert_codegen_src_compiles(
    "fn rank(b: Byte) Int {\n  case b {\n    0x41 => 1,\n    0x42 => 2,\n    0x43 => 3,\n    0x44 => 4,\n    _ => 0,\n  }\n}\nprintln(Int.to_string(rank(0x42)))\n",
    "match dense byte data table",
  )
  try assert.str_contains(wat, "array.get $rt_types__ArrayI64")
  .Ok({})
}

fn test_match_sparse_int_stays_chain() Result<Void, String> {
  // Sparse integer case (literals far apart) is not dense enough for a lookup
  // table; it stays a comparison chain.
  wat := try assert_codegen_src_compiles(
    "fn classify(n: Int) Int {\n  case n {\n    0 => 1,\n    1000 => 2,\n    50000 => 3,\n    999999 => 4,\n    _ => 0,\n  }\n}\nprintln(Int.to_string(classify(0)))\n",
    "match sparse int chain",
  )
  try assert.str_contains(wat, "i64.eq")
  .Ok({})
}

fn test_match_result_ok_err() Result<Void, String> {
  // Result<Int, String> dispatch: Ok/Err variant matching
  wat := try assert_codegen_src_compiles(
    "fn unwrap_or(r: Result<Int, String>, d: Int) Int {\n  case r {\n    .Ok(v) => v,\n    .Err(_) => d,\n  }\n}\nres: Result<Int, String> = .Ok(42)\nprintln(Int.to_string(unwrap_or(res, 0)))\n",
    "match result ok/err",
  )

  // Variant dispatch reads the tag field
  try assert.str_contains(wat, "struct.get")
  .Ok({})
}

fn test_match_wildcard_catch_all() Result<Void, String> {
  // Wildcard as catch-all arm after specific variant
  wat := try assert_codegen_src_compiles(
    "fn is_some(opt: Int?) Bool {\n  case opt {\n    .Some(_) => true,\n    _ => false,\n  }\n}\nprintln(Bool.to_string(is_some(.Some(1))))\n",
    "match wildcard catch-all",
  )
  try assert.str_contains(wat, "struct.get")
  .Ok({})
}

fn test_match_all_diverging_arms() Result<Void, String> {
  // Every arm calls error() — both arms diverge, so emit_arm_chain must
  // produce an if with no result type and append an outer unreachable.
  wat := try assert_codegen_src_compiles(
    "fn crash(opt: Int?) Int {\n  case opt {\n    .Some(_) => error(\"some\"),\n    .None => error(\"none\"),\n  }\n}\nprintln(Int.to_string(crash(.Some(1))))\n",
    "match all-diverging arms",
  )

  // Both arms trap; the if block should have no result type
  try assert.str_contains(wat, "unreachable")
  .Ok({})
}

fn test_match_named_sum_multi_variant() Result<Void, String> {
  // Named sum type with variants of different arities
  wat := try assert_codegen_src_compiles(
    "type Shape = { Circle(Float), Rect(Float, Float) }\nfn area(s: Shape) Float {\n  case s {\n    .Circle(r) => 3.14 * r * r,\n    .Rect(w, h) => w * h,\n  }\n}\nprintln(Float.to_string(area(.Circle(1.0))))\n",
    "match named sum multi-variant",
  )

  // Tag check and payload extraction
  try assert.str_contains(wat, "struct.get")
  try assert.str_contains(wat, "f64.mul")
  .Ok({})
}

// ── Structural validation (inspects LinkedModule, not WAT text) ─────
fn has_func_named(linked: LinkedModule, name: String) Bool {
  for f in linked.funcs {
    if f.name == name {
      return true
    }
  }

  false
}

fn has_export_named(linked: LinkedModule, name: String) Bool {
  for e in linked.exports {
    if e.wasm_name == name {
      return true
    }
  }

  false
}

fn has_type_named(linked: LinkedModule, name: String) Bool {
  for t in linked.types {
    case t {
      .Struct(n, _, _, _) => if n == name {
        return true
      },
      .Array(n, _) => if n == name {
        return true
      },
      .FuncType(n, _, _) => if n == name {
        return true
      },
    }
  }

  false
}

fn instr_has_call(instrs: Vector<Instr>, target: String) Bool {
  for instr in instrs {
    case instr {
      .Call(sym) => if sym == target {
        return true
      },
      .Block(_, _, body) => if instr_has_call(body, target) {
        return true
      },
      .Loop(_, _, body) => if instr_has_call(body, target) {
        return true
      },
      .If(_, then_body, else_body) => {
        if instr_has_call(then_body, target) {
          return true
        }

        if instr_has_call(else_body, target) {
          return true
        }
      },
      _ => {},
    }
  }

  false
}

fn instr_has_struct_new(instrs: Vector<Instr>, target: String) Bool {
  for instr in instrs {
    case instr {
      .StructNew(sym) => if sym == target {
        return true
      },
      .Block(_, _, body) => if instr_has_struct_new(body, target) {
        return true
      },
      .Loop(_, _, body) => if instr_has_struct_new(body, target) {
        return true
      },
      .If(_, then_body, else_body) => {
        if instr_has_struct_new(then_body, target) {
          return true
        }

        if instr_has_struct_new(else_body, target) {
          return true
        }
      },
      _ => {},
    }
  }

  false
}

fn test_structural_linked_module_exports_entry() Result<Void, String> {
  // A program with top-level statements exports an explicit entry function for the host.
  // The linker intentionally avoids a Wasm start section so JSPI hosts can wrap startup.
  linked := try codegen_harness.codegen_linked("println(\"hello\")")
  try assert.ok(has_export_named(linked, "__twinkle_start"), "missing __twinkle_start export")
  try assert.ok(
    case linked.start {
      .None => true,
      _ => false,
    },
    "linked program should not use a Wasm start section",
  )
  .Ok({})
}

fn test_structural_linked_module_has_runtime_types() Result<Void, String> {
  // Any linked program must include core runtime type definitions.
  linked := try codegen_harness.codegen_linked("x := 1")
  try assert.ok(has_type_named(linked, "rt_types__String"), "missing rt_types__String type")
  try assert.ok(has_type_named(linked, "rt_types__Array"), "missing rt_types__Array type")
  try assert.ok(has_type_named(linked, "rt_types__Closure"), "missing rt_types__Closure type")
  .Ok({})
}

fn test_structural_user_func_present() Result<Void, String> {
  // A program with top-level code should produce at least one user-namespace function.
  linked := try codegen_harness.codegen_linked("println(Int.to_string(42))")
  found := false

  for f in linked.funcs {
    if f.name.starts_with("user__") {
      found = true
    }
  }

  try assert.ok(found, "expected at least one user function in linked module")
  .Ok({})
}

fn test_structural_host_imports_are_host_only() Result<Void, String> {
  // After linking, all remaining imports must come from "twinkle_runtime" module.
  linked := try codegen_harness.codegen_linked("println(\"hi\")")

  for imp in linked.imports {
    try assert.ok(
      imp.module == "twinkle_runtime",
      "non-host import survived linking: ${imp.module}.${imp.name}",
    )
  }

  .Ok({})
}

fn test_structural_option_produces_typed_sum_struct() Result<Void, String> {
  // A program using Option<Int> should produce a typed sum struct type.
  linked := try codegen_harness.codegen_linked(
    "x: Int? = .Some(42)\ncase x { .Some(n) => println(Int.to_string(n)), .None => println(\"none\") }",
  )
  found_option := false

  for t in linked.types {
    case t {
      .Struct(name, _, _, _) => if name.starts_with("user__$Option_") {
        found_option = true
      },
      _ => {},
    }
  }

  try assert.ok(found_option, "expected a typed Option struct in linked module types")
  .Ok({})
}

fn test_dict_index_materializes_typed_option() Result<Void, String> {
  linked := try codegen_harness.codegen_linked(
    "d: Dict<String, Int> = Dict.new()\nd[\"x\"] = 10\nprintln(Int.to_string(d[\"x\"].unwrap_or(0)))",
  )
  found_get := false
  found_get_option := false
  found_option_struct := false

  for f in linked.funcs {
    if f.name.starts_with("user__") {
      if instr_has_call(f.body, "rt_dict__get") {
        found_get = true
      }

      if instr_has_call(f.body, "rt_dict__get_option") {
        found_get_option = true
      }

      if instr_has_struct_new(f.body, "user__$Option_opt_i64") {
        found_option_struct = true
      }
    }
  }

  try assert.ok(found_get, "expected dict indexing to call rt_dict__get")
  try assert.ok(!found_get_option, "dict indexing should not call rt_dict__get_option")
  try assert.ok(found_option_struct, "expected dict indexing to construct a typed Option<Int>")
  .Ok({})
}

// ── Suite ───────────────────────────────────────────────────────────
// ── Extern Vector<Byte> marshaling tests ───────────────────────────
fn test_extern_vector_byte_import_uses_array_type() Result<Void, String> {
  // extern twinkle_runtime { fn echo_bytes(xs: Vector<Byte>) Vector<Byte> }
  // The host boundary must declare the import as $Array (not $PVec) for both
  // param and result. The call site must wrap the arg with rt_arr__to_array and
  // unwrap the result with rt_arr__from_array.
  src := "extern twinkle_runtime {\n  fn echo_bytes(xs: Vector<Byte>) Vector<Byte>\n}\nfn go(xs: Vector<Byte>) Vector<Byte> { twinkle_runtime.echo_bytes(xs) }\ngo([1, 2, 3])\n"
  wat := try assert_codegen_src_compiles(src, "extern Vector<Byte> marshaling")

  // The import functype that takes/returns $Array must exist. Since all echo_bytes
  // traffic goes through a single functype, find the pattern
  // "(func (param (ref null $rt_types__Array)) (result (ref null $rt_types__Array)))".
  // This confirms the extern import signature uses $Array, not $PVec.
  try assert.str_contains(
    wat,
    "(func (param (ref null $rt_types__Array)) (result (ref null $rt_types__Array)))",
  )

  // Call site must wrap the PVec arg to Array before the call
  try assert.str_contains(wat, "call $rt_arr__to_array")

  // Call site must unwrap the Array result to PVec after the call
  try assert.str_contains(wat, "call $rt_arr__from_array")

  .Ok({})
}

pub fn suite() runner.Suite {
  runner
    .suite("codegen integration (M11)")
    .test("emit_wat produces valid linked WAT", test_emit_wat_basic)
    .test(
      "codegen compiles a simple source program end to end",
      test_codegen_end_to_end_simple_program,
    )
    .test(
      "phase 1 option boundary fixture compiles through boot codegen",
      test_phase1_option_boundary_fixture,
    )
    .test(
      "bound-only IndexRead element local over builtin backings",
      test_bound_only_element_slot_builtin_backings,
    )
    .test(
      "bound-only IndexRead element local over View backing",
      test_bound_only_element_slot_view_backing,
    )
    .test("phase 2 return inside if compiles through boot codegen", test_phase2_return_inside_if)
    .test("phase 2 return inside for compiles through boot codegen", test_phase2_return_inside_for)
    .test(
      "phase 3 string.get fixture compiles through boot codegen",
      test_phase3_string_get_fixture,
    )
    .test("phase 3 bool case compiles through boot codegen", test_phase3_bool_case)
    .test(
      "phase 3 large string index fixture compiles through boot codegen",
      test_phase3_large_string_index_fixture,
    )
    .test(
      "phase 4 record field access compiles through boot codegen",
      test_phase4_record_field_access,
    )
    .test(
      "cell record field uses declared typed cell symbol",
      test_cell_record_field_uses_declared_typed_cell_symbol,
    )
    .test("rt.buf module has correct shape", test_rt_buf_module_shape)
    .test("runtime_modules returns all runtime modules", test_runtime_modules_count)
    .test("runtime_modules has correct namespaces", test_runtime_modules_namespaces)
    .test("linking runtime resolves all inter-module imports", test_link_runtime_resolves_imports)
    .test("linked runtime emits valid WAT with qualified names", test_link_runtime_emits_valid_wat)
    .test("linked runtime preserves host imports", test_link_runtime_host_imports_preserved)
    .test("runtime-only link has no start function", test_link_runtime_no_start_function)
    .test("vector index emits checked i64→i32 narrowing", test_checked_narrowing_vector_index)
    .test("runtime call emits checked i64→i32 narrowing", test_checked_narrowing_runtime_call)
    .test("string index emits checked i64→i32 narrowing", test_checked_narrowing_string_index)
    .test(
      "large vector literals build through rt.arr.push",
      test_large_vector_literal_uses_runtime_push,
    )
    .test("first-class function arg wraps as closure", test_closure_first_class_function_arg)
    .test("closure type is subtype of base", test_closure_struct_is_subtype_of_base)
    .test(
      "closure call uses universal funcref via call_ref",
      test_closure_call_uses_universal_funcref,
    )
    .test(
      "iterator unfold wraps named step as closure",
      test_iterator_unfold_wraps_named_step_as_closure,
    )
    .test(
      "cell update wraps named function as closure",
      test_cell_update_wraps_named_function_as_closure,
    )
    .test(
      "builtin first-class function arg uses builtin trampolines",
      test_builtin_first_class_function_arg_uses_builtin_trampolines,
    )
    .test(
      "wrapper-backed builtin first-class function arg uses wrapper trampoline",
      test_wrapper_backed_builtin_first_class_function_arg_uses_wrapper_trampoline,
    )
    .test(
      "cell update builtin first-class function arg uses wrapper trampoline",
      test_cell_update_builtin_first_class_function_arg_uses_wrapper_trampoline,
    )
    .test(
      "iterator unfold builtin first-class function arg uses wrapper trampoline",
      test_iterator_unfold_builtin_first_class_function_arg_uses_wrapper_trampoline,
    )
    .test(
      "builtin function stored in local then called indirectly",
      test_builtin_stored_in_local_then_called,
    )
    .test(
      "builtin function returned from function then called indirectly",
      test_builtin_returned_from_function_then_called,
    )
    .test(
      "builtin function stored in record field then called indirectly",
      test_builtin_stored_in_record_field_then_called,
    )
    .test(
      "user function stored in record field then called indirectly",
      test_user_function_stored_in_record_field_then_called,
    )
    .test(
      "user function returned from function then called indirectly",
      test_user_function_returned_from_function_then_called,
    )
    .test("match: wildcard and var binding", test_match_wildcard_and_var_binding)
    .test("match: string literal emits rt_str__eq", test_match_literal_string)
    .test("match: string trie dispatch", test_match_string_trie_dispatch)
    .test("match: int literal emits i64.eq", test_match_literal_int)
    .test("match: dense int data-table dispatch", test_match_dense_int_data_table)
    .test("match: dense byte data-table dispatch", test_match_dense_byte_data_table)
    .test("match: sparse int stays comparison chain", test_match_sparse_int_stays_chain)
    .test("match: Result Ok/Err dispatch", test_match_result_ok_err)
    .test("match: wildcard catch-all arm", test_match_wildcard_catch_all)
    .test("match: all-diverging arms", test_match_all_diverging_arms)
    .test("match: named sum with multiple variants", test_match_named_sum_multi_variant)
    .test("linked program exports host-callable entry", test_structural_linked_module_exports_entry)
    .test(
      "linked program includes runtime type definitions",
      test_structural_linked_module_has_runtime_types,
    )
    .test("user function appears in linked module", test_structural_user_func_present)
    .test("all imports are host-only after linking", test_structural_host_imports_are_host_only)
    .test(
      "Option usage produces typed sum struct",
      test_structural_option_produces_typed_sum_struct,
    )
    .test("dict index materializes typed Option", test_dict_index_materializes_typed_option)
    .test(
      "anon record variant compiles to WAT",
      fn() {
        src := "type Msg = { Hello(.{ name: String }), Bye } fn greet(m: Msg) String { case m { .Hello(h) => h.name, .Bye => \"bye\" } } greet(Msg.Hello(.{ name: \"world\" }))"
        try assert_codegen_src_compiles(src, "anon record variant")
        .Ok({})
      },
    )
    .test(
      "extern Vector<Byte> import uses $Array at boundary and wraps call site",
      test_extern_vector_byte_import_uses_array_type,
    )
}
