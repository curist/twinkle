fn test_bound_only_element_slot_builtin_backings() Result<Void, String> {
  src := "fn has_empty_slot<C: IndexRead<E>, E>(c: C) Bool { best: E? = .None case best { .Some(_) => true, .None => false } }\nprintln(has_empty_slot([1, 2, 3]).to_string())\nprintln(has_empty_slot(\"abc\").to_string())\n"
  try assert_codegen_src_compiles(src, "bound-only IndexRead element over builtin backings")
  .Ok({})
}

fn test_bound_only_element_slot_view_backing() Result<Void, String> {
  src := "use @std.view\nfn slot<C: IndexRead<E>, E>(c: C) Bool { best: E? = .None case best { .Some(_) => true, .None => false } }\nprintln(slot(view.from([1, 2, 3])).to_string())\n"
  try assert_codegen_src_compiles(src, "bound-only IndexRead element over View backing")
  .Ok({})
}

