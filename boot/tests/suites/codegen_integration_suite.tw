fn test_phase4_record_field_access() Result<Void, String> {
  dollar: String = case String.from_code_point(36) {
    .Some(d) => d,
    .None => return .Err("failed to create dollar sign"),
  }
  src: String = "type Pair = .{ x: Int, y: Int }\nfn main() Void { p := Pair.{ x: 41, y: 1 }\nprintln(\""
    .concat(dollar)
    .concat("{p.x}\")\nprintln(\"")
    .concat(dollar)
    .concat("{p.y}\") }\nmain()\n")
  wat := try assert_codegen_src_compiles(src, "phase 4 record field access")
  try assert.str_contains(wat, "struct.get")
  .Ok({})
}

fn test_cell_record_field_uses_declared_typed_cell_symbol() Result<Void, String> {
  wat := try assert_codegen_src_compiles(
    "type Inner = .{ value: Int }\ntype Outer = .{ slot: Cell<Inner> }\no := Outer.{ slot: Cell.new(Inner.{ value: 1 }) }\nprintln(Int.to_string(Cell.get(o.slot).value))\n",
    "cell record field typed symbol",
  )
  try assert.str_contains(
    wat,
    "(type $user__$Cell_anyref (sub (struct (field $value (mut anyref)))))",
  )
  try assert.str_contains(wat, "(field $slot (mut (ref null $user__$Cell_anyref)))")
  try assert.str_contains(wat, "struct.new $user__$Cell_anyref")
  try assert.str_contains(wat, "struct.get $user__$Cell_anyref 0")
  try assert.ok(
    !wat.contains("$$Cell_anyref"),
    "cell codegen should not reference unqualified $$Cell_anyref",
  )
  .Ok({})
}

