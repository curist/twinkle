use @std.heap
use @std.heap.{Heap, Pop}
use @std.testing.assert as assert
use @std.testing as runner

fn min_int(a: Int, b: Int) Order {
  a.compare(b)
}

fn max_int(a: Int, b: Int) Order {
  b.compare(a)
}

fn some_int(opt: Int?, fallback: Int) Int {
  case opt {
    .Some(v) => v,
    .None => fallback,
  }
}

fn pop_value(opt: Pop<Int>?) Int {
  case opt {
    .Some(p) => p.value,
    .None => -999,
  }
}

pub fn suite() runner.Suite {
  runner
    .suite("stdlib heap")
    .test(
      "new heap is empty",
      fn() {
        h: Heap<Int> = heap.new(min_int)
        try assert.equal(h.len(), 0)
        try assert.is_true(h.is_empty())
        try assert.is_none(h.peek())
        .Ok({})
      },
    )
    .test(
      "singleton holds one value",
      fn() {
        h := heap.singleton(42, min_int)
        try assert.equal(h.len(), 1)
        try assert.is_false(h.is_empty())
        try assert.equal(some_int(h.peek(), -1), 42)
        .Ok({})
      },
    )
    .test(
      "push keeps highest priority on top",
      fn() {
        h: Heap<Int> = heap.new(min_int)
        h = .push(5).push(3).push(8).push(1).push(4)
        try assert.equal(h.len(), 5)
        try assert.equal(some_int(h.peek(), -1), 1)
        .Ok({})
      },
    )
    .test(
      "pop returns values in priority order",
      fn() {
        h: Heap<Int> = heap.new(min_int)
        h = .push(5).push(3).push(8).push(1).push(4).push(1)
        out: Vector<Int> = []

        for h.len() > 0 {
          case h.pop() {
            .Some(p) => {
              out = .append(p.value)
              h = p.rest
            },
            .None => {},
          }
        }

        try assert.equal(out.len(), 6)
        try assert.equal(out[0], 1)
        try assert.equal(out[1], 1)
        try assert.equal(out[2], 3)
        try assert.equal(out[3], 4)
        try assert.equal(out[4], 5)
        try assert.equal(out[5], 8)
        .Ok({})
      },
    )
    .test(
      "pop leaves the original heap unchanged",
      fn() {
        h: Heap<Int> = heap.new(min_int)
        h = .push(2).push(1).push(3)
        first := pop_value(h.pop())
        try assert.equal(first, 1)
        try assert.equal(h.len(), 3)
        try assert.equal(some_int(h.peek(), -1), 1)
        .Ok({})
      },
    )
    .test(
      "merge combines two heaps",
      fn() {
        a: Heap<Int> = heap.new(min_int)
        a = .push(5).push(2)
        b: Heap<Int> = heap.new(min_int)
        b = .push(3).push(1)

        m := a.merge(b)
        try assert.equal(m.len(), 4)
        try assert.equal(some_int(m.peek(), -1), 1)
        try assert.equal(a.len(), 2)
        try assert.equal(b.len(), 2)
        .Ok({})
      },
    )
    .test(
      "from_vector then to_vector sorts by priority",
      fn() {
        h := heap.from_vector([5, 3, 8, 1, 4], min_int)
        sorted := h.to_vector()
        try assert.equal(sorted.len(), 5)
        try assert.equal(sorted[0], 1)
        try assert.equal(sorted[1], 3)
        try assert.equal(sorted[2], 4)
        try assert.equal(sorted[3], 5)
        try assert.equal(sorted[4], 8)
        try assert.equal(h.len(), 5)
        .Ok({})
      },
    )
    .test(
      "to_vector of empty heap is empty",
      fn() {
        h: Heap<Int> = heap.new(min_int)
        try assert.equal(h.to_vector().len(), 0)
        .Ok({})
      },
    )
    .test(
      "new_ord builds a min-heap from the Ord contract",
      fn() {
        h: Heap<Int> = heap.new_ord()
        h = .push(5).push(1).push(3)
        try assert.equal(some_int(h.peek(), -1), 1)
        .Ok({})
      },
    )
    .test(
      "reversed comparator builds a max-heap",
      fn() {
        h := heap.from_vector([5, 3, 8, 1, 4], max_int)
        try assert.equal(some_int(h.peek(), -1), 8)
        try assert.equal(h.to_vector()[0], 8)
        .Ok({})
      },
    )
}
