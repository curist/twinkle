use compiler.query.cache as query_cache
use lib.json
use lib.lsp.document_store
use lib.lsp.protocol
use lib.lsp.server_core
use tests.assert
use tests.runner

fn state_with_doc(uri: String, text: String) server_core.State {
  docs := document_store.empty().open(uri, text, .Some(1))
  server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: false,
    diagnostics_deadline_ms: 0.0,
    last_published_versions: Dict.new(),
  }
}

/// Simulate the real editing flow: first process valid code (populating cache),
/// then update the document with incomplete code. Returns the state with
/// warmed cache and the new incomplete document text.
fn state_with_warm_cache(uri: String, valid_text: String, incomplete_text: String) server_core.State {
  state := state_with_doc(uri, valid_text)

  // Trigger a request on the valid code to populate the query cache
  step := state.handle_message(sig_help_request(1, uri, 0, 0))

  // Now update the document with incomplete code
  step.state.documents = .change_full_text(uri, incomplete_text, .Some(2))
  step.state
}

fn sig_help_request(id: Int, uri: String, line: Int, character: Int) protocol.Message {
  params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri))])),
    json.kv(
      "position",
      json.object([json.kv("line", .Int(line)), json.kv("character", .Int(character))]),
    ),
  ])
  protocol.Message.Request(.{
    id: .IntId(id),
    method: "textDocument/signatureHelp",
    params: .Some(params),
  })
}

type SigHelpInfo = .{ label: String, active_param: Int, param_labels: Vector<String> }

fn extract_sig_help(step: server_core.Step) SigHelpInfo?!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))

  case result {
    .Null => .Ok(.None),
    _ => {
      active_param := try result.decode(json.field("activeParameter", json.int()))
      sigs := try result.decode(json.field("signatures", json.raw()))
      items := case sigs {
        .Array(arr) => arr,
        _ => { return .Err("expected signatures array") },
      }

      if items.len() == 0 {
        return .Ok(.None)
      }

      sig := items[0]
      label := try sig.decode(json.field("label", json.string()))
      params_json := try sig.decode(json.field("parameters", json.raw()))
      param_items := case params_json {
        .Array(arr) => arr,
        _ => [],
      }
      param_labels: Vector<String> = []

      for p in param_items {
        pl := try p.decode(json.field("label", json.string()))
        param_labels = .append(pl)
      }

      .Ok(.Some(.{ label, active_param, param_labels }))
    },
  }
}

pub fn suite() runner.Suite {
  runner.suite("lsp signature help")
    .test(
      "cursor after open paren reports active parameter 0",
      fn() {
        // fn add(a: Int, b: Int) Int { a + b }
        // add(|)
        //     ^ cursor here, char 4
        src := "fn add(a: Int, b: Int) Int { a + b }\nadd()\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 4))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.equal(h.active_param, 0)
            try assert.str_contains(h.label, "add")
            try assert.equal(h.param_labels.len(), 2)
            try assert.equal(h.param_labels[0], "a: Int")
            try assert.equal(h.param_labels[1], "b: Int")
          },
          .None => { return .Err("expected signature help, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "cursor after first comma reports active parameter 1",
      fn() {
        // fn add(a: Int, b: Int) Int { a + b }
        // add(1, |)
        //        ^ cursor here, char 7
        src := "fn add(a: Int, b: Int) Int { a + b }\nadd(1, 2)\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 7))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => try assert.equal(h.active_param, 1),
          .None => { return .Err("expected signature help, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "nested calls choose innermost call",
      fn() {
        // fn outer(x: Int) Int { x }
        // fn inner(a: String) String { a }
        // outer(inner(|))
        //              ^ cursor here inside inner's args
        src := "fn outer(x: Int) Int { x }\nfn inner(a: String) String { a }\nouter(inner())\n"
        state := state_with_doc("file:///a.tw", src)

        // "outer(inner(" is 12 chars on line 2, cursor at char 12
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 2, 12))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "inner")
            try assert.equal(h.param_labels[0], "a: String")
          },
          .None => { return .Err("expected signature help for inner, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "method call shows receiver-adjusted signature",
      fn() {
        // type Point = .{ x: Int, y: Int }
        // fn translate(p: Point, dx: Int, dy: Int) Point { ... }
        // p.translate(|)
        // Should show translate with receiver skipped → params are dx, dy
        src := "type Point = .{ x: Int, y: Int }\nfn translate(p: Point, dx: Int, dy: Int) Point {\n  .{ x: p.x + dx, y: p.y + dy }\n}\np := Point.{ x: 0, y: 0 }\np.translate(1, 2)\n"
        state := state_with_doc("file:///a.tw", src)

        // p.translate( is on line 5, cursor at char 12
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 5, 12))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.equal(h.active_param, 0)
            try assert.equal(h.param_labels.len(), 2)
            try assert.equal(h.param_labels[0], "dx: Int")
            try assert.equal(h.param_labels[1], "dy: Int")
          },
          .None => { return .Err("expected signature help for method call, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "unknown callee returns null",
      fn() {
        src := "unknown_fn()\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 0, 11))
        info := try extract_sig_help(step)
        try assert.is_none(info)
        .Ok({})
      },
    )
    .test(
      "module-qualified call shows signature",
      fn() {
        src := "use @std.path\npath.join(\"a\", \"b\")\n"
        state := state_with_doc("file:///a.tw", src)

        // path.join( → cursor at char 10 on line 1
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 10))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => try assert.str_contains(h.label, "join"),
          .None => { return .Err("expected signature help for qualified call, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "signature help inside function body",
      fn() {
        // Signature help should work when the call is inside a function body,
        // not just at top level.
        src := "fn greet(name: String, loud: Bool) String { name }\nfn main() String {\n  greet(\"hi\", true)\n}\n"
        state := state_with_doc("file:///a.tw", src)

        // cursor after comma: line 2 char 14
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 2, 14))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "greet")
            try assert.equal(h.active_param, 1)
            try assert.equal(h.param_labels[0], "name: String")
            try assert.equal(h.param_labels[1], "loud: Bool")
          },
          .None => { return .Err("expected signature help inside fn body, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "third parameter active with multiple commas",
      fn() {
        src := "fn make(a: Int, b: String, c: Bool) Int { a }\nmake(1, \"x\", true)\n"
        state := state_with_doc("file:///a.tw", src)

        // cursor after second comma: "make(1, \"x\", " → char 13
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 13))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.equal(h.active_param, 2)
            try assert.equal(h.param_labels.len(), 3)
            try assert.equal(h.param_labels[2], "c: Bool")
          },
          .None => { return .Err("expected active param 2, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "zero-arg function shows empty params",
      fn() {
        src := "fn noop() Void { }\nnoop()\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 5))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "noop")
            try assert.equal(h.param_labels.len(), 0)
            try assert.equal(h.active_param, 0)
          },
          .None => { return .Err("expected signature help for zero-arg fn, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "multibyte text before call maps positions correctly",
      fn() {
        // "café" has é (2 UTF-8 bytes, 1 UTF-16 code unit)
        // Line 0: fn add(a: Int, b: Int) Int { a + b }
        // Line 1: x := "café"    ← multibyte
        // Line 2: add(1, 2)
        // fn defined before multibyte line so the call on line 2 can resolve
        src := "fn add(a: Int, b: Int) Int { a + b }\nx := \"café\"\nadd(1, 2)\n"
        state := state_with_doc("file:///a.tw", src)

        // cursor after comma on line 2, char 7
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 2, 7))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "add")
            try assert.equal(h.active_param, 1)
          },
          .None => { return .Err("expected signature help after multibyte text, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete call: cursor after open paren with no closing paren",
      fn() {
        // User just typed "add(" — no closing paren, parse fails as Call
        valid := "fn add(a: Int, b: Int) Int { a + b }\nadd(1, 2)\n"
        incomplete := "fn add(a: Int, b: Int) Int { a + b }\nadd("
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end of file: line 1, char 4
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 4))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "add")
            try assert.equal(h.active_param, 0)
            try assert.equal(h.param_labels.len(), 2)
            try assert.equal(h.param_labels[0], "a: Int")
            try assert.equal(h.param_labels[1], "b: Int")
          },
          .None => { return .Err("expected signature help for incomplete call, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete call: cursor after comma with no closing paren",
      fn() {
        // User typed "add(1, " — second arg not yet filled, no close paren
        valid := "fn add(a: Int, b: Int) Int { a + b }\nadd(1, 2)\n"
        incomplete := "fn add(a: Int, b: Int) Int { a + b }\nadd(1, "
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end: line 1, char 7
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 7))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "add")
            try assert.equal(h.active_param, 1)
          },
          .None => {
            return .Err("expected signature help for incomplete call after comma, got null")
          },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete call inside function body",
      fn() {
        // Editing inside a function body — code won't typecheck
        valid := "fn greet(name: String, loud: Bool) String { name }\nfn main() String {\n  greet(\"hi\", true)\n}\n"
        incomplete := "fn greet(name: String, loud: Bool) String { name }\nfn main() String {\n  greet("
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end: line 2, char 8
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 2, 8))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "greet")
            try assert.equal(h.active_param, 0)
            try assert.equal(h.param_labels[0], "name: String")
            try assert.equal(h.param_labels[1], "loud: Bool")
          },
          .None => {
            return .Err("expected signature help for incomplete call in fn body, got null")
          },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete call: multiple commas tracks active param",
      fn() {
        // User typed three args, working on fourth (no close paren)
        valid := "fn make(a: Int, b: String, c: Bool) Int { a }\nmake(1, \"x\", true)\n"
        incomplete := "fn make(a: Int, b: String, c: Bool) Int { a }\nmake(1, \"x\", "
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end: line 1, char 13
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 13))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "make")
            try assert.equal(h.active_param, 2)
          },
          .None => { return .Err("expected active param 2 for incomplete call, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete call ignores nested comma while selecting active param",
      fn() {
        // The comma inside `(1, 2)` is not an argument separator for make.
        valid := "fn make(a: Int, b: Int) Int { a }\nmake(1, 2)\n"
        incomplete := "fn make(a: Int, b: Int) Int { a }\nmake((1, 2), "
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end: line 1, char 13
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 13))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "make")
            try assert.equal(h.active_param, 1)
          },
          .None => { return .Err("expected signature help with nested comma, got null") },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete nested call resolves inner function",
      fn() {
        // outer(inner( — cursor inside inner's open paren
        valid := "fn outer(x: Int) Int { x }\nfn inner(a: String) String { a }\nouter(inner(\"x\"))\n"
        incomplete := "fn outer(x: Int) Int { x }\nfn inner(a: String) String { a }\nouter(inner("
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end: line 2, char 12
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 2, 12))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => {
            try assert.str_contains(h.label, "inner")
            try assert.equal(h.param_labels[0], "a: String")
          },
          .None => {
            return .Err("expected signature help for inner in incomplete nested call, got null")
          },
        }

        .Ok({})
      },
    )
    .test(
      "incomplete module-qualified call shows signature",
      fn() {
        // User typed "path.join(" — module-qualified, incomplete
        valid := "use @std.path\npath.join(\"a\", \"b\")\n"
        incomplete := "use @std.path\npath.join("
        state := state_with_warm_cache("file:///a.tw", valid, incomplete)

        // cursor at end: line 1, char 10
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 10))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => try assert.str_contains(h.label, "join"),
          .None => {
            return .Err("expected signature help for incomplete qualified call, got null")
          },
        }

        .Ok({})
      },
    )
    .test(
      "complete call that fails typed resolution falls back to source scan",
      fn() {
        // io.write_stdout_text( ) parses as a complete Call, but typed
        // resolution may fail — the source-scan fallback should still work.
        valid := "use @std.path\npath.join(\"a\", \"b\")\n"
        edited := "use @std.path\npath.join( )\n"
        state := state_with_warm_cache("file:///a.tw", valid, edited)

        // cursor inside parens: line 1, char 11
        step := state.handle_message(sig_help_request(1, "file:///a.tw", 1, 11))
        info := try extract_sig_help(step)

        case info {
          .Some(h) => try assert.str_contains(h.label, "join"),
          .None => {
            return .Err("expected signature help for parseable but unresolved call, got null")
          },
        }

        .Ok({})
      },
    )
    .test(
      "initialize advertises signatureHelpProvider",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)
        out := step.outgoing[0]
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        sig_help := try caps.decode(json.field("signatureHelpProvider", json.raw()))
        triggers := try sig_help.decode(json.field("triggerCharacters", json.raw()))

        case triggers {
          .Array(arr) => try assert.is_true(arr.len() >= 2),
          _ => { return .Err("expected triggerCharacters array") },
        }

        .Ok({})
      },
    )
}
