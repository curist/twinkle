use @std.fs

use compiler.fmt.formatter
use compiler.lexer
use compiler.parser
use tests.assert
use tests.runner

fn format_ok(src: String) Result<String, String> {
  lexed := lexer.lex(src, 0)

  if lexed.diagnostics.len() > 0 {
    return .Err("expected no lexer diagnostics")
  }

  parsed := parser.parse(src, 0)

  if parsed.diagnostics.len() > 0 {
    return .Err("expected no parser diagnostics")
  }

  .Ok(formatter.format(parsed.value, lexed.value, src))
}

fn read_case(name: String, suffix: String) Result<String, String> {
  path := "boot/tests/suites/fmt_cases/${name}.${suffix}"

  case fs.read_text(path) {
    .Ok(content) => .Ok(content),
    .Err(_) => .Err("failed to read fixture: ${path}"),
  }
}

fn assert_fmt_case(name: String) fn() Result<Void, String> {
  fn() {
    original := try read_case(name, "original")
    expected := try read_case(name, "expected")
    formatted := try format_ok(original)
    try assert.equal(formatted, expected)
    reformatted := try format_ok(expected)
    try assert.equal(reformatted, expected)
    .Ok({})
  }
}

fn test_unicode_escape_formatting() Result<Void, String> {
  formatted := try format_ok("fn f() String { \"\\u{0065}\" }")
  assert.equal(formatted, "fn f() String {\n  \"e\"\n}\n")
}

// Raw/multiline formatting lives in `fmt_cases/` fixtures (raw_string,
// multiline_block, multiline_rebinding, multiline_trailing_newline,
// multiline_return, multiline_non_tail_cooked, raw_interpolation,
// multiline_interpolation). This case stays inline because its point is a
// trailing space inside content, which a fixture file would invite editors/git
// to strip.
fn test_multiline_block_preserves_content_trailing_space() Result<Void, String> {
  // Trailing whitespace after the marker is part of the value (F3): keep it.
  src := "x :=\n  \\\\a \n  \\\\b\n"
  formatted := try format_ok(src)
  assert.equal(formatted, src)
}

fn test_unary_not_preserves_binary_parens() Result<Void, String> {
  // `!` binds tighter than comparison/`and`, so the parens are load-bearing:
  // dropping them turns `!(x >= 0 and x <= 9)` into `(!x) >= 0 and x <= 9`.
  formatted := try format_ok("fn f(x: Int) Bool { !(x >= 0 and x <= 9) }")
  assert.equal(formatted, "fn f(x: Int) Bool {\n  !(x >= 0 and x <= 9)\n}\n")
}

fn test_unary_neg_preserves_binary_parens() Result<Void, String> {
  // Same for negation: `-(a + b)` must not become `-a + b`.
  formatted := try format_ok("fn g(a: Int, b: Int) Int { -(a + b) }")
  assert.equal(formatted, "fn g(a: Int, b: Int) Int {\n  -(a + b)\n}\n")
}

fn test_dollar_string_formatting() Result<Void, String> {
  formatted := try format_ok("fn f() String { \"byte$to_int\" }")
  try assert.equal(formatted, "fn f() String {\n  \"byte$to_int\"\n}\n")

  interpolation_source := "fn g() String { \"".concat("\\").concat("$").concat("{name}\" }")
  interpolation_expected := "fn g() String {\n  \"".concat("\\").concat("$").concat("{name}\"\n}\n")
  interpolation_sentinel := try format_ok(interpolation_source)
  assert.equal(interpolation_sentinel, interpolation_expected)
}

pub fn suite() runner.Suite {
  runner
    .suite("fmt")
    .test("preserves right-nested non-associative binary parens", assert_fmt_case("binary_parens"))
    .test("breaks logical or chains by alternative", assert_fmt_case("logical_or_chain"))
    .test("formats declarations and top-level spacing", assert_fmt_case("declarations"))
    .test("formats unicode escapes as scalars", test_unicode_escape_formatting)
    .test("keeps parens around a not'd binary expression", test_unary_not_preserves_binary_parens)
    .test("keeps parens around a negated binary expression", test_unary_neg_preserves_binary_parens)
    .test("formats dollar strings without changing meaning", test_dollar_string_formatting)
    .test("preserves raw single-line strings", assert_fmt_case("raw_string"))
    .test("reflows and preserves multiline blocks", assert_fmt_case("multiline_block"))
    .test("preserves multiline block in rebinding", assert_fmt_case("multiline_rebinding"))
    .test(
      "preserves multiline trailing-newline line",
      assert_fmt_case("multiline_trailing_newline"),
    )
    .test("reflows multiline block in return", assert_fmt_case("multiline_return"))
    .test("preserves multiline block in a record field", assert_fmt_case("multiline_record_field"))
    .test("preserves multiline block in a call argument", assert_fmt_case("multiline_call_arg"))
    .test(
      "preserves multiline block in an array element",
      assert_fmt_case("multiline_array_element"),
    )
    .test(
      "preserves multiline block in a variant argument",
      assert_fmt_case("multiline_variant_arg"),
    )
    .test("preserves raw interpolation", assert_fmt_case("raw_interpolation"))
    .test(
      "reflows and preserves multiline interpolation",
      assert_fmt_case("multiline_interpolation"),
    )
    .test(
      "preserves multiline content trailing space",
      test_multiline_block_preserves_content_trailing_space,
    )
    .test("formats literals and wrapped calls", assert_fmt_case("literals_and_calls"))
    .test("formats control-flow blocks", assert_fmt_case("control_flow"))
    .test(
      "does not auto-insert blank lines around flow statements",
      assert_fmt_case("cond_arm_compact_block"),
    )
    .test("preserves interleaved binary comments", assert_fmt_case("interleaved_comments"))
    .test("groups extern declarations by module", assert_fmt_case("extern_decls"))
    .test("breaks method chains consistently", assert_fmt_case("method_chain"))
    .test("breaks complex inline blocks", assert_fmt_case("inline_blocks"))
    .test("preserves blank lines and auto-blanks before comments", assert_fmt_case("blank_lines"))
    .test(
      "preserves author blank lines between top-level statements",
      assert_fmt_case("top_level_blank_lines"),
    )
    .test(
      "preserves author blank lines between case and cond arms",
      assert_fmt_case("case_cond_blank_lines"),
    )
    .test(
      "preserves comments inside record and array literals",
      assert_fmt_case("record_field_comments"),
    )
    .test(
      "preserves trailing comments on case and cond arms",
      assert_fmt_case("case_cond_trailing_comments"),
    )
    .test("preserves comments inside call arguments", assert_fmt_case("call_arg_comments"))
    .test("preserves comments inside function parameters", assert_fmt_case("param_comments"))
    .test("preserves comments inside closure parameters", assert_fmt_case("closure_param_comments"))
    .test(
      "preserves comments inside type declaration fields and variants",
      assert_fmt_case("type_decl_comments"),
    )
    .test("preserves comments inside import lists", assert_fmt_case("import_comments"))
    .test(
      "preserves comments inside variant constructor arguments",
      assert_fmt_case("variant_arg_comments"),
    )
    .test("inserts blank line after module doc comments", assert_fmt_case("module_doc"))
    .test("applies rebinding shorthand in assign expressions", assert_fmt_case("assign_shorthand"))
    .test(
      "keeps a doc comment attached to the first declaration",
      assert_fmt_case("doc_on_first_decl"),
    )
    .test(
      "preserves a separated module doc above the first declaration",
      assert_fmt_case("module_doc_then_decl"),
    )
    .test(
      "preserves a blank between a module doc and a doc-less declaration",
      assert_fmt_case("module_doc_blank_before_decl"),
    )
}
