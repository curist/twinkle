use compiler.query.cache as query_cache
use lib.json
use lib.lsp.document_store
use lib.lsp.protocol
use lib.lsp.server_core
use tests.assert
use tests.runner

fn state_with_doc(uri: String, text: String) server_core.State {
  docs := document_store.empty().open(uri, text, .Some(1))
  base := server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: true,
    diagnostics_deadline_ms: 0.0,
    last_published: Dict.new(),
    diagnostics_tier: .Full,
    parse_dirty_uris: Dict.new(),
    full_dirty: false,
    closure_snapshot: .None,
  }

  // Heavy features serve only a completed full snapshot, so warm the cache with a
  // full diagnostics pass before issuing feature requests.
  base.publish_due_diagnostics().state
}

fn inlay_hint_request(id: Int, uri: String, start_line: Int, end_line: Int) protocol.Message {
  params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri))])),
    json.kv(
      "range",
      json.object([
        json.kv(
          "start",
          json.object([json.kv("line", .Int(start_line)), json.kv("character", .Int(0))]),
        ),
        json.kv(
          "end",
          json.object([json.kv("line", .Int(end_line)), json.kv("character", .Int(0))]),
        ),
      ]),
    ),
  ])
  protocol.Message.Request(.{
    id: .IntId(id),
    method: "textDocument/inlayHint",
    params: .Some(params),
  })
}

fn hint_labels(step: server_core.Step) Vector<String>!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))
  items := try result.decode(json.raw().list())
  labels: Vector<String> = []

  for item in items {
    label := try item.decode(json.field("label", json.string()))
    labels = .append(label)
  }

  .Ok(labels)
}

fn hint_kinds(step: server_core.Step) Vector<Int>!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))
  items := try result.decode(json.raw().list())
  kinds: Vector<Int> = []

  for item in items {
    kind := try item.decode(json.field("kind", json.int()))
    kinds = .append(kind)
  }

  .Ok(kinds)
}

pub fn suite() runner.Suite {
  runner
    .suite("lsp inlay hints")
    .test(
      "type hint for inferred binding",
      fn() {
        // x := [1, 2, 3]  — type is Vector<Int>, should get a hint
        src := "x := [1, 2, 3]\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 1))
        labels := try hint_labels(step)
        try assert.equal(labels.len(), 1)
        try assert.equal(labels[0], ": Vector<Int>")
        .Ok({})
      },
    )
    .test(
      "no type hint for obvious literal",
      fn() {
        src := "x := 42\ny := \"hello\"\nz := true\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 3))
        labels := try hint_labels(step)
        try assert.equal(labels.len(), 0)
        .Ok({})
      },
    )
    .test(
      "no type hint for annotated binding",
      fn() {
        src := "x: Int = 42\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 1))
        labels := try hint_labels(step)
        try assert.equal(labels.len(), 0)
        .Ok({})
      },
    )
    .test(
      "type hint kind is 1",
      fn() {
        src := "x := [1, 2]\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 1))
        kinds := try hint_kinds(step)
        try assert.equal(kinds.len(), 1)
        try assert.equal(kinds[0], 1)
        .Ok({})
      },
    )
    .test(
      "parameter hints for multi-arg call",
      fn() {
        src := "fn add(a: Int, b: Int) Int { a + b }\nx := add(1, 2)\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 2))
        labels := try hint_labels(step)

        // Should have type hint for x := add(1, 2) and param hints for a:, b:
        try assert.is_true(labels.contains("a: "))
        try assert.is_true(labels.contains("b: "))
        .Ok({})
      },
    )
    .test(
      "no parameter hint when arg matches param name",
      fn() {
        src := "fn greet(name: String) String { name }\nname := \"world\"\nx := greet(name)\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 3))
        labels := try hint_labels(step)

        // Should NOT have a "name: " parameter hint since arg is already `name`
        try assert.is_true(!labels.contains("name: "))
        .Ok({})
      },
    )
    .test(
      "empty result for unknown document",
      fn() {
        state := state_with_doc("file:///a.tw", "x := 1\n")
        step := state.handle_message(inlay_hint_request(1, "file:///unknown.tw", 0, 1))
        labels := try hint_labels(step)
        try assert.equal(labels.len(), 0)
        .Ok({})
      },
    )
    .test(
      "type hint for for-loop pattern variable",
      fn() {
        src := "xs := [1, 2, 3]\nfor x in xs {\n  x\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 4))
        labels := try hint_labels(step)
        try assert.is_true(labels.contains(": Int"))
        .Ok({})
      },
    )
    .test(
      "type hint for collect pattern variable",
      fn() {
        src := "xs := [1, 2, 3]\nys := collect x in xs { x + 1 }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 2))
        labels := try hint_labels(step)

        // Should have hint for xs, ys, and x
        try assert.is_true(labels.contains(": Int"))
        .Ok({})
      },
    )
    .test(
      "type hint for closure parameter",
      fn() {
        src := "xs := [1, 2, 3]\nys := xs.map(fn(x) { x + 1 })\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 2))
        labels := try hint_labels(step)

        // Should have a type hint for the closure param x
        try assert.is_true(labels.contains(": Int"))
        .Ok({})
      },
    )
    .test(
      "no closure param hint when type is annotated",
      fn() {
        src := "xs := [1, 2, 3]\nys := xs.map(fn(x: Int) { x + 1 })\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(inlay_hint_request(1, "file:///a.tw", 0, 2))
        labels := try hint_labels(step)

        // Count how many ": Int" hints — should NOT have one for the annotated closure param
        count := labels.filter(fn(l) { l == ": Int" }).len()
        try assert.equal(count, 0)
        .Ok({})
      },
    )
    .test(
      "inlayHintProvider advertised in capabilities",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)

        if step.outgoing.len() != 1 {
          return .Err("expected one message")
        }

        out := step.outgoing[0]
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        hint_cap := try caps.decode(json.field("inlayHintProvider", json.bool()))
        try assert.is_true(hint_cap)
        .Ok({})
      },
    )
}
