use tests.runner
use tests.assert
use lib.query.keys

pub fn suite() runner.Suite {
  runner.suite("query keys")

    // -- hash_text: verified against Rust FNV-1a reference --

    .test("hash_text empty string matches reference", fn() {
      // Rust: fnv1a_64(b"") = 14695981039346656037u64 = -3750763034362895579i64
      try assert.int_eq(keys.hash_text(""), 0 - 3750763034362895579)
      .Ok({})
    })

    .test("hash_text single char matches reference", fn() {
      // Rust: fnv1a_64(b"a") = -5808556873153909620i64
      try assert.int_eq(keys.hash_text("a"), 0 - 5808556873153909620)
      .Ok({})
    })

    .test("hash_text multi-char matches reference", fn() {
      // Rust: fnv1a_64(b"hello") = -6615550055289275125i64
      try assert.int_eq(keys.hash_text("hello"), 0 - 6615550055289275125)
      .Ok({})
    })

    .test("hash_text stage name matches reference", fn() {
      // Rust: fnv1a_64(b"parse") = 886795330685173132i64
      try assert.int_eq(keys.hash_text("parse"), 886795330685173132)
      .Ok({})
    })

    // -- determinism --

    .test("hash_text is deterministic", fn() {
      a := keys.hash_text("test string")
      b := keys.hash_text("test string")
      try assert.int_eq(a, b)
      .Ok({})
    })

    .test("hash_text different inputs produce different hashes", fn() {
      a := keys.hash_text("foo")
      b := keys.hash_text("bar")
      try assert.is_true(a != b)
      .Ok({})
    })

    // -- parse_key: verified against Rust mix_many reference --

    .test("parse_key matches reference", fn() {
      source_hash := keys.hash_text("fn main() {}")
      // Verify source hash first
      try assert.int_eq(source_hash, 0 - 6186732394119585521)
      pk := keys.parse_key("test.tw", source_hash)
      // Rust: mix_many(&[1, hash_text("parse"), hash_text("test.tw"), source_hash])
      //     = -1554403158589966462i64
      try assert.int_eq(pk, 0 - 1554403158589966462)
      .Ok({})
    })

    .test("parse_key differs for different paths", fn() {
      sh := keys.hash_text("source")
      a := keys.parse_key("a.tw", sh)
      b := keys.parse_key("b.tw", sh)
      try assert.is_true(a != b)
      .Ok({})
    })

    .test("parse_key differs for different source", fn() {
      a := keys.parse_key("test.tw", keys.hash_text("v1"))
      b := keys.parse_key("test.tw", keys.hash_text("v2"))
      try assert.is_true(a != b)
      .Ok({})
    })

    // -- resolve_key --

    .test("resolve_key includes deps_hash", fn() {
      sh := keys.hash_text("source")
      a := keys.resolve_key("test.tw", sh, 100)
      b := keys.resolve_key("test.tw", sh, 200)
      try assert.is_true(a != b)
      .Ok({})
    })

    // -- typecheck_key --

    .test("typecheck_key differs by allow_host_builtins", fn() {
      sh := keys.hash_text("source")
      a := keys.typecheck_key("test.tw", sh, 0, true)
      b := keys.typecheck_key("test.tw", sh, 0, false)
      try assert.is_true(a != b)
      .Ok({})
    })

    // -- lower_key --

    .test("lower_key differs by next_global_local_id", fn() {
      sh := keys.hash_text("source")
      a := keys.lower_key("test.tw", sh, 0, 100)
      b := keys.lower_key("test.tw", sh, 0, 200)
      try assert.is_true(a != b)
      .Ok({})
    })

    // -- deps_hash: verified against Rust reference --

    .test("deps_hash matches reference", fn() {
      // Rust: mix_many(&[hash_text("deps"), hash_text("a.tw"), 100, hash_text("b.tw"), 200])
      //     = 5538049689009683815i64
      entries: Vector<keys.DepEntry> = [
        keys.DepEntry.{ path: "a.tw", hash: 100 },
        keys.DepEntry.{ path: "b.tw", hash: 200 },
      ]
      try assert.int_eq(keys.deps_hash(entries), 5538049689009683815)
      .Ok({})
    })

    .test("deps_hash is order-independent", fn() {
      // Entries should be sorted by path internally
      forward: Vector<keys.DepEntry> = [
        keys.DepEntry.{ path: "a.tw", hash: 1 },
        keys.DepEntry.{ path: "b.tw", hash: 2 },
      ]
      reversed: Vector<keys.DepEntry> = [
        keys.DepEntry.{ path: "b.tw", hash: 2 },
        keys.DepEntry.{ path: "a.tw", hash: 1 },
      ]
      try assert.int_eq(keys.deps_hash(forward), keys.deps_hash(reversed))
      .Ok({})
    })

    .test("deps_hash empty entries", fn() {
      entries: Vector<keys.DepEntry> = []
      // Should still produce a valid hash (just hash_text("deps"))
      result := keys.deps_hash(entries)
      try assert.is_true(result != 0)
      .Ok({})
    })

    // -- module_hash: verified against Rust reference --

    .test("module_hash matches reference", fn() {
      source_hash := keys.hash_text("fn main() {}")
      dh := 5538049689009683815  // from deps_hash test above
      // Rust: mix_many(&[1, hash_text("module"), source_hash, dh])
      //     = 7533646049685068476i64
      try assert.int_eq(keys.module_hash(source_hash, dh), 7533646049685068476)
      .Ok({})
    })

    // -- context_hash --

    .test("context_hash is order-independent", fn() {
      a: Vector<keys.DepEntry> = [
        keys.DepEntry.{ path: "x.tw", hash: 10 },
        keys.DepEntry.{ path: "y.tw", hash: 20 },
      ]
      b: Vector<keys.DepEntry> = [
        keys.DepEntry.{ path: "y.tw", hash: 20 },
        keys.DepEntry.{ path: "x.tw", hash: 10 },
      ]
      try assert.int_eq(keys.context_hash(a), keys.context_hash(b))
      .Ok({})
    })

    .test("context_hash differs from deps_hash for same entries", fn() {
      entries: Vector<keys.DepEntry> = [
        keys.DepEntry.{ path: "a.tw", hash: 1 },
      ]
      // context_hash uses "ctx" tag, deps_hash uses "deps" tag
      try assert.is_true(keys.context_hash(entries) != keys.deps_hash(entries))
      .Ok({})
    })

    // -- with_context --

    .test("with_context combines base and context", fn() {
      base := keys.parse_key("test.tw", keys.hash_text("src"))
      ctx := keys.context_hash([
        keys.DepEntry.{ path: "dep.tw", hash: 42 },
      ])
      result := keys.with_context(base, ctx)
      // Should differ from base alone
      try assert.is_true(result != base)
      // Should be deterministic
      try assert.int_eq(result, keys.with_context(base, ctx))
      .Ok({})
    })

    // -- schema version sensitivity --

    .test("keys change when schema version would change", fn() {
      // parse_key includes schema version in the mix
      // We can't change the version at runtime, but we verify
      // that the key incorporates it (same inputs, same output)
      sh := keys.hash_text("test")
      a := keys.parse_key("test.tw", sh)
      b := keys.parse_key("test.tw", sh)
      try assert.int_eq(a, b)
      .Ok({})
    })
}
