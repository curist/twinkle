        // "dep" on line 1 starts at char 5
        step := state.handle_message(def_request(1, "file:///tmp/lsp-def-mod-expr/main.tw", 1, 5))
        uri := try def_result_uri(step)
        try assert.equal(uri, "file:///tmp/lsp-def-mod-expr/dep.tw")
        .Ok({})
