    .test(
      "goto def on closure parameter type",
      fn() {
        // type Msg = .{ text: String }
        // fn apply() String {
        //   f := fn(m: Msg) String { m.text }
        //              ^^^
        //   f(.{ text: "hi" })
        // }
        src := "type Msg = .{ text: String }\nfn apply() String {\n  f := fn(m: Msg) String { m.text }\n  f(.{ text: \"hi\" })\n}\n"
        state := state_with_doc("file:///a.tw", src)

        // "Msg" on line 2 at char 13
        step := state.handle_message(def_request(1, "file:///a.tw", 2, 13))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 5)
        try assert.equal(r.end_char, 8)
        .Ok({})
      },
    )
    .test(
      "goto def on type param returns null",
      fn() {
        // fn identity<T>(x: T) T { x }
        //                    ^  cursor on T in param type — type params have no definition site
        src := "fn identity<T>(x: T) T { x }\n"
        state := state_with_doc("file:///a.tw", src)

        // "T" on line 0 at char 18
        step := state.handle_message(def_request(1, "file:///a.tw", 0, 18))
        try assert.is_true(try is_null_result(step))
        .Ok({})
      },
    )
    .test(
      "goto def on top-level let binding",
      fn() {
        // x := 42
        // y := x + 1
        //      ^
        src := "x := 42\ny := x + 1\n"
        state := state_with_doc("file:///a.tw", src)

        // "x" on line 1 at char 5
        step := state.handle_message(def_request(1, "file:///a.tw", 1, 5))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 0)
        .Ok({})
      },
    )
    .test(
      "goto def with variable shadowing resolves to inner binding",
      fn() {
        // fn foo() Int {
        //   x := 1
        //   x := x + 1
        //   x
        // }
        src := "fn foo() Int {\n  x := 1\n  x := x + 1\n  x\n}\n"
        state := state_with_doc("file:///a.tw", src)

        // "x" on line 3 (the tail) at char 2 should resolve to the second binding on line 2
        step := state.handle_message(def_request(1, "file:///a.tw", 3, 2))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 2)
        .Ok({})
      },
    )
    .test(
      "goto def on collect comprehension binding",
      fn() {
        // fn foo() Vector<Int> {
        //   collect x in [1, 2, 3] {
        //     x * 2
        //   }
        // }
        src := "fn foo() Vector<Int> {\n  collect x in [1, 2, 3] {\n    x * 2\n  }\n}\n"
        state := state_with_doc("file:///a.tw", src)

        // "x" on line 2 at char 4
        step := state.handle_message(def_request(1, "file:///a.tw", 2, 4))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 1)
        try assert.equal(r.start_char, 10)
        try assert.equal(r.end_char, 11)
        .Ok({})
      },
    )
    .test(
      "goto def in string interpolation resolves variable",
      fn() {
        // fn greet(name: String) String {
        //   "hello ${name}"
        // }
        dollar := String.from_code_point(36).unwrap_or("")
        src := "fn greet(name: String) String {\n  \"hello ".concat(dollar).concat("{name}\"\n}\n")
        state := state_with_doc("file:///a.tw", src)

        // "name" inside interpolation — line 1, char 11
        step := state.handle_message(def_request(1, "file:///a.tw", 1, 11))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 9)
        .Ok({})
      },
    )
    .test(
      "goto def on variant constructor in expression",
      fn() {
        // type Color = { Red, Green, Blue }
        // c := Color.Red
        //            ^^^
        src := "type Color = { Red, Green, Blue }\nc := Color.Red\n"
        state := state_with_doc("file:///a.tw", src)

        // "Red" on line 1 at char 11
        step := state.handle_message(def_request(1, "file:///a.tw", 1, 11))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 15)
        try assert.equal(r.end_char, 18)
        .Ok({})
      },
    )
    .test(
      "goto def on record field access jumps to field declaration",
      fn() {
        // type Point = .{ x: Int, y: Int }
        // fn get_x(p: Point) Int { p.x }
        //                            ^
        src := "type Point = .{ x: Int, y: Int }\nfn get_x(p: Point) Int { p.x }\n"
        state := state_with_doc("file:///a.tw", src)

        // ".x" on line 1 — "x" at char 27
        step := state.handle_message(def_request(1, "file:///a.tw", 1, 27))
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 16)
        try assert.equal(r.end_char, 17)
        .Ok({})
      },
    )
    .test(
      "goto def on imported record field jumps to field in defining module",
      fn() {
        dep := "pub type Point = .{ x: Int, y: Int }\n"
        main := "use dep\nfn get_x(p: dep.Point) Int { p.x }\n"
        state := state_with_two_docs(
          "file:///tmp/lsp-def-field/dep.tw",
          dep,
          "file:///tmp/lsp-def-field/main.tw",
          main,
        )

        // ".x" on line 1 — "x" at char 31
        step := state.handle_message(def_request(1, "file:///tmp/lsp-def-field/main.tw", 1, 31))
        uri := try def_result_uri(step)
        try assert.equal(uri, "file:///tmp/lsp-def-field/dep.tw")
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 20)
        try assert.equal(r.end_char, 21)
        .Ok({})
      },
    )
}
