        // "answer" in `use dep.{answer}` — line 0, char 9
        step := state.handle_message(def_request(1, "file:///tmp/lsp-def-destr/main.tw", 0, 9))
        uri := try def_result_uri(step)
        try assert.equal(uri, "file:///tmp/lsp-def-destr/dep.tw")
        r := try def_result_range(step)
        try assert.equal(r.start_line, 0)
        try assert.equal(r.start_char, 7)
        try assert.equal(r.end_char, 13)
        .Ok({})
