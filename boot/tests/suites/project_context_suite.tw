use @std.testing.assert as assert
use @std.testing as runner

use lib.module.loader
use lib.project.config
use lib.project.context

fn cfg_with(name: String?, project: Vector<String>, test: Vector<String>) config.Config {
  config.Config.{ name, project_entries: project, test_entries: test }
}

fn fixture_root() String {
  root := loader.find_project_root("boot")
  "${root}/tests/fixtures/project_reachable"
}

pub fn suite() runner.Suite {
  runner
    .suite("project context")
    .test(
      "target name is the stem for a nested non-main entry",
      fn() {
        try assert.equal(context.derive_target_name("cmd/server.tw", .None), "server")
        .Ok({})
      },
    )
    .test(
      "target name is the parent dir for a nested main entry",
      fn() {
        try assert.equal(context.derive_target_name("cmd/server/main.tw", .None), "server")
        .Ok({})
      },
    )
    .test(
      "root main entry uses the project name when present",
      fn() {
        try assert.equal(context.derive_target_name("main.tw", .Some("demo")), "demo")
        .Ok({})
      },
    )
    .test(
      "root main entry falls back to 'main' without a project name",
      fn() {
        try assert.equal(context.derive_target_name("main.tw", .None), "main")
        .Ok({})
      },
    )
    .test(
      "from_root builds entry targets with derived names and absolute paths",
      fn() {
        cfg := cfg_with(.Some("demo"), ["cmd/server.tw"], [])
        ctx := try context.from_root("/proj", cfg)
        try assert.equal(ctx.project_entries.len(), 1)
        try assert.equal(ctx.project_entries[0].name, "server")
        try assert.equal(ctx.project_entries[0].rel_path, "cmd/server.tw")
        try assert.equal(ctx.project_entries[0].abs_path, "/proj/cmd/server.tw")
        .Ok({})
      },
    )
    .test(
      "from_root keeps project and test entries separate",
      fn() {
        cfg := cfg_with(.None, ["cmd/app.tw"], ["tests/main.tw"])
        ctx := try context.from_root("/proj", cfg)
        try assert.equal(ctx.project_entries.len(), 1)
        try assert.equal(ctx.test_entries.len(), 1)
        try assert.equal(ctx.test_entries[0].rel_path, "tests/main.tw")
        try assert.equal(ctx.test_entries[0].abs_path, "/proj/tests/main.tw")
        .Ok({})
      },
    )
    .test(
      "from_root rejects project entries that derive the same target name",
      fn() {
        cfg := cfg_with(.None, ["cmd/server.tw", "other/server.tw"], [])
        case context.from_root("/proj", cfg) {
          .Ok(_) => .Err("expected duplicate target-name rejection"),
          .Err(_) => .Ok({}),
        }
      },
    )
    .test(
      "reachable_modules returns project-local modules and excludes stdlib",
      fn() {
        cfg := cfg_with(.None, ["main.tw"], [])
        ctx := try context.from_root(fixture_root(), cfg)
        r := context.reachable_modules(ctx, ctx.project_entries)
        try assert.equal(r.failed.len(), 0)

        // main.tw imports a project-local sibling (helper.tw) and @std.path;
        // only the two project-local files are reported.
        try assert.equal(r.modules.len(), 2)

        for m in r.modules {
          try assert.is_false(m.starts_with("/__twinkle_core"))
        }

        .Ok({})
      },
    )
    .test(
      "reachable_modules dedupes a module shared across entries",
      fn() {
        cfg := cfg_with(.None, ["main.tw", "other.tw"], [])
        ctx := try context.from_root(fixture_root(), cfg)
        r := context.reachable_modules(ctx, ctx.project_entries)

        // main.tw + other.tw + the shared helper.tw, counted once.
        try assert.equal(r.modules.len(), 3)
        .Ok({})
      },
    )
    .test(
      "reachable_modules records a failing entry without aborting siblings",
      fn() {
        // `missing.tw` does not exist on disk, so discovery fails to load it.
        cfg := cfg_with(.None, ["missing.tw", "main.tw"], [])
        ctx := try context.from_root(fixture_root(), cfg)
        r := context.reachable_modules(ctx, ctx.project_entries)
        try assert.is_true(r.failed.len() >= 1)

        // The sibling entry is still fully discovered.
        try assert.is_true(r.modules.len() >= 2)
        .Ok({})
      },
    )
}
