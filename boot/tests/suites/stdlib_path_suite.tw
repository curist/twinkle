use tests.runner
use tests.assert
use @std.path

pub fn suite() runner.Suite {
  runner.suite("stdlib path")
    .test("is_absolute detects leading slash", fn() {
      try assert.is_true(path.is_absolute("/usr/bin"))
      try assert.is_false(path.is_absolute("usr/bin"))
      try assert.is_false(path.is_absolute(""))
      .Ok({})
    })
    .test("join two segments", fn() {
      try assert.str_eq(path.join("a", "b"), "a/b")
      try assert.str_eq(path.join("a/", "b"), "a/b")
      try assert.str_eq(path.join("a", "/b"), "a/b")
      try assert.str_eq(path.join("a/", "/b"), "a/b")
      .Ok({})
    })
    .test("join with empty segment", fn() {
      try assert.str_eq(path.join("", "b"), "b")
      try assert.str_eq(path.join("a", ""), "a")
      .Ok({})
    })
    .test("join_all combines multiple parts", fn() {
      parts: Vector<String> = ["usr", "local", "bin"]
      try assert.str_eq(path.join_all(parts), "usr/local/bin")
      .Ok({})
    })
    .test("join_all with single part", fn() {
      parts: Vector<String> = ["only"]
      try assert.str_eq(path.join_all(parts), "only")
      .Ok({})
    })
    .test("join_all empty returns empty", fn() {
      parts: Vector<String> = []
      try assert.str_eq(path.join_all(parts), "")
      .Ok({})
    })
    .test("dirname of nested path", fn() {
      try assert.str_eq(path.dirname("/usr/local/bin"), "/usr/local")
      try assert.str_eq(path.dirname("/usr"), "/")
      try assert.str_eq(path.dirname("a/b"), "a")
      .Ok({})
    })
    .test("dirname of bare name returns dot", fn() {
      try assert.str_eq(path.dirname("file.txt"), ".")
      try assert.str_eq(path.dirname(""), ".")
      .Ok({})
    })
    .test("basename extracts filename", fn() {
      try assert.str_eq(path.basename("/usr/local/bin"), "bin")
      try assert.str_eq(path.basename("a/b.txt"), "b.txt")
      try assert.str_eq(path.basename("solo"), "solo")
      .Ok({})
    })
    .test("basename of empty is empty", fn() {
      try assert.str_eq(path.basename(""), "")
      .Ok({})
    })
    .test("stem strips extension", fn() {
      try assert.str_eq(path.stem("file.txt"), "file")
      try assert.str_eq(path.stem("/a/b.tar.gz"), "b.tar")
      try assert.str_eq(path.stem("noext"), "noext")
      .Ok({})
    })
    .test("extension extracts dot suffix", fn() {
      try assert.str_eq(path.extension("file.txt"), ".txt")
      try assert.str_eq(path.extension("archive.tar.gz"), ".gz")
      try assert.str_eq(path.extension("noext"), "")
      .Ok({})
    })
    .test("normalize removes dot segments", fn() {
      try assert.str_eq(path.normalize("a/./b"), "a/b")
      try assert.str_eq(path.normalize("a/b/../c"), "a/c")
      try assert.str_eq(path.normalize("./a"), "a")
      .Ok({})
    })
    .test("normalize collapses double slashes", fn() {
      try assert.str_eq(path.normalize("a//b//c"), "a/b/c")
      .Ok({})
    })
    .test("normalize absolute path stays absolute", fn() {
      try assert.str_eq(path.normalize("/a/b/../c"), "/a/c")
      try assert.str_eq(path.normalize("/.."), "/")
      try assert.str_eq(path.normalize("/a/../../b"), "/b")
      .Ok({})
    })
    .test("normalize relative dotdot preserved", fn() {
      try assert.str_eq(path.normalize("../a"), "../a")
      try assert.str_eq(path.normalize("../../a"), "../../a")
      .Ok({})
    })
    .test("normalize empty and dot", fn() {
      try assert.str_eq(path.normalize(""), ".")
      try assert.str_eq(path.normalize("."), ".")
      try assert.str_eq(path.normalize("/"), "/")
      .Ok({})
    })
}
