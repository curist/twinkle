use @std.date
use @std.time

use tests.assert
use tests.runner

// Helpers proving stackful suspension is legal anywhere direct-style code runs:
// inside ordinary functions, recursion, and higher-order callbacks. None of
// these need a compiler transform or function coloring.
fn yielding_helper(log: Cell<String>) {
  log.update(fn(s) { s.concat("h") })
  Task.yield()
  log.update(fn(s) { s.concat("H") })
}

fn countdown(n: Int, acc: Cell<Int>) {
  if n > 0 {
    Task.yield()
    acc.update(fn(v) { v + n })
    countdown(n - 1, acc)
  }
}

fn apply_twice(f: fn() Int) Int {
  f() + f()
}

pub fn suite() runner.Suite {
  runner
    .suite("task concurrency")
    .test(
      "spawn and await returns value",
      fn() {
        t := Task.spawn(fn() Int { 42 })
        try assert.equal(t.await(), 42)
        .Ok({})
      },
    )
    .test(
      "spawn and await string",
      fn() {
        t := Task.spawn(fn() String { "hello" })
        try assert.equal(t.await(), "hello")
        .Ok({})
      },
    )
    .test(
      "spawn and await bool",
      fn() {
        t := Task.spawn(fn() Bool { true })
        try assert.is_true(t.await())
        .Ok({})
      },
    )
    .test(
      "spawn and await float",
      fn() {
        t := Task.spawn(fn() Float { 3.14 })
        result := t.await()

        // Float comparison: check it's close enough
        try assert.is_true(result > 3.13)
        try assert.is_true(result < 3.15)
        .Ok({})
      },
    )
    .test(
      "void task spawn and await",
      fn() {
        c := Cell.new(0)
        t := Task.spawn(fn() { c.set(1) })
        t.await()
        try assert.equal(c.get(), 1)
        .Ok({})
      },
    )
    .test(
      "multiple spawns all execute",
      fn() {
        c := Cell.new(0)
        t1 := Task.spawn(fn() {
          c.update(fn(n) { n + 1 })
        })
        t2 := Task.spawn(fn() {
          c.update(fn(n) { n + 10 })
        })
        t3 := Task.spawn(fn() {
          c.update(fn(n) { n + 100 })
        })
        t1.await()
        t2.await()
        t3.await()
        try assert.equal(c.get(), 111)
        .Ok({})
      },
    )
    .test(
      "awaiting first task runs it",
      fn() {
        c := Cell.new(0)
        t1 := Task.spawn(fn() Int {
          c.update(fn(n) { n + 1 })
          10
        })
        t2 := Task.spawn(fn() Int {
          c.update(fn(n) { n + 1 })
          20
        })

        // Awaiting t1 should run it (and possibly t2 too since scheduler drains)
        r1 := t1.await()
        try assert.equal(r1, 10)
        r2 := t2.await()
        try assert.equal(r2, 20)
        try assert.equal(c.get(), 2)
        .Ok({})
      },
    )
    .test(
      "task does not run immediately at spawn",
      fn() {
        c := Cell.new(0)
        t := Task.spawn(fn() { c.set(42) })

        // Before await, side effect hasn't happened yet
        // (it runs when we await or at drain)
        val_before := c.get()
        t.await()
        val_after := c.get()
        try assert.equal(val_before, 0)
        try assert.equal(val_after, 42)
        .Ok({})
      },
    )
    .test(
      "task closure captures variables",
      fn() {
        x := 10
        y := 20
        t := Task.spawn(fn() Int { x + y })
        try assert.equal(t.await(), 30)
        .Ok({})
      },
    )
    .test(
      "task closure captures mutable cell",
      fn() {
        c := Cell.new("before")
        t := Task.spawn(fn() String {
          c.set("after")
          c.get()
        })
        result := t.await()
        try assert.equal(result, "after")
        try assert.equal(c.get(), "after")
        .Ok({})
      },
    )
    .test(
      "await same task twice returns same result",
      fn() {
        t := Task.spawn(fn() Int { 99 })
        r1 := t.await()
        r2 := t.await()
        try assert.equal(r1, 99)
        try assert.equal(r2, 99)
        .Ok({})
      },
    )
    .test(
      "task returning vector",
      fn() {
        t := Task.spawn(fn() Vector<Int> {
          [1, 2, 3]
        })
        result := t.await()
        try assert.equal(result.len(), 3)
        try assert.equal(result[0], 1)
        try assert.equal(result[2], 3)
        .Ok({})
      },
    )
    .test(
      "task returning optional",
      fn() {
        t := Task.spawn(fn() Int? {
          .Some(5)
        })
        result := t.await()
        try assert.is_some(result)
        .Ok({})
      },
    )
    .test(
      "yield interleaves tasks",
      fn() {
        log := Cell.new("")
        t1 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("A1") })
          Task.yield()
          log.update(fn(s) { s.concat("A2") })
        })
        t2 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("B1") })
          Task.yield()
          log.update(fn(s) { s.concat("B2") })
        })
        t1.await()
        t2.await()
        try assert.equal(log.get(), "A1B1A2B2")
        .Ok({})
      },
    )
    .test(
      "yield with return value",
      fn() {
        t := Task.spawn(fn() Int {
          Task.yield()
          42
        })
        try assert.equal(t.await(), 42)
        .Ok({})
      },
    )
    .test(
      "multiple yields",
      fn() {
        log := Cell.new("")
        t1 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("1") })
          Task.yield()
          log.update(fn(s) { s.concat("2") })
          Task.yield()
          log.update(fn(s) { s.concat("3") })
        })
        t2 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("a") })
          Task.yield()
          log.update(fn(s) { s.concat("b") })
          Task.yield()
          log.update(fn(s) { s.concat("c") })
        })
        t1.await()
        t2.await()
        try assert.equal(log.get(), "1a2b3c")
        .Ok({})
      },
    )
    .test(
      "yield preserves captures",
      fn() {
        x := 10
        y := 20
        t := Task.spawn(fn() Int {
          Task.yield()
          x + y
        })
        try assert.equal(t.await(), 30)
        .Ok({})
      },
    )
    .test(
      "yield with cell mutation across suspend",
      fn() {
        c := Cell.new(0)
        t := Task.spawn(fn() Int {
          c.set(1)
          Task.yield()
          c.set(c.get() + 10)
          c.get()
        })
        try assert.equal(t.await(), 11)
        .Ok({})
      },
    )
    .test(
      "task-body await on completed task",
      fn() {
        t1 := Task.spawn(fn() Int { 10 })
        t2 := Task.spawn(fn() Int {
          // t1 will be done by the time we run (FIFO, t1 first)
          r := t1.await()
          r + 5
        })
        try assert.equal(t2.await(), 15)
        .Ok({})
      },
    )
    .test(
      "task-body await on pending task",
      fn() {
        log := Cell.new("")
        t1 := Task.spawn(fn() Int {
          log.update(fn(s) { s.concat("A") })
          Task.yield()
          log.update(fn(s) { s.concat("B") })
          42
        })
        t2 := Task.spawn(fn() Int {
          // t1 is not done yet — will block until t1 finishes
          r := t1.await()
          log.update(fn(s) { s.concat("C") })
          r + 1
        })
        try assert.equal(t2.await(), 43)
        try assert.equal(log.get(), "ABC")
        .Ok({})
      },
    )
    .test(
      "tasks execute in FIFO order",
      fn() {
        log := Cell.new("")
        t1 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("A") })
        })
        t2 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("B") })
        })
        t3 := Task.spawn(fn() {
          log.update(fn(s) { s.concat("C") })
        })
        t1.await()
        t2.await()
        t3.await()
        try assert.equal(log.get(), "ABC")
        .Ok({})
      },
    )
    .test(
      "task can spawn subtask",
      fn() {
        t := Task.spawn(fn() Int {
          inner := Task.spawn(fn() Int { 7 })
          inner.await() * 6
        })
        try assert.equal(t.await(), 42)
        .Ok({})
      },
    )
    .test(
      "task with loop computation",
      fn() {
        t := Task.spawn(fn() Int {
          sum := Cell.new(0)

          for i in 0..10 {
            sum.update(fn(n) { n + i })
          }

          sum.get()
        })
        try assert.equal(t.await(), 45)
        .Ok({})
      },
    )
    .test(
      "suspend inside ordinary helper",
      fn() {
        log := Cell.new("")
        t := Task.spawn(fn() { yielding_helper(log) })
        t.await()
        try assert.equal(log.get(), "hH")
        .Ok({})
      },
    )
    .test(
      "suspend inside recursive helper",
      fn() {
        acc := Cell.new(0)
        t := Task.spawn(fn() Int {
          countdown(4, acc)
          acc.get()
        })
        try assert.equal(t.await(), 10)
        .Ok({})
      },
    )
    .test(
      "suspend inside higher-order callback",
      fn() {
        c := Cell.new(0)
        t := Task.spawn(fn() Int {
          apply_twice(fn() {
            Task.yield()
            c.update(fn(n) { n + 1 })
            5
          })
        })
        try assert.equal(t.await(), 10)
        try assert.equal(c.get(), 2)
        .Ok({})
      },
    )
    .test(
      "sleep yields control to other tasks",
      fn() {
        log := Cell.new("")
        sleeper := Task.spawn(fn() {
          time.sleep(5)
          log.update(fn(s) { s.concat("slept") })
        })
        runner_task := Task.spawn(fn() {
          log.update(fn(s) { s.concat("ran") })
        })
        sleeper.await()
        runner_task.await()

        // The non-sleeping task runs while the sleeper is parked on the timer.
        try assert.equal(log.get(), "ranslept")
        .Ok({})
      },
    )
    .test(
      "Task.yield does not starve host timers",
      fn() {
        woke := Cell.new(false)
        sleeper := Task.spawn(fn() {
          time.sleep(5)
          woke.set(true)
        })

        // Busy-yield for ~60ms of wall time. A 5ms sleeper must wake well within
        // that window; if Task.yield only re-scheduled via a microtask it would
        // starve the host timer phase and the sleeper would not fire until the
        // loop ended.
        start := date.now()

        for date.now() - start < 60.0 {
          Task.yield()
        }
        woke_during_loop := woke.get()
        sleeper.await()
        try assert.is_true(woke_during_loop)
        .Ok({})
      },
    )
}
