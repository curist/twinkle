  try assert.int_eq(reg.type_defs.len(), 0)
  try assert.int_eq(reg.runtime_imports.len(), 0)
  .Ok({})
}

// ── plan_wasm_types: module globals ──────────────────────────────────

pub fn test_plan_higher_order_global_func_does_not_synthesize_capture_layout() Result<Void, String> {
  // apply(f, x) calls a function-typed parameter directly.
  apply_fn := mk_func_def(3, "apply",
    [
      Param.{ local: mk_local(0), ty: MonoType.Function([MonoType.Int], MonoType.Int) },
      Param.{ local: mk_local(1), ty: MonoType.Int },
    ],
    MonoType.Int,
    .Let(mk_local(2), .ACall(.ALocal(mk_local(0)), [.ALocal(mk_local(1))]),
      .Atom(.ALocal(mk_local(2)))),
    mono1(2, MonoType.Int),
  )
  double_fn := mk_func_def(4, "double",
    [Param.{ local: mk_local(10), ty: MonoType.Int }],
    MonoType.Int,
    .Let(mk_local(11), .ABinOp(.Add, .ALocal(mk_local(10)), .ALocal(mk_local(10)), .Int),
      .Atom(.ALocal(mk_local(11)))),
    mono1(11, MonoType.Int),
  )
  main_fn := mk_func_def(5, "main",
    [],
    MonoType.Int,
    .Let(mk_local(20), .ACall(.AGlobalFunc(mk_func(3)), [.AGlobalFunc(mk_func(4)), .ALitInt(21)]),
      .Atom(.ALocal(mk_local(20)))),
    mono1(20, MonoType.Int),
  )

  reg := plan(mk_module([apply_fn, double_fn, main_fn]), resolver.empty_env(), empty_builtins())

  case reg.capture_layouts[4] {
    .Some(_) => assert.fail("higher-order global function should not get synthesized empty capture layout"),
    .None => .Ok({}),
  }
}

pub fn test_plan_module_globals() Result<Void, String> {
  // __init__ function defines local 0 and local 1
  init_mono: Dict<Int, MonoType> = Dict.new()
  init_mono[0] = MonoType.Int
  init_mono[1] = MonoType.String
  init_fn := mk_func_def(1, "__init__",
    [],
    MonoType.Void,
    .Let(mk_local(0), .AInit(.ALitInt(42)),
      .Let(mk_local(1), .AInit(.ALitStr("hello")),
        .Atom(.ALitVoid))),
    init_mono,
  )
  // Another function references local 0 (a module global) but not local 1
  user_mono := mono1(10, MonoType.Int)
  user_fn := mk_func_def(2, "get_val",
    [],
    MonoType.Int,
    .Let(mk_local(10), .AInit(.ALocal(mk_local(0))),
      .Atom(.ALocal(mk_local(10)))),
    user_mono,
  )
  anf := AnfModule.{ functions: [init_fn, user_fn], init_func_id: .Some(mk_func(1)) }
  reg := plan(anf, resolver.empty_env(), empty_builtins())

  // local 0 should be a module global (referenced outside init, bound in init)
  case reg.module_globals[0] {
    .Some(gentry) => {
      try assert.str_contains(gentry.sym, "0")
      result: Result<Void, String> = case gentry.mono {
        .Int => .Ok({}),
        _ => assert.fail("expected Int mono for global 0"),
      }
      result
    },
    .None => { return assert.fail("expected local 0 in module_globals") },
  }
  // local 1 should NOT be a module global (not referenced outside init)
  case reg.module_globals[1] {
    .Some(_) => assert.fail("local 1 should not be a module global"),
    .None => .Ok({}),
  }
}

pub fn test_plan_nested_record_dependencies_are_ordered() Result<Void, String> {
  env := env_with_two_records()
  outer_ty: MonoType = .Named(TypeId.{ id: 11 }, [])
  mono := mono1(0, outer_ty)
  f := mk_func_def(100, "mk_outer",
    [],
    outer_ty,
    .Let(mk_local(0), .ARecord(TypeId.{ id: 11 }, []),
      .Atom(.ALocal(mk_local(0)))),
    mono,
  )
  reg := plan(mk_module([f]), env, empty_builtins())

  inner_idx := try reg.type_index["$Inner_t10"].ok_or("missing Inner type index")
  outer_idx := try reg.type_index["$Outer_t11"].ok_or("missing Outer type index")
  try assert.ok(inner_idx < outer_idx, "expected Inner to be registered before Outer")
  .Ok({})
}

pub fn test_plan_recursive_record_terminates() Result<Void, String> {
  env := env_with_recursive_record()
  node_ty: MonoType = .Named(TypeId.{ id: 12 }, [])
  mono := mono1(0, node_ty)
  f := mk_func_def(100, "mk_node",
    [],
    node_ty,
    .Let(mk_local(0), .ARecord(TypeId.{ id: 12 }, []),
      .Atom(.ALocal(mk_local(0)))),
    mono,
  )
  reg := plan(mk_module([f]), env, empty_builtins())

  case reg.type_index["$Node_t12"] {
    .Some(_) => .Ok({}),
    .None => assert.fail("expected recursive Node type to be registered"),
  }
}

// ── Suite ───────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("wasm plan")
    .test("FuncSigEntry construction", test_func_sig_entry)
    .test("CaptureEntry construction", test_capture_entry)
    .test("StringPoolEntry construction", test_string_pool_entry)
    .test("WasmTypeRegistry empty", test_registry_empty)
    .test("plan empty module", test_plan_empty_module)
    .test("plan primitive func", test_plan_primitive_func)
    .test("plan record type", test_plan_record_type)
    .test("plan string literals", test_plan_string_literals)
    .test("plan string pool byte offsets", test_plan_string_offsets)
    .test("plan closure", test_plan_closure)
    .test("plan closure registers functype", test_plan_closure_registers_func_type)
    .test("plan closure capture types", test_plan_capture_types)
    .test("plan closure populates concrete_func_sigs", test_plan_closure_func_sigs)
    .test("plan bare higher-order global function arg registers concrete func sig", test_plan_higher_order_global_function_arg_registers_func_sig)
    .test("plan runtime imports", test_plan_runtime_imports)
    .test("plan optional type", test_plan_optional_type)
    .test("plan higher-order global func does not synthesize capture layout", test_plan_higher_order_global_func_does_not_synthesize_capture_layout)
    .test("plan module globals", test_plan_module_globals)
    .test("plan nested record dependencies are ordered", test_plan_nested_record_dependencies_are_ordered)
    .test("plan recursive record terminates", test_plan_recursive_record_terminates)
}
