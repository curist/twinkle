use tests.runner
use tests.assert
use lib.source.span
use compiler.resolver
use compiler.resolver.{MonoType, TypeId, ResolvedEnv, ResolvedTypeDef, ResolvedField, ResolvedVariant, TypeEntry}
use compiler.core_ir.{LocalId, FuncId, FieldId, VariantId, Param}
use compiler.builtins as bi
use compiler.builtins.{BuiltinRegistry}
use compiler.anf.{
  OpKind, IndexKind, Atom, AnfExpr, AnfOp, FieldAtom, AnfMatchArm,
  AnfFunctionDef, AnfModule,
}
use compiler.codegen.wasm_ir.{ValType, HeapType, TypeDef, ImportDef}
use compiler.codegen.wasm_layout.{WasmLayout, WasmValType, layout_of, mono_to_key}
use compiler.codegen.wasm_plan.{plan_wasm_types}
use compiler.codegen.wasm_plan_types.{
  WasmTypeRegistry, FuncSigEntry, CaptureEntry, StringPoolEntry, ModuleGlobalEntry,
}
use compiler.backend.prepared_ir.{CaptureParam}
use compiler.backend.prepare.{prepare_backend, PreparedModule}
use compiler.backend.closure_convert.{convert_closures}

// ── Helpers ─────────────────────────────────────────────────────────

fn dummy_span() span.Span { span.Span.{ file_id: 0, start: 0, end: 0 } }

fn empty_builtins() BuiltinRegistry {
  BuiltinRegistry.{ by_name: Dict.new(), by_id: Dict.new(), by_canonical: Dict.new(), entries: [], next_id: 0 }
}

fn simple_builtins() BuiltinRegistry {
  empty_builtins()
    .runtime("print", "rt.core", "print")
    .runtime("println", "rt.core", "println")
}

fn mk_local(n: Int) LocalId { LocalId.{ id: n } }
fn mk_func(n: Int) FuncId { FuncId.{ id: n } }

fn mono1(key: Int, val: MonoType) Dict<Int, MonoType> {
  d: Dict<Int, MonoType> = Dict.new()
  d[key] = val
  d
}

fn mk_func_def(
  id: Int,
  name: String,
  params: Vector<Param>,
  ret: MonoType,
  body: AnfExpr,
  mono_map: Dict<Int, MonoType>,
) AnfFunctionDef {
  f: AnfFunctionDef = AnfFunctionDef.{
    func_id: mk_func(id),
    name: name,
    params: params,
    op_result_mono: mono_map,
    body: body,
    return_ty: ret,
  }
  f
}

fn mk_module(funcs: Vector<AnfFunctionDef>) AnfModule {
  m: AnfModule = AnfModule.{ functions: funcs, init_func_id: .None }
  m
}

fn env_with_record(name: String, type_id: Int, fields: Vector<ResolvedField>) ResolvedEnv {
  entry := TypeEntry.{
    id: TypeId.{ id: type_id },
    arity: 0,
    def: .Some(ResolvedTypeDef.Record(name, [], fields)),
    span: dummy_span(),
  }
  resolver.empty_env().add_type(entry, name)
}

fn env_with_two_records() ResolvedEnv {
  inner := TypeEntry.{
    id: TypeId.{ id: 10 },
    arity: 0,
    def: .Some(ResolvedTypeDef.Record("Inner", [], [
      ResolvedField.{ name: "value", ty: MonoType.Int },
    ])),
    span: dummy_span(),
  }
  outer := TypeEntry.{
    id: TypeId.{ id: 11 },
    arity: 0,
    def: .Some(ResolvedTypeDef.Record("Outer", [], [
      ResolvedField.{ name: "inner", ty: MonoType.Named(TypeId.{ id: 10 }, []) },
    ])),
    span: dummy_span(),
  }
  resolver.empty_env().add_type(inner, "Inner").add_type(outer, "Outer")
}

fn env_with_recursive_record() ResolvedEnv {
  node := TypeEntry.{
    id: TypeId.{ id: 12 },
    arity: 0,
    def: .Some(ResolvedTypeDef.Record("Node", [], [
      ResolvedField.{ name: "next", ty: MonoType.Optional(MonoType.Named(TypeId.{ id: 12 }, [])) },
    ])),
    span: dummy_span(),
  }
  resolver.empty_env().add_type(node, "Node")
}

fn empty_captures() Dict<Int, Vector<CaptureParam>> {
  d: Dict<Int, Vector<CaptureParam>> = Dict.new()
  d
}

fn prepare(anf: AnfModule, env: ResolvedEnv, builtins: BuiltinRegistry) PreparedModule {
  prepare_backend(anf, env, builtins, empty_captures())
}

fn plan(anf: AnfModule, env: ResolvedEnv, builtins: BuiltinRegistry) WasmTypeRegistry {
  plan_wasm_types(prepare(anf, env, builtins), env, builtins)
}

fn plan_with_closures(anf: AnfModule, env: ResolvedEnv, builtins: BuiltinRegistry) WasmTypeRegistry {
  closure_conversion := convert_closures(anf, env)
  prepared := prepare_backend(closure_conversion.anf, env, builtins, closure_conversion.captures)
  plan_wasm_types(prepared, env, builtins)
}

// ── Registry types construction ─────────────────────────────────────

pub fn test_func_sig_entry() Result<Void, String> {
  e := FuncSigEntry.{
    param_types: [MonoType.Int, MonoType.Float],
    return_type: MonoType.Bool,
  }
  try assert.int_eq(e.param_types.len(), 2)
  .Ok({})
}

pub fn test_capture_entry() Result<Void, String> {
  e := CaptureEntry.{
    local_id: mk_local(5),
    ty: MonoType.Int,
  }
  try assert.int_eq(e.local_id.id, 5)
  .Ok({})
}

pub fn test_string_pool_entry() Result<Void, String> {
  e := StringPoolEntry.{
    global_sym: "$str_0",
    getter_sym: "$str_0_get",
    data_segment_name: "$data_strings",
    byte_offset: 0,
    byte_len: 5,
  }
  try assert.str_eq(e.global_sym, "$str_0")
  try assert.int_eq(e.byte_len, 5)
  .Ok({})
}

// ── plan_wasm_types: empty module ───────────────────────────────────

pub fn test_plan_empty_module() Result<Void, String> {
  anf := AnfModule.{ functions: [], init_func_id: .None }
  env := resolver.empty_env()
  builtins := empty_builtins()
  reg := plan(anf, env, builtins)
  try assert.int_eq(reg.string_pool.len(), 0)
  .Ok({})
}

// ── plan_wasm_types: collects primitive types ───────────────────────

pub fn test_plan_primitive_func() Result<Void, String> {
  // fn add(a: Int, b: Int) Int { a + b }
  mono := mono1(0, MonoType.Int)
  f := mk_func_def(100, "add",
    [Param.{ local: mk_local(0), ty: MonoType.Int }, Param.{ local: mk_local(1), ty: MonoType.Int }],
    MonoType.Int,
    .Let(mk_local(2), .ABinOp(.Add, .ALocal(mk_local(0)), .ALocal(mk_local(1)), .Int),
      .Atom(.ALocal(mk_local(2)))),
    mono,
  )
  anf := mk_module([f])
  env := resolver.empty_env()
  builtins := empty_builtins()
  reg := plan(anf, env, builtins)
  // Primitives don't need struct defs, so type_defs should be empty or minimal
  // But the layout cache should have entries
  key := mono_to_key(MonoType.Int)
  case reg.layout_cache[key] {
    .Some(l) => {
      case l {
        .Scalar(.WI64) => .Ok({}),
        _ => assert.fail("expected Scalar(WI64) in cache"),
      }
    },
    .None => assert.fail("Int layout not cached"),
  }
}

// ── plan_wasm_types: collects record types ──────────────────────────

pub fn test_plan_record_type() Result<Void, String> {
  // A function that creates a Point record
  env := env_with_record("Point", 10, [
    ResolvedField.{ name: "x", ty: MonoType.Int },
    ResolvedField.{ name: "y", ty: MonoType.Int },
  ])
  point_ty: MonoType = .Named(TypeId.{ id: 10 }, [])
  mono := mono1(0, point_ty)
  f := mk_func_def(100, "mk_point",
    [],
    point_ty,
    .Let(mk_local(0),
      .ARecord(TypeId.{ id: 10 }, [
        FieldAtom.{ field: FieldId.{ id: 0 }, value: .ALitInt(1) },
        FieldAtom.{ field: FieldId.{ id: 1 }, value: .ALitInt(2) },
      ]),
      .Atom(.ALocal(mk_local(0)))),
    mono,
  )
  anf := mk_module([f])
  builtins := empty_builtins()
  reg := plan(anf, env, builtins)

  // Should have a struct TypeDef for Point
  found := false
  for td in reg.type_defs {
    case td {
      .Struct(name, _, _, _) => {
        if name.contains("Point") { found = true }
      },
      _ => {},
    }
  }
  if found { .Ok({}) } else { assert.fail("expected Point struct in type_defs") }
}

// ── plan_wasm_types: collects string literals ───────────────────────

pub fn test_plan_string_literals() Result<Void, String> {
  mono := mono1(0, MonoType.String)
  f := mk_func_def(100, "greet",
    [],
    MonoType.String,
    .Let(mk_local(0), .AInit(.ALitStr("hello")),
      .Let(mk_local(1), .AInit(.ALitStr("world")),
        .Let(mk_local(2), .AInit(.ALitStr("hello")),
          .Atom(.ALocal(mk_local(0)))))),
    mono,
  )
  anf := mk_module([f])
  env := resolver.empty_env()
  builtins := empty_builtins()
  reg := plan(anf, env, builtins)

  // "hello" and "world" — 2 unique strings
  try assert.int_eq(reg.string_pool.len(), 2)
  case reg.string_pool["hello"] {
    .Some(entry) => try assert.int_eq(entry.byte_len, 5),
    .None => { return assert.fail("missing 'hello' in string pool") },
  }
  case reg.string_pool["world"] {
    .Some(entry) => try assert.int_eq(entry.byte_len, 5),
    .None => { return assert.fail("missing 'world' in string pool") },
  }
  .Ok({})
}

// ── plan_wasm_types: string pool byte offsets ────────────────────────

pub fn test_plan_string_offsets() Result<Void, String> {
  mono := mono1(0, MonoType.String)
  f := mk_func_def(100, "strs",
    [],
    MonoType.String,
    .Let(mk_local(0), .AInit(.ALitStr("ab")),       // 2 bytes, offset 0
      .Let(mk_local(1), .AInit(.ALitStr("cde")),    // 3 bytes, offset 2
        .Let(mk_local(2), .AInit(.ALitStr("f")),    // 1 byte, offset 5
          .Atom(.ALocal(mk_local(0)))))),
    mono,
  )
  anf := mk_module([f])
  reg := plan(anf, resolver.empty_env(), empty_builtins())

  try assert.int_eq(reg.string_pool.len(), 3)
  // Offsets should be cumulative: "ab"=0, "cde"=2, "f"=5
  case reg.string_pool["ab"] {
    .Some(e) => {
      try assert.int_eq(e.byte_offset, 0)
      try assert.int_eq(e.byte_len, 2)
    },
    .None => { return assert.fail("missing 'ab'") },
  }
  case reg.string_pool["cde"] {
    .Some(e) => {
      try assert.int_eq(e.byte_offset, 2)
      try assert.int_eq(e.byte_len, 3)
    },
    .None => { return assert.fail("missing 'cde'") },
  }
  case reg.string_pool["f"] {
    .Some(e) => {
      try assert.int_eq(e.byte_offset, 5)
      try assert.int_eq(e.byte_len, 1)
    },
    .None => { return assert.fail("missing 'f'") },
  }
  .Ok({})
}

// ── plan_wasm_types: collects closure signatures ────────────────────

pub fn test_plan_closure() Result<Void, String> {
  // A function that creates a closure capturing local 0
  closure_mono := mono1(0, MonoType.Function([MonoType.Int], MonoType.Int))
  // The closure's target function (func_id 200)
  closure_fn := mk_func_def(200, "adder",
    [Param.{ local: mk_local(10), ty: MonoType.Int }],
    MonoType.Int,
    .Atom(.ALocal(mk_local(10))),
    Dict.new(),
  )
  // The outer function that makes the closure
  outer := mk_func_def(100, "make_adder",
    [Param.{ local: mk_local(0), ty: MonoType.Int }],
    MonoType.Function([MonoType.Int], MonoType.Int),
    .Let(mk_local(1), .AMakeClosure(mk_func(200), [mk_local(0)]),
      .Atom(.ALocal(mk_local(1)))),
    closure_mono,
  )
  anf := mk_module([outer, closure_fn])
  env := resolver.empty_env()
  builtins := empty_builtins()
  reg := plan_with_closures(anf, env, builtins)

  // Should have capture layout for func 200
  case reg.capture_layouts[200] {
    .Some(caps) => {
      try assert.int_eq(caps.len(), 1)
      try assert.int_eq(caps[0].local_id.id, 0)
      .Ok({})
    },
    .None => assert.fail("missing capture layout for func 200"),
  }
}

pub fn test_plan_closure_registers_func_type() Result<Void, String> {
  closure_mono := mono1(0, MonoType.Function([MonoType.Int], MonoType.Int))
  closure_fn := mk_func_def(200, "adder",
    [Param.{ local: mk_local(10), ty: MonoType.Int }],
    MonoType.Int,
    .Atom(.ALocal(mk_local(10))),
    Dict.new(),
  )
  outer := mk_func_def(100, "make_adder",
    [Param.{ local: mk_local(0), ty: MonoType.Int }],
    MonoType.Function([MonoType.Int], MonoType.Int),
    .Let(mk_local(1), .AMakeClosure(mk_func(200), [mk_local(0)]),
      .Atom(.ALocal(mk_local(1)))),
    closure_mono,
  )
  anf := mk_module([outer, closure_fn])
  reg := plan_with_closures(anf, resolver.empty_env(), empty_builtins())

  found_func_type := false
  found_closure_struct := false
  for td in reg.type_defs {
    case td {
      .FuncType(name, _, _) => {
        if name.contains("$ft_") { found_func_type = true }
      },
      .Struct(name, _, _, _) => {
        if name.contains("$closure_") { found_closure_struct = true }
      },
      _ => {},
    }
  }
  try assert.is_true(found_func_type)
  try assert.is_true(found_closure_struct)
  .Ok({})
}

// ── plan_wasm_types: capture layouts have real types ─────────────────

pub fn test_plan_capture_types() Result<Void, String> {
  // Outer function has local 0: Int (param), local 1: String (let-bound)
  // Closure captures both
  closure_fn := mk_func_def(200, "use_both",
    [Param.{ local: mk_local(10), ty: MonoType.Int }],
    MonoType.Int,
    .Atom(.ALocal(mk_local(10))),
    Dict.new(),
  )
  mono: Dict<Int, MonoType> = Dict.new()
  mono[0] = MonoType.Function([MonoType.Int], MonoType.Int)
  mono[1] = MonoType.String
  mono[2] = MonoType.Function([MonoType.Int], MonoType.Int)
  outer := mk_func_def(100, "make_closure",
    [Param.{ local: mk_local(0), ty: MonoType.Int }],
    MonoType.Function([MonoType.Int], MonoType.Int),
    .Let(mk_local(1), .AInit(.ALitStr("hello")),
      .Let(mk_local(2), .AMakeClosure(mk_func(200), [mk_local(0), mk_local(1)]),
        .Atom(.ALocal(mk_local(2))))),
    mono,
  )
  anf := mk_module([outer, closure_fn])
  reg := plan_with_closures(anf, resolver.empty_env(), empty_builtins())

  case reg.capture_layouts[200] {
    .Some(caps) => {
      try assert.int_eq(caps.len(), 2)
      // local 0 is Int (from param)
      try assert.ok(
        case caps[0].ty { .Int => true, _ => false },
        "expected capture 0 type Int, got other",
      )
      // local 1 is String (from op_result_mono)
      try assert.ok(
        case caps[1].ty { .String => true, _ => false },
        "expected capture 1 type String, got other",
      )
      .Ok({})
    },
    .None => assert.fail("missing capture layout for func 200"),
  }
}

// ── plan_wasm_types: closure populates concrete_func_sigs ───────────

pub fn test_plan_closure_func_sigs() Result<Void, String> {
  // The closure's target function (func_id 200): fn(Int) Int
  closure_fn := mk_func_def(200, "adder",
    [Param.{ local: mk_local(10), ty: MonoType.Int }],
    MonoType.Int,
    .Atom(.ALocal(mk_local(10))),
    Dict.new(),
  )
  // The outer function makes the closure
  closure_mono := mono1(0, MonoType.Function([MonoType.Int], MonoType.Int))
  outer := mk_func_def(100, "make_adder",
    [Param.{ local: mk_local(0), ty: MonoType.Int }],
    MonoType.Function([MonoType.Int], MonoType.Int),
    .Let(mk_local(1), .AMakeClosure(mk_func(200), [mk_local(0)]),
      .Atom(.ALocal(mk_local(1)))),
    closure_mono,
  )
  anf := mk_module([outer, closure_fn])
  reg := plan_with_closures(anf, resolver.empty_env(), empty_builtins())

  // concrete_func_sigs should have entry for func 200
  case reg.concrete_func_sigs[200] {
    .Some(sig) => {
      try assert.int_eq(sig.param_types.len(), 1)
      try assert.ok(
        case sig.param_types[0] { .Int => true, _ => false },
        "expected param type Int",
      )
      try assert.ok(
        case sig.return_type { .Int => true, _ => false },
        "expected return type Int",
      )
      .Ok({})
    },
    .None => assert.fail("missing concrete_func_sigs entry for func 200"),
  }
}

pub fn test_plan_higher_order_global_function_arg_registers_func_sig() Result<Void, String> {
  adder := mk_func_def(300, "adder",
    [Param.{ local: mk_local(20), ty: MonoType.Int }],
    MonoType.Int,
    .Atom(.ALocal(mk_local(20))),
    Dict.new(),
  )
  apply_mono: Dict<Int, MonoType> = Dict.new()
  apply_mono[10] = MonoType.Int
  apply := mk_func_def(200, "apply",
    [
      Param.{ local: mk_local(0), ty: MonoType.Function([MonoType.Int], MonoType.Int) },
      Param.{ local: mk_local(1), ty: MonoType.Int },
    ],
    MonoType.Int,
    .Let(mk_local(10), .ACall(.ALocal(mk_local(0)), [.ALocal(mk_local(1))]),
      .Atom(.ALocal(mk_local(10)))),
    apply_mono,
  )
  caller_mono: Dict<Int, MonoType> = Dict.new()
  caller_mono[11] = MonoType.Int
  caller := mk_func_def(100, "caller", [], MonoType.Int,
    .Let(mk_local(11), .ACall(.AGlobalFunc(mk_func(200)), [.AGlobalFunc(mk_func(300)), .ALitInt(7)]),
      .Atom(.ALocal(mk_local(11)))),
    caller_mono,
  )

  reg := plan(mk_module([caller, apply, adder]), resolver.empty_env(), empty_builtins())

  case reg.concrete_func_sigs[300] {
    .Some(sig) => {
      try assert.int_eq(sig.param_types.len(), 1)
      try assert.ok(
        case sig.param_types[0] { .Int => true, _ => false },
        "expected higher-order bare global arg param type Int",
      )
      try assert.ok(
        case sig.return_type { .Int => true, _ => false },
        "expected higher-order bare global arg return type Int",
      )
      .Ok({})
    },
    .None => assert.fail("missing concrete_func_sigs entry for bare global function argument"),
  }
}

// ── plan_wasm_types: collects runtime imports ───────────────────────

pub fn test_plan_runtime_imports() Result<Void, String> {
  builtins := simple_builtins()
  // A function that calls println (a runtime builtin)
  print_id := bi.id(builtins, "println")
  mono := mono1(0, MonoType.Void)
  f := mk_func_def(100, "main",
    [],
    MonoType.Void,
    .Let(mk_local(0), .ACall(.AGlobalFunc(print_id), [.ALitStr("hi")]),
      .Atom(.ALitVoid)),
    mono,
  )
  anf := mk_module([f])
  env := resolver.empty_env()
  reg := plan(anf, env, builtins)

  // Should have runtime import for println with non-empty params
  found := false
  for imp in reg.runtime_imports {
    if imp.name == "println" {
      found = true
      try assert.int_eq(imp.params.len(), 1)
      case imp.params[0] {
        .Ref(nullable, .Named(name)) => {
          try assert.bool_eq(nullable, true)
          try assert.str_eq(name, "rt_types__String")
        },
        _ => { return assert.fail("expected println import param to use builtin ABI ref null $String") },
      }
    }
  }
  if found { .Ok({}) } else { assert.fail("expected println in runtime_imports") }
}

// ── plan_wasm_types: collects Optional sum type ─────────────────────

pub fn test_plan_optional_type() Result<Void, String> {
  opt_ty: MonoType = .Optional(.Int)
  mono := mono1(0, opt_ty)
  f := mk_func_def(100, "maybe",
    [],
    opt_ty,
    .Let(mk_local(0), .AVariant(TypeId.{ id: -1 }, VariantId.{ id: 1 }, [.ALitInt(42)]),
      .Atom(.ALocal(mk_local(0)))),
    mono,
  )
  anf := mk_module([f])
  env := resolver.empty_env()
  builtins := empty_builtins()
  reg := plan(anf, env, builtins)

  // Should have a sum struct for Option<Int>
  found := false
  for td in reg.type_defs {
    case td {
      .Struct(name, _, _, _) => {
        if name.contains("Option") { found = true }
      },
      _ => {},
    }
  }
  if found { .Ok({}) } else { assert.fail("expected Option struct in type_defs") }
}

// ── WasmTypeRegistry field access ───────────────────────────────────

pub fn test_registry_empty() Result<Void, String> {
  reg := WasmTypeRegistry.{
    type_defs: [],
    layout_cache: Dict.new(),
    in_progress: Dict.new(),
    type_index: Dict.new(),
    concrete_func_sigs: Dict.new(),
    capture_layouts: Dict.new(),
    module_globals: Dict.new(),
    module_globals_order: [],
    string_pool: Dict.new(),
    string_pool_order: [],
