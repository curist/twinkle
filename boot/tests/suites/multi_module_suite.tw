use tests.runner
use tests.assert
use compiler.module_compiler
use compiler.pipeline
use lib.module.loader

fn fixtures_dir() String {
  root := loader.find_project_root("boot")
  "${root}/tests/fixtures/multi"
}

fn project_root() String {
  loader.find_project_root("boot")
}

pub fn suite() runner.Suite {
  dir := fixtures_dir()
  root := project_root()

  runner.suite("multi-module compilation")

    .test("compile single file with no imports", fn() {
      result := module_compiler.compile_entry("${dir}/math_lib.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("compile file importing relative module (functions)", fn() {
      result := module_compiler.compile_entry("${dir}/uses_math.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("compile file importing relative module (types)", fn() {
      result := module_compiler.compile_entry("${dir}/uses_types.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("mixed full and selective import reuses exported type ids", fn() {
      result := module_compiler.compile_entry("${dir}/duplicate_type_imports_main.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("vector get supports optional return annotations", fn() {
      result := module_compiler.compile_entry("${dir}/vector_get_optional_return.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("selective-only imported sum types resolve shorthand variants", fn() {
      result := module_compiler.compile_entry("${dir}/selective_only_variants_main.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("type from full import flows correctly through exported function signature", fn() {
      result := module_compiler.compile_entry("${dir}/type_flow_consumer.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("function from source module accepts value obtained via full-import bridge", fn() {
      result := module_compiler.compile_entry("${dir}/type_flow_method_consumer.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("type from full import flows through record type in lex/parse topology", fn() {
      result := module_compiler.compile_entry("${dir}/lex_sim_parser.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("real boot lexer module typechecks through compiler import topology", fn() {
      result := module_compiler.compile_entry("${root}/compiler/lexer.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected boot compiler lexer module to compile, got: ${msg}"),
      }
    })

    .test("method call works: bridge full-import then source full-import", fn() {
      result := module_compiler.compile_entry("${dir}/method_call_consumer_full.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("method call works: bridge full-import then source selective-import", fn() {
      result := module_compiler.compile_entry("${dir}/method_call_consumer.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("method call works: source selective-import then bridge full-import", fn() {
      result := module_compiler.compile_entry("${dir}/method_call_consumer_rev.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("compile transitive dependency chain (a -> b -> c)", fn() {
      result := module_compiler.compile_entry("${dir}/transitive_a.tw")
      case result {
        .Ok(_) => .Ok({}),
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("selective import does not bring parent module into scope", fn() {
      result := module_compiler.compile_entry("${dir}/selective_no_parent_scope.tw")
      case result {
        .Ok(_) => .Err("expected selective import to reject parent module access"),
        .Err(msg) => {
          try assert.is_true(msg.contains("math_lib.add") or msg.contains("math_lib"))
          .Ok({})
        },
      }
    })

    .test("circular import detected", fn() {
      result := module_compiler.compile_entry("${dir}/circular_a.tw")
      case result {
        .Ok(_) => .Err("expected circular import error"),
        .Err(msg) => {
          try assert.is_true(msg.contains("Circular import"))
          .Ok({})
        },
      }
    })

    // ── Step 4: Core IR linking ──────────────────────────────────────────

    .test("linked output contains functions from all modules", fn() {
      result := module_compiler.compile_entry("${dir}/uses_math.tw")
      case result {
        .Ok(artifacts) => {
          // After linking, Core IR should have functions from both modules.
          // math_lib defines: add, multiply, internal_helper
          // uses_math defines: main (plus __init__)
          names := collect f in artifacts.core.functions { f.name }
          try assert.vec_contains(names, "add")
          try assert.vec_contains(names, "multiply")
          try assert.vec_contains(names, "main")
          .Ok({})
        },
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    // ── Step 5: Pipeline integration ────────────────────────────────────

    .test("compile_entry handles program with init code calling cross-module functions", fn() {
      result := module_compiler.compile_entry("${dir}/entry_calls_lib.tw")
      case result {
        .Ok(artifacts) => {
          names := collect f in artifacts.core.functions { f.name }
          try assert.vec_contains(names, "add")
          try assert.vec_contains(names, "__init__")
          .Ok({})
        },
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("pipeline.compile_entry_path handles multi-module entry file", fn() {
      result := pipeline.compile_entry_path("${dir}/entry_calls_lib.tw")
      case result {
        .Ok(artifacts) => {
          names := collect f in artifacts.core.functions { f.name }
          try assert.vec_contains(names, "add")
          try assert.vec_contains(names, "__init__")
          .Ok({})
        },
        .Err(msg) => .Err("expected success, got: ${msg}"),
      }
    })

    .test("compile_entry reports every diagnostic with source locations", fn() {
      result := module_compiler.compile_entry("${dir}/two_type_errors.tw")
      case result {
        .Ok(_) => .Err("expected checker diagnostics"),
        .Err(msg) => {
          try assert.str_contains(msg, "check:\n")
          try assert.str_contains(msg, "${dir}/two_type_errors.tw:2:")
          try assert.str_contains(msg, "${dir}/two_type_errors.tw:3:")
          try assert.is_false(msg.contains("(and "))
          .Ok({})
        },
      }
    })
}
