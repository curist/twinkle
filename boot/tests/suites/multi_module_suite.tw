fn fixtures_dir() String {
  root := loader.find_project_root("boot")
  "${root}/tests/fixtures/multi"
}

fn project_root() String {
  loader.find_project_root("boot")
}

fn has_box_to_string_param(env: ResolvedEnv, func: FunctionDef) Bool {
  if func.name != "to_string" {
    return false
  }

  if func.params.len() == 0 {
    return false
  }

  env.ty_to_string_env(func.params[0].ty).starts_with("Box")
}

// Recursively check whether any ContractCall node remains in an expression tree.
fn has_contract_call(expr: CoreExpr) Bool {
  case expr.kind {
    .ContractCall(_, _, _, _) => true,
    .Let(_, value, body) => has_contract_call(value) or has_contract_call(body),
    .Assign(_, value) => has_contract_call(value),
    .BinOp(_, lhs, rhs) => has_contract_call(lhs) or has_contract_call(rhs),
    .UnOp(_, inner) => has_contract_call(inner),
    .Call(callee, args) => {
      if has_contract_call(callee) {
        return true
      }

      for a in args {
        if has_contract_call(a) {
          return true
        }
      }

      false
    },
    .If(cond_e, then_e, else_e) => has_contract_call(cond_e)
      or has_contract_call(then_e)
      or has_contract_call(else_e),
    .Match(scrut, arms) => {
      if has_contract_call(scrut) {
        return true
      }

      for arm in arms {
        if has_contract_call(arm.body) {
          return true
        }
      }

      false
    },
    .Loop(body) => has_contract_call(body),
    .Break(val) => case val {
      .Some(v) => has_contract_call(v),
      .None => false,
    },
    .Return(val) => case val {
      .Some(v) => has_contract_call(v),
      .None => false,
    },
    .Defer(inner) => has_contract_call(inner),
    .Record(_, fields) => {
      for fi in fields {
        if has_contract_call(fi.value) {
          return true
        }
      }

      false
    },
    .RecordGet(target, _) => has_contract_call(target),
    .RecordUpdate(base, _, value) => has_contract_call(base) or has_contract_call(value),
    .Variant(_, _, args) => {
      for a in args {
        if has_contract_call(a) {
          return true
        }
      }

      false
    },
    .ArrayLit(elems) => {
      for e in elems {
        if has_contract_call(e) {
          return true
        }
      }

      false
    },
    .Index(base, idx) => has_contract_call(base) or has_contract_call(idx),
    _ => false,
  }
}

// Check whether the expression tree contains a Call targeting the given FuncId.
fn has_call_to(expr: CoreExpr, target_id: Int) Bool {
  case expr.kind {
    .Call(callee, args) => {
      case callee.kind {
        .GlobalFunc(fid) => if fid.id == target_id {
          return true
        },
        _ => {},
      }

      if has_call_to(callee, target_id) {
        return true
      }

      for a in args {
        if has_call_to(a, target_id) {
          return true
        }
      }

      false
    },
    .Let(_, value, body) => has_call_to(value, target_id) or has_call_to(body, target_id),
    .Assign(_, value) => has_call_to(value, target_id),
    .If(_, then_e, else_e) => has_call_to(then_e, target_id) or has_call_to(else_e, target_id),
    .Match(_, arms) => {
      for arm in arms {
        if has_call_to(arm.body, target_id) {
          return true
        }
      }

      false
    },
    .Loop(body) => has_call_to(body, target_id),
    _ => false,
  }
}

pub fn suite() runner.Suite {
  dir := fixtures_dir()
  root := project_root()
  runner.suite("multi-module compilation")
    .test(
      "compile single file with no imports",
      fn() {
        result := module_compiler.compile_entry("${dir}/math_lib.tw")

        case result {
          .Ok(_) => .Ok({}),
          .Err(err) => .Err("expected success, got: ${format_compile_error(err)}"),
        }
      },
    )
    .test(
      "compile file importing relative module (functions)",
      fn() {
        result := module_compiler.compile_entry("${dir}/uses_math.tw")

