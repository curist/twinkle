    .test(
      "linked core remaps cross-module TypeIds for contract receiver methods",
      fn() {
        artifacts := case module_compiler.compile_entry("${dir}/contract_fallback_main.tw") {
          .Ok(value) => value,
          .Err(err) => {
            return .Err(
              "expected contract fallback fixture to compile, got: ${format_compile_error(err)}",
            )
          },
        }
        found := artifacts.core.functions.any(
          fn(func) {
            has_box_to_string_param(artifacts.core.type_env, func)
          },
        )

        if !found {
          return .Err("expected linked Box.to_string param to use canonical Box TypeId")
        }

        .Ok({})
      },
    )
    .test(
      "contract fallback ignores unrelated methods loaded earlier",
      fn() {
        wat := try codegen_harness.codegen_path("${dir}/contract_fallback_main.tw")
        try assert.str_contains(wat, "show_box")
        .Ok({})
      },
    )
    .test(
      "contract fallback ignores unrelated generic methods loaded earlier",
      fn() {
        wat := try codegen_harness.codegen_path("${dir}/contract_generic_fallback_main.tw")
        try assert.str_contains(wat, "to_string__Int")
        .Ok({})
      },
    )
    .test(
      "method table maps Box.to_string by receiver TypeId after linking",
      fn() {
        artifacts := case module_compiler.compile_entry("${dir}/contract_generic_fallback_main.tw") {
          .Ok(value) => value,
          .Err(err) => {
            return .Err("expected fixture to compile, got: ${format_compile_error(err)}")
          },
        }

        // Find the Box type's TypeId in the linked environment.
        box_tid := case artifacts.core.type_env.lookup_registered_type("Box") {
          .Some(entry) => entry.id,
          .None => { return .Err("Box type not found in linked env") },
        }
        key := "t${box_tid.id}::to_string"

        case artifacts.core.method_table[key] {
          .Some(fid) => {
            // Verify the FuncId points at a function with Box receiver.
            found := artifacts.core.functions.any(
              fn(func) {
                func.func_id.id == fid.id and has_box_to_string_param(artifacts.core.type_env, func)
              },
            )

            if !found {
              return .Err(
                "method_table[${key}] = FuncId(${fid.id}) but no matching Box.to_string function found",
              )
            }

            .Ok({})
          },
          .None => .Err("method_table missing key '${key}' for Box.to_string"),
        }
      },
    )
    .test(
      "cross-module pub value emits global.set in per-module \$init",
      fn() {
        wat := try codegen_harness.codegen_path("${dir}/module_global_init_main.tw")
        try assert.str_contains(wat, "global.set \$user__global_local_")
        .Ok({})
      },
    )
    .test(
      "record shorthand with module function across modules",
      fn() {
        result := module_compiler.compile_entry("${dir}/record_shorthand_main.tw")

        case result {
          .Ok(_) => .Ok({}),
          .Err(err) => .Err("expected success, got: ${format_compile_error(err)}"),
        }
      },
    )
    .test(
      "import order does not affect contract method target choice",
      fn() {
        // Compile with original order (box first, provider second)
        wat_original := try codegen_harness.codegen_path("${dir}/contract_generic_fallback_main.tw")

        // Compile with reversed order (provider first, box second)
        wat_reversed := try codegen_harness.codegen_path("${dir}/contract_order_reversed_main.tw")

        // Both must produce the correct Box.to_string specialization
        try assert.str_contains(wat_original, "to_string__Int")
        try assert.str_contains(wat_reversed, "to_string__Int")
        .Ok({})
      },
    )
    .test(
      "no ContractCall survives monomorphization",
      fn() {
        artifacts := case pipeline.compile_entry_path("${dir}/contract_generic_fallback_main.tw") {
          .Ok(a) => a,
          .Err(err) => { return .Err("compile failed: ${format_compile_error(err)}") },
        }

        // After monomorphization, no ContractCall should remain in any function body.
        for func in artifacts.mono.functions {
          if has_contract_call(func.body) {
            return .Err(
              "ContractCall survived monomorphization in function '${func.name}' (FuncId ${func.func_id.id})",
            )
          }
        }

        .Ok({})
      },
    )
    .test(
      "monomorphized show(Box<Int>) calls exact Box.to_string FuncId",
      fn() {
        artifacts := case pipeline.compile_entry_path("${dir}/contract_generic_fallback_main.tw") {
          .Ok(a) => a,
          .Err(err) => { return .Err("compile failed: ${format_compile_error(err)}") },
        }

        // Find the Box.to_string FuncId from the method table.
        box_tid := case artifacts.mono.type_env.lookup_registered_type("Box") {
          .Some(entry) => entry.id,
          .None => { return .Err("Box type not found in linked env") },
        }
        key := "t${box_tid.id}::to_string"

        if !artifacts.mono.method_table.has(key) {
          return .Err("method_table missing key '${key}'")
        }

        // Find the specialized show__T* function in the mono IR.
        show_func: FunctionDef? = .None

        for func in artifacts.mono.functions {
          if func.name.starts_with("show__") {
            show_func = .Some(func)
          }
        }

        func := case show_func {
          .Some(f) => f,
          .None => { return .Err("no specialized show__* function found in mono IR") },
        }

        // The specialized show function should call the Box.to_string specialization.
        // After monomorphization, the specialized to_string gets a new FuncId, but
        // it should be a specialization of the original Box.to_string generic function.
        // Verify the specialized show calls a to_string__* specialization (not the
        // provider's unrelated to_string).
        found_to_string := false

        for mono_func in artifacts.mono.functions {
          if mono_func.name.starts_with("to_string__") and mono_func.params.len() > 0 {
            // Check this to_string specialization has a Box receiver param.
            param_ty_str := artifacts.mono.type_env.ty_to_string_env(mono_func.params[0].ty)

            if param_ty_str.starts_with("Box") {
              // Verify show__* calls this exact FuncId.
              if has_call_to(func.body, mono_func.func_id.id) {
                found_to_string = true
              }
            }
          }
        }

        if !found_to_string {
          return .Err("specialized show function does not call the Box.to_string specialization")
        }

        .Ok({})
      },
    )
}
