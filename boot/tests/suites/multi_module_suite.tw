        }
      },
    )
    .test(
      "linked output contains functions from all modules",
      fn() {
        result := module_compiler.compile_entry("${dir}/uses_math.tw")

        case result {
          .Ok(artifacts) => {
            // After linking, Core IR should have functions from both modules.
            // math_lib defines: add, multiply, internal_helper
            // uses_math defines: main (plus $init)
            names := collect f in artifacts.core.functions {
              f.name
            }
            try assert.vec_contains(names, "add")
            try assert.vec_contains(names, "multiply")
            try assert.vec_contains(names, "main")
            .Ok({})
          },
          .Err(err) => .Err("expected success, got: ${format_compile_error(err)}"),
        }
      },
    )
    .test(
      "compile_entry handles program with init code calling cross-module functions",
      fn() {
        result := module_compiler.compile_entry("${dir}/entry_calls_lib.tw")

        case result {
          .Ok(artifacts) => {
            names := collect f in artifacts.core.functions {
              f.name
            }
            try assert.vec_contains(names, "add")
            try assert.vec_contains(names, "\$init")
            .Ok({})
          },
          .Err(err) => .Err("expected success, got: ${format_compile_error(err)}"),
        }
      },
    )
    .test(
      "pipeline.compile_entry_path handles multi-module entry file",
      fn() {
        result := pipeline.compile_entry_path("${dir}/entry_calls_lib.tw")

        case result {
          .Ok(artifacts) => {
            names := collect f in artifacts.core.functions {
              f.name
