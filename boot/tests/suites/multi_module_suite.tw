        result := module_compiler.compile_entry("${dir}/duplicate_type_imports_main.tw")

        case result {
          .Ok(_) => .Ok({}),
          .Err(err) => .Err("expected success, got: ${format_compile_error(err)}"),
        }
      },
    )
    .test(
      "vector get supports optional return annotations",
