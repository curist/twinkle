// ── AInit transfer: source tainted → no transfer ────────────────────

fn test_init_transfer_tainted_source() Result<Void, String> {
  // fn test(v: Vec) {    // v is a param → tainted
  //   let w = AInit(v);  // should NOT transfer uniqueness (v tainted)
  //   let r = vec_set(w, 0, 42);
  //   Atom(r) }
  body: AnfExpr = .Let(lid(1), .AInit(.ALocal(lid(0))),
    .Let(lid(2),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(1)), .ALitInt(0), .ALitInt(42)]),
      .Atom(.ALocal(lid(2)))))
  params: Vector<Param> = [Param.{ local: lid(0), ty: .Void }]
  func := make_func_with_params(params, body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (tainted source init transfer)"),
  }
}

// ── Record update: consume-reassign with uniqueness ─────────────────

fn test_record_update_consume_reassign() Result<Void, String> {
  // let r = Record(tid, [f0: 1, f1: 2])   // fresh
  // let r2 = ARecordUpdate(r, f0, 99, false, tid)
  // let _ = AAssign(r, r2)
  // let r3 = ARecordUpdate(r, f1, 88, false, tid)
  // Atom(r3)
  //
  // r is fresh. First update consumes r and reassigns. Second update should also mark in-place.
  body: AnfExpr = .Let(lid(0),
    .ARecord(tid(7), [
      FieldAtom.{ field: field(0), value: .ALitInt(1) },
      FieldAtom.{ field: field(1), value: .ALitInt(2) },
    ]),
    .Let(lid(1),
      .ARecordUpdate(.ALocal(lid(0)), field(0), .ALitInt(99), false, tid(7)),
      .Let(lid(5), .AAssign(lid(0), .ALocal(lid(1))),
        .Let(lid(2),
          .ARecordUpdate(.ALocal(lid(0)), field(1), .ALitInt(88), false, tid(7)),
          .Atom(.ALocal(lid(2)))))))
  func := make_func(body)
  result := rewrite(func)

  // First update: consume-reassign → can_reuse = true
  case result.body {
    .Let(_, _, .Let(_, .ARecordUpdate(_, _, _, can_reuse1, _),
      .Let(_, _, .Let(_, .ARecordUpdate(_, _, _, can_reuse2, _), _)))) => {
      try assert.is_true(can_reuse1)
      assert.is_true(can_reuse2)
    },
    _ => .Err("expected both record updates in-place"),
  }
}

// ── Helpers for regression tests ─────────────────────────────────────

fn find_vec_set(e: AnfExpr) FuncId? {
  case e {
    .Let(_, .ACall(.AGlobalFunc(f), _), body) => {
      if f.id == mock_vec_set().id or f.id == mock_vec_set_in_place().id {
        .Some(f)
      } else {
        find_vec_set(body)
      }
    },
    .Let(_, _, body) => find_vec_set(body),
    _ => .None,
  }
}

fn find_builder_local(e: AnfExpr) LocalId? {
  case e {
    .Let(local, .ACall(.AGlobalFunc(f), _), body) => {
      if f.id == mock_builder_new().id {
        .Some(local)
      } else {
        find_builder_local(body)
      }
    },
    .Let(_, _, body) => find_builder_local(body),
    _ => .None,
  }
}

// ── Issue 1: Loop rewrite continuation must be recursively rewritten ─

fn test_loop_rewrite_continues_into_cont() Result<Void, String> {
  // let v = AArrayLit([])       // fresh, empty
  // let _ = ALoop(
  //   let tmp = vec_push(v, 1)
  //   let _ = AAssign(v, tmp)
  //   Continue)
  // let r = vec_set(v, 0, 42)   // v is now builder_freeze result → fresh → rewritable
  // Atom(r)
  //
  // After loop rewrite, v holds builder_freeze output (a fresh producer).
  // The vec_set(v, ...) in the continuation should also be rewritten to vec_set_in_place.
  loop_body: AnfExpr = .Let(lid(1),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))),
      .Continue))
  body: AnfExpr = .Let(lid(0),
    .AArrayLit([]),
    .Let(lid(3), .ALoop(loop_body),
      .Let(lid(4),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(4))))))
  func := make_func(body)
  result := rewrite(func)

  // Find the vec_set/vec_set_in_place call deep in the rewritten tree.
  case find_vec_set(result.body) {
    .Some(f) => assert.int_eq(f.id, mock_vec_set_in_place().id),
    .None => .Err("expected to find vec_set call in rewritten tree"),
  }
}

// ── Issue 2: max_local_in_op must visit pattern-bound locals ────────

fn test_loop_rewrite_authors_builder_monos() Result<Void, String> {
  loop_body: AnfExpr = .Let(lid(1),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))),
      .Continue))
  body: AnfExpr = .Let(lid(0),
    .AArrayLit([]),
    .Let(lid(3), .ALoop(loop_body),
      .Atom(.ALocal(lid(0)))))
  monos: Dict<Int, MonoType> = Dict.new()
  monos[0] = .Vector(.Int)
  monos[1] = .Vector(.Int)
  monos[2] = .Void
  monos[3] = .Void
  result := rewrite(make_func_with_mono(body, monos))

  case result.op_result_mono[4] {
    .Some(.Vector(.Int)) => {},
    .Some(_) => { return .Err("expected builder local mono Vector<Int>") },
    .None => { return .Err("expected builder local mono entry") },
  }
  case result.op_result_mono[5] {
    .Some(.Vector(.Int)) => {},
    .Some(_) => { return .Err("expected freeze local mono Vector<Int>") },
    .None => { return .Err("expected freeze local mono entry") },
  }
  case result.op_result_mono[6] {
    .Some(.Void) => .Ok({}),
    .Some(_) => .Err("expected assign local mono Void"),
    .None => .Err("expected assign local mono entry"),
  }
}

fn test_max_local_pattern_bindings() Result<Void, String> {
  // A Variant pattern binds a local with a high ID that is unused in the body.
  // max_local_in_op must walk patterns, not just bodies.
  // Without the fix, next_local_id misses lid(5) from the pattern, returns 5,
  // and the builder local collides.
  //
  // let v = AArrayLit([])
  // let _ = AMatch(scrutinee, [
  //   Variant(tid, vid, [Var(lid(5))]) => Atom(ALitVoid)   // binds 5 but unused
  // ])
  // let _ = ALoop(...)
  // Atom(v)
  match_arm := AnfMatchArm.{
    pattern: .Variant(tid(0), VariantId.{ id: 0 }, [.Var(lid(5))]),
    body: .Atom(.ALitVoid),
  }
  loop_body: AnfExpr = .Let(lid(2),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(3), .AAssign(lid(0), .ALocal(lid(2))),
      .Continue))
  body: AnfExpr = .Let(lid(0),
    .AArrayLit([]),
    .Let(lid(1),
      .AMatch(.ALitBool(true), [match_arm]),
      .Let(lid(4), .ALoop(loop_body),
        .Atom(.ALocal(lid(0))))))
  func := make_func(body)
  result := rewrite(func)

  // Find builder_new call and check its bound local ID.
  case find_builder_local(result.body) {
    .Some(local) => {
      // builder local must be >= 6 (not 5 which collides with pattern local)
      if local.id >= 6 {
        .Ok({})
      } else {
        .Err("builder local ${local.id} collides with pattern local 5")
      }
    },
    .None => .Err("expected builder_new call in rewritten tree"),
  }
}

// ── Suite ───────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  s := runner.suite("Opt: Uniqueness Rewrite")
  // Phase 1: tainted detection
  s = s.test("params tainted → no rewrite", test_params_tainted_no_rewrite)
  s = s.test("closure capture taints", test_closure_capture_taints)
  s = s.test("non-COW call taints args", test_non_cow_call_taints)
  s = s.test("read-only call does not taint", test_read_only_no_taint)
  s = s.test("COW base arg not tainted", test_cow_base_arg_not_tainted)
  s = s.test("stored in array taints", test_stored_in_array_taints)
  s = s.test("alias taints when source live", test_alias_taints)
  // Phase 2: uniqueness tracking + rewrite
  s = s.test("fresh producer + dead → rewrite", test_fresh_unique_rewrite)
  s = s.test("fresh producer + dead → rewrite via semantics", test_fresh_unique_rewrite_with_semantics_entry)
  s = s.test("array literal is fresh", test_array_lit_fresh)
  s = s.test("record literal is fresh", test_record_fresh)
  s = s.test("variant literal is fresh", test_variant_fresh)
  s = s.test("base still live → no rewrite", test_base_live_no_rewrite)
  s = s.test("AInit uniqueness transfer", test_init_transfer)
  s = s.test("AAssign uniqueness transfer", test_assign_transfer)
  s = s.test("consume-reassign pattern", test_consume_reassign)
  s = s.test("branches conservative", test_branches_conservative)
  s = s.test("dict set rewrite", test_dict_set_rewrite)
  // Correctness: AAssign alias taint
  s = s.test("assign alias taints", test_assign_alias_taints)
  s = s.test("assign alias source dead → safe", test_assign_alias_source_dead_ok)
  s = s.test("assign chain taint", test_assign_chain_taint)
  // Correctness: branch-boundary alias escape
  s = s.test("branch-boundary alias escape", test_branch_boundary_alias_escape)
  s = s.test("branch-boundary else branch", test_branch_boundary_else_branch)
  s = s.test("branch alias source not live-out → safe", test_branch_alias_source_not_live_out)
  s = s.test("match arm alias escape", test_match_arm_alias_escape)
  // Correctness: AAssign alias across scope
  s = s.test("assign alias across scope", test_assign_alias_cross_scope)
  // Correctness: container/call taint coverage
  s = s.test("stored in record taints", test_stored_in_record_taints)
  s = s.test("stored in variant taints", test_stored_in_variant_taints)
  s = s.test("indirect call taints", test_indirect_call_taints)
  s = s.test("COW non-base arg tainted", test_cow_non_base_arg_tainted)
  // Correctness: init transfer with tainted source
  s = s.test("init transfer tainted source", test_init_transfer_tainted_source)
  // Correctness: record update consume-reassign
  s = s.test("record update consume-reassign chain", test_record_update_consume_reassign)
  // Phase 3: loop region rewrite
  s = s.test("loop accumulator → builder_new", test_loop_accumulator_rewrite)
  s = s.test("loop accumulator → builder_from", test_loop_accumulator_from)
  s = s.test("loop rewrite authors builder monos", test_loop_rewrite_authors_builder_monos)
  s = s.test("loop tainted → no builder rewrite", test_loop_tainted_no_rewrite)
  s = s.test("loop base used in non-push way", test_loop_base_used_non_push)
  s = s.test("loop push in conditional branch", test_loop_push_in_branch)
  // Regression: loop rewrite recurses into continuation
  s = s.test("loop rewrite continues into cont", test_loop_rewrite_continues_into_cont)
  // Regression: max_local_id accounts for pattern bindings
  s = s.test("max local accounts for pattern bindings", test_max_local_pattern_bindings)
  s
}
