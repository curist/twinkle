use tests.runner
use tests.assert
use compiler.core_ir.{LocalId, FuncId, FieldId, VariantId, BinOp, Param}
use compiler.anf.{Atom, AnfExpr, AnfOp, AnfFunctionDef, AnfMatchArm, FieldAtom, OpKind}
use compiler.anf_analysis.{set_has}
use compiler.builder_family.{BuilderConfig}
use compiler.resolver.{MonoType, TypeId}
use compiler.opt.semantics.{OptimizerSemantics, CallSemantics}
use compiler.opt.uniqueness.{uniqueness_rewrite_with_semantics}

// ── Helpers ─────────────────────────────────────────────────────────

fn lid(id: Int) LocalId { LocalId.{ id: id } }
fn fid(id: Int) FuncId { FuncId.{ id: id } }
fn field(id: Int) FieldId { FieldId.{ id: id } }
fn tid(id: Int) TypeId { TypeId.{ id: id } }

// Mock FuncIds for testing
// COW ops
fn mock_vec_set() FuncId { fid(200) }
fn mock_vec_set_in_place() FuncId { fid(201) }
fn mock_dict_set() FuncId { fid(202) }
fn mock_dict_set_in_place() FuncId { fid(203) }
fn mock_vec_push() FuncId { fid(204) }
// Fresh producers
fn mock_vec_make() FuncId { fid(210) }
fn mock_dict_new() FuncId { fid(211) }
// Read-only
fn mock_vec_len() FuncId { fid(220) }
// Builder
fn mock_builder_new() FuncId { fid(230) }
fn mock_builder_from() FuncId { fid(231) }
fn mock_builder_push() FuncId { fid(232) }
fn mock_builder_freeze() FuncId { fid(233) }

fn mock_semantics() OptimizerSemantics {
  calls: Dict<Int, CallSemantics> = Dict.new()
  calls[mock_vec_set().id] = .{
    effect: .Update,
    fresh_result: false,
    cow_base_arg: .Some(0),
    in_place_equivalent: .Some(mock_vec_set_in_place()),
  }
  calls[mock_dict_set().id] = .{
    effect: .Update,
    fresh_result: false,
    cow_base_arg: .Some(0),
    in_place_equivalent: .Some(mock_dict_set_in_place()),
  }
  calls[mock_vec_push().id] = .{
    effect: .Update,
    fresh_result: false,
    cow_base_arg: .Some(0),
    in_place_equivalent: .None,
  }
  calls[mock_vec_make().id] = .{
    effect: .Allocate,
    fresh_result: true,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  calls[mock_dict_new().id] = .{
    effect: .Allocate,
    fresh_result: true,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  calls[mock_builder_new().id] = .{
    effect: .Allocate,
    fresh_result: true,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  calls[mock_builder_from().id] = .{
    effect: .Allocate,
    fresh_result: true,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  calls[mock_builder_push().id] = .{
    effect: .Update,
    fresh_result: false,
    cow_base_arg: .Some(0),
    in_place_equivalent: .None,
  }
  calls[mock_builder_freeze().id] = .{
    effect: .Allocate,
    fresh_result: true,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  calls[mock_vec_len().id] = .{
    effect: .ReadOnly,
    fresh_result: false,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }

  OptimizerSemantics.{
    call_semantics: calls,
    builder: BuilderConfig.{
      push_id: mock_vec_push(),
      builder_new_id: mock_builder_new(),
      builder_from_id: mock_builder_from(),
      builder_push_id: mock_builder_push(),
      builder_freeze_id: mock_builder_freeze(),
    },
  }
}

fn rewrite(func: AnfFunctionDef) AnfFunctionDef {
  uniqueness_rewrite_with_semantics(func, mock_semantics())
}

fn make_func(body: AnfExpr) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: fid(1),
    name: "test",
    params: [],
    op_result_mono: Dict.new(),
    body: body,
    return_ty: .Void,
  }
}

fn make_func_with_params(params: Vector<Param>, body: AnfExpr) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: fid(1),
    name: "test",
    params: params,
    op_result_mono: Dict.new(),
    body: body,
    return_ty: .Void,
  }
}

fn make_func_with_mono(body: AnfExpr, op_result_mono: Dict<Int, MonoType>) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: fid(1),
    name: "test",
    params: [],
    op_result_mono: op_result_mono,
    body: body,
    return_ty: .Void,
  }
}

// ── Phase 1: Tainted detection (params) ─────────────────────────────

fn test_params_tainted_no_rewrite() Result<Void, String> {
  // fn test(v: Vec) { let r = vec_set(v, 0, 42); Atom(r) }
  // Param v (local 0) is tainted → vec_set should NOT be rewritten
  body: AnfExpr = .Let(lid(1),
    .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
    .Atom(.ALocal(lid(1))))
  params: Vector<Param> = [Param.{ local: lid(0), ty: .Void }]
  func := make_func_with_params(params, body)
  result := rewrite(func)

  // Should still be MOCK_VEC_SET, not MOCK_VEC_SET_IN_PLACE
  case result.body {
    .Let(_, .ACall(.AGlobalFunc(f), _), _) => assert.int_eq(f.id, mock_vec_set().id),
    _ => .Err("expected ACall"),
  }
}

// ── Phase 1: Closure capture taints ─────────────────────────────────

fn test_closure_capture_taints() Result<Void, String> {
  // let v = vec_make(); let _ = make_closure(f, [v]); let r = vec_set(v, 0, 1); Atom(r)
  // v is captured by closure → tainted → no rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AMakeClosure(fid(99), [lid(0)]),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(1)]),
        .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  // Dig into: Let(0, ..., Let(1, ..., Let(2, ACall(...), ...)))
  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected nested Let with ACall"),
  }
}

// ── Phase 2: Fresh producer + unique → rewrite ──────────────────────

fn test_fresh_unique_rewrite() Result<Void, String> {
  // let v = vec_make(); let r = vec_set(v, 0, 42); Atom(r)
  // v is fresh (unique), v is dead after vec_set → rewrite to vec_set_in_place
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
      .Atom(.ALocal(lid(1)))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewritten to in_place"),
  }
}

fn test_fresh_unique_rewrite_with_semantics_entry() Result<Void, String> {
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
      .Atom(.ALocal(lid(1)))))
  func := make_func(body)
  result := uniqueness_rewrite_with_semantics(func, mock_semantics())

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected semantics entry point to rewrite to in_place"),
  }
}

// ── Phase 2: Array literal is fresh ─────────────────────────────────

fn test_array_lit_fresh() Result<Void, String> {
  // let v = [1, 2, 3]; let r = vec_set(v, 0, 99); Atom(r)
  // AArrayLit produces fresh value → unique → rewrite
  body: AnfExpr = .Let(lid(0),
    .AArrayLit([.ALitInt(1), .ALitInt(2), .ALitInt(3)]),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(99)]),
      .Atom(.ALocal(lid(1)))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewritten to in_place"),
  }
}

// ── Phase 2: Record literal is fresh ────────────────────────────────

fn test_record_fresh() Result<Void, String> {
  // let r = Record(tid, [f0: 1]); let r2 = ARecordUpdate(r, f0, 99, false, tid); Atom(r2)
  // ARecord produces fresh → unique → can_reuse_in_place = true
  body: AnfExpr = .Let(lid(0),
    .ARecord(tid(7), [FieldAtom.{ field: field(0), value: .ALitInt(1) }]),
    .Let(lid(1),
      .ARecordUpdate(.ALocal(lid(0)), field(0), .ALitInt(99), false, tid(7)),
      .Atom(.ALocal(lid(1)))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ARecordUpdate(_, _, _, can_reuse, _), _)) => {
      assert.is_true(can_reuse)
    },
    _ => .Err("expected ARecordUpdate with can_reuse"),
  }
}

// ── Phase 2: Base still live → no rewrite ───────────────────────────

fn test_base_live_no_rewrite() Result<Void, String> {
  // let v = vec_make(); let r = vec_set(v, 0, 42); let x = AInit(v); Atom(x)
  // v is still used after vec_set → NOT dead → no rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
      .Let(lid(2), .AInit(.ALocal(lid(0))), .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (base live)"),
  }
}

// ── Phase 2: AInit uniqueness transfer ──────────────────────────────

fn test_init_transfer() Result<Void, String> {
  // let v = vec_make(); let w = AInit(v); let r = vec_set(w, 0, 42); Atom(r)
  // v is fresh → unique. AInit transfers uniqueness to w. vec_set(w,...) should rewrite.
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AInit(.ALocal(lid(0))),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(1)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewritten after init transfer"),
  }
}

// ── Phase 2: Consume-reassign pattern ───────────────────────────────

fn test_consume_reassign() Result<Void, String> {
  // let v = vec_make()
  // let r = vec_set(v, 0, 42)
  // let _ = AAssign(v, r)
  // let r2 = vec_set(v, 1, 99)
  // Atom(r2)
  // v is fresh, vec_set consumes v and reassigns → both should rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
      .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))),
        .Let(lid(3),
          .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(1), .ALitInt(99)]),
          .Atom(.ALocal(lid(3)))))))
  func := make_func(body)
  result := rewrite(func)

  // First vec_set should be rewritten (consume-reassign: v dead because immediately reassigned)
  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f1), _),
      .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f2), _), _)))) => {
      try assert.int_eq(f1.id, mock_vec_set_in_place().id)
      assert.int_eq(f2.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected both vec_set rewritten"),
  }
}

// ── Phase 2: Non-COW call taints args ───────────────────────────────

fn test_non_cow_call_taints() Result<Void, String> {
  // let v = vec_make(); let _ = some_func(v); let r = vec_set(v, 0, 42); Atom(r)
  // v passed to unknown function → tainted → no rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .ACall(.AGlobalFunc(fid(999)), [.ALocal(lid(0))]),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (tainted by non-COW call)"),
  }
}

// ── Phase 2: Read-only call does not taint ──────────────────────────

fn test_read_only_no_taint() Result<Void, String> {
  // let v = vec_make(); let _ = vec_len(v); let r = vec_set(v, 0, 42); Atom(r)
  // vec_len is read-only → v stays unique → rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .ACall(.AGlobalFunc(mock_vec_len()), [.ALocal(lid(0))]),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewrite (read-only doesn't taint)"),
  }
}

// ── Phase 2: COW op base arg not tainted ────────────────────────────

fn test_cow_base_arg_not_tainted() Result<Void, String> {
  // let v = vec_make(); let r = vec_set(v, 0, 42); Atom(r)
  // base arg (v) in a COW op should NOT be tainted by the call itself
  // (already covered by fresh_unique_rewrite, but explicit)
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
      .Atom(.ALocal(lid(1)))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewrite (COW base not tainted)"),
  }
}

// ── Phase 2: Stored in container taints ─────────────────────────────

fn test_stored_in_array_taints() Result<Void, String> {
  // let v = vec_make(); let _ = [v]; let r = vec_set(v, 0, 42); Atom(r)
  // v stored in array → tainted → no rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AArrayLit([.ALocal(lid(0))]),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (stored in array)"),
  }
}

// ── Phase 2: Variant literal is fresh ───────────────────────────────

fn test_variant_fresh() Result<Void, String> {
  // let v = Variant(tid, vid, [1]); — fresh
  // (Variant itself is fresh, just verifying the uniqueness tracking doesn't crash)
  body: AnfExpr = .Let(lid(0),
    .AVariant(tid(7), VariantId.{ id: 0 }, [.ALitInt(1)]),
    .Atom(.ALocal(lid(0))))
  func := make_func(body)
  result := rewrite(func)
  // No crash, body unchanged
  case result.body {
    .Let(_, .AVariant(_, _, _), _) => .Ok({}),
    _ => .Err("expected AVariant preserved"),
  }
}

// ── Phase 2: Branches conservative ──────────────────────────────────

fn test_branches_conservative() Result<Void, String> {
  // Uniqueness created inside a branch should NOT leak to the continuation.
  // let _ = if(cond,
  //   { let v = vec_make(); Atom(ALocal(v)) },   // v is unique inside this branch
  //   Atom(ALitVoid))
  // The result is bound to local 5. But even though the then branch produces a fresh
  // value, at the join point we can't know which branch ran.
  // Here we just test that the inner branch vec_make → vec_set rewrites correctly
  // while loops correctly don't propagate uniqueness.
  //
  // Test: uniqueness from outer scope IS preserved after branches (no consumption).
  // let v = vec_make()
  // let _ = if(cond, Atom(void), Atom(void))  // branches don't touch v
  // let r = vec_set(v, 0, 42)
  // Atom(r)
  // v was unique before the if, branches didn't consume it → still unique after
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .AIf(.ALitBool(true), .Atom(.ALitVoid), .Atom(.ALitVoid)),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(2))))))
  func := make_func(body)
  result := rewrite(func)

  // v is still unique after the harmless branch → should rewrite
  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewrite (unique preserved across harmless branch)"),
  }
}

// ── Phase 3: Loop accumulator pattern → builder ─────────────────────

fn test_loop_accumulator_rewrite() Result<Void, String> {
  // let v = AArrayLit([])   // fresh, empty
  // let _ = ALoop(
  //   let tmp = vec_push(v, 1)
  //   let _ = AAssign(v, tmp)
  //   Continue
  // )
  // Atom(v)
  //
  // After rewrite:
  // Let(0, AArrayLit([]),
  //   Let(builder, builder_new(),
  //     Let(3, Loop(rewritten),
  //       Let(freeze, freeze(builder),
  //         Let(assign, Assign(0, freeze), Atom(ALocal(0)))))))
  loop_body: AnfExpr = .Let(lid(1),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))),
      .Continue))
  body: AnfExpr = .Let(lid(0),
    .AArrayLit([]),
    .Let(lid(3), .ALoop(loop_body),
      .Atom(.ALocal(lid(0)))))
  func := make_func(body)
  result := rewrite(func)

  // Check: Let(0, AArrayLit, Let(builder, Call(builder_new, []), ...))
  case result.body {
    .Let(_, .AArrayLit(_), .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_builder_new().id)
    },
    _ => .Err("expected builder_new call after array lit"),
  }
}

// ── Phase 3: Non-empty accumulator uses builder_from ────────────────

fn test_loop_accumulator_from() Result<Void, String> {
  // let v = vec_make()   // fresh but NOT empty (came from vec_make, not AArrayLit([]))
  // let _ = ALoop(
  //   let tmp = vec_push(v, 1)
  //   let _ = AAssign(v, tmp)
  //   Continue
  // )
  // Atom(v)
  //
  // Should use builder_from (not builder_new) since v is not known empty
  loop_body: AnfExpr = .Let(lid(1),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))),
      .Continue))
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(3), .ALoop(loop_body),
      .Atom(.ALocal(lid(0)))))
  func := make_func(body)
  result := rewrite(func)

  // Check: Let(0, Call(vec_make), Let(builder, Call(builder_from, [ALocal(0)]), ...))
  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_builder_from().id)
    },
    _ => .Err("expected builder_from call"),
  }
}

// ── Phase 2: Dict set rewrite ───────────────────────────────────────

fn test_dict_set_rewrite() Result<Void, String> {
  // let d = dict_new(); let r = dict_set(d, key, val); Atom(r)
  // d is fresh → unique → rewrite to dict_set_in_place
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_dict_new()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_dict_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
      .Atom(.ALocal(lid(1)))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)) => {
      assert.int_eq(f.id, mock_dict_set_in_place().id)
    },
    _ => .Err("expected dict_set rewritten to in_place"),
  }
}

// ── Phase 2: AAssign uniqueness transfer ────────────────────────────

fn test_assign_transfer() Result<Void, String> {
  // let v = AInit(0)  // not unique (literal)
  // let fresh = vec_make()  // fresh → unique
  // let _ = AAssign(v, fresh)  // transfer uniqueness from fresh to v
  // let r = vec_set(v, 0, 42)
  // Atom(r)
  body: AnfExpr = .Let(lid(0), .AInit(.ALitInt(0)),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_make()), []),
      .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))),
        .Let(lid(3),
          .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
          .Atom(.ALocal(lid(3)))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)))) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewrite after assign transfer"),
  }
}

// ── Phase 2: Alias taints when source still live ────────────────────

fn test_alias_taints() Result<Void, String> {
  // let v = vec_make(); let w = AInit(v); let r = vec_set(v, 0, 42); let _ = AInit(w); Atom(_)
  // w = v creates alias; v is still live (used in vec_set AND w is used after)
  // Actually: the key is v is aliased (w = v means two names for same value)
  // → v should be tainted → no rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AInit(.ALocal(lid(0))),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Let(lid(3), .AInit(.ALocal(lid(1))),
          .Atom(.ALocal(lid(3)))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (aliased)"),
  }
}

// ── Correctness: AAssign alias taint ─────────────────────────────────

fn test_assign_alias_taints() Result<Void, String> {
  // let v = vec_make()
  // let w = AInit(0)         // w is some mutable local
  // let _ = AAssign(w, v)    // w = v — creates alias through reassignment
  // let r = vec_set(v, 0, 42)
  // let _ = AInit(w)         // w is still used → v is aliased
  // Atom(_)
  //
  // v is aliased via AAssign(w, v) because w is still live → v tainted → no rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AInit(.ALitInt(0)),
      .Let(lid(5), .AAssign(lid(1), .ALocal(lid(0))),
        .Let(lid(2),
          .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
          .Let(lid(3), .AInit(.ALocal(lid(1))),
            .Atom(.ALocal(lid(3))))))))
  func := make_func(body)
  result := rewrite(func)

  // vec_set should NOT be rewritten because v is aliased through w
  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (assign alias)"),
  }
}

// ── Correctness: Branch-boundary alias escape ───────────────────────

fn test_branch_boundary_alias_escape() Result<Void, String> {
  // let x = vec_make()    // fresh, unique
  // let _ = if(cond,
  //   { let y = AInit(x); let _ = AMakeClosure(f, [y]); Atom(void) },
  //   Atom(void))
  // let r = vec_set(x, 0, 42)
  // Atom(r)
  //
  // Inside the then branch: y = x (alias), y is captured by closure → y tainted.
  // x is live-out of the branch (used in vec_set after) → x should be tainted
  // via branch-boundary alias escape. vec_set should NOT rewrite.
  then_branch: AnfExpr = .Let(lid(1), .AInit(.ALocal(lid(0))),
    .Let(lid(2), .AMakeClosure(fid(99), [lid(1)]),
      .Atom(.ALitVoid)))
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(3),
      .AIf(.ALitBool(true), then_branch, .Atom(.ALitVoid)),
      .Let(lid(4),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
        .Atom(.ALocal(lid(4))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (branch-boundary alias escape)"),
  }
}

// ── Correctness: AAssign alias across branch boundary ───────────────

fn test_assign_alias_cross_scope() Result<Void, String> {
  // let v = vec_make()
  // let w = AInit(0)
  // let _ = if(cond,
  //   { let _ = AAssign(w, v); Atom(void) },   // alias v→w in branch
  //   Atom(void))
  // let r = vec_set(v, 0, 42)
  // let _ = AInit(w)    // w used after → v aliased across scope
  // Atom(_)
  //
  // AAssign(w, v) in a branch, v still live after branch → v tainted → no rewrite
  then_branch: AnfExpr = .Let(lid(5), .AAssign(lid(1), .ALocal(lid(0))),
    .Atom(.ALitVoid))
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AInit(.ALitInt(0)),
      .Let(lid(3),
        .AIf(.ALitBool(true), then_branch, .Atom(.ALitVoid)),
        .Let(lid(4),
          .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
          .Let(lid(6), .AInit(.ALocal(lid(1))),
            .Atom(.ALocal(lid(6))))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (assign alias across scope)"),
  }
}

// ── AAssign alias: source dead after assign → NOT tainted (safe) ────

fn test_assign_alias_source_dead_ok() Result<Void, String> {
  // let v = vec_make()
  // let w = AInit(0)
  // let _ = AAssign(w, v)    // w = v
  // let r = vec_set(w, 0, 42)
  // Atom(r)
  //
  // After AAssign(w, v), v is NOT used again. w is the only name.
  // So v is NOT aliased (source dead) → w gets uniqueness via transfer → rewrite
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AInit(.ALitInt(0)),
      .Let(lid(5), .AAssign(lid(1), .ALocal(lid(0))),
        .Let(lid(2),
          .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(1)), .ALitInt(0), .ALitInt(42)]),
          .Atom(.ALocal(lid(2)))))))
  func := make_func(body)
  result := rewrite(func)

  // w is unique (transferred from v) → vec_set should rewrite
  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)))) => {
      assert.int_eq(f.id, mock_vec_set_in_place().id)
    },
    _ => .Err("expected rewrite (source dead after assign)"),
  }
}

// ── AAssign alias: multiple assigns chain ───────────────────────────

fn test_assign_chain_taint() Result<Void, String> {
  // let v = vec_make()
  // let w = AInit(0)
  // let x = AInit(0)
  // let _ = AAssign(w, v)    // w = v
  // let _ = AAssign(x, w)    // x = w (= v)
  // let r = vec_set(v, 0, 42)
  // let _ = AInit(x)          // x is used → w is aliased → v is aliased
  // Atom(_)
  //
  // Chain: v → w → x. x is still live → v should be tainted
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .AInit(.ALitInt(0)),
      .Let(lid(7), .AInit(.ALitInt(0)),
        .Let(lid(5), .AAssign(lid(1), .ALocal(lid(0))),
          .Let(lid(6), .AAssign(lid(7), .ALocal(lid(1))),
            .Let(lid(2),
              .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(42)]),
              .Let(lid(3), .AInit(.ALocal(lid(7))),
                .Atom(.ALocal(lid(3))))))))))
  func := make_func(body)
  result := rewrite(func)

  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)))))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (chain alias)"),
  }
}

