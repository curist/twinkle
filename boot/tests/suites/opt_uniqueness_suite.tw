// ── COW non-base arg IS tainted ─────────────────────────────────────

fn test_cow_non_base_arg_tainted() Result<Void, String> {
  // let v = vec_make()   // fresh
  // let w = vec_make()   // fresh
  // let r = vec_set(v, 0, w)  // w is non-base arg in cow op → w tainted
  // let r2 = vec_set(w, 0, 1) // w tainted → no rewrite
  // Atom(r2)
  //
  // v is base (arg 0), w is value (arg 2, non-base) → w gets tainted
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1),
      .ACall(.AGlobalFunc(mock_vec_make()), []),
      .Let(lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALocal(lid(1))]),
        .Let(lid(3),
          .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(1)), .ALitInt(0), .ALitInt(1)]),
          .Atom(.ALocal(lid(3)))))))
  func := make_func(body)
  result := rewrite(func)

  // The second vec_set(w, ...) should NOT be rewritten because w was tainted
  // as a non-base arg in the first vec_set
  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, _, .Let(_, .ACall(.AGlobalFunc(f), _), _)))) => {
      assert.int_eq(f.id, mock_vec_set().id)
    },
    _ => .Err("expected no rewrite (non-base arg tainted)"),
  }
}

// ── Loop: unique but tainted → no builder rewrite ───────────────────

fn test_loop_tainted_no_rewrite() Result<Void, String> {
  // let v = vec_make()
  // let _ = some_func(v)    // taints v
  // let _ = ALoop(
  //   let tmp = vec_push(v, 1)
  //   let _ = AAssign(v, tmp)
  //   Continue)
  // Atom(v)
  //
  // v is tainted → loop region rewrite should NOT fire
  loop_body: AnfExpr = .Let(lid(2),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(3), .AAssign(lid(0), .ALocal(lid(2))),
      .Continue))
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(1), .ACall(.AGlobalFunc(fid(999)), [.ALocal(lid(0))]),
      .Let(lid(4), .ALoop(loop_body),
        .Atom(.ALocal(lid(0))))))
  func := make_func(body)
  result := rewrite(func)

  // Should still have ALoop, no builder wrapping
  case result.body {
    .Let(_, _, .Let(_, _, .Let(_, .ALoop(_), _))) => .Ok({}),
    _ => .Err("expected ALoop preserved (tainted)"),
  }
}

