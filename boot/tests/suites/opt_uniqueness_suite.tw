  }
}

// ── Branch-boundary: alias in branch but source NOT live-out → safe ─

fn test_branch_alias_source_not_live_out() Result<Void, String> {
  // let x = vec_make()
  // let _ = if(cond,
  //   { let y = AInit(x); let _ = AMakeClosure(f, [y]); Atom(void) },
  //   Atom(void))
  // Atom(ALitVoid)
  //
  // x is NOT used after the if → x is NOT live-out → no boundary escape.
  // The alias+capture happens but x dies → should not taint x for
  // operations before the if (there are none, but this verifies no crash/false-taint).
  then_branch: AnfExpr = .Let(lid(1), .AInit(.ALocal(lid(0))),
    .Let(lid(2), .AMakeClosure(fid(99), [lid(1)]),
      .Atom(.ALitVoid)))
  body: AnfExpr = .Let(lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(lid(3),
      .AIf(.ALitBool(true), then_branch, .Atom(.ALitVoid)),
      .Atom(.ALitVoid)))
  func := make_func(body)
  // Should not crash. x is not used after if, so no observable taint effect.
  result := rewrite(func)
  case result.body {
    .Let(_, _, _) => .Ok({}),
    _ => .Err("expected Let preserved"),
  }
}

