// Tests for boot/compiler/backend/prepare.tw — Phase 4a.
//
// Verifies that prepare_backend() absorbs boundary insertion: the returned
// PreparedModule.anf contains post-boundary ANF (AWrapAnyref/AUnwrapAnyref
// nodes present where needed), and slot maps in PreparedModule.funcs include
// boundary temporaries allocated during insertion.
//
// Phase 4a exit criteria covered here:
//   - boundary insertion has an explicit architectural home (inside prepare_backend)
//   - prepared backend IR has an explicit representation-transition story
//   - slot maps reflect post-boundary locals including wrap/unwrap temporaries

use tests.runner
use tests.assert
use compiler.resolver
use compiler.resolver.{MonoType, ResolvedEnv}
use compiler.core_ir.{LocalId, FuncId, Param}
use compiler.builtins.{BuiltinRegistry}
use compiler.anf.{AnfExpr, AnfOp, AnfFunctionDef, AnfModule, Atom}
use compiler.codegen.wasm_ir.{ValType, AbiContract}
use compiler.codegen.wasm_layout.{layout_of, mono_to_key}
use compiler.codegen.wasm_plan_types.{WasmTypeRegistry}
use compiler.backend.prepared_ir.{CaptureParam, SlotRole}
use compiler.backend.prepare.{prepare_backend}

// ── Construction helpers ─────────────────────────────────────────────

fn lid(n: Int) LocalId { LocalId.{ id: n } }
fn fid(n: Int) FuncId { FuncId.{ id: n } }

fn empty_env() ResolvedEnv { resolver.empty_env() }

fn empty_registry() WasmTypeRegistry {
  WasmTypeRegistry.{
    type_defs: [],
    layout_cache: Dict.new(),
    in_progress: Dict.new(),
    type_index: Dict.new(),
    concrete_func_sigs: Dict.new(),
    capture_layouts: Dict.new(),
    module_globals: Dict.new(),
    module_globals_order: [],
    string_pool: Dict.new(),
    string_pool_order: [],
    runtime_imports: [],
  }
}

fn registry_with_layouts(types: Vector<MonoType>) WasmTypeRegistry {
  reg := empty_registry()
  env := empty_env()
  for ty in types {
    key := mono_to_key(ty)
    reg.layout_cache[key] = layout_of(ty, env)
  }
  reg
}

fn empty_builtins() BuiltinRegistry {
  BuiltinRegistry.{ by_name: Dict.new(), by_id: Dict.new(), by_canonical: Dict.new(), entries: [], next_id: 100 }
}

fn no_captures() Dict<Int, Vector<CaptureParam>> { Dict.new() }

fn mk_param(id: Int, ty: MonoType) Param {
  Param.{ local: lid(id), ty: ty }
}

fn mk_mono_map(entries: Vector<Int>, types: Vector<MonoType>) Dict<Int, MonoType> {
  d: Dict<Int, MonoType> = Dict.new()
  for k,i in entries { d[k] = types[i] }
  d
}

fn mk_func_def(
  id: Int,
  name: String,
  params: Vector<Param>,
  ret: MonoType,
  body: AnfExpr,
  mono_map: Dict<Int, MonoType>,
) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: fid(id),
    name: name,
    params: params,
    op_result_mono: mono_map,
    body: body,
    return_ty: ret,
  }
}

fn mk_module(funcs: Vector<AnfFunctionDef>) AnfModule {
  AnfModule.{ functions: funcs, init_func_id: .None }
}

fn mk_abi(params: Vector<ValType>, results: Vector<ValType>) AbiContract {
  AbiContract.{ param_types: params, result_types: results }
}

// ── ANF inspection helpers ───────────────────────────────────────────

fn count_wraps_expr(expr: AnfExpr) Int {
  case expr {
    .Let(_, op, body) => count_wraps_op(op) + count_wraps_expr(body),
    _ => 0,
  }
}

fn count_wraps_op(op: AnfOp) Int {
  case op {
    .AWrapAnyref(_, _) => 1,
    .AIf(_, then_e, else_e) => count_wraps_expr(then_e) + count_wraps_expr(else_e),
    .AMatch(_, arms) => {
      s := 0
      for arm in arms { s = s + count_wraps_expr(arm.body) }
      s
    },
    .ALoop(inner) => count_wraps_expr(inner),
    _ => 0,
  }
}

fn count_unwraps_expr(expr: AnfExpr) Int {
  case expr {
    .Let(_, op, body) => count_unwraps_op(op) + count_unwraps_expr(body),
    _ => 0,
  }
}

fn count_unwraps_op(op: AnfOp) Int {
  case op {
    .AUnwrapAnyref(_, _) => 1,
    .AIf(_, then_e, else_e) => count_unwraps_expr(then_e) + count_unwraps_expr(else_e),
    .AMatch(_, arms) => {
      s := 0
      for arm in arms { s = s + count_unwraps_expr(arm.body) }
      s
    },
    .ALoop(inner) => count_unwraps_expr(inner),
    _ => 0,
  }
}

// Collect all LocalIds that are let-bound (including boundary temps).
fn collect_let_lids_expr(expr: AnfExpr) Vector<Int> {
  case expr {
    .Let(local, _, body) => [local.id].concat(collect_let_lids_expr(body)),
    _ => [],
  }
}

// ── Tests ────────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("backend prepare (Phase 4a)")

  // ── No-boundary pass-through ──

  .test("user function with no ABI calls: no boundaries inserted", fn() {
    // fn f(x: Int) Int { let t0 = call(user_fn#99, [x]); t0 }
    // User functions have no ABI contracts, so no wraps/unwraps.
    body: AnfExpr = .Let(lid(10),
      .ACall(.AGlobalFunc(fid(99)), [.ALocal(lid(0))]),
      .Atom(.ALocal(lid(10))))
    func := mk_func_def(1, "f", [mk_param(0, .Int)], .Int, body,
      mk_mono_map([10], [MonoType.Int]))
    anf := mk_module([func])

    prepared := prepare_backend(anf, empty_env(), empty_builtins(), no_captures())

    result_body := prepared.anf.functions[0].body
    try assert.int_eq(count_wraps_expr(result_body), 0)
    try assert.int_eq(count_unwraps_expr(result_body), 0)
    .Ok({})
  })

  .test("user function: param and let local appear in slot map", fn() {
    // fn f(x: Int) Int { let t0 = call(fn#99, [x]); t0 }
    // Slot 0: Param x, Slot 1: Local t0
    body: AnfExpr = .Let(lid(10),
      .ACall(.AGlobalFunc(fid(99)), [.ALocal(lid(0))]),
      .Atom(.ALocal(lid(10))))
    func := mk_func_def(1, "f", [mk_param(0, .Int)], .Int, body,
      mk_mono_map([10], [MonoType.Int]))
    anf := mk_module([func])

    prepared := prepare_backend(anf, empty_env(), empty_builtins(), no_captures())

    pf := prepared.funcs[0]
    try assert.int_eq(pf.params.len(), 1)
    try assert.int_eq(pf.locals.len(), 1)
    // L0 → slot 0 (Param), L10 → slot 1 (Local)
    case pf.local_to_slot[0] {
      .None => { return .Err("L0 has no slot") },
      .Some(s) => try assert.int_eq(s.id, 0),
    }
    case pf.local_to_slot[10] {
      .None => { return .Err("L10 has no slot") },
      .Some(s) => try assert.int_eq(s.id, 1),
    }
    .Ok({})
  })

  // ── Wrap temporary included in slot map ──

  .test("wrap temporary allocated by boundary insertion has a slot", fn() {
    // fn f(x: Int) String { let t0 = builtin(x); t0 }
    // Builtin ABI: (anyref) → (anyref). x is Int (i64) → needs wrap.
    // Boundary insertion allocates a fresh local for the wrapped Int.
    // That temporary must appear in the slot map.
    builtins := empty_builtins().runtime_with_abi(
      "box_it", "rt.test", "box_it", mk_abi([.Anyref], [.Anyref]))
    box_fid := builtins.id("box_it")

    body: AnfExpr = .Let(lid(10),
      .ACall(.AGlobalFunc(box_fid), [.ALocal(lid(0))]),
      .Atom(.ALocal(lid(10))))
    func := mk_func_def(1, "f", [mk_param(0, .Int)], .String, body,
      mk_mono_map([10], [MonoType.String]))
    anf := mk_module([func])

    prepared := prepare_backend(anf, empty_env(), builtins, no_captures())

    // Boundary insertion should have added one AWrapAnyref for the Int arg
    result_body := prepared.anf.functions[0].body
    try assert.int_eq(count_wraps_expr(result_body), 1)

    // The wrap temp local must be in the slot map
    all_lids := collect_let_lids_expr(result_body)
    // all_lids includes the wrap temp (allocated at next_local = 11) and t0
    pf := prepared.funcs[0]
    for l in all_lids {
      case pf.local_to_slot[l] {
        .None => { return .Err("let-bound local L${l} missing from slot map") },
        .Some(_) => {},
      }
    }
    .Ok({})
  })

  .test("slot count includes wrap temporary", fn() {
    // Same setup as above: 1 param + 1 result local + 1 wrap temp = 3 total slots
    builtins := empty_builtins().runtime_with_abi(
      "box_it", "rt.test", "box_it", mk_abi([.Anyref], [.Anyref]))
    box_fid := builtins.id("box_it")

    body: AnfExpr = .Let(lid(10),
      .ACall(.AGlobalFunc(box_fid), [.ALocal(lid(0))]),
      .Atom(.ALocal(lid(10))))
    func := mk_func_def(1, "f", [mk_param(0, .Int)], .String, body,
      mk_mono_map([10], [MonoType.String]))
    anf := mk_module([func])

    prepared := prepare_backend(anf, empty_env(), builtins, no_captures())

    pf := prepared.funcs[0]
    total_slots := pf.captures.len() + pf.params.len() + pf.locals.len()
    // 0 captures + 1 param (x) + 3 locals: wrap temp (Int→anyref), raw call result (anyref),
    // t0 unwrap target (anyref→String, since String is a typed ref not anyref-exact) = 4
    try assert.int_eq(total_slots, 4)
    .Ok({})
  })

  // ── Unwrap temporary included in slot map ──

  .test("unwrap temporary allocated by boundary insertion has a slot", fn() {
    // fn f(x: String) Int { let t0 = builtin(x); t0 }
    // Builtin ABI: (anyref) → (anyref), result mono = Int → needs unwrap.
    // Boundary insertion: raw_local = call(builtin, x); t0 = AUnwrapAnyref(raw_local, Int).
    // raw_local must appear in slot map.
    builtins := empty_builtins().runtime_with_abi(
      "unbox_it", "rt.test", "unbox_it", mk_abi([.Anyref], [.Anyref]))
    unbox_fid := builtins.id("unbox_it")

    body: AnfExpr = .Let(lid(10),
      .ACall(.AGlobalFunc(unbox_fid), [.ALocal(lid(0))]),
      .Atom(.ALocal(lid(10))))
    func := mk_func_def(1, "f", [mk_param(0, .String)], .Int, body,
      mk_mono_map([10], [MonoType.Int]))
    anf := mk_module([func])

    prepared := prepare_backend(anf, empty_env(), builtins, no_captures())

    result_body := prepared.anf.functions[0].body
    try assert.int_eq(count_unwraps_expr(result_body), 1)

    all_lids := collect_let_lids_expr(result_body)
    pf := prepared.funcs[0]
    for l in all_lids {
      case pf.local_to_slot[l] {
        .None => { return .Err("let-bound local L${l} missing from slot map after unwrap insertion") },
        .Some(_) => {},
      }
    }
    .Ok({})
  })

  // ── PreparedModule.anf is post-boundary ──

  .test("prepared.anf holds post-boundary ANF, not pre-boundary", fn() {
    // Before Phase 4a, the old prepare_backend() stored pre-boundary ANF.
    // Now it must store post-boundary ANF (boundaries already inserted).
    // Verify: if the builtin call needs a wrap, the boundary node is in prepared.anf.
    builtins := empty_builtins().runtime_with_abi(
      "store_int", "rt.test", "store", mk_abi([.Anyref], [.Anyref]))
    store_fid := builtins.id("store_int")

    body: AnfExpr = .Let(lid(5),
      .ACall(.AGlobalFunc(store_fid), [.ALocal(lid(0))]),
      .Atom(.ALitVoid))
    func := mk_func_def(1, "g", [mk_param(0, .Int)], .Void, body,
      mk_mono_map([5], [MonoType.Void]))
    anf := mk_module([func])

    prepared := prepare_backend(anf, empty_env(), builtins, no_captures())

    // prepared.anf should show the boundary node
    try assert.int_eq(count_wraps_expr(prepared.anf.functions[0].body), 1)
    // The pre-boundary anf (original) has no wrap
    try assert.int_eq(count_wraps_expr(anf.functions[0].body), 0)
    .Ok({})
  })

  // ── Closure captures preserved ──

  .test("closure_captures from caller are stored in PreparedModule", fn() {
    // Verify that the caller-provided closure_captures map flows through
    // to PreparedModule.closure_captures unchanged.
    body: AnfExpr = .Atom(.ALitVoid)
    func := mk_func_def(1, "h", [], .Void, body, Dict.new())
    anf := mk_module([func])

    cap: CaptureParam = CaptureParam.{ local_id: lid(0), ty: .Int }
    captures: Dict<Int, Vector<CaptureParam>> = Dict.new()
    captures[42] = [cap]

    prepared := prepare_backend(anf, empty_env(), empty_builtins(), captures)

    case prepared.closure_captures[42] {
      .None => .Err("closure_captures not preserved in PreparedModule"),
      .Some(caps) => {
        try assert.int_eq(caps.len(), 1)
        try assert.int_eq(caps[0].local_id.id, 0)
        .Ok({})
      },
    }
  })
}
