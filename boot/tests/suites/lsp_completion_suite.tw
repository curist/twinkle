use lib.json
use lib.lsp.protocol
use lib.lsp.server_core
use tests.runner

fn publish_due_now(step: server_core.Step) server_core.Step {
  state := step.state
  state.diagnostics_deadline_ms = 0.0
  state.publish_due_diagnostics()
}

// Simulate editor flow: didOpen with valid source, let diagnostics warm the cache,
// didChange with completion source, then complete.
fn open_then_complete(valid_src: String, completion_src: String, line: Int, character: Int) server_core.Step {
  uri := "file:///a.tw"

  // didOpen with valid source to populate cache
  open_params := json.object([
    json.kv(
      "textDocument",
      json.object([
        json.kv("uri", .Str(uri)),
        json.kv("languageId", .Str("twinkle")),
        json.kv("version", .Int(1)),
        json.kv("text", .Str(valid_src)),
      ]),
    ),
  ])
  open_msg := protocol.Message.Notification(.{
    method: "textDocument/didOpen",
    params: .Some(open_params),
  })
  step1 := publish_due_now(server_core.initial_state().handle_message(open_msg))

  // didChange with incomplete source
  change_params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri)), json.kv("version", .Int(2))])),
    json.kv("contentChanges", json.array([json.object([json.kv("text", .Str(completion_src))])])),
  ])
  change_msg := protocol.Message.Notification(.{
    method: "textDocument/didChange",
    params: .Some(change_params),
  })
  step2 := step1.state.handle_message(change_msg)

  // completion request
  comp_params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri))])),
    json.kv(
      "position",
      json.object([json.kv("line", .Int(line)), json.kv("character", .Int(character))]),
    ),
  ])
  comp_msg := protocol.Message.Request(.{
    id: .IntId(1),
    method: "textDocument/completion",
    params: .Some(comp_params),
  })
  step2.state.handle_message(comp_msg)
}

fn open_change_publish_then_complete(
  valid_src: String,
  completion_src: String,
  line: Int,
  character: Int,
) server_core.Step {
  uri := "file:///a.tw"

  open_params := json.object([
    json.kv(
      "textDocument",
      json.object([
        json.kv("uri", .Str(uri)),
        json.kv("languageId", .Str("twinkle")),
        json.kv("version", .Int(1)),
        json.kv("text", .Str(valid_src)),
      ]),
    ),
  ])
  open_msg := protocol.Message.Notification(.{
    method: "textDocument/didOpen",
    params: .Some(open_params),
  })
  step1 := publish_due_now(server_core.initial_state().handle_message(open_msg))

  change_params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri)), json.kv("version", .Int(2))])),
    json.kv("contentChanges", json.array([json.object([json.kv("text", .Str(completion_src))])])),
  ])
  change_msg := protocol.Message.Notification(.{
    method: "textDocument/didChange",
    params: .Some(change_params),
  })
  step2 := step1.state.handle_message(change_msg)

  // Force the debounced diagnostics pass to run before completion. This mirrors
  // editors that pause after typing an incomplete construct, then request
  // completion once diagnostics have already published.
  state := step2.state
  state.diagnostics_deadline_ms = 0.0
  published := state.publish_due_diagnostics()

  comp_params := json.object([
    json.kv("textDocument", json.object([json.kv("uri", .Str(uri))])),
    json.kv(
      "position",
      json.object([json.kv("line", .Int(line)), json.kv("character", .Int(character))]),
    ),
  ])
  comp_msg := protocol.Message.Request(.{
    id: .IntId(1),
    method: "textDocument/completion",
    params: .Some(comp_params),
  })
  published.state.handle_message(comp_msg)
}

fn completion_labels(step: server_core.Step) Vector<String>!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))
  items := case result {
    .Array(arr) => arr,
    _ => return .Err("expected array result"),
  }
  labels: Vector<String> = []

  for item in items {
    label := try item.decode(json.field("label", json.string()))
    labels = .append(label)
  }

  .Ok(labels)
}

fn has_label(labels: Vector<String>, target: String) Bool {
  for l in labels {
    if l == target {
      return true
    }
  }

  false
}

fn count_label(labels: Vector<String>, target: String) Int {
  n := 0
  for l in labels {
    if l == target {
      n = n + 1
    }
  }

  n
}

pub fn suite() runner.Suite {
  runner
    .suite("lsp completion")
    .test(
      "member completion on vector shows len",
      fn() {
        valid := "xs := [1, 2, 3]\nxs\n"
        incomplete := "xs := [1, 2, 3]\nxs.\n"
        step := open_then_complete(valid, incomplete, 1, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected 'len' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion on string shows len",
      fn() {
        valid := "s := \"hello\"\ns\n"
        incomplete := "s := \"hello\"\ns.\n"
        step := open_then_complete(valid, incomplete, 1, 2)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected 'len' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion on record shows fields",
      fn() {
        valid := "type Point = .{ x: Int, y: Int }\np := Point.{ x: 1, y: 2 }\np\n"
        incomplete := "type Point = .{ x: Int, y: Int }\np := Point.{ x: 1, y: 2 }\np.\n"
        step := open_then_complete(valid, incomplete, 2, 2)
        labels := try completion_labels(step)

        if !has_label(labels, "x") or !has_label(labels, "y") {
          return .Err("expected 'x' and 'y' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "variant completion in case shows scrutinee variants",
      fn() {
        valid := "type Color = { Red, Green, Blue }\nc := Color.Red\ncase c {\n  .Red => {},\n}\n"
        incomplete := "type Color = { Red, Green, Blue }\nc := Color.Red\ncase c {\n  .\n}\n"
        step := open_then_complete(valid, incomplete, 3, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "Red") or !has_label(labels, "Green") or !has_label(labels, "Blue") {
          return .Err("expected Red, Green, Blue in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "variant completion excludes already matched arms",
      fn() {
        valid := "type Color = { Red, Green, Blue }\nc := Color.Red\ncase c {\n  .Red => {},\n  .Green => {},\n}\n"
        incomplete := "type Color = { Red, Green, Blue }\nc := Color.Red\ncase c {\n  .Red => {},\n  .\n}\n"
        step := open_then_complete(valid, incomplete, 4, 3)
        labels := try completion_labels(step)

        if has_label(labels, "Red") {
          return .Err("expected 'Red' to be excluded, got: ${labels}")
        }

        if !has_label(labels, "Green") or !has_label(labels, "Blue") {
          return .Err("expected Green, Blue in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "variant completion for Option shows Some and None",
      fn() {
        valid := "x: Int? = .Some(1)\ncase x {\n  .Some(v) => {},\n}\n"
        incomplete := "x: Int? = .Some(1)\ncase x {\n  .\n}\n"
        step := open_then_complete(valid, incomplete, 2, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "Some") or !has_label(labels, "None") {
          return .Err("expected Some, None in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "variant completion for Option excludes matched",
      fn() {
        valid := "x: Int? = .Some(1)\ncase x {\n  .Some(v) => {},\n  .None => {},\n}\n"
        incomplete := "x: Int? = .Some(1)\ncase x {\n  .Some(v) => {},\n  .\n}\n"
        step := open_then_complete(valid, incomplete, 3, 3)
        labels := try completion_labels(step)

        if has_label(labels, "Some") {
          return .Err("expected 'Some' to be excluded, got: ${labels}")
        }

        if !has_label(labels, "None") {
          return .Err("expected 'None' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "general completion includes keywords",
      fn() {
        valid := "fn foo() Void {\n  1\n}\n"
        incomplete := "fn foo() Void {\n  \n}\n"
        step := open_then_complete(valid, incomplete, 1, 2)
        labels := try completion_labels(step)

        if !has_label(labels, "if") or !has_label(labels, "for") or !has_label(labels, "case") {
          return .Err("expected keywords in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "local variable appears in completions",
      fn() {
        valid := "fn foo() Int {\n  x := 42\n  x\n}\n"
        incomplete := "fn foo() Int {\n  x := 42\n  \n}\n"
        step := open_then_complete(valid, incomplete, 2, 2)
        labels := try completion_labels(step)

        if !has_label(labels, "x") {
          return .Err("expected local 'x' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "function parameter appears in completions",
      fn() {
        valid := "fn greet(name: String) String {\n  name\n}\n"
        incomplete := "fn greet(name: String) String {\n  \n}\n"
        step := open_then_complete(valid, incomplete, 1, 2)
        labels := try completion_labels(step)

        if !has_label(labels, "name") {
          return .Err("expected parameter 'name' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "multiple locals and params in completions",
      fn() {
        valid := "fn add(a: Int, b: Int) Int {\n  sum := a + b\n  sum\n}\n"
        incomplete := "fn add(a: Int, b: Int) Int {\n  sum := a + b\n  \n}\n"
        step := open_then_complete(valid, incomplete, 2, 2)
        labels := try completion_labels(step)

        if !has_label(labels, "a") or !has_label(labels, "b") or !has_label(labels, "sum") {
          return .Err("expected 'a', 'b', 'sum' in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "local variable member completion",
      fn() {
        valid := "fn foo() Int {\n  xs := [1, 2, 3]\n  xs.len()\n}\n"
        incomplete := "fn foo() Int {\n  xs := [1, 2, 3]\n  xs.\n}\n"
        step := open_then_complete(valid, incomplete, 2, 5)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected 'len' in member completions for local, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion across line boundary",
      fn() {
        // When user types `xs.` at end of line with code on next line,
        // the parser without cursor-hole merges `xs.` with `result` into `xs.result`.
        // Cursor-hole re-parsing should prevent this.
        valid := "xs := [1, 2, 3]\nresult := xs.len()\n"
        incomplete := "xs := [1, 2, 3]\nxs.\nresult := xs.len()\n"
        step := open_then_complete(valid, incomplete, 1, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected 'len' in cross-line member completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion with diverged expression IDs",
      fn() {
        // Extra statements before the cursor shift expression IDs so the
        // stale type_map entries no longer align with the current AST nodes.
        valid := "xs := [1, 2, 3]\nxs.len()\n"
        incomplete := "xs := [1, 2, 3]\na := 1\nxs.\n"
        step := open_then_complete(valid, incomplete, 2, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected 'len' with diverged IDs, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion after method call uses call result type",
      fn() {
        valid := "type Checksum = .{ bytes: String }\nfn to_string(c: Checksum) String { c.bytes }\nfn part() Void {\n  checksum := Checksum.{ bytes: \"abc\" }\n  checksum.to_string().len()\n}\n"
        incomplete := "type Checksum = .{ bytes: String }\nfn to_string(c: Checksum) String { c.bytes }\nfn part() Void {\n  checksum := Checksum.{ bytes: \"abc\" }\n  checksum.to_string().\n}\n"
        step := open_then_complete(valid, incomplete, 4, 23)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected String completions after method call, got: ${labels}")
        }

        if has_label(labels, "bytes") {
          return .Err("expected method-call receiver, not original checksum, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion after field access uses field type",
      fn() {
        valid := "type Wrapper = .{ inner: String, bytes: Int }\nfn part() Void {\n  wrapper := Wrapper.{ inner: \"abc\", bytes: 1 }\n  wrapper.inner.len()\n}\n"
        incomplete := "type Wrapper = .{ inner: String, bytes: Int }\nfn part() Void {\n  wrapper := Wrapper.{ inner: \"abc\", bytes: 1 }\n  wrapper.inner.\n}\n"
        step := open_then_complete(valid, incomplete, 3, 16)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected String completions after field access, got: ${labels}")
        }

        if has_label(labels, "inner") or has_label(labels, "bytes") {
          return .Err("expected field receiver, not original wrapper, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "member completion still works after diagnostics publish",
      fn() {
        valid := "xs := [1, 2, 3]\nxs\n"
        incomplete := "xs := [1, 2, 3]\nxs.\n"
        step := open_change_publish_then_complete(valid, incomplete, 1, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "len") {
          return .Err("expected 'len' after diagnostics publish, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "import completion suggests stdlib modules after @std.",
      fn() {
        valid := "x := 1\n"
        incomplete := "use @std.\nx := 1\n"
        step := open_then_complete(valid, incomplete, 0, 9)
        labels := try completion_labels(step)

        if !has_label(labels, "path") or !has_label(labels, "fs") {
          return .Err("expected stdlib modules like 'path' and 'fs', got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "import completion does not duplicate modules backed by both file and dir",
      fn() {
        // `crypto`, `regexp`, and `tuple` each exist as both `<name>.tw` and a
        // `<name>/` submodule directory; completion should list each once.
        valid := "x := 1\n"
        incomplete := "use @std.\nx := 1\n"
        step := open_then_complete(valid, incomplete, 0, 9)
        labels := try completion_labels(step)

        for name in ["crypto", "regexp", "tuple"] {
          count := count_label(labels, name)
          if count != 1 {
            return .Err("expected '${name}' exactly once, got ${count}: ${labels}")
          }
        }

        .Ok({})
      },
    )
    .test(
      "import completion at bare use suggests @std",
      fn() {
        valid := "x := 1\n"
        incomplete := "use \nx := 1\n"
        step := open_then_complete(valid, incomplete, 0, 4)
        labels := try completion_labels(step)

        if !has_label(labels, "@std") {
          return .Err("expected '@std' in import completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion for io. in assignment",
      fn() {
        // `use @std.io` imports the io module; `foo := io.` should
        // complete with io's exported functions.
        valid := "use @std.io\nfoo := io.stdin_eof()\n"
        incomplete := "use @std.io\nfoo := io.\n"
        step := open_then_complete(valid, incomplete, 1, 10)
        labels := try completion_labels(step)

        if !has_label(labels, "read_stdin_chunk") {
          return .Err("expected 'read_stdin_chunk' in io module completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion for io. at top level",
      fn() {
        // Top-level `io.` (without assignment) should also trigger
        // module member completions.
        valid := "use @std.io\nio.stdin_eof()\n"
        incomplete := "use @std.io\nio.\n"
        step := open_then_complete(valid, incomplete, 1, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "stdin_eof") {
          return .Err("expected 'stdin_eof' in top-level io completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion does not continue previous import line",
      fn() {
        // The `io.` on the second line must be classified as member access, not
        // as a continuation of `use @std.io` from the first line.
        valid := "use @std.io\nio.stdin_eof()\n"
        incomplete := "use @std.io\nio.\n"
        step := open_then_complete(valid, incomplete, 1, 3)
        labels := try completion_labels(step)

        if !has_label(labels, "stdin_eof") {
          return .Err("expected io member completions after import line, got: ${labels}")
        }

        if has_label(labels, "fs") or has_label(labels, "path") {
          return .Err("expected member completions, not stdlib import completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion inside function body",
      fn() {
        valid := "use @std.io\nfn foo() Bool {\n  io.stdin_eof()\n}\n"
        incomplete := "use @std.io\nfn foo() Bool {\n  io.\n}\n"
        step := open_then_complete(valid, incomplete, 2, 5)
        labels := try completion_labels(step)

        if !has_label(labels, "stdin_eof") or !has_label(labels, "read_stdin_chunk") {
          return .Err("expected io functions in completions inside fn body, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion as function argument",
      fn() {
        valid := "use @std.io\nfn check(b: Bool) { }\ncheck(io.stdin_eof())\n"
        incomplete := "use @std.io\nfn check(b: Bool) { }\ncheck(io.)\n"
        step := open_then_complete(valid, incomplete, 2, 9)
        labels := try completion_labels(step)

        if !has_label(labels, "stdin_eof") {
          return .Err("expected io functions in fn argument context, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion for path module",
      fn() {
        valid := "use @std.path\nresult := path.is_absolute(\"/foo\")\n"
        incomplete := "use @std.path\nresult := path.\n"
        step := open_then_complete(valid, incomplete, 1, 15)
        labels := try completion_labels(step)

        if !has_label(labels, "is_absolute") or !has_label(labels, "join") {
          return .Err("expected path functions in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion includes pub value bindings",
      fn() {
        // `math.pi`/`math.e` are module-level `pub` value bindings, not
        // functions, so they must surface alongside the module's functions.
        valid := "use @std.math\nresult := math.abs(3)\n"
        incomplete := "use @std.math\nresult := math.\n"
        step := open_then_complete(valid, incomplete, 1, 15)
        labels := try completion_labels(step)

        if !has_label(labels, "pi") or !has_label(labels, "e") {
          return .Err("expected math value bindings 'pi' and 'e', got: ${labels}")
        }

        if !has_label(labels, "abs") {
          return .Err("expected math functions alongside values, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion with aliased import",
      fn() {
        valid := "use @std.path as p\nresult := p.is_absolute(\"/foo\")\n"
        incomplete := "use @std.path as p\nresult := p.\n"
        step := open_then_complete(valid, incomplete, 1, 12)
        labels := try completion_labels(step)

        if !has_label(labels, "is_absolute") or !has_label(labels, "join") {
          return .Err("expected path functions under alias 'p', got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion in if body",
      fn() {
        valid := "use @std.io\nif true {\n  io.stdin_eof()\n}\n"
        incomplete := "use @std.io\nif true {\n  io.\n}\n"
        step := open_then_complete(valid, incomplete, 2, 5)
        labels := try completion_labels(step)

        if !has_label(labels, "stdin_eof") {
          return .Err("expected io functions in if body, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion with partial identifier",
      fn() {
        // Typing `io.rea` should still trigger module member completions
        // since classify_context sees Ident after Dot and returns Member.
        valid := "use @std.io\nfoo := io.read_stdin_chunk(1024)\n"
        incomplete := "use @std.io\nfoo := io.rea\n"

        // Cursor after `rea`: line 1, col 13 → after the partial identifier
        step := open_then_complete(valid, incomplete, 1, 13)

        if step.outgoing.len() != 1 {
          return .Err("expected one outgoing message, got ${step.outgoing.len()}")
        }

        labels := try completion_labels(step)

        if !has_label(labels, "read_stdin_chunk") {
          return .Err("expected 'read_stdin_chunk' with partial 'rea', got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion with multiple imports",
      fn() {
        // Both io and path are imported; completing `io.` should show io
        // functions, not path functions.
        valid := "use @std.io\nuse @std.path\nfoo := io.stdin_eof()\n"
        incomplete := "use @std.io\nuse @std.path\nfoo := io.\n"
        step := open_then_complete(valid, incomplete, 2, 10)
        labels := try completion_labels(step)

        if !has_label(labels, "stdin_eof") {
          return .Err("expected io functions, got: ${labels}")
        }

        if has_label(labels, "is_absolute") {
          return .Err("should not contain path functions in io completions, got: ${labels}")
        }

        .Ok({})
      },
    )
    .test(
      "module member completion for fs module shows functions",
      fn() {
        valid := "use @std.fs\nresult := fs.read_text(\"a.txt\")\n"
        incomplete := "use @std.fs\nresult := fs.\n"
        step := open_then_complete(valid, incomplete, 1, 13)
        labels := try completion_labels(step)

        if !has_label(labels, "read_text") or !has_label(labels, "write_text") {
          return .Err("expected fs functions in completions, got: ${labels}")
        }

        .Ok({})
      },
    )
}
