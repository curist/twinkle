/// Phase 0 guardrail tests: lock the current behaviour of builtin_env() and
/// register_builtin_methods() before the signature-source-of-truth refactor.
///
/// These tests are meant to stay green throughout all phases so that any
/// unintended regression during the refactor is caught immediately.

use compiler.base_env.{builtin_env}
use compiler.resolver.{
  FunctionSig, lookup_function, lookup_function_origin, lookup_method, lookup_registered_function,
}
use tests.assert
use tests.runner

// â”€â”€ helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
fn require_sig(name: String) Result<FunctionSig, String> {
  case lookup_function(builtin_env(), name) {
    .Some(sig) => .Ok(sig),
    .None => .Err("builtin_env() missing function: ${name}"),
  }
}

fn require_registered_sig(name: String) Result<FunctionSig, String> {
  case lookup_registered_function(builtin_env(), name) {
    .Some(sig) => .Ok(sig),
    .None => .Err("builtin_env() missing registered function: ${name}"),
  }
}

fn require_method(type_name: String, method_name: String) Result<String, String> {
  case lookup_method(builtin_env(), type_name, method_name) {
    .Some(fn_name) => .Ok(fn_name),
    .None => .Err("builtin_env() missing method ${type_name}.${method_name}"),
  }
}

// â”€â”€ function signature presence â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
pub fn suite() runner.Suite {
  runner.suite("base_env guardrails")
    .test(
      "builtin_env has string$len",
      fn() {
        sig := try require_registered_sig("string$len")
        try assert.equal(sig.params.len(), 1)
        try assert.equal(sig.type_params.len(), 0)
        .Ok({})
      },
    )
    .test(
      "builtin_env has string$concat with two params",
      fn() {
        sig := try require_registered_sig("string$concat")
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has string$get returning Option<Byte>",
      fn() {
        sig := try require_registered_sig("string$get")
        try assert.equal(sig.params.len(), 2)
        inner := try sig.ret.ok_or("expected Some")

        case inner {
          .Optional(.Byte) => .Ok({}),
          _ => .Err("expected Optional(Byte)"),
        }
      },
    )
    .test(
      "builtin_env has vector$append with type param T",
      fn() {
        sig := try require_registered_sig("vector$append")
        try assert.equal(sig.type_params.len(), 1)
        try assert.equal(sig.type_params[0].name, "T")
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has vector$get returning Option<T>",
      fn() {
        sig := try require_registered_sig("vector$get")
        try assert.equal(sig.type_params.len(), 1)
        inner := try sig.ret.ok_or("expected Some")

        case inner {
          .Optional(.Var(_)) => .Ok({}),
          _ => .Err("expected Optional(Var(_))"),
        }
      },
    )
    .test(
      "builtin_env has vector$map",
      fn() {
        sig := try require_registered_sig("vector$map")
        try assert.equal(sig.type_params.len(), 2)
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has dict$new with two type params",
      fn() {
        sig := try require_registered_sig("dict$new")
        try assert.equal(sig.type_params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has dict$set",
      fn() {
        _ := try require_registered_sig("dict$set")
        .Ok({})
      },
    )
    .test(
      "builtin_env has range_from",
      fn() {
        sig := try require_sig("range_from")
        try assert.equal(sig.params.len(), 2)
        try assert.equal(sig.type_params.len(), 0)
        .Ok({})
      },
    )
    .test(
      "builtin_env has range",
      fn() {
        sig := try require_sig("range")
        try assert.equal(sig.params.len(), 1)
        .Ok({})
      },
    )
    .test(
      "builtin_env has range_step with three params",
      fn() {
        sig := try require_sig("range_step")
        try assert.equal(sig.params.len(), 3)
        .Ok({})
      },
    )
    .test(
      "builtin_env has cell$new",
      fn() {
        sig := try require_registered_sig("cell$new")
        try assert.equal(sig.type_params.len(), 1)
        .Ok({})
      },
    )
    .test(
      "builtin_env has cell$set",
      fn() {
        sig := try require_registered_sig("cell$set")
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has iterator$unfold",
      fn() {
        sig := try require_registered_sig("iterator$unfold")
        try assert.equal(sig.type_params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env records canonical origin for prelude-backed functions",
      fn() {
        case lookup_function_origin(builtin_env(), "vector$map") {
          .Some(origin) => {
            try assert.str_contains(origin.module_path, "prelude/vector.tw")
            try assert.equal(origin.func_name, "map")
            .Ok({})
          },
          .None => .Err("expected builtin_env to record origin for vector$map"),
        }
      },
    )
    .test(
      "builtin_env has iterator$map",
      fn() {
        sig := try require_registered_sig("iterator$map")
        try assert.equal(sig.type_params.len(), 2)
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has option$map",
      fn() {
        sig := try require_registered_sig("option$map")
        try assert.equal(sig.type_params.len(), 2)
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has result$map",
      fn() {
        sig := try require_registered_sig("result$map")
        try assert.equal(sig.type_params.len(), 3)
        try assert.equal(sig.params.len(), 2)
        .Ok({})
      },
    )
    .test(
      "builtin_env has byte$to_int",
      fn() {
        sig := try require_registered_sig("byte$to_int")
        try assert.equal(sig.params.len(), 1)
        .Ok({})
      },
    )
    .test(
      "builtin_env has byte$from_int returning Option<Byte>",
      fn() {
        sig := try require_registered_sig("byte$from_int")
        inner := try sig.ret.ok_or("expected Some")

        case inner {
          .Optional(.Byte) => .Ok({}),
          _ => .Err("expected Optional(Byte)"),
        }
      },
    )
    .test(
      "builtin_env has int$to_string",
      fn() {
        _ := try require_registered_sig("int$to_string")
        .Ok({})
      },
    )
    .test(
      "builtin_env has float$to_string",
      fn() {
        _ := try require_registered_sig("float$to_string")
        .Ok({})
      },
    )
    .test(
      "builtin_env hides internal implementation names from free namespace",
      fn() {
        try assert.is_none(lookup_function(builtin_env(), "bool$to_string"))
        try assert.is_none(lookup_function(builtin_env(), "int$to_string"))
        try assert.is_none(lookup_function(builtin_env(), "string$len"))
        try assert.is_none(lookup_function(builtin_env(), "dict$new"))
        try assert.is_none(lookup_function(builtin_env(), "string$substring"))
        try assert.is_none(lookup_function(builtin_env(), "vector$builder_new"))
        try assert.is_none(lookup_function(builtin_env(), "host_read_file"))
        .Ok({})
      },
    )
    .test(
      "String.len resolves to string$len",
      fn() {
        fn_name := try require_method("String", "len")
        try assert.equal(fn_name, "string$len")
        .Ok({})
      },
    )
    .test(
      "String.get resolves to string$get",
      fn() {
        fn_name := try require_method("String", "get")
        try assert.equal(fn_name, "string$get")
        .Ok({})
      },
    )
    .test(
      "String.concat resolves to string$concat",
      fn() {
        fn_name := try require_method("String", "concat")
        try assert.equal(fn_name, "string$concat")
        .Ok({})
      },
    )
    .test(
      "Vector.len resolves to vector$len",
      fn() {
        fn_name := try require_method("Vector", "len")
        try assert.equal(fn_name, "vector$len")
        .Ok({})
      },
    )
    .test(
      "Vector.append resolves to vector$append",
      fn() {
        fn_name := try require_method("Vector", "append")
        try assert.equal(fn_name, "vector$append")
        .Ok({})
      },
    )
    .test(
      "Vector.map resolves to vector$map",
      fn() {
        fn_name := try require_method("Vector", "map")
        try assert.equal(fn_name, "vector$map")
        .Ok({})
      },
    )
    .test(
      "Dict.get resolves to dict$get",
      fn() {
        fn_name := try require_method("Dict", "get")
        try assert.equal(fn_name, "dict$get")
        .Ok({})
      },
    )
    .test(
      "Cell.set resolves to cell$set",
      fn() {
        fn_name := try require_method("Cell", "set")
        try assert.equal(fn_name, "cell$set")
        .Ok({})
      },
    )
    .test(
      "Int.to_string resolves to int$to_string",
      fn() {
        fn_name := try require_method("Int", "to_string")
        try assert.equal(fn_name, "int$to_string")
        .Ok({})
      },
    )
    .test(
      "Byte.to_int resolves to byte$to_int",
      fn() {
        fn_name := try require_method("Byte", "to_int")
        try assert.equal(fn_name, "byte$to_int")
        .Ok({})
      },
    )
    .test(
      "Iterator.unfold resolves to iterator$unfold",
      fn() {
        fn_name := try require_method("Iterator", "unfold")
        try assert.equal(fn_name, "iterator$unfold")
        .Ok({})
      },
    )
    .test(
      "Iterator.map resolves to iterator$map",
      fn() {
        fn_name := try require_method("Iterator", "map")
        try assert.equal(fn_name, "iterator$map")
        .Ok({})
      },
    )
    .test(
      "Option.map resolves to option$map",
      fn() {
        fn_name := try require_method("Option", "map")
        try assert.equal(fn_name, "option$map")
        .Ok({})
      },
    )
    .test(
      "Result.map resolves to result$map",
      fn() {
        fn_name := try require_method("Result", "map")
        try assert.equal(fn_name, "result$map")
        .Ok({})
      },
    )
}
