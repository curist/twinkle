//! Tests for the `--lib` export-surface selection in module_compiler.
//!
//! Each test compiles a tiny .tw source through `compile_source_lib`, the
//! in-memory equivalent of a `twk build --lib`, then inspects the resulting
//! `anf.lib_exports` (the eligible surface) and `warnings` (members skipped as
//! ineligible). v1 exports only primitive `pub` members; generics and
//! non-primitive types are skipped with a warning rather than exported.

use @std.testing.assert as assert
use @std.testing as runner

use compiler.codegen.codegen
use compiler.core_ir.{LibExport, LibType}
use compiler.pipeline
use compiler.query.analyze
use lib.source.diagnostics as diag

fn find_export(exports: Vector<LibExport>, name: String) LibExport? {
  for e in exports {
    if e.name == name {
      return .Some(e)
    }
  }
  .None
}

fn is_function_target(e: LibExport) Bool {
  case e.target {
    .Function(_) => true,
    .Value(_) => false,
  }
}

fn lib_type_eq(p: LibType, want: LibType) Bool {
  case p {
    .Int => case want {
      .Int => true,
      _ => false,
    },
    .Float => case want {
      .Float => true,
      _ => false,
    },
    .Bool => case want {
      .Bool => true,
      _ => false,
    },
    .Void => case want {
      .Void => true,
      _ => false,
    },
    .Str => case want {
      .Str => true,
      _ => false,
    },
    .Fn(ps, r) => case want {
      .Fn(wps, wr) => if ps.len() != wps.len() {
        false
      } else {
        ok := lib_type_eq(r, wr)
        for i in 0..ps.len() {
          if !lib_type_eq(ps[i], wps[i]) {
            ok = false
          }
        }
        ok
      },
      _ => false,
    },
  }
}

// Join every warning message so a test can assert a member was skipped without
// depending on warning ordering.
fn warning_text(warnings: Vector<analyze.AnalysisDiag>) String {
  parts := collect w in warnings {
    diag.message(w.kind)
  }
  parts.join("\n")
}

fn eligible_src() String {
  "pub fn add(a: Int, b: Int) Int {\n  a + b\n}\n\npub fn is_positive(n: Int) Bool {\n  n > 0\n}\n\npub pi: Float = 3.14159\n"
}

pub fn suite() runner.Suite {
  runner
    .suite("lib exports")
    .test(
      "selects primitive pub fn with its param/return kinds",
      fn() {
        artifacts := try pipeline.compile_source_lib(eligible_src())
        add := try find_export(artifacts.anf.lib_exports, "add").ok_or("add not exported")
        try assert.equal(is_function_target(add), true)
        try assert.equal(add.wasm_name, "add")
        try assert.equal(add.params.len(), 2)
        try assert.equal(lib_type_eq(add.params[0], .Int), true)
        try assert.equal(lib_type_eq(add.params[1], .Int), true)
        try assert.equal(lib_type_eq(add.ret, .Int), true)
        .Ok({})
      },
    )
    .test(
      "Bool return is carried through",
      fn() {
        artifacts := try pipeline.compile_source_lib(eligible_src())
        f := try find_export(artifacts.anf.lib_exports, "is_positive").ok_or("missing")
        try assert.equal(lib_type_eq(f.ret, .Bool), true)
        .Ok({})
      },
    )
    .test(
      "primitive pub value global is exported as a getter",
      fn() {
        artifacts := try pipeline.compile_source_lib(eligible_src())
        pi := try find_export(artifacts.anf.lib_exports, "pi").ok_or("pi not exported")
        try assert.equal(is_function_target(pi), false)
        try assert.equal(pi.wasm_name, "__get_pi")
        try assert.equal(pi.params.len(), 0)
        try assert.equal(lib_type_eq(pi.ret, .Float), true)
        .Ok({})
      },
    )
    .test(
      "String param and return are exported as Str, not skipped",
      fn() {
        src := "${eligible_src()}\npub fn greet(name: String) String {\n  name\n}\n"
        artifacts := try pipeline.compile_source_lib(src)
        greet := try find_export(artifacts.anf.lib_exports, "greet").ok_or("greet not exported")
        try assert.equal(is_function_target(greet), true)
        try assert.equal(greet.params.len(), 1)
        try assert.equal(lib_type_eq(greet.params[0], .Str), true)
        try assert.equal(lib_type_eq(greet.ret, .Str), true)
        try assert.equal(warning_text(artifacts.warnings).contains("greet"), false)
        .Ok({})
      },
    )
    .test(
      "String pub value global is exported as a Str getter",
      fn() {
        src := "${eligible_src()}\npub greeting: String = \"hi\"\n"
        artifacts := try pipeline.compile_source_lib(src)
        g := try find_export(artifacts.anf.lib_exports, "greeting").ok_or("greeting not exported")
        try assert.equal(is_function_target(g), false)
        try assert.equal(g.wasm_name, "__get_greeting")
        try assert.equal(g.params.len(), 0)
        try assert.equal(lib_type_eq(g.ret, .Str), true)
        .Ok({})
      },
    )
    .test(
      "fn-typed param is selected with a recursive Fn descriptor",
      fn() {
        src := "${eligible_src()}\npub fn each(name: String, f: fn(String) Void) Void {\n  f(name)\n}\n"
        artifacts := try pipeline.compile_source_lib(src)
        e := try find_export(artifacts.anf.lib_exports, "each").ok_or("each not exported")
        try assert.equal(e.params.len(), 2)
        try assert.equal(lib_type_eq(e.params[0], .Str), true)
        try assert.equal(lib_type_eq(e.params[1], .Fn([.Str], .Void)), true)
        .Ok({})
      },
    )
    .test(
      "value-returning fn-typed param is eligible",
      fn() {
        src := "${eligible_src()}\npub fn pick(n: Int, p: fn(Int) Bool) Bool {\n  p(n)\n}\n"
        artifacts := try pipeline.compile_source_lib(src)
        e := try find_export(artifacts.anf.lib_exports, "pick").ok_or("pick not exported")
        try assert.equal(lib_type_eq(e.params[1], .Fn([.Int], .Bool)), true)
        .Ok({})
      },
    )
    .test(
      "fn with compound arg is skipped with a warning",
      fn() {
        src := "${eligible_src()}\npub fn go(f: fn(Vector<Int>) Void) Void {\n  {}\n}\n"
        artifacts := try pipeline.compile_source_lib(src)
        try assert.equal(find_export(artifacts.anf.lib_exports, "go").is_some(), false)
        try assert.str_contains(warning_text(artifacts.warnings), "`go`")
        .Ok({})
      },
    )
    .test(
      "generic pub fn is skipped with a warning",
      fn() {
        src := "${eligible_src()}\npub fn identity<T>(x: T) T {\n  x\n}\n"
        artifacts := try pipeline.compile_source_lib(src)
        try assert.equal(find_export(artifacts.anf.lib_exports, "identity").is_some(), false)
        try assert.str_contains(warning_text(artifacts.warnings), "`identity`")
        .Ok({})
      },
    )
    .test(
      "non-pub functions are neither exported nor warned about",
      fn() {
        src := "${eligible_src()}\nfn secret() Int {\n  42\n}\n"
        artifacts := try pipeline.compile_source_lib(src)
        try assert.equal(find_export(artifacts.anf.lib_exports, "secret").is_some(), false)
        try assert.equal(warning_text(artifacts.warnings).contains("secret"), false)
        .Ok({})
      },
    )
    .test(
      "export_type_json nests fn descriptors, leaves stay bare strings",
      fn() {
        try assert.equal(codegen.export_type_json(.Str), "\"str\"")
        try assert.equal(codegen.export_type_json(.Int), "\"int\"")
        try assert.equal(
          codegen.export_type_json(.Fn([.Str], .Void)),
          "{\"kind\":\"fn\",\"args\":[\"str\"],\"ret\":\"void\"}",
        )
        try assert.equal(
          codegen.export_type_json(.Fn([.Int], .Bool)),
          "{\"kind\":\"fn\",\"args\":[\"int\"],\"ret\":\"bool\"}",
        )
        .Ok({})
      },
    )
    .test(
      "a non-lib compile selects no exports even with pub members",
      fn() {
        artifacts := try pipeline.compile_source(eligible_src())
        try assert.equal(artifacts.anf.lib_exports.len(), 0)
        .Ok({})
      },
    )
}
