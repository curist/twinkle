      try assert.int_eq(count_make_closures_expr(result.functions[0].body), 1)
      .Ok({})
    })

    .test("materializes global func in function-valued array literal", fn() {
      body: AnfExpr = .Let(lid(10), .AArrayLit([.AGlobalFunc(fid(2))]), .Atom(.ALocal(lid(10))))
      mono := mk_mono_map([10], [MonoType.Vector(MonoType.Function([.Int], .Int))])
      holder := mk_func_def(1, "holder", [], .Vector(MonoType.Function([.Int], .Int)), body, mono)
      target := mk_func_def(2, "target", [mk_param(0, .Int)], .Int, .Atom(.ALocal(lid(0))), Dict.new())
