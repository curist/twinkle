      try assert.int_eq(count_make_closures_expr(result.functions[0].body), 1)
      .Ok({})
    })

    .test("materializes global func in function-valued record field", fn() {
      env := env_with_record_and_sum()
      body: AnfExpr = .Let(lid(10), .ARecord(TypeId.{ id: 10 }, [FieldAtom.{ field: FieldId.{ id: 0 }, value: .AGlobalFunc(fid(2)) }]), .Atom(.ALocal(lid(10))))
      mono := mk_mono_map([10], [MonoType.Named(TypeId.{ id: 10 }, [])])
      holder := mk_func_def(1, "holder", [], MonoType.Named(TypeId.{ id: 10 }, []), body, mono)
      target := mk_func_def(2, "target", [mk_param(0, .Int)], .Int, .Atom(.ALocal(lid(0))), Dict.new())
      result := insert_boundaries(mk_module([holder, target]), empty_registry(), empty_builtins(), env)
      try assert.int_eq(count_make_closures_expr(result.functions[0].body), 1)
      .Ok({})
    })

    .test("materializes global func in function-valued record update", fn() {
      env := env_with_record_and_sum()
