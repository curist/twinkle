use lib.text.line_index
use tests.assert
use tests.runner

pub fn suite() runner.Suite {
  runner
    .suite("line index")
    .test(
      "new records line starts",
      fn() {
        idx := line_index.new("one\ntwo\nthree")
        try assert.equal(idx.line_starts.len(), 3)
        try assert.equal(idx.line_starts[0], 0)
        try assert.equal(idx.line_starts[1], 4)
        try assert.equal(idx.line_starts[2], 8)
        .Ok({})
      },
    )
    .test(
      "byte offset converts to utf16 position",
      fn() {
        idx := line_index.new("a𝄞b\ncd")
        p0 := idx.byte_offset_to_position(0, .Utf16)
        try assert.equal(p0.line, 0)
        try assert.equal(p0.character, 0)
        p1 := idx.byte_offset_to_position(1, .Utf16)
        try assert.equal(p1.line, 0)
        try assert.equal(p1.character, 1)
        p2 := idx.byte_offset_to_position(5, .Utf16)
        try assert.equal(p2.line, 0)
        try assert.equal(p2.character, 3)
        p3 := idx.byte_offset_to_position(7, .Utf16)
        try assert.equal(p3.line, 1)
        try assert.equal(p3.character, 0)
        .Ok({})
      },
    )
    .test(
      "utf16 position converts to byte offset",
      fn() {
        idx := line_index.new("a𝄞b\ncd")
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 0, character: 0 }, .Utf16).ok_or("missing"),
          0,
        )
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 0, character: 1 }, .Utf16).ok_or("missing"),
          1,
        )
        try assert.is_none(idx.position_to_byte_offset(.{ line: 0, character: 2 }, .Utf16))
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 0, character: 3 }, .Utf16).ok_or("missing"),
          5,
        )
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 1, character: 1 }, .Utf16).ok_or("missing"),
          8,
        )
        try assert.is_none(idx.position_to_byte_offset(.{ line: 9, character: 0 }, .Utf16))
        try assert.is_none(idx.position_to_byte_offset(.{ line: 1, character: 99 }, .Utf16))
        .Ok({})
      },
    )
    .test(
      "utf8 and utf32 encodings are supported",
      fn() {
        idx := line_index.new("a𝄞b")
        p8 := idx.byte_offset_to_position(5, .Utf8)
        try assert.equal(p8.character, 5)
        p32 := idx.byte_offset_to_position(5, .Utf32)
        try assert.equal(p32.character, 2)
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 0, character: 5 }, .Utf8).ok_or("missing"),
          5,
        )
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 0, character: 2 }, .Utf32).ok_or("missing"),
          5,
        )
        .Ok({})
      },
    )
    .test(
      "byte range converts to lsp range",
      fn() {
        idx := line_index.new("a𝄞b\ncd")
        r := idx.byte_range_to_range(1, 8, .Utf16)
        try assert.equal(r.start.line, 0)
        try assert.equal(r.start.character, 1)
        try assert.equal(r.end.line, 1)
        try assert.equal(r.end.character, 1)
        .Ok({})
      },
    )
    .test(
      "crlf line endings exclude carriage return from line content",
      fn() {
        idx := line_index.new("a\r\nb")
        p := idx.byte_offset_to_position(3, .Utf16)
        try assert.equal(p.line, 1)
        try assert.equal(p.character, 0)
        try assert.equal(
          try idx.position_to_byte_offset(.{ line: 0, character: 1 }, .Utf16).ok_or("missing"),
          1,
        )
        try assert.is_none(idx.position_to_byte_offset(.{ line: 0, character: 2 }, .Utf16))
        .Ok({})
      },
    )
}
