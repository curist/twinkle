use @std.stack
use @std.stack.{Stack}

use tests.assert
use tests.runner

fn top_or<T>(s: Stack<T>, fallback: T) T {
  case s.top() {
    .Some(v) => v,
    .None => fallback,
  }
}

fn size<T>(s: Stack<T>) Int {
  s.to_vector().len()
}

pub fn suite() runner.Suite {
  runner.suite("stack")
    .test(
      "new creates an empty stack",
      fn() {
        s: Stack<Int> = stack.new()
        try assert.is_true(s.is_empty())
        try assert.is_none(s.top())
        .Ok({})
      },
    )
    .test(
      "push then top returns last pushed",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .push(3)
        try assert.equal(size(s), 3)
        try assert.is_false(s.is_empty())
        try assert.equal(top_or(s, -1), 3)
        .Ok({})
      },
    )
    .test(
      "pop removes the top element",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .pop()
        try assert.equal(size(s), 1)
        try assert.equal(top_or(s, -1), 1)
        .Ok({})
      },
    )
    .test(
      "pop on empty is a no-op",
      fn() {
        s: Stack<Int> = stack.new()
        s = .pop()
        try assert.is_true(s.is_empty())
        .Ok({})
      },
    )
    .test(
      "push after pop",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .pop()
        s = .push(9)
        try assert.equal(size(s), 2)
        try assert.equal(top_or(s, -1), 9)
        .Ok({})
      },
    )
    .test(
      "to_vector returns elements bottom-to-top",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .push(3)
        vs := s.to_vector()
        try assert.equal(vs.len(), 3)
        try assert.equal(vs[0], 1)
        try assert.equal(vs[2], 3)
        .Ok({})
      },
    )
}
