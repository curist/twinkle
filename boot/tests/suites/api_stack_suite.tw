use @std.stack
use @std.stack.{Stack}

use tests.assert
use tests.runner

fn top_or<T>(s: Stack<T>, fallback: T) T {
  case s.top() {
    .Some(v) => v,
    .None => fallback,
  }
}

// Stack satisfies IndexRead<T> via len/at (bottom-to-top), so it flows through a
// generic `<C: IndexRead<E>, E>` bound just like Vector/String/View.
fn count_via_index_read<C: IndexRead<E>, E>(c: C) Int {
  c.len()
}

fn index_via_bracket<C: IndexRead<E>, E>(c: C, i: Int) E {
  c[i]
}

fn sum_via_index_read<C: IndexRead<Int>>(c: C) Int {
  total := 0
  i := 0

  for i < c.len() {
    total = total + c.at(i)
    i = i + 1
  }

  total
}

pub fn suite() runner.Suite {
  runner.suite("stack")
    .test(
      "new creates an empty stack",
      fn() {
        s: Stack<Int> = stack.new()
        try assert.equal(s.len(), 0)
        try assert.is_true(s.is_empty())
        try assert.is_none(s.top())
        .Ok({})
      },
    )
    .test(
      "push then top returns last pushed",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .push(3)
        try assert.equal(s.len(), 3)
        try assert.is_false(s.is_empty())
        try assert.equal(top_or(s, -1), 3)
        .Ok({})
      },
    )
    .test(
      "pop removes the top element",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .pop()
        try assert.equal(s.len(), 1)
        try assert.equal(top_or(s, -1), 1)
        .Ok({})
      },
    )
    .test(
      "pop on empty is a no-op",
      fn() {
        s: Stack<Int> = stack.new()
        s = .pop()
        try assert.equal(s.len(), 0)
        try assert.is_true(s.is_empty())
        .Ok({})
      },
    )
    .test(
      "push after pop",
      fn() {
        s: Stack<Int> = stack.new()
        s = .push(1)
        s = .push(2)
        s = .pop()
        s = .push(9)
        try assert.equal(s.len(), 2)
        try assert.equal(top_or(s, -1), 9)
        .Ok({})
      },
    )
    .test(
      "at reads bottom-to-top and top is at(len-1)",
      fn() {
        s := stack.from_vector([10, 20, 30])
        try assert.equal(s.at(0), 10)
        try assert.equal(s.at(2), 30)
        try assert.equal(s.at(s.len() - 1), top_or(s, -1))
        .Ok({})
      },
    )
    .test(
      "Stack satisfies IndexRead through a generic bound",
      fn() {
        s := stack.from_vector([10, 20, 30])
        try assert.equal(count_via_index_read(s), 3)
        try assert.equal(index_via_bracket(s, 1), 20)
        try assert.equal(sum_via_index_read(s), 60)
        .Ok({})
      },
    )
    .test(
      "from_vector and to_vector round-trip",
      fn() {
        xs: Vector<Int> = [1, 2, 3]
        s := stack.from_vector(xs)
        try assert.equal(s.len(), 3)
        try assert.equal(top_or(s, -1), 3)
        vs := s.to_vector()
        try assert.equal(vs.len(), 3)
        try assert.equal(vs[0], 1)
        try assert.equal(vs[2], 3)
        .Ok({})
      },
    )
}
