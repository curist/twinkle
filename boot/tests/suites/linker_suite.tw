        results: [],
      },
    ],
    funcs: [
      FuncDef.{
        name: "main",
        params: [],
        results: [],
        locals: [],
        body: [Instr.Call("host_print")],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  // Host import should be preserved (but qualified)
  try assert.ok(has_import(linked, "host", "print"), "host import should be preserved")
  .Ok({})
}

fn test_link_unresolved_import_is_external() Result<Void, String> {
