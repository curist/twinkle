use compiler.codegen.linker.{LinkedModule, link}
use compiler.codegen.wasm_ir.{
  DataSegment, ElemDef, ExportDef, FieldDef, FuncDef, GlobalDef, HeapType, ImportDef, Instr,
  TableDef, TypeDef, ValType, WasmModule,
}
use tests.assert
use tests.runner

// ── Helpers ─────────────────────────────────────────────────────────
fn empty_module(ns: String) WasmModule {
  WasmModule.{
    namespace: ns,
    types: [],
    imports: [],
    funcs: [],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
}

fn contains(haystack: String, needle: String) Bool {
  if needle.len() > haystack.len() {
    return false
  }
  if needle.len() == 0 {
    return true
  }

  for i in 0..haystack.len() - needle.len() + 1 {
    if haystack.slice(i, i + needle.len()) == needle {
      return true
    }
  }

  false
}

fn link_ok(modules: Vector<WasmModule>, entry: String?) Result<LinkedModule, String> {
  case link(modules, entry) {
    .Ok(linked) => .Ok(linked),
    .Err(errors) => .Err("link failed with errors"),
  }
}

fn find_func(linked: LinkedModule, name: String) FuncDef? {
  for f in linked.funcs {
    if f.name == name {
      return .Some(f)
    }
  }

  .None
}

fn find_export(linked: LinkedModule, wasm_name: String) ExportDef? {
  for e in linked.exports {
    if e.wasm_name == wasm_name {
      return .Some(e)
    }
  }

  .None
}

fn find_global(linked: LinkedModule, name: String) GlobalDef? {
  for g in linked.globals {
    if g.name == name {
      return .Some(g)
    }
  }

  .None
}

fn find_type(linked: LinkedModule, name: String) TypeDef? {
  for td in linked.types {
    case td {
      .Struct(n, _, _, _) => {
        if n == name {
          return .Some(td)
        }
      },
      .Array(n, _) => {
        if n == name {
          return .Some(td)
        }
      },
      .FuncType(n, _, _) => {
        if n == name {
          return .Some(td)
        }
      },
    }
  }

  .None
}

fn has_import(linked: LinkedModule, module: String, name: String) Bool {
  for imp in linked.imports {
    if imp.module == module and imp.name == name {
      return true
    }
  }

  false
}

fn has_export(linked: LinkedModule, wasm_name: String) Bool {
  for exp in linked.exports {
    if exp.wasm_name == wasm_name {
      return true
    }
  }

  false
}

fn instr_has_call(instrs: Vector<Instr>, target: String) Bool {
  for instr in instrs {
    case instr {
      .Call(sym) => {
        if sym == target {
          return true
        }
      },
      .Block(_, _, body) => {
        if instr_has_call(body, target) {
          return true
        }
      },
      .Loop(_, _, body) => {
        if instr_has_call(body, target) {
          return true
        }
      },
      .If(_, then_body, else_body) => {
        if instr_has_call(then_body, target) {
          return true
        }
        if instr_has_call(else_body, target) {
          return true
        }
      },
      _ => {},
    }
  }

  false
}

fn instr_has_struct_new(instrs: Vector<Instr>, target: String) Bool {
  for instr in instrs {
    case instr {
      .StructNew(sym) => {
        if sym == target {
          return true
        }
      },
      .Block(_, _, body) => {
        if instr_has_struct_new(body, target) {
          return true
        }
      },
      .Loop(_, _, body) => {
        if instr_has_struct_new(body, target) {
          return true
        }
      },
      .If(_, then_body, else_body) => {
        if instr_has_struct_new(then_body, target) {
          return true
        }
        if instr_has_struct_new(else_body, target) {
          return true
        }
      },
      _ => {},
    }
  }

  false
}

// ── Tests: empty/single module ──────────────────────────────────────
fn test_link_empty_modules() Result<Void, String> {
  linked := try link_ok([], .None)
  try assert.equal(linked.funcs.len(), 0)
  try assert.equal(linked.types.len(), 0)
  try assert.ok(
    case linked.start {
      .None => true,
      _ => false,
    },
    "no start",
  )
  .Ok({})
}

fn test_link_single_module_qualifies_funcs() Result<Void, String> {
  m := empty_module("math")
  m = WasmModule.{
    namespace: m.namespace,
    types: m.types,
    imports: m.imports,
    funcs: [
      FuncDef.{
        name: "add",
        params: [.I64, .I64],
        results: [.I64],
        locals: [],
        body: [Instr.LocalGet(0), Instr.LocalGet(1), Instr.I64Add],
      },
    ],
    globals: m.globals,
    tables: m.tables,
    elems: m.elems,
    exports: m.exports,
    memory_exports: m.memory_exports,
    memories: m.memories,
    data: m.data,
    start: m.start,
  }
  linked := try link_ok([m], .None)
  try assert.equal(linked.funcs.len(), 1)
  try assert.equal(linked.funcs[0].name, "math__add")
  .Ok({})
}

fn test_link_single_module_qualifies_types() Result<Void, String> {
  m := empty_module("geom")
  m = WasmModule.{
    namespace: m.namespace,
    types: [
      TypeDef.Struct(
        "Point",
        [FieldDef.{ name: .Some("x"), mutable: false, ty: .I64 }],
        .None,
        true,
      ),
    ],
    imports: m.imports,
    funcs: m.funcs,
    globals: m.globals,
    tables: m.tables,
    elems: m.elems,
    exports: m.exports,
    memory_exports: m.memory_exports,
    memories: m.memories,
    data: m.data,
    start: m.start,
  }
  linked := try link_ok([m], .None)
  try assert.ok(
    case find_type(linked, "geom__Point") {
      .Some(_) => true,
      .None => false,
    },
    "type should be qualified as geom__Point",
  )
  .Ok({})
}

fn test_link_single_module_qualifies_globals() Result<Void, String> {
