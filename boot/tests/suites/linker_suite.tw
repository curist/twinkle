// ── Tests: symbol rewriting in instructions ─────────────────────────
fn test_link_rewrites_call_in_func_body() Result<Void, String> {
  // Module "a" has func "f" that calls "g" (also in "a")
  m := WasmModule.{
    namespace: "a",
    types: [],
    imports: [],
    funcs: [
      FuncDef.{ name: "f", params: [], results: [], locals: [], body: [Instr.Call("g")] },
      FuncDef.{ name: "g", params: [], results: [], locals: [], body: [] },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "a__f").ok_or("missing a__f")
  try assert.ok(instr_has_call(f.body, "a__g"), "call should be rewritten to a__g")
  .Ok({})
}

fn test_link_rewrites_global_get_set() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [],
    imports: [],
    funcs: [
      FuncDef.{
        name: "f",
        params: [],
        results: [.I64],
        locals: [],
        body: [
          Instr.GlobalGet("counter"),
          Instr.I64Const(1),
          Instr.I64Add,
          Instr.GlobalSet("counter"),
          Instr.GlobalGet("counter"),
        ],
      },
    ],
    globals: [GlobalDef.{ name: "counter", mutable: true, ty: .I64, init: [Instr.I64Const(0)] }],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "ns__f").ok_or("missing ns__f")
  // Check GlobalGet was rewritten
  found_get := false
  found_set := false

  for instr in f.body {
    case instr {
      .GlobalGet(sym) => {
        if sym == "ns__counter" { found_get = true }
      },
      .GlobalSet(sym) => {
        if sym == "ns__counter" { found_set = true }
      },
      _ => {},
    }
  }

  try assert.ok(found_get, "GlobalGet should be rewritten to ns__counter")
  try assert.ok(found_set, "GlobalSet should be rewritten to ns__counter")
  .Ok({})
}

fn test_link_rewrites_struct_new_and_get() Result<Void, String> {
  m := WasmModule.{
    namespace: "mod",
    types: [
      TypeDef.Struct("Pt", [FieldDef.{ name: .Some("x"), mutable: false, ty: .I64 }], .None, true),
    ],
    imports: [],
    funcs: [
      FuncDef.{
        name: "mk",
        params: [],
        results: [.I64],
        locals: [],
        body: [Instr.I64Const(1), Instr.StructNew("Pt"), Instr.StructGet("Pt", 0)],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "mod__mk").ok_or("missing mod__mk")
  try assert.ok(instr_has_struct_new(f.body, "mod__Pt"), "StructNew should be rewritten")
  // Check StructGet
  found := false

  for instr in f.body {
    case instr {
      .StructGet(sym, _) => {
        if sym == "mod__Pt" { found = true }
      },
      _ => {},
    }
  }

  try assert.ok(found, "StructGet should be rewritten to mod__Pt")
  .Ok({})
}

fn test_link_rewrites_ref_cast_type() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [TypeDef.Struct("Foo", [], .None, true)],
    imports: [],
    funcs: [
      FuncDef.{
        name: "f",
        params: [.Anyref],
        results: [ValType.Ref(false, HeapType.Named("Foo"))],
        locals: [],
        body: [Instr.LocalGet(0), Instr.RefCast(false, HeapType.Named("Foo"))],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "ns__f").ok_or("missing ns__f")
  found := false

  for instr in f.body {
    case instr {
      .RefCast(_, .Named(name)) => {
        if name == "ns__Foo" { found = true }
      },
      _ => {},
    }
  }

  try assert.ok(found, "RefCast heap type should be rewritten to ns__Foo")
  .Ok({})
}

fn test_link_rewrites_if_block_loop_result_types() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [TypeDef.Struct("Box", [], .None, true)],
    imports: [],
    funcs: [
      FuncDef.{
        name: "f",
        params: [],
        results: [],
        locals: [],
        body: [
          Instr.Block(
            "b",
            .Some(ValType.Ref(false, HeapType.Named("Box"))),
            [
              Instr.I32Const(1),
              Instr.If(
                .Some(ValType.Ref(false, HeapType.Named("Box"))),
                [Instr.Unreachable],
                [Instr.Unreachable],
              ),
            ],
          ),
          Instr.Drop,
        ],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "ns__f").ok_or("missing ns__f")
  // Check Block result type was rewritten
  found_block := false
  found_if := false

  for instr in f.body {
    case instr {
      .Block(_, .Some(.Ref(_, .Named(name))), body) => {
        if name == "ns__Box" {
          found_block = true

          // Check If inside block
          for inner in body {
            case inner {
              .If(.Some(.Ref(_, .Named(if_name))), _, _) => {
                if if_name == "ns__Box" { found_if = true }
              },
              _ => {},
            }
          }
        }
      },
      _ => {},
    }
  }

  try assert.ok(found_block, "Block result type should be rewritten to ns__Box")
  try assert.ok(found_if, "If result type should be rewritten to ns__Box")
  .Ok({})
}

fn test_link_rewrites_func_param_result_types() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [TypeDef.Struct("Rec", [], .None, true)],
    imports: [],
    funcs: [
      FuncDef.{
        name: "f",
        params: [ValType.Ref(false, HeapType.Named("Rec"))],
        results: [ValType.Ref(false, HeapType.Named("Rec"))],
        locals: [ValType.Ref(true, HeapType.Named("Rec"))],
        body: [Instr.LocalGet(0)],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "ns__f").ok_or("missing ns__f")

  // Check param type rewritten
  case f.params[0] {
    .Ref(_, .Named(name)) => try assert.equal(name, "ns__Rec"),
    _ => { return assert.fail("param should be ref to ns__Rec") },
  }

  case f.results[0] {
    .Ref(_, .Named(name)) => try assert.equal(name, "ns__Rec"),
    _ => { return assert.fail("result should be ref to ns__Rec") },
  }

  case f.locals[0] {
    .Ref(_, .Named(name)) => try assert.equal(name, "ns__Rec"),
    _ => { return assert.fail("local should be ref to ns__Rec") },
  }

  .Ok({})
}

// ── Tests: cross-module import resolution ───────────────────────────
fn test_link_resolves_import_to_export() Result<Void, String> {
  // Module "lib" exports "helper"
  lib := WasmModule.{
    namespace: "lib",
    types: [],
    imports: [],
    funcs: [FuncDef.{ name: "helper", params: [], results: [], locals: [], body: [] }],
    globals: [],
    tables: [],
    elems: [],
    exports: [ExportDef.{ wasm_name: "helper", func_sym: "helper" }],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  // Module "app" imports "helper" from "lib"
  app := WasmModule.{
    namespace: "app",
    types: [],
    imports: [
      ImportDef.{ module: "lib", name: "helper", as_sym: "lib_helper", params: [], results: [] },
    ],
    funcs: [
      FuncDef.{
        name: "main",
        params: [],
        results: [],
        locals: [],
        body: [Instr.Call("lib_helper")],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([lib, app], .None)
  // The import should be resolved — not present in linked imports
  try assert.ok(!has_import(linked, "lib", "helper"), "inter-module import should be resolved")
  // The call in "main" should now target the qualified export symbol
  f := try find_func(linked, "app__main").ok_or("missing app__main")
  try assert.ok(instr_has_call(f.body, "lib__helper"), "call should target lib__helper")
  .Ok({})
}

