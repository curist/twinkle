// ── Tests: start function synthesis ─────────────────────────────────
fn test_link_synthesizes_init_from_multiple_starts() Result<Void, String> {
  a := WasmModule.{
    namespace: "a",
    types: [],
    imports: [],
    funcs: [FuncDef.{ name: "init_a", params: [], results: [], locals: [], body: [] }],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .Some("init_a"),
  }
  b := WasmModule.{
    namespace: "b",
    types: [],
    imports: [],
    funcs: [FuncDef.{ name: "init_b", params: [], results: [], locals: [], body: [] }],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .Some("init_b"),
  }
  linked := try link_ok([a, b], .None)
  // Should have a synthesized __linked_init exported as __twinkle_start
  exp := try find_export(linked, "__twinkle_start").ok_or("missing __twinkle_start export")
  try assert.equal(exp.func_sym, "__linked_init")
  init_fn := try find_func(linked, "__linked_init").ok_or("missing __linked_init")
  try assert.ok(instr_has_call(init_fn.body, "a__init_a"), "should call a__init_a")
  try assert.ok(instr_has_call(init_fn.body, "b__init_b"), "should call b__init_b")
  .Ok({})
}

fn test_link_single_start_no_synth() Result<Void, String> {
  m := WasmModule.{
    namespace: "app",
    types: [],
    imports: [],
    funcs: [FuncDef.{ name: "init", params: [], results: [], locals: [], body: [] }],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .Some("init"),
  }
  linked := try link_ok([m], .None)
  // Single start → exported directly as __twinkle_start, no __linked_init needed
  exp := try find_export(linked, "__twinkle_start").ok_or("missing __twinkle_start export")
  try assert.equal(exp.func_sym, "app__init")
  .Ok({})
}

fn test_link_entry_appended_to_init() Result<Void, String> {
  m := WasmModule.{
    namespace: "app",
    types: [],
    imports: [],
    funcs: [
      FuncDef.{ name: "init", params: [], results: [], locals: [], body: [] },
      FuncDef.{ name: "main", params: [], results: [], locals: [], body: [] },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .Some("init"),
  }
  linked := try link_ok([m], .Some("app__main"))
  // With entry, we need __linked_init that calls init then main
  init_fn := try find_func(linked, "__linked_init").ok_or("missing __linked_init")
  try assert.ok(instr_has_call(init_fn.body, "app__init"), "should call app__init")
  try assert.ok(instr_has_call(init_fn.body, "app__main"), "should call app__main")
  .Ok({})
}

