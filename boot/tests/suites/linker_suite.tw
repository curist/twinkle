// ── Tests: supertype rewriting ──────────────────────────────────────
fn test_link_rewrites_struct_supertype() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [
      TypeDef.Struct("Base", [], .None, false),
      TypeDef.Struct("Child", [], .Some("Base"), true),
    ],
    imports: [],
    funcs: [],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)

  // Child's supertype should be rewritten to ns__Base
  case find_type(linked, "ns__Child") {
    .Some(.Struct(_, _, .Some(sup), _)) => try assert.equal(sup, "ns__Base"),
    .Some(_) => { return assert.fail("Child should have supertype") },
    .None => { return assert.fail("missing ns__Child") },
  }

  .Ok({})
}

// ── Tests: elem segment rewriting ───────────────────────────────────
fn test_link_rewrites_elem_func_syms() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [],
    imports: [],
    funcs: [
      FuncDef.{ name: "f1", params: [], results: [], locals: [], body: [] },
      FuncDef.{ name: "f2", params: [], results: [], locals: [], body: [] },
    ],
    globals: [],
    tables: [TableDef.{ name: "tbl", elem_type: .Funcref, min: 2, max: .Some(2) }],
    elems: [ElemDef.{ table: "tbl", offset: [Instr.I32Const(0)], func_syms: ["f1", "f2"] }],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  try assert.equal(linked.elems.len(), 1)
  try assert.equal(linked.elems[0].func_syms[0], "ns__f1")
  try assert.equal(linked.elems[0].func_syms[1], "ns__f2")
  try assert.equal(linked.elems[0].table, "ns__tbl")
  .Ok({})
}

// ── Tests: export rewriting ─────────────────────────────────────────
fn test_link_qualifies_exports() Result<Void, String> {
  m := WasmModule.{
    namespace: "app",
    types: [],
    imports: [],
    funcs: [FuncDef.{ name: "main", params: [], results: [], locals: [], body: [] }],
    globals: [],
    tables: [],
    elems: [],
    exports: [ExportDef.{ wasm_name: "main", func_sym: "main" }],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  try assert.equal(linked.exports.len(), 1)
  try assert.equal(linked.exports[0].func_sym, "app__main")
  .Ok({})
}

// ── Tests: RefFunc and ArrayNewData rewriting ───────────────────────
fn test_link_rewrites_ref_func() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [],
    imports: [],
    funcs: [
      FuncDef.{ name: "target", params: [], results: [], locals: [], body: [] },
      FuncDef.{
        name: "f",
        params: [],
        results: [.Funcref],
        locals: [],
        body: [Instr.RefFunc("target")],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "ns__f").ok_or("missing ns__f")
  found := false

  for instr in f.body {
    case instr {
      .RefFunc(sym) => {
        if sym == "ns__target" { found = true }
      },
      _ => {},
    }
  }

  try assert.ok(found, "RefFunc should be rewritten to ns__target")
  .Ok({})
}

fn test_link_rewrites_array_new_data() Result<Void, String> {
  m := WasmModule.{
    namespace: "ns",
    types: [TypeDef.Array("Bytes", FieldDef.{ name: .None, mutable: false, ty: .I8 })],
    imports: [],
    funcs: [
      FuncDef.{
        name: "f",
        params: [],
        results: [.Anyref],
        locals: [],
        body: [Instr.I32Const(0), Instr.I32Const(3), Instr.ArrayNewData("Bytes", "d0")],
      },
    ],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    memory_exports: [],
    memories: [],
    data: [DataSegment.{ name: "d0", offset: [], bytes: [1, 2, 3] }],
    start: .None,
  }
  linked := try link_ok([m], .None)
  f := try find_func(linked, "ns__f").ok_or("missing ns__f")
  found := false

  for instr in f.body {
    case instr {
      .ArrayNewData(ty_sym, data_sym) => {
        if ty_sym == "ns__Bytes" and data_sym == "ns__d0" { found = true }
      },
      _ => {},
    }
  }

  try assert.ok(found, "ArrayNewData should rewrite both type and data syms")
  .Ok({})
}

// ── Suite ───────────────────────────────────────────────────────────
pub fn suite() runner.Suite {
  runner.suite("linker (M9)").test("link empty modules", test_link_empty_modules).test(
    "single module qualifies funcs",
    test_link_single_module_qualifies_funcs,
  ).test("single module qualifies types", test_link_single_module_qualifies_types).test(
    "single module qualifies globals",
    test_link_single_module_qualifies_globals,
  ).test("qualifies data segments", test_link_qualifies_data_segments).test(
    "dots in namespace replaced",
    test_link_dots_in_namespace_replaced,
  ).test("rewrites Call in func body", test_link_rewrites_call_in_func_body).test(
    "rewrites GlobalGet/GlobalSet",
    test_link_rewrites_global_get_set,
  ).test("rewrites StructNew/StructGet", test_link_rewrites_struct_new_and_get).test(
    "rewrites RefCast heap type",
    test_link_rewrites_ref_cast_type,
  ).test("rewrites if/block/loop result types", test_link_rewrites_if_block_loop_result_types).test(
    "rewrites func param/result/local types",
    test_link_rewrites_func_param_result_types,
  ).test("rewrites RefFunc", test_link_rewrites_ref_func).test(
    "rewrites ArrayNewData",
    test_link_rewrites_array_new_data,
  ).test("rewrites struct supertype", test_link_rewrites_struct_supertype).test(
    "rewrites elem func syms",
    test_link_rewrites_elem_func_syms,
  ).test("qualifies exports", test_link_qualifies_exports).test(
    "resolves import to export",
    test_link_resolves_import_to_export,
  ).test("preserves host imports", test_link_preserves_host_imports).test(
    "unresolved import is external",
    test_link_unresolved_import_is_external,
  ).test(
    "synthesizes __linked_init from multiple starts",
    test_link_synthesizes_init_from_multiple_starts,
  ).test("single start just qualifies", test_link_single_start_no_synth).test(
    "entry appended to init",
    test_link_entry_appended_to_init,
  )
}
