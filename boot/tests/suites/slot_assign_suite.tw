// Tests for boot/compiler/backend/slot_assign.tw
//
// Verifies that assign_slots() correctly classifies function locals into
// CaptureParam, Param, Local, PatternLocal, and DeadPlaceholder slots,
// with correct ABI ordering and mono type resolution.

use tests.runner
use tests.assert
use compiler.resolver
use compiler.mono_type.{MonoType, TypeId}

use compiler.core_ir.{LocalId, FuncId, VariantId, Param}

use compiler.anf.{AnfExpr, AnfMatchArm, AnfFunctionDef}

use compiler.backend.prepared_ir.{CaptureParam, SlotRole, SlotInfo, PreparedFunc}

use compiler.backend.slot_assign.{assign_slots}


// ── Helpers ─────────────────────────────────────────────────────────

fn mk_local(n: Int) LocalId { LocalId.{ id: n } }
fn mk_func(n: Int) FuncId { FuncId.{ id: n } }

fn mk_func_def(
  id: Int,
  name: String,
  params: Vector<Param>,
  return_ty: MonoType,
  body: AnfExpr,
  op_result_mono: Dict<Int, MonoType>,
) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: mk_func(id),
    name: name,
    params: params,
    return_ty: return_ty,
    body: body,
    op_result_mono: op_result_mono,
    is_init: false,
  }
}

fn no_captures() Dict<Int, Vector<CaptureParam>> { Dict.new() }

fn captures_for(fid: Int, caps: Vector<CaptureParam>) Dict<Int, Vector<CaptureParam>> {
  d: Dict<Int, Vector<CaptureParam>> = Dict.new()
  d[fid] = caps
  d
}

fn slot_for_local(pf: PreparedFunc, lid: Int) SlotInfo? {
  for sid in pf.slots.keys() {
    case pf.slots[sid] {
      .Some(info) => if info.source_local.id == lid { return .Some(info) },
      .None => {},
    }
  }
  .None
}

// assert_slot_id: check that LocalId lid maps to slot with the given id.
fn assert_slot_id(pf: PreparedFunc, lid: Int, expected_sid: Int) Result<Void, String> {
  case slot_for_local(pf, lid) {
    .Some(info) => assert.equal(info.slot.id, expected_sid),
    .None => assert.fail("L${lid} has no slot"),
  }
}

// assert_role: check that the slot for LocalId lid has the given SlotRole.
fn assert_role(pf: PreparedFunc, lid: Int, expected: SlotRole) Result<Void, String> {
  case slot_for_local(pf, lid) {
    .None => assert.fail("no slot for L${lid}"),
    .Some(info) => {
      role_ok := case info.role {
        .Param => case expected { .Param => true, _ => false },
        .CaptureParam => case expected { .CaptureParam => true, _ => false },
        .Local => case expected { .Local => true, _ => false },
        .PatternLocal => case expected { .PatternLocal => true, _ => false },
        .DeadPlaceholder => case expected { .DeadPlaceholder => true, _ => false },
      }
      if role_ok { .Ok({}) } else { assert.fail("L${lid}: wrong role") }
    },
  }
}

// assert_mono: check that the slot for LocalId lid has the given MonoType.
fn assert_mono(pf: PreparedFunc, lid: Int, expected: MonoType) Result<Void, String> {
  case slot_for_local(pf, lid) {
    .None => assert.fail("no slot for L${lid}"),
    .Some(info) => {
      mono_ok := case info.mono {
        .Int => case expected { .Int => true, _ => false },
        .Float => case expected { .Float => true, _ => false },
        .Bool => case expected { .Bool => true, _ => false },
        .String => case expected { .String => true, _ => false },
        .Void => case expected { .Void => true, _ => false },
        .Never => case expected { .Never => true, _ => false },
        .Optional(inner) => case expected {
          .Optional(_) => true,
          _ => false,
        },
        _ => false,
      }
      if mono_ok { .Ok({}) } else { assert.fail("L${lid}: wrong mono") }
    },
  }
}

// ── Tests ────────────────────────────────────────────────────────────

// Simple function: no closures, just params and a let-local.
fn test_simple_params_and_local() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[2] = MonoType.Int
  func := mk_func_def(100, "add",
    [
      Param.{ local: mk_local(0), ty: MonoType.Int },
      Param.{ local: mk_local(1), ty: MonoType.Int },
    ],
    MonoType.Int,
    .Let(mk_local(2), .ABinOp(.Add, .ALocal(mk_local(0)), .ALocal(mk_local(1)), .Int),
      .Atom(.ALocal(mk_local(2)))),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  try assert.equal(pf.captures.len(), 0)
  try assert.equal(pf.params.len(), 2)
  try assert.equal(pf.locals.len(), 1)

  // params get Param role in ABI order
  try assert_role(pf, 0, .Param)
  try assert_role(pf, 1, .Param)
  // let-local gets Local role with correct mono
  try assert_role(pf, 2, .Local)
  try assert_mono(pf, 2, MonoType.Int)

  // slot ids: L0→slot 0, L1→slot 1, L2→slot 2
  try assert_slot_id(pf, 0, 0)
  try assert_slot_id(pf, 1, 1)
  try assert_slot_id(pf, 2, 2)
  .Ok({})
}

// Closure function: capture params come first in ABI order.
fn test_capture_params_precede_declared_params() Result<Void, String> {
  // Hoisted fn(Int) Int with one capture (L5: String from outer scope)
  mono: Dict<Int, MonoType> = Dict.new()
  mono[10] = MonoType.Int
  func := mk_func_def(200, "adder",
    [Param.{ local: mk_local(10), ty: MonoType.Int }],
    MonoType.Int,
    .Atom(.ALocal(mk_local(10))),
    mono,
  )
  captures := captures_for(200, [
    CaptureParam.{ local_id: mk_local(5), param_local: mk_local(50), ty: MonoType.String },
  ])
  pf := assign_slots(func, captures, resolver.empty_env())

  try assert.equal(pf.captures.len(), 1)
  try assert.equal(pf.params.len(), 1)
  try assert.equal(pf.locals.len(), 0)

  // rewritten capture param L50 → slot 0; user param L10 → slot 1
  try assert_slot_id(pf, 50, 0)
  try assert_role(pf, 50, .CaptureParam)
  try assert_mono(pf, 50, MonoType.String)
  try assert_slot_id(pf, 10, 1)
  try assert_role(pf, 10, .Param)
  .Ok({})
}

// Multiple captures, ordering preserved.
fn test_multiple_captures_ordered() Result<Void, String> {
  func := mk_func_def(300, "use_both",
    [],
    MonoType.Int,
    .Atom(.ALitInt(0)),
    Dict.new(),
  )
  captures := captures_for(300, [
    CaptureParam.{ local_id: mk_local(1), param_local: mk_local(21), ty: MonoType.Int },
    CaptureParam.{ local_id: mk_local(3), param_local: mk_local(23), ty: MonoType.Float },
    CaptureParam.{ local_id: mk_local(7), param_local: mk_local(27), ty: MonoType.Bool },
  ])
  pf := assign_slots(func, captures, resolver.empty_env())

  try assert.equal(pf.captures.len(), 3)
  try assert_slot_id(pf, 21, 0)
  try assert_slot_id(pf, 23, 1)
  try assert_slot_id(pf, 27, 2)
  try assert_role(pf, 21, .CaptureParam)
  try assert_role(pf, 23, .CaptureParam)
  try assert_role(pf, 27, .CaptureParam)
  .Ok({})
}

// Never-typed local gets DeadPlaceholder role.
fn test_dead_placeholder_for_never_local() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[1] = MonoType.Never
  func := mk_func_def(100, "diverge",
    [],
    MonoType.Never,
    .Let(mk_local(1), .ACall(.AGlobalFunc(mk_func(999)), []),
      .Return(.None)),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  try assert_role(pf, 1, .DeadPlaceholder)
  try assert_mono(pf, 1, MonoType.Never)
  .Ok({})
}

// AAssign target and init local both get Local role.
fn test_assign_target_is_local() Result<Void, String> {
  // let x = 0; let _v = assign(x = 1); x
  mono: Dict<Int, MonoType> = Dict.new()
  mono[0] = MonoType.Int
  mono[1] = MonoType.Void
  func := mk_func_def(100, "counter",
    [],
    MonoType.Int,
    .Let(mk_local(0), .AInit(.ALitInt(0)),
      .Let(mk_local(1), .AAssign(mk_local(0), .ALitInt(1)),
        .Atom(.ALocal(mk_local(0))))),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  try assert_role(pf, 0, .Local)
  try assert_mono(pf, 0, MonoType.Int)
  try assert_role(pf, 1, .Local)
  .Ok({})
}

// Pattern local in match arm gets PatternLocal role with correct mono
// derived from the Optional scrutinee type.
fn test_pattern_local_in_match() Result<Void, String> {
  // case x { .Some(v) => v, .None => 0 }
  // L0: Option<Int> (param), L1: match result (Int), L2: pattern var v (Int)
  mono: Dict<Int, MonoType> = Dict.new()
  mono[1] = MonoType.Int
  func := mk_func_def(100, "unwrap",
    [Param.{ local: mk_local(0), ty: MonoType.Optional(MonoType.Int) }],
    MonoType.Int,
    .Let(mk_local(1), .AMatch(.ALocal(mk_local(0)), [
      AnfMatchArm.{
        pattern: .Variant(TypeId.{ id: -1 }, VariantId.{ id: 1 }, [.Var(mk_local(2))]),
        body: .Atom(.ALocal(mk_local(2))),
      },
      AnfMatchArm.{
        pattern: .Variant(TypeId.{ id: -1 }, VariantId.{ id: 0 }, []),
        body: .Atom(.ALitInt(0)),
      },
    ]),
    .Atom(.ALocal(mk_local(1)))),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  // L0: Param, L1: Local (let result), L2: PatternLocal with mono=Int
  try assert_role(pf, 0, .Param)
  try assert_role(pf, 1, .Local)
  try assert_role(pf, 2, .PatternLocal)
  try assert_mono(pf, 2, MonoType.Int)
  .Ok({})
}

// Wildcard and literal patterns don't introduce extra locals.
fn test_no_slots_for_non_binding_patterns() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[1] = MonoType.Void
  func := mk_func_def(100, "check",
    [Param.{ local: mk_local(0), ty: MonoType.Int }],
    MonoType.Void,
    .Let(mk_local(1), .AMatch(.ALocal(mk_local(0)), [
      AnfMatchArm.{ pattern: .LitInt(0), body: .Atom(.ALitVoid) },
      AnfMatchArm.{ pattern: .Wildcard, body: .Atom(.ALitVoid) },
    ]),
    .Atom(.ALitVoid)),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  // Only param L0 and let-result L1 — no phantom pattern locals
  try assert.equal(pf.captures.len(), 0)
  try assert.equal(pf.params.len(), 1)
  try assert.equal(pf.locals.len(), 1)
  .Ok({})
}

// source_local uniquely identifies each slot's semantic origin.
fn test_source_locals_are_unique() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[2] = MonoType.String
  mono[3] = MonoType.Bool
  func := mk_func_def(100, "f",
    [
      Param.{ local: mk_local(0), ty: MonoType.Int },
      Param.{ local: mk_local(1), ty: MonoType.Float },
    ],
    MonoType.Void,
    .Let(mk_local(2), .AInit(.ALitStr("hi")),
      .Let(mk_local(3), .AInit(.ALitBool(true)),
        .Atom(.ALitVoid))),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  seen: Dict<Int, Int> = Dict.new()
  for k in pf.slots.keys() {
    case pf.slots[k] {
      .Some(info) => {
        case seen[info.source_local.id] {
          .Some(other_sid) => {
            return assert.fail("L${info.source_local.id} appears in both slot ${other_sid} and slot ${info.slot.id}")
          },
          .None => { seen[info.source_local.id] = info.slot.id },
        }
      },
      .None => {},
    }
  }
  .Ok({})
}

// Nested locals under ADefer still need slots because prepare_backend runs
// after boundary insertion and defer elimination is later.
fn test_collects_locals_inside_defer_body() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[1] = MonoType.Void
  mono[2] = MonoType.Int
  mono[3] = MonoType.Void
  func := mk_func_def(100, "defer_locals",
    [],
    MonoType.Void,
    .Let(mk_local(1), .ADefer(
      .Let(mk_local(2), .AInit(.ALitInt(1)),
        .Let(mk_local(3), .AAssign(mk_local(2), .ALitInt(2)),
          .Atom(.ALitVoid)))),
      .Atom(.ALitVoid)),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  try assert_role(pf, 1, .Local)
  try assert_role(pf, 2, .Local)
  try assert_role(pf, 3, .Local)
  .Ok({})
}

// Closure free vars can reference locals declared earlier inside a match arm.
fn test_nested_pattern_scrutinee_uses_pattern_mono() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[1] = MonoType.Int
  func := mk_func_def(100, "nested_pattern_mono",
    [Param.{ local: mk_local(0), ty: MonoType.Optional(MonoType.Optional(MonoType.Int)) }],
    MonoType.Int,
    .Let(mk_local(1), .AMatch(.ALocal(mk_local(0)), [
      AnfMatchArm.{
        pattern: .Variant(TypeId.{ id: 0 }, VariantId.{ id: 1 }, [.Var(mk_local(2))]),
        body: .Let(mk_local(4), .AMatch(.ALocal(mk_local(2)), [
          AnfMatchArm.{
            pattern: .Variant(TypeId.{ id: 0 }, VariantId.{ id: 1 }, [.Var(mk_local(3))]),
            body: .Atom(.ALocal(mk_local(3))),
          },
          AnfMatchArm.{
            pattern: .Variant(TypeId.{ id: 0 }, VariantId.{ id: 0 }, []),
            body: .Atom(.ALitInt(0)),
          },
        ]),
          .Atom(.ALocal(mk_local(4)))),
      },
      AnfMatchArm.{
        pattern: .Variant(TypeId.{ id: 0 }, VariantId.{ id: 0 }, []),
        body: .Atom(.ALitInt(0)),
      },
    ]),
    .Atom(.ALocal(mk_local(1)))),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  try assert_role(pf, 2, .PatternLocal)
  try assert_role(pf, 3, .PatternLocal)
  try assert_mono(pf, 2, MonoType.Optional(MonoType.Int))
  try assert_mono(pf, 3, MonoType.Int)
  .Ok({})
}

fn test_collects_arm_locals_used_as_closure_free_vars() Result<Void, String> {
  mono: Dict<Int, MonoType> = Dict.new()
  mono[1] = MonoType.String
  mono[2] = MonoType.String
  mono[3] = MonoType.Function([], MonoType.String)
  mono[4] = MonoType.Function([], MonoType.String)
  mono[5] = MonoType.String
  mono[6] = MonoType.Function([], MonoType.String)
  func := mk_func_def(100, "arm_closure",
    [Param.{ local: mk_local(0), ty: MonoType.Bool }],
    MonoType.Function([], MonoType.String),
    .Let(mk_local(4), .AMatch(.ALocal(mk_local(0)), [
      AnfMatchArm.{
        pattern: .LitBool(true),
        body: .Let(mk_local(1), .AInit(.ALitStr("interp")),
          .Let(mk_local(2), .AInit(.ALocal(mk_local(1))),
            .Let(mk_local(3), .AMakeClosure(mk_func(999), [mk_local(2)]),
              .Atom(.ALocal(mk_local(3)))))),
      },
      AnfMatchArm.{
        pattern: .Wildcard,
        body: .Let(mk_local(5), .AInit(.ALitStr("wasm")),
          .Let(mk_local(6), .AMakeClosure(mk_func(999), [mk_local(5)]),
            .Atom(.ALocal(mk_local(6))))),
      },
    ]),
    .Atom(.ALocal(mk_local(4)))),
    mono,
  )
  pf := assign_slots(func, no_captures(), resolver.empty_env())

  try assert_role(pf, 2, .Local)
  try assert_role(pf, 3, .Local)
  try assert_role(pf, 5, .Local)
  try assert_role(pf, 6, .Local)
  .Ok({})
}

// ── Suite ────────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("slot assignment")
    .test("simple params and local", test_simple_params_and_local)
    .test("capture params precede declared params", test_capture_params_precede_declared_params)
    .test("multiple captures in order", test_multiple_captures_ordered)
    .test("never local is dead placeholder", test_dead_placeholder_for_never_local)
    .test("assign target is Local", test_assign_target_is_local)
    .test("pattern local in match arm", test_pattern_local_in_match)
    .test("no slots for non-binding patterns", test_no_slots_for_non_binding_patterns)
    .test("source locals are unique", test_source_locals_are_unique)
    .test("collects locals inside defer body", test_collects_locals_inside_defer_body)
    .test("nested pattern scrutinee uses pattern mono", test_nested_pattern_scrutinee_uses_pattern_mono)
    .test("collects arm locals used as closure free vars", test_collects_arm_locals_used_as_closure_free_vars)
}
