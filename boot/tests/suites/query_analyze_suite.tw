use compiler.base_env
use compiler.query.analyze
use compiler.query.cache
use lib.source.identity
use lib.source.overlay
use tests.assert
use tests.runner

fn ov_doc(path: String, text: String) overlay.OverlayDocument {
  .{ identity: identity.from_path(path), text, version: .Some(1) }
}

pub fn suite() runner.Suite {
  runner
    .suite("query analyze (shared path)")
    .test(
      "single module analysis succeeds via overlay",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "pub fn answer() Int { 42 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(result.ok)
        try assert.equal(result.diagnostics.len(), 0)
        try assert.is_true(result.state.exports.has("/tmp/analyze/main.tw"))
        .Ok({})
      },
    )
    .test(
      "cross-module analysis resolves imports via overlay",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use dep\nx := dep.answer()\n"),
          ov_doc("/tmp/analyze/dep.tw", "pub fn answer() Int { 42 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(result.ok)
        try assert.equal(result.diagnostics.len(), 0)
        try assert.is_true(result.state.exports.has("/tmp/analyze/dep.tw"))
        try assert.is_true(result.state.exports.has("/tmp/analyze/main.tw"))
        .Ok({})
      },
    )
    .test(
      "analysis rejects value-initialization import cycles",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/a.tw", "use b\npub av := b.bv + 1\n"),
          ov_doc("/tmp/analyze/b.tw", "use a\npub bv := a.av + 1\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/a.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        msg := result.diagnostics[0].kind.message()
        try assert.str_contains(msg, "initialization cycle")
        .Ok({})
      },
    )
    .test(
      "analysis reports parse errors",
      fn() {
        ov := overlay.from_documents([ov_doc("/tmp/analyze/bad.tw", "fn f( {")])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/bad.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "parse")
        .Ok({})
      },
    )
    .test(
      "analysis reports typecheck errors",
      fn() {
        ov := overlay.from_documents([ov_doc("/tmp/analyze/err.tw", "fn answer() String { 42 }")])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/err.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "check")
        .Ok({})
      },
    )
    .test(
      "a failed module is analyzed once across multiple paths (no re-walk blowup)",
      fn() {
        // Diamond: main -> {a, b} -> broken. `broken` fails to resolve. The
        // failure must be memoized so it is reported exactly once, not once per
        // path. Without memoization this re-walks broken per path — the source
        // of an exponential hang on large graphs.
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use a\nuse b\nx := a.x() + b.x()\n"),
          ov_doc("/tmp/analyze/a.tw", "use broken\npub fn x() Int { broken.x() }\n"),
          ov_doc("/tmp/analyze/b.tw", "use broken\npub fn x() Int { broken.x() }\n"),
          ov_doc("/tmp/analyze/broken.tw", "pub fn x() Int { nope }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.equal(result.diagnostics.len(), 1)
        try assert.is_true(result.state.failed.has("/tmp/analyze/broken.tw"))
        .Ok({})
      },
    )
    .test(
      "analysis caches stages on re-analysis",
      fn() {
        ov := overlay.from_documents([ov_doc("/tmp/analyze/cached.tw", "x := 1\n")])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/cached.tw")
        first := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(first.ok)

        // Re-analyze with same source — should get cache hits
        state2 := analyze.new_state(base_env.builtin_env(), first.state.cache, ov, "/tmp/analyze")
        second := analyze.analyze_module(id, base_env.builtin_env(), state2)
        try assert.is_true(second.ok)
        stats := cache.get_stats(second.state.cache)
        try assert.is_true(stats.parse_hits > 0)
        try assert.is_true(stats.resolve_hits > 0)
        try assert.is_true(stats.typecheck_hits > 0)
        .Ok({})
      },
    )
    .test(
      "analysis tracks module order for downstream consumers",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use dep\nx := dep.answer()\n"),
          ov_doc("/tmp/analyze/dep.tw", "pub fn answer() Int { 42 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(result.ok)

        // dep should come before main (dependency order), with bundled prelude modules allowed.
        dep_index := -1
        main_index := -1
        i := 0

        for p in result.state.module_order {
          if p == "/tmp/analyze/dep.tw" {
            dep_index = i
          }

          if p == "/tmp/analyze/main.tw" {
            main_index = i
          }

          i = i + 1
        }

        try assert.is_true(dep_index >= 0)
        try assert.is_true(main_index >= 0)
        try assert.is_true(dep_index < main_index)
        .Ok({})
      },
    )
    .test(
      "dep typecheck error reports diagnostic with dep path",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use dep\nx := dep.answer()\n"),
          ov_doc("/tmp/analyze/dep.tw", "pub fn answer() String { 42 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)

        // Diagnostic should point to the dep file, not the entry
        try assert.equal(result.diagnostics[0].identity.path, "/tmp/analyze/dep.tw")
        try assert.equal(result.diagnostics[0].stage, "check")
        try assert.is_true(result.diagnostics[0].kind.span().start >= 0)
        .Ok({})
      },
    )
    .test(
      "missing dep reports source error",
      fn() {
        ov := overlay.from_documents([ov_doc("/tmp/analyze/main.tw", "use missing\nx := 1\n")])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "import")
        .Ok({})
      },
    )
    .test(
      "missing dep diagnostic span points to the use statement",
      fn() {
        // "use missing" occupies bytes 0..11; span.end should be > 0, not the
        // old zero sentinel that was emitted before import spans were tracked.
        ov := overlay.from_documents([ov_doc("/tmp/analyze/main.tw", "use missing\nx := 1\n")])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        d := result.diagnostics[0]

        // Identity should be the importing file
        try assert.equal(d.identity.path, "/tmp/analyze/main.tw")

        // Span should be non-zero (points to `use missing`, not the old zero sentinel)
        try assert.is_true(d.kind.span().end > 0)
        .Ok({})
      },
    )
    .test(
      "circular import diagnostic points to importing file's use statement",
      fn() {
        // a.tw has `use b` at bytes 0..5; b.tw has `use a` at bytes 0..5.
        // A value-initialization cycle is detected when b tries to re-import a.
        // Diagnostic should be attributed to b.tw at its `use a` span.
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/a.tw", "use b\npub av := b.bv + 1\n"),
          ov_doc("/tmp/analyze/b.tw", "use a\npub bv := a.av + 1\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/a.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        d := result.diagnostics[0]

        // b.tw triggers the circular detection when it imports a.tw
        try assert.equal(d.identity.path, "/tmp/analyze/b.tw")

        // Span should point to `use a` in b.tw, not the zero sentinel
        try assert.is_true(d.kind.span().end > 0)
        .Ok({})
      },
    )
    .test(
      "user modules cannot define reserved stdlib View type",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "type View = .{ value: Int }\nx := 1\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "resolve")
        try assert.str_contains(result.diagnostics[0].kind.message(), "reserved")
        try assert.str_contains(result.diagnostics[0].kind.message(), "View")
        .Ok({})
      },
    )
    .test(
      "module_runners populated for all analyzed modules",
      fn() {
        ov := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use dep\nx := dep.answer()\n"),
          ov_doc("/tmp/analyze/dep.tw", "pub fn answer() Int { 42 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(result.ok)

        // Every module in module_order should have a runner
        for mod_path in result.state.module_order {
          try assert.is_true(result.state.module_runners.has(mod_path))
        }

        .Ok({})
      },
    )
    .test(
      "cycle sibling edit invalidates every group member",
      fn() {
        ov1 := overlay.from_documents([
          ov_doc(
            "/tmp/analyze/cyc_a.tw",
            "use cyc_b\npub fn a(n: Int) Int { if n == 0 { 0 } else { cyc_b.b(n - 1) + 1 } }\n",
          ),
          ov_doc(
            "/tmp/analyze/cyc_b.tw",
            "use cyc_a\npub fn b(n: Int) Int { if n == 0 { 0 } else { cyc_a.a(n - 1) + 1 } }\n",
          ),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov1, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/cyc_a.tw")
        first := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(first.ok)
        first_a_typed := cache.changed_at(first.state.cache, "/tmp/analyze/cyc_a.tw", .Typed)

        ov2 := overlay.from_documents([
          ov_doc(
            "/tmp/analyze/cyc_a.tw",
            "use cyc_b\npub fn a(n: Int) Int { if n == 0 { 0 } else { cyc_b.b(n - 1) + 1 } }\n",
          ),
          ov_doc(
            "/tmp/analyze/cyc_b.tw",
            "use cyc_a\npub fn b(n: Int) Int { if n == 0 { 1 } else { cyc_a.a(n - 1) + 1 } }\n",
          ),
        ])
        state2 := analyze.new_state(base_env.builtin_env(), first.state.cache, ov2, "/tmp/analyze")
        second := analyze.analyze_module(id, base_env.builtin_env(), state2)
        try assert.is_true(second.ok)
        try assert.is_true(
          cache.changed_at(second.state.cache, "/tmp/analyze/cyc_a.tw", .Typed) != first_a_typed,
        )
        .Ok({})
      },
    )
    .test(
      "group with failed external dep reports only dependency diagnostics",
      fn() {
        ov := overlay.from_documents([
          ov_doc(
            "/tmp/analyze/group_ext_a.tw",
            "use group_ext_b\nuse broken\npub type A = .{ b: group_ext_b.B }\npub fn f() Int { broken.nope() }\n",
          ),
          ov_doc(
            "/tmp/analyze/group_ext_b.tw",
            "use group_ext_a\npub type B = .{ a: group_ext_a.A }\n",
          ),
          ov_doc("/tmp/analyze/broken.tw", "pub fn nope() Int { missing }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/group_ext_a.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.equal(result.diagnostics.len(), 1)
        try assert.equal(result.diagnostics[0].identity.path, "/tmp/analyze/broken.tw")
        .Ok({})
      },
    )
    .test(
      "group members reject reserved stdlib type shadowing",
      fn() {
        ov := overlay.from_documents([
          ov_doc(
            "/tmp/analyze/reserved_cycle_a.tw",
            "use reserved_cycle_b\npub type View = .{ x: Int }\npub fn f(v: reserved_cycle_b.B) Int { 1 }\n",
          ),
          ov_doc(
            "/tmp/analyze/reserved_cycle_b.tw",
            "use reserved_cycle_a\npub type B = .{ x: Int }\npub fn g(v: reserved_cycle_a.View<Int>) Int { 2 }\n",
          ),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/reserved_cycle_a.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "resolve")
        try assert.str_contains(result.diagnostics[0].kind.message(), "reserved")
        .Ok({})
      },
    )
    .test(
      "failed group does not publish partial member interfaces",
      fn() {
        ov := overlay.from_documents([
          ov_doc(
            "/tmp/analyze/partial_group_a.tw",
            "use partial_group_b\npub type A = .{ b: partial_group_b.B }\npub fn bad() Int { missing }\n",
          ),
          ov_doc(
            "/tmp/analyze/partial_group_b.tw",
            "use partial_group_a\npub type B = .{ a: partial_group_a.A }\npub fn ok() Int { 1 }\n",
          ),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/partial_group_a.tw")
        result := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_false(result.ok)
        try assert.is_false(result.state.exports.has("/tmp/analyze/partial_group_a.tw"))
        try assert.is_false(result.state.exports.has("/tmp/analyze/partial_group_b.tw"))
        try assert.is_false(result.state.module_order.contains("/tmp/analyze/partial_group_a.tw"))
        try assert.is_false(result.state.module_order.contains("/tmp/analyze/partial_group_b.tw"))
        .Ok({})
      },
    )
    .test(
      "early cutoff: dep body change preserves importer cache hits",
      fn() {
        ov1 := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use helper\nx := helper.value()\n"),
          ov_doc("/tmp/analyze/helper.tw", "pub fn value() Int { 1 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov1, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        first := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(first.ok)

        // Change dep body but keep same signature
        ov2 := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use helper\nx := helper.value()\n"),
          ov_doc("/tmp/analyze/helper.tw", "pub fn value() Int { 999 }\n"),
        ])
        state2 := analyze.new_state(base_env.builtin_env(), first.state.cache, ov2, "/tmp/analyze")
        second := analyze.analyze_module(id, base_env.builtin_env(), state2)
        try assert.is_true(second.ok)
        stats := cache.get_stats(second.state.cache)

        // Importer should get resolve+typecheck cache hits
        try assert.is_true(stats.resolve_hits > 0)
        try assert.is_true(stats.typecheck_hits > 0)
        .Ok({})
      },
    )
    .test(
      "early cutoff: dep export change invalidates importer typecheck",
      fn() {
        ov1 := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use helper\nx: Int = helper.value()\n"),
          ov_doc("/tmp/analyze/helper.tw", "pub fn value() Int { 1 }\n"),
        ])
        state := analyze.new_state(base_env.builtin_env(), cache.empty(), ov1, "/tmp/analyze")
        id := identity.from_path("/tmp/analyze/main.tw")
        first := analyze.analyze_module(id, base_env.builtin_env(), state)
        try assert.is_true(first.ok)
        first_changed := cache.changed_at(first.state.cache, "/tmp/analyze/main.tw", .Typed)
        ov2 := overlay.from_documents([
          ov_doc("/tmp/analyze/main.tw", "use helper\nx: Int = helper.value()\n"),
          ov_doc("/tmp/analyze/helper.tw", "pub fn value() String { \"one\" }\n"),
        ])
        state2 := analyze.new_state(base_env.builtin_env(), first.state.cache, ov2, "/tmp/analyze")
        second := analyze.analyze_module(id, base_env.builtin_env(), state2)
        try assert.is_false(second.ok)
        try assert.is_true(second.diagnostics.len() > 0)
        try assert.is_true(
          cache.changed_at(second.state.cache, "/tmp/analyze/main.tw", .Typed) != first_changed,
        )
        .Ok({})
      },
    )
}
