use @std.proc
use tests.runner
use tests.assert
use compiler.query.cache
use compiler.query.diagnostics
use compiler.query.semantic

fn input(text: String) diagnostics.DocumentInput {
  .{ uri: "file:///main.tw", text, version: .Some(1) }
}

fn doc(uri: String, text: String, version: Int) diagnostics.DocumentInput {
  .{ uri, text, version: .Some(version) }
}

pub fn suite() runner.Suite {
  runner.suite("query diagnostics")
    .test("clean document has no diagnostics", fn() {
      result := diagnostics.analyze_document(cache.empty(), input("x := 1\n"))
      try assert.int_eq(result.diagnostics.len(), 0)
      .Ok({})
    })
    .test("reports parse diagnostics", fn() {
      result := diagnostics.analyze_document(cache.empty(), input("fn f( {"))
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.str_eq(result.diagnostics[0].stage, "parse")
      try assert.str_eq(result.diagnostics[0].uri, "file:///main.tw")
      try assert.int_eq(try result.diagnostics[0].version.ok_or("missing version"), 1)
      .Ok({})
    })
    .test("reports resolve diagnostics", fn() {
      result := diagnostics.analyze_document(cache.empty(), input("fn f(x: Missing) Void { }"))
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.str_eq(result.diagnostics[0].stage, "resolve")
      try assert.str_contains(result.diagnostics[0].message, "undefined type")
      .Ok({})
    })
    .test("reports typecheck diagnostics", fn() {
      result := diagnostics.analyze_document(cache.empty(), input("fn answer() String { 42 }"))
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.str_eq(result.diagnostics[0].stage, "check")
      try assert.str_contains(result.diagnostics[0].message, "type mismatch")
      .Ok({})
    })
    .test("semantic snapshot exposes parsed resolved and typed artifacts", fn() {
      entry := "file:///tmp/semantic-main.tw"
      result := semantic.snapshot_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp",
        open_documents: [doc(entry, "fn answer() Int { 42 }\nx := answer()\n", 5)],
      })
      try assert.is_true(result.ok)
      try assert.is_some(result.parsed)
      try assert.is_some(result.resolved)
      try assert.is_some(result.typed)
      try assert.int_eq(try result.version.ok_or("missing version"), 5)
      .Ok({})
    })
    .test("semantic snapshot preserves partial artifacts on errors", fn() {
      entry := "file:///tmp/semantic-error.tw"
      result := semantic.snapshot(cache.empty(), doc(entry, "fn answer() Missing { 42 }\n", 1))
      try assert.is_false(result.ok)
      try assert.is_some(result.parsed)
      try assert.is_some(result.resolved)
      try assert.is_none(result.typed)
      try assert.is_true(result.diagnostics.len() > 0)
      .Ok({})
    })
    .test("semantic snapshot stays usable across edits", fn() {
      entry := "file:///tmp/semantic-edit.tw"
      first := semantic.snapshot(cache.empty(), doc(entry, "fn answer() Int { 1 }\n", 1))
      second := semantic.snapshot(first.cache, doc(entry, "fn answer() Int { 2 }\n", 2))
      try assert.is_true(second.ok)
      try assert.int_eq(try second.version.ok_or("missing version"), 2)
      sym := try semantic.symbol_at_position(second, 4).ok_or("missing symbol")
      try assert.str_eq(sym.name, "answer")
      .Ok({})
    })
    .test("semantic snapshot finds symbols and enclosing syntax by byte offset", fn() {
      entry := "file:///tmp/semantic-symbol.tw"
      result := semantic.snapshot(cache.empty(), doc(entry, "type Point = .{ x: Int }\nfn answer() Int { 42 }\ny := answer()\n", 1))
      sym := try semantic.symbol_at_position(result, 31).ok_or("missing symbol")
      try assert.str_eq(sym.name, "answer")
      syntax := try semantic.enclosing_syntax(result, 55).ok_or("missing syntax")
      try assert.str_eq(syntax.kind, "let")
      .Ok({})
    })
    .test("reuses cached stages on second analysis", fn() {
      first := diagnostics.analyze_document(cache.empty(), input("x := 1\n"))
      second := diagnostics.analyze_document(first.cache, input("x := 1\n"))
      try assert.int_eq(second.diagnostics.len(), 0)
      stats := cache.get_stats(second.cache)
      try assert.int_eq(stats.parse_hits, 1)
      try assert.int_eq(stats.resolve_hits, 1)
      try assert.int_eq(stats.typecheck_hits, 1)
      .Ok({})
    })
    .test("workspace diagnostics use imported overlay module exports", fn() {
      entry := "file:///tmp/twinkle-query-main.tw"
      dep := "file:///tmp/dep.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp",
        open_documents: [
          doc(entry, "use dep\nx := dep.answer()\n", 1),
          doc(dep, "pub fn answer() Int { 42 }\n", 1),
        ],
      })
      try assert.int_eq(result.diagnostics.len(), 0)
      .Ok({})
    })
    .test("workspace diagnostics resolve relative overlay imports", fn() {
      entry := "file:///tmp/twinkle-query-main.tw"
      dep := "file:///tmp/dep.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp",
        open_documents: [
          doc(entry, "use .dep\nx := dep.answer()\n", 1),
          doc(dep, "pub fn answer() Int { 42 }\n", 1),
        ],
      })
      try assert.int_eq(result.diagnostics.len(), 0)
      .Ok({})
    })
    .test("workspace diagnostics resolve stdlib imports from disk", fn() {
      root := "${proc.cwd()}/boot"
      entry := "file:///tmp/twinkle-query-main.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: root,
        open_documents: [doc(entry, "use @std.path\nx := path.join(\"a\", \"b\")\n", 1)],
      })
      try assert.int_eq(result.diagnostics.len(), 0)
      .Ok({})
    })
    .test("workspace cache reuses unchanged dependency stages after entry edit", fn() {
      entry := "file:///tmp/twinkle-query-cache/main.tw"
      dep := "file:///tmp/twinkle-query-cache/cache_dep.tw"
      first := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp/twinkle-query-cache",
        open_documents: [
          doc(entry, "use cache_dep as dep\nx := dep.answer()\n", 1),
          doc(dep, "pub fn answer() Int { 42 }\n", 1),
        ],
      })
      second := diagnostics.analyze_workspace(first.cache, .{
        entry_uri: entry,
        project_root: "/tmp/twinkle-query-cache",
        open_documents: [
          doc(entry, "use cache_dep as dep\nx := dep.answer()\ny := 1\n", 2),
          doc(dep, "pub fn answer() Int { 42 }\n", 1),
        ],
      })
      try assert.int_eq(second.diagnostics.len(), 0)
      stats := cache.get_stats(second.cache)
      try assert.is_true(stats.parse_hits > 0)
      try assert.is_true(stats.resolve_hits > 0)
      try assert.is_true(stats.typecheck_hits > 0)
      .Ok({})
    })
    .test("workspace cache invalidates importer semantics after dependency edit", fn() {
      entry := "file:///tmp/twinkle-query-cache/main.tw"
      dep := "file:///tmp/twinkle-query-cache/cache_dep.tw"
      first := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp/twinkle-query-cache",
        open_documents: [
          doc(entry, "use cache_dep as dep\nx: Int = dep.answer()\n", 1),
          doc(dep, "pub fn answer() Int { 42 }\n", 1),
        ],
      })
      second := diagnostics.analyze_workspace(first.cache, .{
        entry_uri: entry,
        project_root: "/tmp/twinkle-query-cache",
        open_documents: [
          doc(entry, "use cache_dep as dep\nx: Int = dep.answer()\n", 1),
          doc(dep, "pub fn answer() String { \"nope\" }\n", 2),
        ],
      })
      try assert.is_true(second.diagnostics.len() > 0)
      stats := cache.get_stats(second.cache)
      try assert.is_true(stats.parse_hits > 0)
      try assert.int_eq(stats.resolve_hits, 0)
      try assert.int_eq(stats.typecheck_hits, 0)
      .Ok({})
    })
    .test("workspace diagnostics groups results by uri and includes clean open docs", fn() {
      entry := "file:///tmp/twinkle-query-main.tw"
      dep := "file:///tmp/dep.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp",
        open_documents: [
          doc(entry, "use dep\nx: Int = dep.answer()\n", 1),
          doc(dep, "pub fn answer() String { \"nope\" }\n", 2),
        ],
      })
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.int_eq(result.diagnostics_by_uri.len(), 2)
      for group in result.diagnostics_by_uri {
        if group.uri == entry {
          try assert.is_true(group.diagnostics.len() > 0)
        }
        if group.uri == dep {
          try assert.int_eq(group.diagnostics.len(), 0)
        }
      }
      .Ok({})
    })
    .test("workspace diagnostics report dependency errors on dependency uri", fn() {
      entry := "file:///tmp/twinkle-query-main.tw"
      dep := "file:///tmp/dep.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp",
        open_documents: [
          doc(entry, "use dep\nx := dep.answer()\n", 1),
          doc(dep, "pub fn answer() String { 42 }\n", 3),
        ],
      })
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.str_eq(result.diagnostics[0].uri, dep)
      try assert.str_eq(result.diagnostics[0].stage, "check")
      try assert.int_eq(try result.diagnostics[0].version.ok_or("missing version"), 3)
      .Ok({})
    })
    .test("workspace diagnostics report missing imports without crashing", fn() {
      entry := "file:///tmp/twinkle-query-main.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: entry,
        project_root: "/tmp",
        open_documents: [doc(entry, "use missing\nx := 1\n", 2)],
      })
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.str_eq(result.diagnostics[0].uri, entry)
      try assert.str_eq(result.diagnostics[0].stage, "import")
      try assert.str_contains(result.diagnostics[0].message, "Cannot resolve module")
      .Ok({})
    })
    .test("workspace diagnostics report import cycles without crashing", fn() {
      a := "file:///tmp/a.tw"
      b := "file:///tmp/b.tw"
      result := diagnostics.analyze_workspace(cache.empty(), .{
        entry_uri: a,
        project_root: "/tmp",
        open_documents: [
          doc(a, "use b\npub fn a() Int { b.b() }\n", 1),
          doc(b, "use a\npub fn b() Int { a.a() }\n", 1),
        ],
      })
      try assert.is_true(result.diagnostics.len() > 0)
      try assert.str_eq(result.diagnostics[0].stage, "import")
      try assert.str_contains(result.diagnostics[0].message, "Circular import")
      .Ok({})
    })
}
