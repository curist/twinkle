use @std.proc

use compiler.query.cache
use compiler.query.diagnostics
use compiler.query.progress
use compiler.query.semantic
use lib.json
use tests.assert
use tests.runner

fn stage_tag(stage: progress.AnalysisStage) String {
  case stage {
    .Loading => "loading",
    .Parsing => "parsing",
    .PlanningImports => "planning",
    .AnalyzingDependencies => "deps",
    .Resolving => "resolving",
    .Publishing => "publishing",
  }
}

fn input(text: String) diagnostics.DocumentInput {
  .{ uri: "file:///main.tw", text, version: .Some(1) }
}

fn doc(uri: String, text: String, version: Int) diagnostics.DocumentInput {
  .{ uri, text, version: .Some(version) }
}

pub fn suite() runner.Suite {
  runner
    .suite("query diagnostics")
    .test(
      "clean document has no diagnostics",
      fn() {
        result := diagnostics.analyze_document(cache.empty(), input("x := 1\n"))
        try assert.equal(result.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "reports parse diagnostics",
      fn() {
        result := diagnostics.analyze_document(cache.empty(), input("fn f( {"))
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "parse")
        try assert.equal(result.diagnostics[0].uri, "file:///main.tw")
        try assert.equal(try result.diagnostics[0].version.ok_or("missing version"), 1)
        .Ok({})
      },
    )
    .test(
      "reports resolve diagnostics",
      fn() {
        result := diagnostics.analyze_document(cache.empty(), input("fn f(x: Missing) Void { }"))
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "resolve")
        try assert.str_contains(result.diagnostics[0].message, "undefined type")
        .Ok({})
      },
    )
    .test(
      "reports typecheck diagnostics",
      fn() {
        result := diagnostics.analyze_document(cache.empty(), input("fn answer() String { 42 }"))
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "check")
        try assert.str_contains(result.diagnostics[0].message, "type mismatch")
        .Ok({})
      },
    )
    .test(
      "absent-method error survives a top-level let type correction",
      fn() {
        // Regression: `a := make()` calls an unannotated function, so `a`'s type
        // is a fresh metavar in checker Pass 1 and only resolved to `Int` in
        // Pass 3 — flipping `any_type_updated`. That used to truncate the Pass-3
        // diagnostics, silently dropping the real "no method" error on the
        // following let (and, for a generic stdlib receiver like `View`, letting
        // the unresolved call crash lowering). The error must survive.
        result := diagnostics.analyze_document(
          cache.empty(),
          input("fn make() {\n  42\n}\na := make()\nb := a.bogus()\n"),
        )
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "check")
        try assert.str_contains(result.diagnostics[0].message, "no method")
        .Ok({})
      },
    )
    .test(
      "qualified Option and Result variant constructors type-check",
      fn() {
        // Option/Result are both builtin type names and module aliases; the
        // qualified constructor form must resolve to the canonical Optional /
        // Result types rather than erroring or producing a Named type.
        for src in [
          "fn f() Int? { Option.Some(1) }\n",
          "fn f() Int? { Option.None }\n",
          "fn f() Result<Int, String> { Result.Ok(1) }\n",
          "fn f() Result<Int, String> { Result.Err(\"e\") }\n",
        ] {
          result := diagnostics.analyze_document(cache.empty(), input(src))
          try assert.equal(result.diagnostics.len(), 0)
        }
        .Ok({})
      },
    )
    .test(
      "qualified builtin variant constructor still rejects unknown variants",
      fn() {
        result := diagnostics.analyze_document(
          cache.empty(),
          input("fn f() Int? { Option.Nope(1) }\n"),
        )
        try assert.is_true(result.diagnostics.len() > 0)
        .Ok({})
      },
    )
    .test(
      "semantic snapshot exposes parsed resolved and typed artifacts",
      fn() {
        entry := "file:///tmp/semantic-main.tw"
        result := semantic.snapshot_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [doc(entry, "fn answer() Int { 42 }\nx := answer()\n", 5)],
          },
        )
        try assert.is_true(result.ok)
        try assert.is_some(result.parsed)
        try assert.is_some(result.resolved)
        try assert.is_some(result.typed)
        try assert.equal(try result.version.ok_or("missing version"), 5)
        .Ok({})
      },
    )
    .test(
      "semantic snapshot preserves partial artifacts on errors",
      fn() {
        entry := "file:///tmp/semantic-error.tw"
        result := semantic.snapshot(cache.empty(), doc(entry, "fn answer() Missing { 42 }\n", 1))
        try assert.is_false(result.ok)
        try assert.is_some(result.parsed)
        try assert.is_some(result.resolved)
        try assert.is_none(result.typed)
        try assert.is_true(result.diagnostics.len() > 0)
        .Ok({})
      },
    )
    .test(
      "workspace semantic snapshot drops stale entry semantics when a dependency fails",
      fn() {
        entry := "file:///tmp/semantic-workspace/main.tw"
        dep := "file:///tmp/semantic-workspace/dep.tw"
        first := semantic.snapshot_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/semantic-workspace",
            open_documents: [
              doc(entry, "use dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
        )
        try assert.is_true(first.ok)
        try assert.is_some(first.typed)
        second := semantic.snapshot_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/semantic-workspace",
            open_documents: [
              doc(entry, "use dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() String { 42 }\n", 2),
            ],
          },
        )
        try assert.is_false(second.ok)
        try assert.is_some(second.parsed)
        try assert.is_none(second.resolved)
        try assert.is_none(second.typed)
        .Ok({})
      },
    )
    .test(
      "semantic snapshot stays usable across edits",
      fn() {
        entry := "file:///tmp/semantic-edit.tw"
        first := semantic.snapshot(cache.empty(), doc(entry, "fn answer() Int { 1 }\n", 1))
        second := semantic.snapshot(first.cache, doc(entry, "fn answer() Int { 2 }\n", 2))
        try assert.is_true(second.ok)
        try assert.equal(try second.version.ok_or("missing version"), 2)
        sym := try second.symbol_at_position(4).ok_or("missing symbol")
        try assert.equal(sym.name, "answer")
        .Ok({})
      },
    )
    .test(
      "semantic snapshot finds symbols and enclosing syntax by byte offset",
      fn() {
        entry := "file:///tmp/semantic-symbol.tw"
        result := semantic.snapshot(
          cache.empty(),
          doc(entry, "type Point = .{ x: Int }\nfn answer() Int { 42 }\ny := answer()\n", 1),
        )
        sym := try result.symbol_at_position(31).ok_or("missing symbol")
        try assert.equal(sym.name, "answer")
        syntax := try result.enclosing_syntax(55).ok_or("missing syntax")
        try assert.equal(syntax.kind, "let")
        .Ok({})
      },
    )
    .test(
      "analyze_parse reports parse diagnostics",
      fn() {
        result := diagnostics.analyze_parse(cache.empty(), input("fn f( {"))
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "parse")
        try assert.equal(result.diagnostics[0].uri, "file:///main.tw")
        try assert.equal(try result.diagnostics[0].version.ok_or("missing version"), 1)
        .Ok({})
      },
    )
    .test(
      "analyze_parse ignores type errors (no false positives)",
      fn() {
        // analyze_document flags this as a "check" type mismatch; parse-only must not.
        result := diagnostics.analyze_parse(cache.empty(), input("fn answer() String { 42 }"))
        try assert.equal(result.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "reuses cached stages on second analysis",
      fn() {
        first := diagnostics.analyze_document(cache.empty(), input("x := 1\n"))
        second := diagnostics.analyze_document(first.cache, input("x := 1\n"))
        try assert.equal(second.diagnostics.len(), 0)
        stats := second.cache.get_stats()
        try assert.equal(stats.parse_hits, 1)
        try assert.equal(stats.resolve_hits, 1)
        try assert.equal(stats.typecheck_hits, 1)
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics use imported overlay module exports",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        dep := "file:///tmp/dep.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [
              doc(entry, "use dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )
        try assert.equal(result.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "progress-aware workspace analysis emits module stage events",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        dep := "file:///tmp/dep.tw"
        events := Cell.new([])
        result := diagnostics.analyze_workspace_with_progress(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [
              doc(entry, "use dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
          .Some(
            fn(ev) {
              events.set(events.get().append("${stage_tag(ev.stage)}:${ev.module}"))
            },
          ),
        )
        try assert.equal(result.diagnostics.len(), 0)
        seen := events.get()

        // Both the entry and its dependency should have emitted stage events.
        try assert.is_true(seen.len() > 0)

        modules: Dict<String, Bool> = Dict.new()
        saw_parsing := false
        saw_resolving := false

        for tag in seen {
          parts := tag.split(":")
          module := parts[1]
          modules[module] = true

          // Module names must be display-friendly, not absolute paths.
          try assert.is_false(module.starts_with("/"))

          if parts[0] == "parsing" {
            saw_parsing = true
          }

          if parts[0] == "resolving" {
            saw_resolving = true
          }
        }
        try assert.is_true(saw_parsing)
        try assert.is_true(saw_resolving)

        // Entry plus dependency = at least two distinct modules.
        try assert.is_true(modules.keys().len() >= 2)

        // The workspace entry shows relative to its project root.
        try assert.is_true(modules.has("twinkle-query-main.tw"))
        .Ok({})
      },
    )
    .test(
      "plain workspace analysis still works without a progress sink",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{ entry_uri: entry, project_root: "/tmp", open_documents: [doc(entry, "x := 1\n", 1)] },
          .None,
        )
        try assert.equal(result.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics resolve relative overlay imports",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        dep := "file:///tmp/dep.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [
              doc(entry, "use .dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )
        try assert.equal(result.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics resolve stdlib imports from disk",
      fn() {
        root := "${proc.cwd()}/boot"
        entry := "file:///tmp/twinkle-query-main.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: root,
            open_documents: [doc(entry, "use @std.path\nx := path.join(\"a\", \"b\")\n", 1)],
          },
          .None,
        )
        try assert.equal(result.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "workspace cache reuses unchanged dependency stages after entry edit",
      fn() {
        entry := "file:///tmp/twinkle-query-cache/main.tw"
        dep := "file:///tmp/twinkle-query-cache/cache_dep.tw"
        first := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-cache",
            open_documents: [
              doc(entry, "use cache_dep as dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )
        second := diagnostics.analyze_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-cache",
            open_documents: [
              doc(entry, "use cache_dep as dep\nx := dep.answer()\ny := 1\n", 2),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )
        try assert.equal(second.diagnostics.len(), 0)
        stats := second.cache.get_stats()
        try assert.is_true(stats.parse_hits > 0)
        try assert.is_true(stats.resolve_hits > 0)
        try assert.is_true(stats.typecheck_hits > 0)
        .Ok({})
      },
    )
    .test(
      "workspace cache invalidates importer semantics after dependency edit",
      fn() {
        entry := "file:///tmp/twinkle-query-cache/main.tw"
        dep := "file:///tmp/twinkle-query-cache/cache_dep.tw"
        first := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-cache",
            open_documents: [
              doc(entry, "use cache_dep as dep\nx: Int = dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )
        second := diagnostics.analyze_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-cache",
            open_documents: [
              doc(entry, "use cache_dep as dep\nx: Int = dep.answer()\n", 1),
              doc(dep, "pub fn answer() String { \"nope\" }\n", 2),
            ],
          },
          .None,
        )
        try assert.is_true(second.diagnostics.len() > 0)
        stats := second.cache.get_stats()
        try assert.is_true(stats.parse_hits > 0)
        try assert.is_true(stats.resolve_misses > 0)
        try assert.is_true(stats.typecheck_misses > 0)
        .Ok({})
      },
    )
    .test(
      "closure snapshot reuse stays correct across an entry edit",
      fn() {
        entry := "file:///tmp/twinkle-query-snap/main.tw"
        dep := "file:///tmp/twinkle-query-snap/snap_dep.tw"
        first := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-snap",
            open_documents: [
              doc(entry, "use snap_dep as dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )
        try assert.equal(first.diagnostics.len(), 0)

        // A snapshot was captured for the entry.
        try assert.is_true(case first.snapshot {
          .Some(_) => true,
          .None => false,
        })

        // Re-analyze the same entry with the snapshot; the dependency is
        // unchanged so it must short-circuit and stay clean.
        second := diagnostics.analyze_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-snap",
            open_documents: [
              doc(entry, "use snap_dep as dep\nx := dep.answer()\ny := 1\n", 2),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          first.snapshot,
        )
        try assert.equal(second.diagnostics.len(), 0)
        .Ok({})
      },
    )
    .test(
      "closure snapshot reuse still reports entry errors",
      fn() {
        entry := "file:///tmp/twinkle-query-snap/main.tw"
        dep := "file:///tmp/twinkle-query-snap/snap_dep.tw"
        first := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-snap",
            open_documents: [
              doc(entry, "use snap_dep as dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )

        // Edit the entry to reference an undefined name; the reused snapshot
        // must not mask the freshly introduced entry error.
        second := diagnostics.analyze_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-snap",
            open_documents: [
              doc(entry, "use snap_dep as dep\nx := undefined_entry_name()\n", 2),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          first.snapshot,
        )
        try assert.is_true(second.diagnostics.len() > 0)
        .Ok({})
      },
    )
    .test(
      "closure snapshot busts when a dependency changes",
      fn() {
        entry := "file:///tmp/twinkle-query-snap/main.tw"
        dep := "file:///tmp/twinkle-query-snap/snap_dep.tw"
        first := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-snap",
            open_documents: [
              doc(entry, "use snap_dep as dep\nx: Int = dep.answer()\n", 1),
              doc(dep, "pub fn answer() Int { 42 }\n", 1),
            ],
          },
          .None,
        )

        // The dependency's return type changes; passing the stale snapshot must
        // not reuse it (the closure module changed), so the type error surfaces.
        second := diagnostics.analyze_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-query-snap",
            open_documents: [
              doc(entry, "use snap_dep as dep\nx: Int = dep.answer()\n", 1),
              doc(dep, "pub fn answer() String { \"nope\" }\n", 2),
            ],
          },
          first.snapshot,
        )
        try assert.is_true(second.diagnostics.len() > 0)
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics groups results by uri and includes clean open docs",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        dep := "file:///tmp/dep.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [
              doc(entry, "use dep\nx: Int = dep.answer()\n", 1),
              doc(dep, "pub fn answer() String { \"nope\" }\n", 2),
            ],
          },
          .None,
        )
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics_by_uri.len(), 2)

        for group in result.diagnostics_by_uri {
          if group.uri == entry {
            try assert.is_true(group.diagnostics.len() > 0)
          }

          if group.uri == dep {
            try assert.equal(group.diagnostics.len(), 0)
          }
        }

        .Ok({})
      },
    )
    .test(
      "workspace diagnostics report dependency errors on dependency uri",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        dep := "file:///tmp/dep.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [
              doc(entry, "use dep\nx := dep.answer()\n", 1),
              doc(dep, "pub fn answer() String { 42 }\n", 3),
            ],
          },
          .None,
        )
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].uri, dep)
        try assert.equal(result.diagnostics[0].stage, "check")
        try assert.equal(try result.diagnostics[0].version.ok_or("missing version"), 3)
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics report missing imports without crashing",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [doc(entry, "use missing\nx := 1\n", 2)],
          },
          .None,
        )
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].uri, entry)
        try assert.equal(result.diagnostics[0].stage, "import")
        try assert.str_contains(result.diagnostics[0].message, "Cannot resolve module")
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics report import cycles without crashing",
      fn() {
        a := "file:///tmp/a.tw"
        b := "file:///tmp/b.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: a,
            project_root: "/tmp",
            open_documents: [
              doc(a, "use b\npub av := b.bv + 1\n", 1),
              doc(b, "use a\npub bv := a.av + 1\n", 1),
            ],
          },
          .None,
        )
        try assert.is_true(result.diagnostics.len() > 0)
        try assert.equal(result.diagnostics[0].stage, "import")
        try assert.str_contains(result.diagnostics[0].message, "initialization cycle")
        .Ok({})
      },
    )
    .test(
      "early cutoff: dep body change with same exports gives importer cache hits",
      fn() {
        entry := "file:///tmp/twinkle-cutoff/main.tw"
        dep := "file:///tmp/twinkle-cutoff/helper.tw"

        // First analysis: establish cache
        first := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-cutoff",
            open_documents: [
              doc(entry, "use helper\nx := helper.value()\n", 1),
              doc(dep, "pub fn value() Int { 1 }\n", 1),
            ],
          },
          .None,
        )
        try assert.equal(first.diagnostics.len(), 0)

        // Second analysis: dep body changes but signature is same
        second := diagnostics.analyze_workspace(
          first.cache,
          .{
            entry_uri: entry,
            project_root: "/tmp/twinkle-cutoff",
            open_documents: [
              doc(entry, "use helper\nx := helper.value()\n", 1),
              doc(dep, "pub fn value() Int { 999 }\n", 2),
            ],
          },
          .None,
        )
        try assert.equal(second.diagnostics.len(), 0)

        // The importer (main) should get resolve+typecheck cache hits
        // because dep's exports fingerprint didn't change
        stats := second.cache.get_stats()
        try assert.is_true(stats.resolve_hits > 0)
        try assert.is_true(stats.typecheck_hits > 0)
        .Ok({})
      },
    )
    .test(
      "workspace diagnostics include unused import data for selective imports",
      fn() {
        entry := "file:///tmp/twinkle-query-main.tw"
        dep := "file:///tmp/dep.tw"
        result := diagnostics.analyze_workspace(
          cache.empty(),
          .{
            entry_uri: entry,
            project_root: "/tmp",
            open_documents: [
              doc(entry, "use dep.{used_fn, unused_fn}\nx := used_fn()\n", 1),
              doc(dep, "pub fn used_fn() Int { 1 }\npub fn unused_fn() Int { 2 }\n", 1),
            ],
          },
          .None,
        )

        // Should have an unused import diagnostic for unused_fn
        found := false

        for d in result.diagnostics {
          if d.message.contains("unused_fn") {
            found = true
            try assert.equal(d.stage, "import")

            case d.data {
              .Some(data) => {
                fixes := try json.decode(data, json.field("fixes", json.list(json.raw())))
                try assert.equal(fixes.len(), 1)
                edits := try json.decode(fixes[0], json.field("edits", json.list(json.raw())))
                replacement := try json.decode(edits[0], json.field("replacement", json.string()))
                try assert.str_contains(replacement, "used_fn")
              },
              .None => return .Err("expected data on unused import diagnostic"),
            }
          }
        }

        try assert.is_true(found)
        .Ok({})
      },
    )
}
