use tests.assert
use tests.runner

fn make_adder(base: Int) fn(Int) Int {
  fn(n: Int) Int { base + n }
}

fn describe_option(x: Option<Int>) String {
  case x {
    .Some(n) => "found ${n}",
    .None => "none",
  }
}

fn describe_result(r: Result<String, Int>) String {
  case r {
    .Ok(s) => s,
    .Err(n) => "err ${n}",
  }
}

fn mark_true(counter: Cell<Int>) Bool {
  counter.update(fn(n) { n + 1 })
  true
}

fn find_first_gt(xs: Vector<Int>, threshold: Int) String {
  for x in xs {
    if x > threshold {
      return "found: ${x}"
    }
  }

  "not found"
}

type Point = .{ x: Int, y: Int }

type User = .{ id: Int, label: String }

type Shape = { Dot, Pixel(Int), Pair(Vector<Int>, Option<Int>) }

type Box<T> = .{ value: T }

fn eq(a: User, b: User) Bool {
  a.id == b.id
}

fn to_string<T: Stringify>(b: Box<T>) String {
  "Box(${b.value})"
}

fn show<T: Stringify>(x: T) String {
  "${x}"
}

// Regression helpers: an unannotated function infers its return type from the
// body, and that type must be usable consistently at every call site —
// including forward references, recursion, and when the result is discarded as
// a statement (which previously left a stray value on the wasm stack).
fn inferred_value() {
  19 + 23
}

fn calls_forward() Int {
  forward_helper() + 1
}

// Body is an expression (like inferred_value) so this stays a forward-referenced
// function with an inferred return type — the property under test — rather than a
// bare-constant function the linter would push toward a module constant.
fn forward_helper() {
  40 + 1
}

fn countdown_sum(n: Int) {
  if n <= 0 {
    0
  } else {
    n + countdown_sum(n - 1)
  }
}

pub fn suite() runner.Suite {
  runner
    .suite("semantic cases")
    .test(
      "unannotated function return type is inferred and usable",
      fn() {
        // Result is usable at the call site (was Void before the fix).
        try assert.equal(inferred_value(), 42)

        // Forward reference resolves to the callee's inferred return type.
        try assert.equal(calls_forward(), 42)

        // Recursion through an unannotated function infers consistently.
        try assert.equal(countdown_sum(5), 15)

        // Discarding the value as a statement must not corrupt the stack.
        inferred_value()
        .Ok({})
      },
    )
    .test(
      "closure capture by value",
      fn() {
        acc := 0
        f := fn() Int { acc }
        acc = acc + 1
        try assert.equal(f(), 0)
        try assert.equal(acc, 1)
        .Ok({})
      },
    )
    .test(
      "closure captures loop value per iteration",
      fn() {
        fns := collect i in [0, 1, 2] {
          fn() Int { i }
        }
        try assert.equal(fns[0](), 0)
        try assert.equal(fns[1](), 1)
        try assert.equal(fns[2](), 2)
        .Ok({})
      },
    )
    .test(
      "closure keeps captured argument",
      fn() {
        add10 := make_adder(10)
        try assert.equal(add10(0), 10)
        try assert.equal(add10(3), 13)
        .Ok({})
      },
    )
    .test(
      "local option and result pattern matching",
      fn() {
        try assert.equal(describe_option(.Some(42)), "found 42")
        try assert.equal(describe_option(.None), "none")
        try assert.equal(describe_result(.Ok("got ok")), "got ok")
        .Ok({})
      },
    )
    .test(
      "boolean short-circuit respects evaluation order",
      fn() {
        hits := Cell.new(0)
        try assert.is_false(false and mark_true(hits))
        try assert.equal(hits.get(), 0)
        try assert.is_true(true or mark_true(hits))
        try assert.equal(hits.get(), 0)
        try assert.is_true(false or mark_true(hits))
        try assert.equal(hits.get(), 1)
        try assert.is_true(true and mark_true(hits))
        try assert.equal(hits.get(), 2)
        .Ok({})
      },
    )
    .test(
      "for loop + early return semantics",
      fn() {
        nums: Vector<Int> = [1, 3, 5, 7, 9]
        try assert.equal(find_first_gt(nums, 6), "found: 7")
        try assert.equal(find_first_gt(nums, 10), "not found")
        .Ok({})
      },
    )
    .test(
      "vector equality is structural",
      fn() {
        a: Vector<Int> = [1, 2, 3]
        b: Vector<Int> = [1, 2, 3]
        c: Vector<Int> = [1, 2]
        d: Vector<Int> = [1, 2, 4]
        try assert.is_true(a == b)
        try assert.is_false(a == c)
        try assert.is_false(a == d)
        .Ok({})
      },
    )
    .test(
      "dict equality is structural and order-insensitive",
      fn() {
        a: Dict<String, Vector<Int>> = Dict.new()
        a["left"] = [1, 2]
        a["right"] = [3]
        b: Dict<String, Vector<Int>> = Dict.new()
        b["right"] = [3]
        b["left"] = [1, 2]
        c: Dict<String, Vector<Int>> = Dict.new()
        c["left"] = [1, 2]
        c["right"] = [4]
        try assert.is_true(a == b)
        try assert.is_false(a == c)
        .Ok({})
      },
    )
    .test(
      "generic interpolation uses Stringify witnesses",
      fn() {
        try assert.equal(show(42), "42")
        try assert.equal(show(Box.{ value: 7 }), "Box(7)")
        .Ok({})
      },
    )
    .test(
      "vector stringify uses prelude witness",
      fn() {
        ints: Vector<Int> = [1, 2, 3]
        boxes: Vector<Box<Int>> = [Box.{ value: 1 }, Box.{ value: 2 }]
        try assert.equal(ints.to_string(), "[1, 2, 3]")
        try assert.equal("${ints}", "[1, 2, 3]")
        try assert.equal(show(ints), "[1, 2, 3]")
        try assert.equal(boxes.to_string(), "[Box(1), Box(2)]")
        .Ok({})
      },
    )
    .test(
      "typed sums compare structurally",
      fn() {
        some_42_a: Option<Int> = .Some(42)
        some_42_b: Option<Int> = .Some(42)
        some_7: Option<Int> = .Some(7)
        none_int: Option<Int> = .None
        try assert.is_true(some_42_a == some_42_b)
        try assert.is_false(some_42_a == some_7)
        try assert.is_false(some_42_a == none_int)
        ok_a: Result<Int, String> = .Ok(5)
        ok_b: Result<Int, String> = .Ok(5)
        err_a: Result<Int, String> = .Err("x")
        err_b: Result<Int, String> = .Err("x")
        try assert.is_true(ok_a == ok_b)
        try assert.is_true(err_a == err_b)
        try assert.is_false(ok_a == err_a)
        p1: Shape = .Pair([1, 2], .Some(3))
        p2: Shape = .Pair([1, 2], .Some(3))
        p3: Shape = .Pair([1, 2], .Some(4))
        try assert.is_true(p1 == p2)
        try assert.is_false(p1 == p3)
        try assert.is_false(Shape.Dot == Shape.Pixel(0))
        .Ok({})
      },
    )
    .test(
      "nested collection equality recurses through typed sums",
      fn() {
        a: Vector<Option<Vector<Int>>> = [.Some([1, 2]), .None, .Some([3])]
        b: Vector<Option<Vector<Int>>> = [.Some([1, 2]), .None, .Some([3])]
        c: Vector<Option<Vector<Int>>> = [.Some([1, 2]), .None, .Some([4])]
        try assert.is_true(a == b)
        try assert.is_false(a == c)
        d1: Dict<String, Result<Vector<Int>, String>> = Dict.new()
        d1["ok"] = .Ok([1, 2])
        d1["err"] = .Err("x")
        d2: Dict<String, Result<Vector<Int>, String>> = Dict.new()
        d2["err"] = .Err("x")
        d2["ok"] = .Ok([1, 2])
        d3: Dict<String, Result<Vector<Int>, String>> = Dict.new()
        d3["err"] = .Err("x")
        d3["ok"] = .Ok([1, 3])
        try assert.is_true(d1 == d2)
        try assert.is_false(d1 == d3)
        .Ok({})
      },
    )
    .test(
      "record equality is structural",
      fn() {
        a := Point.{ x: 1, y: 2 }
        b := Point.{ x: 1, y: 2 }
        try assert.is_true(a == b)
        try assert.is_true(a == a)
        .Ok({})
      },
    )
    .test(
      "custom record eq overrides direct equality",
      fn() {
        a := User.{ id: 1, label: "first" }
        b := User.{ id: 1, label: "renamed" }
        c := User.{ id: 2, label: "other" }
        try assert.is_true(a == b)
        try assert.is_true(a.eq(b))
        try assert.is_true(a != c)
        .Ok({})
      },
    )
    .test(
      "recursive equality compares records structurally",
      fn() {
        same := Point.{ x: 1, y: 2 }
        other := Point.{ x: 1, y: 2 }
        vec_same_a: Vector<Point> = [same]
        vec_same_b: Vector<Point> = [same]
        vec_other: Vector<Point> = [other]
        try assert.is_true(vec_same_a == vec_same_b)
        try assert.is_true(vec_same_a == vec_other)
        dict_same_a: Dict<String, Point> = Dict.new()
        dict_same_b: Dict<String, Point> = Dict.new()
        dict_other: Dict<String, Point> = Dict.new()
        dict_same_a["p"] = same
        dict_same_b["p"] = same
        dict_other["p"] = other
        try assert.is_true(dict_same_a == dict_same_b)
        try assert.is_true(dict_same_a == dict_other)
        sum_same_a: Option<Point> = .Some(same)
        sum_same_b: Option<Point> = .Some(same)
        sum_other: Option<Point> = .Some(other)
        try assert.is_true(sum_same_a == sum_same_b)
        try assert.is_true(sum_same_a == sum_other)
        .Ok({})
      },
    )
}
