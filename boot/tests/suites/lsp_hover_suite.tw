use tests.runner
use tests.assert
use compiler.query.cache as query_cache
use lib.json
use lib.lsp.protocol
use lib.lsp.document_store
use lib.lsp.server_core

fn state_with_doc(uri: String, text: String) server_core.State {
  docs := document_store.open(document_store.empty(), uri, text, .Some(1))
  server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: false,
    diagnostics_deadline_ms: 0.0,
    last_published_versions: Dict.new(),
  }
}

fn state_with_two_docs(uri_a: String, text_a: String, uri_b: String, text_b: String) server_core.State {
  docs0 := document_store.open(document_store.empty(), uri_a, text_a, .Some(1))
  docs := document_store.open(docs0, uri_b, text_b, .Some(1))
  server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: false,
    diagnostics_deadline_ms: 0.0,
    last_published_versions: Dict.new(),
  }
}

fn hover_request(id: Int, uri: String, line: Int, character: Int) protocol.Message {
  params := json.object([
    json.kv("textDocument", json.object([
      json.kv("uri", .Str(uri)),
    ])),
    json.kv("position", json.object([
      json.kv("line", .Int(line)),
      json.kv("character", .Int(character)),
    ])),
  ])
  protocol.Message.Request(.{ id: .IntId(id), method: "textDocument/hover", params: .Some(params) })
}

fn hover_content(step: server_core.Step) String!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }
  out := step.outgoing[0]
  result := try json.decode(out, json.field("result", json.raw()))
  contents := try json.decode(result, json.field("contents", json.raw()))
  value := try json.decode(contents, json.field("value", json.string()))
  .Ok(value)
}

fn is_null_result(step: server_core.Step) Bool!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }
  out := step.outgoing[0]
  result := try json.decode(out, json.field("result", json.raw()))
  case result {
    .Null => .Ok(true),
    _ => .Ok(false),
  }
}

pub fn suite() runner.Suite {
  runner.suite("lsp hover")
    .test("hover on integer literal shows Int", fn() {
      //         01234567
      state := state_with_doc("file:///a.tw", "x := 42\n")
      // "42" is at offset 5-7, line 0 char 5
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on string literal shows String", fn() {
      state := state_with_doc("file:///a.tw", "x := \"hello\"\n")
      // "hello" starts at offset 5, line 0 char 5
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nString\n```")
      .Ok({})
    })
    .test("hover on boolean literal shows Bool", fn() {
      state := state_with_doc("file:///a.tw", "x := true\n")
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nBool\n```")
      .Ok({})
    })
    .test("hover on variable shows inferred type", fn() {
      //                                              0123456789...
      state := state_with_doc("file:///a.tw", "x := 42\ny := x\n")
      // "x" on line 1 is at char 5
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on function name shows function type", fn() {
      state := state_with_doc("file:///a.tw", "fn add(a: Int, b: Int) Int { a + b }\nx := add(1, 2)\n")
      // "add" on line 1 at char 5
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nfn(a: Int, b: Int) Int\n```")
      .Ok({})
    })
    .test("hover on argument shows argument type", fn() {
      state := state_with_doc("file:///a.tw", "fn add(a: Int, b: Int) Int { a + b }\nx := add(1, 2)\n")
      // "1" on line 1 at char 9
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 9))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover returns null for unknown document", fn() {
      state := state_with_doc("file:///a.tw", "x := 1\n")
      step := server_core.handle_message(state, hover_request(1, "file:///other.tw", 0, 0))
      try assert.is_true(try is_null_result(step))
      .Ok({})
    })
    .test("hover returns null for position outside expressions", fn() {
      state := state_with_doc("file:///a.tw", "x := 1\n\n\n")
      // line 2 is empty
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 2, 0))
      try assert.is_true(try is_null_result(step))
      .Ok({})
    })
    .test("hover on nested expression shows inner type", fn() {
      state := state_with_doc("file:///a.tw", "x := 1 + 2\n")
      // "1" at char 5
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on type annotation name shows type", fn() {
      state := state_with_doc("file:///a.tw", "type Program = .{ source: String }\nfn f(x: Program) Program { x }\n")
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 8))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nProgram\n```")
      .Ok({})
    })
    .test("hover on function declaration name shows signature", fn() {
      state := state_with_doc("file:///a.tw", "fn make(x: Int) Int { x }\n")
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 4))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nfn(x: Int) Int\n```")
      .Ok({})
    })
    .test("hover on type declaration name shows type", fn() {
      state := state_with_doc("file:///a.tw", "type Program = .{ source: String }\n")
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 6))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nProgram\n```")
      .Ok({})
    })
    .test("hover on top-level binding name shows inferred type", fn() {
      state := state_with_doc("file:///a.tw", "value := 42\n")
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 1))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on case arm variant shows constructor", fn() {
      source := "type ParseError = { HelpRequested(String), Other }\nfn main(err: ParseError) String {\n  case err {\n    .HelpRequested(msg) => msg,\n    .Other => \"\",\n  }\n}\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 3, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nParseError.HelpRequested(String)\n```")
      .Ok({})
    })
    .test("hover on Result case arm variants shows constructors", fn() {
      source := "fn main() Int {\n  r: Int!String = .Ok(1)\n  case r {\n    .Ok(v) => v,\n    .Err(_) => 0,\n  }\n}\n"
      state := state_with_doc("file:///a.tw", source)
      ok_step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 3, 5))
      ok_content := try hover_content(ok_step)
      try assert.equal(ok_content, "```twinkle\nResult.Ok(Int)\n```")
      err_step := server_core.handle_message(state, hover_request(2, "file:///a.tw", 4, 5))
      err_content := try hover_content(err_step)
      try assert.equal(err_content, "```twinkle\nResult.Err(String)\n```")
      .Ok({})
    })
    .test("hover on receiver method name shows signature with param names", fn() {
      source := "type Counter = .{ value: Int }\nfn inc(c: Counter) Counter { Counter.{ value: c.value + 1 } }\nn := Counter.{ value: 1 }\nresult := n.inc()\n"
      state := state_with_doc("file:///a.tw", source)
      // "inc" on the last line: "result := n.inc()"
      //  0123456789012345
      //  result := n.inc()
      // "inc" starts at char 12
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 3, 12))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nfn(c: Counter) Counter\n```")
      .Ok({})
    })
    .test("hover on module-qualified function shows signature", fn() {
      source := "fn add(a: Int, b: Int) Int { a + b }\nx := add(1, 2)\n"
      state := state_with_doc("file:///a.tw", source)
      // hover on "add" in the call on line 1 at char 5
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 5))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nfn(a: Int, b: Int) Int\n```")
      .Ok({})
    })
    .test("hover on destructured function import shows signature", fn() {
      dep := "pub fn add(a: Int, b: Int) Int { a + b }\n"
      main := "use dep.{add}\nx := add(1, 2)\n"
      state := state_with_two_docs("file:///tmp/lsp-hover-import/dep.tw", dep, "file:///tmp/lsp-hover-import/main.tw", main)
      step := server_core.handle_message(state, hover_request(1, "file:///tmp/lsp-hover-import/main.tw", 0, 10))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nfn(a: Int, b: Int) Int\n```")
      .Ok({})
    })
    .test("hover on destructured type import shows type", fn() {
      dep := "pub type Point = .{ x: Int }\n"
      main := "use dep.{Point}\np: Point = .{ x: 1 }\n"
      state := state_with_two_docs("file:///tmp/lsp-hover-import-type/dep.tw", dep, "file:///tmp/lsp-hover-import-type/main.tw", main)
      step := server_core.handle_message(state, hover_request(1, "file:///tmp/lsp-hover-import-type/main.tw", 0, 10))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nPoint\n```")
      .Ok({})
    })
    .test("hover stable across method name characters", fn() {
      source := "type Counter = .{ value: Int }\nfn inc(c: Counter) Counter { Counter.{ value: c.value + 1 } }\nn := Counter.{ value: 1 }\nresult := n.inc()\n"
      state := state_with_doc("file:///a.tw", source)
      // hover on first char 'i' of "inc" at char 12
      step1 := server_core.handle_message(state, hover_request(1, "file:///a.tw", 3, 12))
      c1 := try hover_content(step1)
      // hover on last char 'c' of "inc" at char 14
      step2 := server_core.handle_message(state, hover_request(2, "file:///a.tw", 3, 14))
      c2 := try hover_content(step2)
      try assert.equal(c1, c2)
      .Ok({})
    })
    .test("hover on function parameter name shows type", fn() {
      //                          fn add(a: Int, b: Int) Int { a + b }
      // line 0:                  0123456789...
      // "a" is at char 7
      state := state_with_doc("file:///a.tw", "fn add(a: Int, b: Int) Int { a + b }\n")
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 7))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on let binding name in function body shows type", fn() {
      source := "fn main() Int {\n  x := 42\n  x\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "x" on line 1 at char 2
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 2))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on for loop value binder shows element type", fn() {
      source := "fn main() Int {\n  sum := 0\n  for x in [1, 2, 3] {\n    sum = sum + x\n  }\n  sum\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "x" on line 2: "  for x in [1, 2, 3] {"
      //                  01234
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 2, 6))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on case pattern binder shows type", fn() {
      source := "fn main() Int {\n  x: Int? = .Some(42)\n  case x {\n    .Some(v) => v,\n    .None => 0,\n  }\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "v" in ".Some(v)" on line 3: "    .Some(v) => v,"
      //                                0123456789
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 3, 10))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on closure parameter shows type", fn() {
      source := "fn main() Int {\n  f := fn(x: Int) Int { x + 1 }\n  f(1)\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "x" in "fn(x: Int)" on line 1: "  f := fn(x: Int) Int { x + 1 }"
      //                                  0123456789...
      // x is at char 10
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 10))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on user function call shows doc comment", fn() {
      source := "/// Add one to x.\nfn add_one(x: Int) Int {\n  x + 1\n}\n\nvalue := add_one(1)\n"
      state := state_with_doc("file:///a.tw", source)
      // "add_one" on line 5: "value := add_one(1)"
      //                       012345678
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 5, 9))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(x: Int) Int")
      try assert.str_contains(content, "Add one to x.")
      .Ok({})
    })
    .test("hover on user function declaration name shows doc comment", fn() {
      source := "/// Add one to x.\nfn add_one(x: Int) Int {\n  x + 1\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "add_one" on line 1: "fn add_one(x: Int) Int {"
