      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 4))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(x: Int) Int")
      try assert.str_contains(content, "Add one to x.")
      .Ok({})
    })
    .test("hover on user type declaration name shows doc comment", fn() {
      source := "/// RGB color value.\ntype Color = .{ r: Int, g: Int, b: Int }\n"
      state := state_with_doc("file:///a.tw", source)
      // "Color" on line 1: "type Color = ..."
      //                      01234567
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 6))
      content := try hover_content(step)
      try assert.str_contains(content, "Color")
      try assert.str_contains(content, "RGB color value.")
      .Ok({})
    })
    .test("hover on builtin println shows docs", fn() {
      source := "println(\"hello\")\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 1))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(s: String) Void")
      try assert.str_contains(content, "Print a string to stdout followed by a newline.")
      .Ok({})
    })
    .test("hover on prelude free function shows signature docs", fn() {
      source := "r := range(10)\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 6))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(end: Int) Range")
      try assert.str_contains(content, "Create a range from 0 to end (exclusive).")
      .Ok({})
