    .test("hover on prelude receiver method shows signature docs", fn() {
      source := "xs := [1, 2, 3]\nn := xs.len()\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 8))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(xs: Vector<Int>) Int")
      try assert.str_contains(content, "Return the number of elements.")
      .Ok({})
    })
    .test("hover on Cell receiver method shows signature docs", fn() {
      source := "sum := Cell.new(0)\nsum.update(fn(s) { s + 1 })\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 5))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(cell: Cell<Int>, f: fn(Int) Int) Void")
      try assert.str_contains(content, "Apply f to the current value and store the result.")
      .Ok({})
    })
    .test("hover on Cell receiver method inside for loop shows signature docs", fn() {
      source := "sum := Cell.new(0)\nfor i in range(10) {\n  sum.update(fn(s) { s + i })\n}\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 2, 6))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(cell: Cell<Int>, f: fn(Int) Int) Void")
      try assert.str_contains(content, "Apply f to the current value and store the result.")
      .Ok({})
    })
    .test("hover on builtin Option type shows docs", fn() {
      source := "x: Option<Int> = .Some(1)\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 3))
      content := try hover_content(step)
      try assert.str_contains(content, "Option")
      try assert.str_contains(content, "Optional value: None or Some(T).")
      .Ok({})
    })
    .test("hover on qualified builtin function shows docs", fn() {
      source := "x := Int.from_string(\"42\")\n"
      state := state_with_doc("file:///a.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 10))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(s: String) Int?")
      try assert.str_contains(content, "Parse a string as an integer")
      .Ok({})
    })
    .test("hover on Option case arm variants shows constructors", fn() {
      source := "fn main() Int {\n  x: Int? = .Some(42)\n  case x {\n    .Some(v) => v,\n    .None => 0,\n  }\n}\n"
      state := state_with_doc("file:///a.tw", source)
      some_step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 3, 5))
      some_content := try hover_content(some_step)
      try assert.equal(some_content, "```twinkle\nOption.Some(Int)\n```")
      none_step := server_core.handle_message(state, hover_request(2, "file:///a.tw", 4, 5))
      none_content := try hover_content(none_step)
      try assert.equal(none_content, "```twinkle\nOption.None\n```")
      .Ok({})
    })
    .test("hover on expression variant constructor shows constructor", fn() {
      source := "fn main() Int!String {\n  .Ok(1)\n}\n"
      state := state_with_doc("file:///variant-expr.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///variant-expr.tw", 1, 3))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nResult.Ok(Int)\n```")
      .Ok({})
    })
    .test("hover on qualified variant constructor shows constructor", fn() {
      source := "type Color = { Red, Rgb(Int, Int, Int) }\nfn main() Color { Color.Rgb(1, 2, 3) }\n"
      state := state_with_doc("file:///qualified-variant.tw", source)
      step := server_core.handle_message(state, hover_request(1, "file:///qualified-variant.tw", 1, 24))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nColor.Rgb(Int, Int, Int)\n```")
      .Ok({})
    })
    .test("hover on imported qualified variant constructor shows constructor", fn() {
      dep := "pub type Color = { Red, Rgb(Int) }\n"
      main := "use dep\nfn main() dep.Color { dep.Color.Rgb(1) }\n"
      state := state_with_two_docs("file:///tmp/lsp-hover-variant/dep.tw", dep, "file:///tmp/lsp-hover-variant/main.tw", main)
      step := server_core.handle_message(state, hover_request(1, "file:///tmp/lsp-hover-variant/main.tw", 1, 32))
      content := try hover_content(step)
      try assert.equal(content, "```twinkle\nColor.Rgb(Int)\n```")
      .Ok({})
    })
    .test("hover on nested pattern variants and binders shows types", fn() {
      source := "type Box = { Box(Int?) }\nfn main(b: Box) Int {\n  case b {\n    .Box(.Some(v)) => v,\n  }\n}\n"
      state := state_with_doc("file:///nested-pattern.tw", source)
      some_step := server_core.handle_message(state, hover_request(1, "file:///nested-pattern.tw", 3, 10))
      some_content := try hover_content(some_step)
      try assert.equal(some_content, "```twinkle\nOption.Some(Int)\n```")
      binder_step := server_core.handle_message(state, hover_request(2, "file:///nested-pattern.tw", 3, 15))
      binder_content := try hover_content(binder_step)
      try assert.equal(binder_content, "```twinkle\nInt\n```")
      .Ok({})
    })
    .test("hover on method with multibyte prefix line is stable", fn() {
      // em-dash — is 3 bytes in UTF-8, 1 code unit in UTF-16... actually 1 char
      // Actually — is U+2014, encoded as 3 bytes UTF-8 but 1 UTF-16 code unit
      source := "type Text = .{ data: String }\nfn greet(t: Text) String { t.data }\n// ASCII \xe2\x80\x94 each char is its own grapheme\nt := Text.{ data: \"hello\" }\ng := t.greet()\n"
      state := state_with_doc("file:///a.tw", source)
      // "greet" on last line: "g := t.greet()"
      //                        01234567
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 4, 7))
      content := try hover_content(step)
      try assert.str_contains(content, "fn(t: Text) String")
      .Ok({})
    })
    .test("hover on Stringify bound in function shows contract info", fn() {
      //                0         1         2         3
      //                0123456789012345678901234567890123456789
      source := "fn show<T: Stringify>(x: T) String { x.to_string() }\n"
      state := state_with_doc("file:///a.tw", source)
      // "Stringify" starts at char 11
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 13))
      content := try hover_content(step)
      try assert.str_contains(content, "contract Stringify")
      try assert.str_contains(content, "to_string")
      .Ok({})
    })
    .test("hover on each bound in multi-bound T: Eq + Stringify", fn() {
      //                0         1         2         3         4
      //                01234567890123456789012345678901234567890123456789
      source := "fn check<T: Eq + Stringify>(a: T, b: T) Bool { a == b }\n"
      state := state_with_doc("file:///a.tw", source)
      // "Eq" starts at char 12
      eq_step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 12))
      eq_content := try hover_content(eq_step)
      try assert.str_contains(eq_content, "contract Eq")
      try assert.str_contains(eq_content, "eq")
      // "Stringify" starts at char 17
      str_step := server_core.handle_message(state, hover_request(2, "file:///a.tw", 0, 19))
      str_content := try hover_content(str_step)
      try assert.str_contains(str_content, "contract Stringify")
      try assert.str_contains(str_content, "to_string")
      .Ok({})
    })
    .test("hover on Stringify bound in type declaration", fn() {
      //                0         1         2
      //                0123456789012345678901234567
      source := "type Box<T: Stringify> = .{ value: T }\n"
      state := state_with_doc("file:///a.tw", source)
      // "Stringify" starts at char 12
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 0, 14))
      content := try hover_content(step)
      try assert.str_contains(content, "contract Stringify")
      try assert.str_contains(content, "to_string")
      .Ok({})
    })
    .test("hover on contract-backed to_string method call", fn() {
      source := "fn show<T: Stringify>(x: T) String {\n  x.to_string()\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "to_string" on line 1: "  x.to_string()"
      //                         01234
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 5))
      content := try hover_content(step)
      try assert.str_contains(content, "fn to_string(value: Self) String")
      try assert.str_contains(content, "Contract method from")
      try assert.str_contains(content, "Stringify")
      .Ok({})
    })
    .test("hover on contract-backed eq method call", fn() {
      source := "fn same<T: Eq>(a: T, b: T) Bool {\n  a.eq(b)\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "eq" on line 1: "  a.eq(b)"
      //                  01234
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 4))
      content := try hover_content(step)
      try assert.str_contains(content, "fn eq(value: Self, other: Self) Bool")
      try assert.str_contains(content, "Contract method from")
      try assert.str_contains(content, "Eq")
      .Ok({})
    })
    .test("hover on contract-backed compare method call", fn() {
      source := "fn cmp<T: Ord>(a: T, b: T) Order {\n  a.compare(b)\n}\n"
      state := state_with_doc("file:///a.tw", source)
      // "compare" on line 1: "  a.compare(b)"
      //                       01234
      step := server_core.handle_message(state, hover_request(1, "file:///a.tw", 1, 5))
      content := try hover_content(step)
      try assert.str_contains(content, "fn compare(value: Self, other: Self) Order")
      try assert.str_contains(content, "Contract method from")
      try assert.str_contains(content, "Ord")
      .Ok({})
    })
    .test("initialize advertises hoverProvider", fn() {
      msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
      step := server_core.handle_message(server_core.initial_state(), msg)
      out := step.outgoing[0]
      result := try json.decode(out, json.field("result", json.raw()))
      caps := try json.decode(result, json.field("capabilities", json.raw()))
      try assert.is_true(try json.decode(caps, json.field("hoverProvider", json.bool())))
      .Ok({})
    })
}
