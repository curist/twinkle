use @std.testing.assert as assert
use @std.testing as runner

use compiler.anf.{AnfExpr, AnfFunctionDef, AnfMatchArm, AnfOp}
use compiler.anf_analysis.{set_has}
use compiler.builder_family.{empty_builder_config}
use compiler.core_ir.{FuncId, LocalId, Param, VariantId}
use compiler.mono_type.{TypeId}
use compiler.opt.analysis.{
  analyze_loop_push_sites, base_reusable_after_binding, collect_tainted, count_global_call_sites,
  loop_push_reassign_elem, next_local_id, op_uses_local_non_recursive,
}
use compiler.opt.semantics.{CallSemantics, OptimizerSemantics}

fn lid(id: Int) LocalId {
  LocalId.{ id }
}

fn fid(id: Int) FuncId {
  FuncId.{ id }
}

fn tid(id: Int) TypeId {
  TypeId.{ id }
}

fn mock_vec_set() FuncId {
  fid(200)
}

fn mock_vec_push() FuncId {
  fid(204)
}

fn mock_vec_make() FuncId {
  fid(210)
}

fn mock_vec_len() FuncId {
  fid(220)
}

fn mock_semantics() OptimizerSemantics {
  calls: Dict<Int, CallSemantics> = Dict.new()
  calls[mock_vec_set().id] = .{
    effect: .Update,
    fresh_result: false,
    cow_base_arg: .Some(0),
    in_place_equivalent: .None,
  }
  calls[mock_vec_make().id] = .{
    effect: .Allocate,
    fresh_result: true,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  calls[mock_vec_len().id] = .{
    effect: .ReadOnly,
    fresh_result: false,
    cow_base_arg: .None,
    in_place_equivalent: .None,
  }
  OptimizerSemantics.{
    call_semantics: calls,
    builder: empty_builder_config(),
    string_builder: empty_builder_config(),
  }
}

fn make_func(body: AnfExpr) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: fid(1),
    name: "test",
    params: [],
    op_result_mono: Dict.new(),
    body,
    return_ty: .Void,
    is_init: false,
  }
}

fn make_func_with_params(params: Vector<Param>, body: AnfExpr) AnfFunctionDef {
  AnfFunctionDef.{
    func_id: fid(1),
    name: "test",
    params,
    op_result_mono: Dict.new(),
    body,
    return_ty: .Void,
    is_init: false,
  }
}

fn test_op_uses_local_non_recursive_direct_operand() Result<Void, String> {
  op: AnfOp = .ACall(.AGlobalFunc(fid(10)), [.ALocal(lid(3)), .ALitInt(1)])
  assert.is_true(op_uses_local_non_recursive(op, lid(3)))
}

fn test_op_uses_local_non_recursive_ignores_nested_branches() Result<Void, String> {
  op: AnfOp = .AIf(.ALitBool(true), .Atom(.ALocal(lid(7))), .Atom(.ALitVoid))
  assert.is_false(op_uses_local_non_recursive(op, lid(7)))
}

fn test_count_global_call_sites_recursive() Result<Void, String> {
  expr: AnfExpr = .Let(
    lid(0),
    .AIf(
      .ALitBool(true),
      .Let(lid(1), .ACall(.AGlobalFunc(fid(20)), []), .Atom(.ALitVoid)),
      .Let(
        lid(2),
        .ALoop(.Let(lid(3), .ACall(.AGlobalFunc(fid(20)), []), .Break(.None))),
        .Atom(.ALitVoid),
      ),
    ),
    .Atom(.ALitVoid),
  )
  assert.equal(count_global_call_sites(expr, fid(20)), 2)
}

fn test_next_local_id_accounts_for_pattern_bindings() Result<Void, String> {
  arm := AnfMatchArm.{
    pattern: .Variant(tid(9), VariantId.{ id: 0 }, [.Var(lid(8))]),
    body: .Atom(.ALocal(lid(8))),
  }
  func := AnfFunctionDef.{
    func_id: fid(1),
    name: "test",
    params: [Param.{ local: lid(5), ty: .Void }],
    op_result_mono: Dict.new(),
    body: .Let(lid(2), .AMatch(.ALocal(lid(1)), [arm]), .Atom(.ALitVoid)),
    return_ty: .Void,
    is_init: false,
  }
  assert.equal(next_local_id(func), 9)
}

fn test_collect_tainted_marks_params() Result<Void, String> {
  func := make_func_with_params([Param.{ local: lid(0), ty: .Void }], .Atom(.ALitVoid))
  tainted := collect_tainted(func, mock_semantics())
  assert.is_true(set_has(tainted, 0))
}

fn test_collect_tainted_skips_cow_base_arg() Result<Void, String> {
  body: AnfExpr = .Let(
    lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(
      lid(1),
      .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(1)]),
      .Atom(.ALocal(lid(1))),
    ),
  )
  tainted := collect_tainted(make_func(body), mock_semantics())
  assert.is_false(set_has(tainted, 0))
}

fn test_collect_tainted_marks_non_base_cow_arg() Result<Void, String> {
  body: AnfExpr = .Let(
    lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(
      lid(1),
      .ACall(.AGlobalFunc(mock_vec_make()), []),
      .Let(
        lid(2),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALocal(lid(1))]),
        .Atom(.ALocal(lid(2))),
      ),
    ),
  )
  tainted := collect_tainted(make_func(body), mock_semantics())
  try assert.is_false(set_has(tainted, 0))
  assert.is_true(set_has(tainted, 1))
}

fn test_collect_tainted_marks_branch_alias_escape() Result<Void, String> {
  then_e: AnfExpr = .Let(
    lid(1),
    .AInit(.ALocal(lid(0))),
    .Let(lid(2), .AMakeClosure(fid(99), [lid(1)]), .Atom(.ALitVoid)),
  )
  body: AnfExpr = .Let(
    lid(0),
    .ACall(.AGlobalFunc(mock_vec_make()), []),
    .Let(
      lid(3),
      .AIf(.ALitBool(true), then_e, .Atom(.ALitVoid)),
      .Let(
        lid(4),
        .ACall(.AGlobalFunc(mock_vec_set()), [.ALocal(lid(0)), .ALitInt(0), .ALitInt(1)]),
        .Atom(.ALocal(lid(4))),
      ),
    ),
  )
  tainted := collect_tainted(make_func(body), mock_semantics())
  assert.is_true(set_has(tainted, 0))
}

fn test_analyze_loop_push_sites_counts_valid_pushes() Result<Void, String> {
  loop_body: AnfExpr = .Let(
    lid(1),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))), .Continue),
  )

  case analyze_loop_push_sites(loop_body, lid(0), mock_vec_push()) {
    .Some(sites) => assert.equal(sites, 1),
    .None => .Err("expected valid loop push site"),
  }
}

fn test_analyze_loop_push_sites_counts_branch_pushes() Result<Void, String> {
  then_e: AnfExpr = .Let(
    lid(2),
    .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)]),
    .Let(lid(3), .AAssign(lid(0), .ALocal(lid(2))), .Atom(.ALitVoid)),
  )
  loop_body: AnfExpr = .Let(lid(1), .AIf(.ALitBool(true), then_e, .Atom(.ALitVoid)), .Continue)

  case analyze_loop_push_sites(loop_body, lid(0), mock_vec_push()) {
    .Some(sites) => assert.equal(sites, 1),
    .None => .Err("expected branch push site to be counted"),
  }
}

fn test_analyze_loop_push_sites_rejects_non_push_base_use() Result<Void, String> {
  loop_body: AnfExpr = .Let(lid(1), .ACall(.AGlobalFunc(fid(999)), [.ALocal(lid(0))]), .Continue)

  case analyze_loop_push_sites(loop_body, lid(0), mock_vec_push()) {
    .Some(_) => .Err("expected non-push base use to be rejected"),
    .None => .Ok({}),
  }
}

fn test_analyze_loop_push_sites_rejects_base_escape_in_terminal_atom() Result<Void, String> {
  loop_body: AnfExpr = .Atom(.ALocal(lid(0)))

  case analyze_loop_push_sites(loop_body, lid(0), mock_vec_push()) {
    .Some(_) => .Err("expected terminal base use to be rejected"),
    .None => .Ok({}),
  }
}

fn test_base_reusable_after_binding_when_base_dead() Result<Void, String> {
  body: AnfExpr = .Atom(.ALocal(lid(1)))
  assert.is_true(base_reusable_after_binding(body, lid(0), lid(1)))
}

fn test_base_reusable_after_binding_with_consume_reassign() Result<Void, String> {
  body: AnfExpr = .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))), .Atom(.ALocal(lid(0))))
  assert.is_true(base_reusable_after_binding(body, lid(0), lid(1)))
}

fn test_base_reusable_after_binding_rejects_live_base() Result<Void, String> {
  body: AnfExpr = .Let(lid(2), .AInit(.ALocal(lid(0))), .Atom(.ALocal(lid(2))))
  assert.is_false(base_reusable_after_binding(body, lid(0), lid(1)))
}

fn test_loop_push_reassign_elem_matches_valid_pattern() Result<Void, String> {
  op: AnfOp = .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALitInt(1)])
  body: AnfExpr = .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))), .Continue)

  case loop_push_reassign_elem(op, body, lid(0), mock_vec_push(), lid(1)) {
    .Some(.ALitInt(value)) => assert.equal(value, 1),
    .Some(_) => .Err("expected pushed element literal"),
    .None => .Err("expected valid push+assign pattern"),
  }
}

fn test_loop_push_reassign_elem_rejects_base_as_element() Result<Void, String> {
  op: AnfOp = .ACall(.AGlobalFunc(mock_vec_push()), [.ALocal(lid(0)), .ALocal(lid(0))])
  body: AnfExpr = .Let(lid(2), .AAssign(lid(0), .ALocal(lid(1))), .Continue)

  case loop_push_reassign_elem(op, body, lid(0), mock_vec_push(), lid(1)) {
    .Some(_) => .Err("expected invalid push element to be rejected"),
    .None => .Ok({}),
  }
}

pub fn suite() runner.Suite {
  runner
    .suite("Opt: Analysis")
    .test(
      "op uses local non-recursive direct operand",
      test_op_uses_local_non_recursive_direct_operand,
    )
    .test(
      "op uses local non-recursive ignores nested branches",
      test_op_uses_local_non_recursive_ignores_nested_branches,
    )
    .test("count global call sites recursive", test_count_global_call_sites_recursive)
    .test(
      "next local id accounts for pattern bindings",
      test_next_local_id_accounts_for_pattern_bindings,
    )
    .test("collect tainted marks params", test_collect_tainted_marks_params)
    .test("collect tainted skips cow base arg", test_collect_tainted_skips_cow_base_arg)
    .test("collect tainted marks non-base cow arg", test_collect_tainted_marks_non_base_cow_arg)
    .test(
      "collect tainted marks branch alias escape",
      test_collect_tainted_marks_branch_alias_escape,
    )
    .test(
      "analyze loop push sites counts valid pushes",
      test_analyze_loop_push_sites_counts_valid_pushes,
    )
    .test(
      "analyze loop push sites counts branch pushes",
      test_analyze_loop_push_sites_counts_branch_pushes,
    )
    .test(
      "analyze loop push sites rejects non-push base use",
      test_analyze_loop_push_sites_rejects_non_push_base_use,
    )
    .test(
      "analyze loop push sites rejects terminal base escape",
      test_analyze_loop_push_sites_rejects_base_escape_in_terminal_atom,
    )
    .test(
      "base reusable after binding when base dead",
      test_base_reusable_after_binding_when_base_dead,
    )
    .test(
      "base reusable after binding with consume-reassign",
      test_base_reusable_after_binding_with_consume_reassign,
    )
    .test(
      "base reusable after binding rejects live base",
      test_base_reusable_after_binding_rejects_live_base,
    )
    .test(
      "loop push reassign elem matches valid pattern",
      test_loop_push_reassign_elem_matches_valid_pattern,
    )
    .test(
      "loop push reassign elem rejects base as element",
      test_loop_push_reassign_elem_rejects_base_as_element,
    )
}
