fn suite() Suite {
  runner.suite("fmt").test("short name", fn() { do_a() }).test("another short name", fn() { do_b() }).test("a longer test name that forces the arguments to wrap onto the next line", fn() { do_c() }).test("yet another test case", fn() { do_d() })
}

fn suite2() Suite {
  runner.suite("fmt2").test("test with multi-statement body", fn() { x := do_a(); println(x) }).test("another multi-statement test", fn() { y := do_b(); z := do_c(); y + z })
}
