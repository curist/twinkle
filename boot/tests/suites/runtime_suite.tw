fn test_rt_dict_set_in_place() Result<Void, String> {
  m := rt_dict.module()
  f := try find_func(m.funcs, "set_in_place").ok_or("missing set_in_place func")
  try assert.equal(f.params.len(), 3)

  // True in-place: calls node_set, mutates PDict via StructSet (no StructNew)
  found_node_set := false
  found_struct_set := false
  found_struct_new := false

  for instr in f.body {
    case instr {
      .Call(name) => if name == "node_set" {
        found_node_set = true
      },
      .StructSet(name, _) => if name == "rt_types__PDict" {
        found_struct_set = true
      },
      .StructNew(name) => if name == "rt_types__PDict" {
        found_struct_new = true
      },
      _ => {},
    }
  }

  try assert.ok(found_node_set, "set_in_place should call node_set")
  try assert.ok(found_struct_set, "set_in_place should mutate PDict via StructSet")
  try assert.ok(!found_struct_new, "set_in_place should not allocate new PDict")
  .Ok({})
}

fn test_rt_dict_remove_in_place() Result<Void, String> {
  m := rt_dict.module()
  f := try find_func(m.funcs, "remove_in_place").ok_or("missing remove_in_place func")
