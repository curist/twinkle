// ── Helpers ─────────────────────────────────────────────────────────
fn contains(haystack: String, needle: String) Bool {
  if needle.len() > haystack.len() {
    return false
  }

  if needle.len() == 0 {
    return true
  }

  for i in 0..haystack.len() - needle.len() + 1 {
    if haystack.slice(i, i + needle.len()) == needle {
      return true
    }
  }

  false
}

fn find_type(types: Vector<TypeDef>, name: String) TypeDef? {
  for td in types {
    case td {
      .Struct(n, _, _, _) => if n == name {
        return .Some(td)
      },
      .Array(n, _) => if n == name {
        return .Some(td)
      },
      .FuncType(n, _, _) => if n == name {
        return .Some(td)
      },
    }
  }

  .None
}

// Recursively check if any instruction in a body (including nested blocks) matches a predicate.
fn has_instr(body: Vector<Instr>, pred: fn(Instr) Bool) Bool {
  for instr in body {
    if pred(instr) {
      return true
    }

    case instr {
      .If(_, then_body, else_body) => {
        if has_instr(then_body, pred) {
          return true
        }

        if has_instr(else_body, pred) {
          return true
        }
      },
      .Block(_, _, inner) => if has_instr(inner, pred) {
        return true
      },
      .Loop(_, _, inner) => if has_instr(inner, pred) {
        return true
      },
      _ => {},
    }
  }

  false
}

// ── rt.types tests ──────────────────────────────────────────────────
fn test_rt_types_namespace() Result<Void, String> {
  m := rt_types.module()
  try assert.equal(m.namespace, "rt.types")
  .Ok({})
}

fn test_rt_types_no_funcs() Result<Void, String> {
  m := rt_types.module()
  try assert.equal(m.funcs.len(), 0)
  try assert.equal(m.imports.len(), 0)
  try assert.equal(m.exports.len(), 0)
  .Ok({})
}

fn test_rt_types_array() Result<Void, String> {
  m := rt_types.module()

  // First type should be Array
  td := m.types[0]

  case td {
    .Array(name, elem) => {
      try assert.equal(name, "Array")
      try assert.ok(elem.mutable, "Array should be mutable")
      try assert.ok(
        case elem.ty {
          .Anyref => true,
          _ => false,
        },
        "Array elem should be anyref",
      )
    },
    _ => { return assert.fail("first type should be Array") },
  }

  .Ok({})
}

fn test_rt_types_string() Result<Void, String> {
  m := rt_types.module()

  // Second type should be String
  td := m.types[1]

  case td {
    .Array(name, elem) => {
      try assert.equal(name, "String")
      try assert.ok(elem.mutable, "String should be mutable")
      try assert.ok(
        case elem.ty {
          .I8 => true,
          _ => false,
        },
        "String elem should be i8",
      )
    },
    _ => { return assert.fail("second type should be String array") },
  }

  .Ok({})
}

fn test_rt_types_pdict() Result<Void, String> {
  m := rt_types.module()

  case find_type(m.types, "PDict") {
    .Some(.Struct(_, fields, _, _)) => {
      try assert.equal(fields.len(), 3)
      try assert.ok(
        case fields[0].name {
          .Some(n) => n == "size",
          .None => false,
        },
        "field 0 should be size",
      )
      try assert.ok(
        case fields[1].name {
          .Some(n) => n == "root",
          .None => false,
        },
        "field 1 should be root",
      )
      try assert.ok(
        case fields[2].name {
          .Some(n) => n == "order",
          .None => false,
        },
        "field 2 should be order",
      )
    },
    _ => { return assert.fail("missing PDict type") },
  }

  .Ok({})
}

