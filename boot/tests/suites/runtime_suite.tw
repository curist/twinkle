  try assert.int_eq(f.params.len(), 3)
  // Should contain If for clamping
  if_count := 0
  for instr in f.body {
    case instr { .If(_, _, _) => { if_count = if_count + 1 }, _ => {} }
  }
  try assert.ok(if_count >= 4, "substring should have clamping ifs")
  .Ok({})
}

fn test_rt_str_eq_loop() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "eq").ok_or("missing eq func")
  try assert.int_eq(f.params.len(), 2)
  try assert.int_eq(f.results.len(), 1)
  // Should contain a Loop for byte comparison
  found_loop := false
  for instr in f.body {
    case instr { .Block(_, _, body) => {
      for inner in body {
        case inner { .Loop(_, _, _) => { found_loop = true }, _ => {} }
      }
    }, _ => {} }
  }
  try assert.ok(found_loop, "eq should have a comparison loop")
  .Ok({})
}

fn test_rt_str_cmp_returns_ordering() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "cmp").ok_or("missing cmp func")
  try assert.int_eq(f.params.len(), 2)
  try assert.int_eq(f.results.len(), 1)
  // Should have locals for min_len, i, byte_a, byte_b, len_a, len_b
  try assert.int_eq(f.locals.len(), 6)
  .Ok({})
}

fn test_rt_str_from_i64_special_cases() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "from_i64").ok_or("missing from_i64 func")
  // Should have I64Eqz check for zero and a digit loop
  found_eqz := false
  found_loop := false
  for instr in f.body {
    case instr {
      .If(_, then_body, _) => {
        for t in then_body {
          case t {
            .ArrayNewFixed(_, 1) => { found_eqz = true },
            _ => {},
          }
        }
      },
      .Loop(_, _, _) => { found_loop = true },
      _ => {},
    }
  }
  try assert.ok(found_eqz, "from_i64 should handle zero case with ArrayNewFixed 1")
  try assert.ok(found_loop, "from_i64 should have digit extraction loop")
  .Ok({})
}

fn test_rt_str_from_f64_delegates() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "from_f64").ok_or("missing from_f64 func")
  found := false
  for instr in f.body {
    case instr { .Call(sym) => { if sym == "host_f64_to_string" { found = true } }, _ => {} }
  }
  try assert.ok(found, "from_f64 should call host_f64_to_string")
  .Ok({})
}

fn test_rt_str_from_bool_literals() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "from_bool").ok_or("missing from_bool func")
  // Should contain ArrayNewFixed for "true" (4 bytes) and "false" (5 bytes)
  found_4 := false
  found_5 := false
  for instr in f.body {
    case instr {
      .If(_, then_body, else_body) => {
        for t in then_body {
          case t { .ArrayNewFixed(_, 4) => { found_4 = true }, _ => {} }
        }
        for e in else_body {
          case e { .ArrayNewFixed(_, 5) => { found_5 = true }, _ => {} }
        }
      },
      _ => {},
    }
  }
  try assert.ok(found_4, "from_bool should emit 'true' (4 bytes)")
  try assert.ok(found_5, "from_bool should emit 'false' (5 bytes)")
  .Ok({})
}

fn test_rt_str_emits_wat() Result<Void, String> {
  m := rt_str.module()
  wat := emit_wat_unlinked_for_test(m)
  try assert.ok(contains(wat, "(func $len"), "WAT should contain len func")
  try assert.ok(contains(wat, "(func $concat"), "WAT should contain concat func")
  try assert.ok(contains(wat, "(func $from_i64"), "WAT should contain from_i64 func")
  .Ok({})
}

