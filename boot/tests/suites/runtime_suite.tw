fn test_rt_str_from_bool_literals() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "from_bool").ok_or("missing from_bool func")

  // Should contain ArrayNewFixed for "true" (4 bytes) and "false" (5 bytes)
  found_4 := false
  found_5 := false

  for instr in f.body {
    case instr {
      .If(_, then_body, else_body) => {
        for t in then_body {
          case t {
            .ArrayNewFixed(_, 4) => {
              found_4 = true
            },
            _ => {},
          }
        }

        for e in else_body {
          case e {
            .ArrayNewFixed(_, 5) => {
              found_5 = true
            },
            _ => {},
          }
        }
      },
      _ => {},
    }
  }

  try assert.ok(found_4, "from_bool should emit 'true' (4 bytes)")
  try assert.ok(found_5, "from_bool should emit 'false' (5 bytes)")
  .Ok({})
}

