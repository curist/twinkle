fn test_rt_str_from_i64_special_cases() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "from_i64").ok_or("missing from_i64 func")

  // Should have I64Eqz check for zero and a digit loop
  found_eqz := false
  found_loop := false

  for instr in f.body {
    case instr {
      .If(_, then_body, _) => {
        for t in then_body {
          case t {
            .ArrayNewFixed(_, 1) => {
              found_eqz = true
            },
            _ => {},
          }
        }
      },
      .Loop(_, _, _) => {
        found_loop = true
      },
      _ => {},
    }
  }

  try assert.ok(found_eqz, "from_i64 should handle zero case with ArrayNewFixed 1")
  try assert.ok(found_loop, "from_i64 should have digit extraction loop")
  .Ok({})
}

