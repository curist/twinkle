// ── Suite ───────────────────────────────────────────────────────────
pub fn suite() runner.Suite {
  runner.suite("runtime modules (M10)")
    .test("rt.types: namespace", test_rt_types_namespace)
    .test("rt.types: no funcs/imports/exports", test_rt_types_no_funcs)
    .test("rt.types: Array is mutable anyref array", test_rt_types_array)
    .test("rt.types: String is mutable i8 array", test_rt_types_string)
    .test("rt.types: PDict has size/root/order fields", test_rt_types_pdict)
    .test("rt.types: Closure is non-final", test_rt_types_closure_non_final)
    .test("rt.types: Variant has 3 fields", test_rt_types_variant)
    .test("rt.types: BoxedInt has i64 field", test_rt_types_boxed_int)
    .test("rt.types: BoxedFloat has f64 field", test_rt_types_boxed_float)
    .test("rt.types: IterState is non-final", test_rt_types_iter_state_non_final)
    .test("rt.types: VecChildren is mutable eqref array", test_rt_types_vec_children)
    .test("rt.types: VecInternal has children and sizes fields", test_rt_types_vec_internal)
    .test("rt.types: PVec has len/shift/root/tail", test_rt_types_pvec)
    .test("rt.types: emits valid WAT", test_rt_types_emits_wat)
    .test("rt.core: namespace", test_rt_core_namespace)
    .test("rt.core: exports all funcs", test_rt_core_exports_all_funcs)
    .test("rt.core: 5 host imports", test_rt_core_host_imports)
    .test("rt.core: imports equality helpers", test_rt_core_eq_imports)
    .test("rt.core: print delegates to host", test_rt_core_print_delegates)
    .test("rt.core: trap ends with unreachable", test_rt_core_trap_unreachable)
    .test("rt.core: eq uses ref.test dispatch", test_rt_core_eq_uses_ref_test)
    .test("rt.core: emits valid WAT", test_rt_core_emits_wat)
    .test("rt.str: namespace", test_rt_str_namespace)
    .test("rt.str: exports all funcs", test_rt_str_exports_all_funcs)
    .test("rt.str: imports host.f64_to_string", test_rt_str_host_f64_import)
    .test("rt.str: len uses array.len", test_rt_str_len)
