fn test_rt_arr_set_cow() Result<Void, String> {
  m := rt_arr.module()
  f := try find_func(m.funcs, "set").ok_or("missing set func")
  try assert.int_eq(f.params.len(), 3)
  // COW: should have ArrayNew + ArrayCopy + ArraySet
  found_new := false
  found_copy := false
  found_set := false
  for instr in f.body {
    case instr {
      .ArrayNew(_) => { found_new = true },
      .ArrayCopy(_, _) => { found_copy = true },
      .ArraySet(_) => { found_set = true },
      _ => {},
    }
  }
  try assert.ok(found_new, "set should allocate new array (COW)")
  try assert.ok(found_copy, "set should copy old array")
  try assert.ok(found_set, "set should set the new value")
  .Ok({})
}

