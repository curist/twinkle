// ── Helpers ─────────────────────────────────────────────────────────

fn contains(haystack: String, needle: String) Bool {
  if needle.len() > haystack.len() { return false }
  if needle.len() == 0 { return true }
  for i in range(haystack.len() - needle.len() + 1) {
    if haystack.slice(i, i + needle.len()) == needle { return true }
  }
  false
}

fn find_type(types: Vector<TypeDef>, name: String) TypeDef? {
  for td in types {
    case td {
      .Struct(n, _, _, _) => { if n == name { return .Some(td) } },
      .Array(n, _) => { if n == name { return .Some(td) } },
      .FuncType(n, _, _) => { if n == name { return .Some(td) } },
    }
  }
  .None
}

fn type_count(m: WasmModule) Int { m.types.len() }

// ── rt.types tests ──────────────────────────────────────────────────

fn test_rt_types_namespace() Result<Void, String> {
  m := rt_types.module()
  try assert.str_eq(m.namespace, "rt.types")
  .Ok({})
}

fn test_rt_types_count() Result<Void, String> {
  m := rt_types.module()
  try assert.int_eq(type_count(m), 11)
  .Ok({})
}

fn test_rt_types_no_funcs() Result<Void, String> {
  m := rt_types.module()
  try assert.int_eq(m.funcs.len(), 0)
  try assert.int_eq(m.imports.len(), 0)
  try assert.int_eq(m.exports.len(), 0)
  .Ok({})
}

fn test_rt_types_array() Result<Void, String> {
  m := rt_types.module()
  // First type should be Array
  td := m.types[0]
  case td {
    .Array(name, elem) => {
      try assert.str_eq(name, "Array")
      try assert.ok(elem.mutable, "Array should be mutable")
      try assert.ok(case elem.ty { .Anyref => true, _ => false }, "Array elem should be anyref")
    },
    _ => { return assert.fail("first type should be Array") },
  }
  .Ok({})
}

fn test_rt_types_string() Result<Void, String> {
  m := rt_types.module()
  // Second type should be String
  td := m.types[1]
  case td {
    .Array(name, elem) => {
      try assert.str_eq(name, "String")
      try assert.ok(elem.mutable, "String should be mutable")
      try assert.ok(case elem.ty { .I8 => true, _ => false }, "String elem should be i8")
    },
    _ => { return assert.fail("second type should be String array") },
  }
  .Ok({})
}

fn test_rt_types_dict_entry() Result<Void, String> {
  m := rt_types.module()
  case find_type(m.types, "DictEntry") {
    .Some(.Struct(_, fields, _, _)) => {
      try assert.int_eq(fields.len(), 2)
      try assert.ok(case fields[0].name { .Some(n) => n == "key", .None => false }, "field 0 should be key")
      try assert.ok(case fields[1].name { .Some(n) => n == "val", .None => false }, "field 1 should be val")
    },
    _ => { return assert.fail("missing DictEntry type") },
  }
  .Ok({})
}

