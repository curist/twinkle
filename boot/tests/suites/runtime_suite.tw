fn test_rt_types_vec_children() Result<Void, String> {
  m := rt_types.module()

  // NOTE: uses two-step match instead of .Some(.Array(...)) due to a nested
  // pattern match codegen issue with .Some(.Array(...)) in large compilation units.
  td := try find_type(m.types, "VecChildren").ok_or("missing VecChildren type")

  case td {
    .Array(name, elem) => {
      try assert.equal(name, "VecChildren")
      try assert.ok(elem.mutable, "VecChildren should be mutable")

      case elem.ty {
        .Ref(nullable, .Eq) => try assert.ok(nullable, "VecChildren elem should be nullable eqref"),
        _ => { return assert.fail("VecChildren elem should be ref null eq") },
      }
    },
    _ => { return assert.fail("VecChildren should be an Array type") },
  }

  .Ok({})
}

fn test_rt_types_vec_internal() Result<Void, String> {
  m := rt_types.module()
  td := try find_type(m.types, "VecInternal").ok_or("missing VecInternal type")

  case td {
    .Struct(_, fields, _, _) => {
      try assert.equal(fields.len(), 2)
      try assert.ok(
        case fields[0].name {
          .Some(n) => n == "children",
          .None => false,
        },
        "field 0 should be children",
      )

      // children field should be non-null ref to VecChildren
      case fields[0].ty {
        .Ref(nullable, .Named(n)) => {
          try assert.ok(!nullable, "children should be non-null ref")
          try assert.equal(n, "VecChildren")
        },
        _ => { return assert.fail("children should be ref VecChildren") },
      }

      try assert.ok(
        case fields[1].name {
          .Some(n) => n == "sizes",
          .None => false,
        },
        "field 1 should be sizes",
      )

      // RRB size table: nullable ref to I32Array (null ⇒ regular node)
      case fields[1].ty {
        .Ref(nullable, .Named(n)) => {
          try assert.ok(nullable, "sizes should be a nullable ref")
          try assert.equal(n, "I32Array")
        },
        _ => { return assert.fail("sizes should be ref null I32Array") },
      }
    },
    _ => { return assert.fail("VecInternal should be a Struct type") },
  }

  .Ok({})
}

fn test_rt_types_pvec() Result<Void, String> {
  m := rt_types.module()
  td := try find_type(m.types, "PVec").ok_or("missing PVec type")

  case td {
    .Struct(_, fields, _, _) => {
      try assert.equal(fields.len(), 4)
      try assert.ok(
        case fields[0].name {
          .Some(n) => n == "len",
          .None => false,
        },
        "field 0 should be len",
      )
      try assert.ok(
        case fields[0].ty {
          .I32 => true,
          _ => false,
        },
        "len should be i32",
      )
      try assert.ok(
        case fields[1].name {
          .Some(n) => n == "shift",
          .None => false,
        },
        "field 1 should be shift",
      )
      try assert.ok(
        case fields[1].ty {
          .I32 => true,
          _ => false,
        },
        "shift should be i32",
      )
      try assert.ok(
        case fields[2].name {
          .Some(n) => n == "root",
          .None => false,
        },
        "field 2 should be root",
      )

      // root: ref null VecInternal
      case fields[2].ty {
        .Ref(nullable, .Named(n)) => {
          try assert.ok(nullable, "root should be nullable")
          try assert.equal(n, "VecInternal")
        },
        _ => { return assert.fail("root should be ref null VecInternal") },
      }

      try assert.ok(
        case fields[3].name {
          .Some(n) => n == "tail",
          .None => false,
        },
        "field 3 should be tail",
      )

      // tail: ref Array (non-null)
      case fields[3].ty {
        .Ref(nullable, .Named(n)) => {
          try assert.ok(!nullable, "tail should be non-null")
          try assert.equal(n, "Array")
        },
        _ => { return assert.fail("tail should be ref Array") },
      }
    },
    _ => { return assert.fail("PVec should be a Struct type") },
  }

  .Ok({})
}

fn test_rt_types_emits_wat() Result<Void, String> {
  m := rt_types.module()
  wat := emit_wat_unlinked_for_test(m)
  try assert.ok(contains(wat, "(module"), "WAT should contain (module")
  try assert.ok(contains(wat, "$Array"), "WAT should contain Array type")
  try assert.ok(contains(wat, "$Closure"), "WAT should contain Closure type")
  try assert.ok(contains(wat, "$String"), "WAT should contain String type")
  .Ok({})
}

// ── rt.core tests ───────────────────────────────────────────────────
fn test_rt_core_namespace() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  try assert.equal(m.namespace, "rt.core")
  .Ok({})
}

fn test_rt_core_exports_all_funcs() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  try assert.equal(m.exports.len(), m.funcs.len())

  for f in m.funcs {
    found := false

    for exp in m.exports {
      if exp.func_sym == f.name {
        found = true
      }
    }

    try assert.ok(found, "function ${f.name} should be exported")
  }

  .Ok({})
}

fn test_rt_core_host_imports() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  host_count := 0
  found_print := false
  found_println := false
  found_error := false
  found_eprint := false
  found_eprintln := false

  for imp in m.imports {
    if imp.module == "host" {
      host_count = host_count + 1

      if imp.name == "print" {
        found_print = true
      }

      if imp.name == "println" {
        found_println = true
      }

      if imp.name == "error" {
        found_error = true
      }

      if imp.name == "eprint" {
        found_eprint = true
      }

      if imp.name == "eprintln" {
        found_eprintln = true
      }
    }
  }

  try assert.equal(host_count, 5)
  try assert.ok(found_print, "should import host.print")
  try assert.ok(found_println, "should import host.println")
  try assert.ok(found_error, "should import host.error")
  try assert.ok(found_eprint, "should import host.eprint")
  try assert.ok(found_eprintln, "should import host.eprintln")
  .Ok({})
}

fn test_rt_core_eq_imports() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  found_str := false
  found_arr_len := false
  found_arr_get := false
  found_dict_len := false
  found_dict_get := false
  found_dict_keys := false

  for imp in m.imports {
    if imp.module == "rt.str" and imp.name == "eq" {
      found_str = true
      try assert.equal(imp.as_sym, "rt_str__eq")
      try assert.equal(imp.params.len(), 2)
      try assert.equal(imp.results.len(), 1)
    }

    if imp.module == "rt.arr" and imp.name == "len" {
      found_arr_len = true
    }

    if imp.module == "rt.arr" and imp.name == "get" {
      found_arr_get = true
    }

    if imp.module == "rt.dict" and imp.name == "len" {
      found_dict_len = true
    }

    if imp.module == "rt.dict" and imp.name == "get" {
      found_dict_get = true
    }

    if imp.module == "rt.dict" and imp.name == "keys" {
      found_dict_keys = true
    }
  }

  try assert.ok(found_str, "should import rt.str.eq")
  try assert.ok(found_arr_len, "should import rt.arr.len")
  try assert.ok(found_arr_get, "should import rt.arr.get")
  try assert.ok(found_dict_len, "should import rt.dict.len")
  try assert.ok(found_dict_get, "should import rt.dict.get")
  try assert.ok(found_dict_keys, "should import rt.dict.keys")
  .Ok({})
}

fn find_func(funcs: Vector<FuncDef>, name: String) FuncDef? {
  for f in funcs {
    if f.name == name {
      return .Some(f)
    }
  }

  .None
}

fn test_rt_core_print_delegates() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  f := try find_func(m.funcs, "print").ok_or("missing print func")
  try assert.equal(f.params.len(), 1)

  // Body should call host_print
  found := false

  for instr in f.body {
    case instr {
      .Call(sym) => if sym == "host_print" {
        found = true
      },
      _ => {},
    }
  }

  try assert.ok(found, "print should call host_print")
  .Ok({})
}

fn test_rt_core_trap_unreachable() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  f := try find_func(m.funcs, "trap").ok_or("missing trap func")
  found_call := false
  found_unreachable := false

  for instr in f.body {
    case instr {
      .Call(sym) => if sym == "host_error" {
        found_call = true
      },
      .Unreachable => {
        found_unreachable = true
      },
      _ => {},
    }
  }

  try assert.ok(found_call, "trap should call host_error")
  try assert.ok(found_unreachable, "trap should end with unreachable")
  .Ok({})
}

fn test_rt_core_eq_uses_ref_test() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  f := try find_func(m.funcs, "eq").ok_or("missing eq func")
  try assert.equal(f.params.len(), 2)
  try assert.equal(f.results.len(), 1)
  found_boxed_int := false
  found_pvec := false
  found_pdict := false
  found_variant := false
  found_ref_eq := false

  for instr in f.body {
    case instr {
      .RefTest(_, .Named(n)) => {
        if n == "rt_types__BoxedInt" {
          found_boxed_int = true
        }

        if n == "rt_types__PVec" {
          found_pvec = true
        }

        if n == "rt_types__PDict" {
          found_pdict = true
        }

        if n == "rt_types__Variant" {
          found_variant = true
        }
      },
      .RefEq => {
        found_ref_eq = true
      },
      _ => {},
    }
  }

  try assert.ok(found_boxed_int, "eq should use ref.test for BoxedInt")
  try assert.ok(found_pvec, "eq should use ref.test for PVec")
  try assert.ok(found_pdict, "eq should use ref.test for PDict")
  try assert.ok(found_variant, "eq should use ref.test for Variant")
  try assert.ok(found_ref_eq, "eq should use ref.eq for identity check")
  .Ok({})
}

fn test_rt_core_emits_wat() Result<Void, String> {
  m := rt_core.module(.{ records: [], sums: [] })
  wat := emit_wat_unlinked_for_test(m)
  try assert.ok(contains(wat, "(func $print"), "WAT should contain print func")
  try assert.ok(contains(wat, "(func $eq"), "WAT should contain eq func")
  try assert.ok(contains(wat, "ref.test"), "WAT should contain ref.test")
  .Ok({})
}

