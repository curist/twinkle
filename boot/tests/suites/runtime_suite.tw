fn test_rt_arr_set_persistent() Result<Void, String> {
  m := rt_arr.module()
  f := try find_func(m.funcs, "set").ok_or("missing set func")
  try assert.equal(f.params.len(), 3)

  // The trie/tail boundary is computed inline as len - tail.len (relaxed-safe),
  // not via tailoff(); the meaningful contract is the do_set trie path below.
  try assert.ok(
    has_instr(
      f.body,
      fn(i: Instr) Bool {
        case i {
          .Call(sym) => sym == "do_set",
          _ => false,
        }
      },
    ),
    "set should call do_set for trie path",
  )
  try assert.ok(
    has_instr(
      f.body,
      fn(i: Instr) Bool {
        case i {
          .StructNew(name) => name == "rt_types__PVec",
          _ => false,
        }
      },
    ),
    "set should construct new PVec",
  )
  .Ok({})
}

