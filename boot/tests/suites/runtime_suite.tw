fn test_rt_str_concat_uses_array_copy() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "concat").ok_or("missing concat func")
  try assert.equal(f.params.len(), 2)

  // Should contain ArrayCopy
  count := 0

  for instr in f.body {
    case instr {
      .ArrayCopy(_, _) => {
        count = count + 1
      },
      _ => {},
    }
  }

  try assert.ok(count >= 2, "concat should use array.copy twice (for a and b)")
  .Ok({})
}

fn test_rt_str_substring_clamps() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "substring").ok_or("missing substring func")
  try assert.equal(f.params.len(), 3)

  // Should contain If for clamping
  if_count := 0

  for instr in f.body {
    case instr {
      .If(_, _, _) => {
        if_count = if_count + 1
      },
      _ => {},
    }
  }

  try assert.ok(if_count >= 4, "substring should have clamping ifs")
  .Ok({})
}

fn test_rt_str_eq_loop() Result<Void, String> {
  m := rt_str.module()
  f := try find_func(m.funcs, "eq").ok_or("missing eq func")
  try assert.equal(f.params.len(), 2)
  try assert.equal(f.results.len(), 1)

  // Should contain a Loop for byte comparison
  found_loop := false

  for instr in f.body {
    case instr {
      .Block(_, _, body) => {
        for inner in body {
          case inner {
            .Loop(_, _, _) => {
              found_loop = true
            },
            _ => {},
          }
        }
      },
      _ => {},
    }
  }

  try assert.ok(found_loop, "eq should have a comparison loop")
  .Ok({})
}

