    "lower for-in iterator loop follows type definition rather than preferred stored name",
    fn() Result<Void, String> {
      s0 := span.Span.{ file_id: 0, start: 0, end: 0 }
      t := mono_type.MonoType.Var("T")
      // Option (TypeId 0) — required by iterator loop pattern matching
      option_tid := mono_type.TypeId.{ id: 0 }
      option_entry := resolver.TypeEntry.{
        id: option_tid,
        arity: 1,
        def: .Some(
          resolver.ResolvedTypeDef.Sum(
            "Option",
            plain_resolved_type_params(["T"]),
            [
              resolver.ResolvedVariant.{ name: "None", fields: [] },
              resolver.ResolvedVariant.{ name: "Some", fields: [t] },
            ],
          ),
        ),
        span: s0,
        is_extern: false,
      }
      // Iterator (TypeId 62) — the type under test, intentionally a Sum
      iter_tid := mono_type.TypeId.{ id: 62 }
      iter_entry := resolver.TypeEntry.{
        id: iter_tid,
        arity: 1,
        def: .Some(
          resolver.ResolvedTypeDef.Sum(
            "Iterator",
            plain_resolved_type_params(["T"]),
            [resolver.ResolvedVariant.{ name: "Item", fields: [t] }],
          ),
        ),
        span: s0,
        is_extern: false,
      }
      // IterItem — required by build_iterator_loop
      iter_item_tid := mono_type.TypeId.{ id: 63 }
      iter_item_entry := resolver.TypeEntry.{
        id: iter_item_tid,
        arity: 1,
        def: .Some(
          resolver.ResolvedTypeDef.Record(
            "IterItem",
            plain_resolved_type_params(["T"]),
            [
              resolver.ResolvedField.{ name: "value", ty: t },
              resolver.ResolvedField.{
                name: "rest",
                ty: mono_type.MonoType.Named(iter_tid, [t]),
              },
            ],
          ),
        ),
        span: s0,
        is_extern: false,
      }
      env := resolver.empty_env().register_type_entry(option_entry, "Option").bind_type(
        "Option",
        option_tid,
      ).register_type_entry(iter_entry, "dep.Iterator").bind_type(
        "Iterator",
        iter_tid,
      ).register_type_entry(iter_item_entry, "IterItem").bind_type(
        "IterItem",
        iter_item_tid,
      )
      src := "fn f(it: Iterator<Int>) Void { for x in it { x } }"
      lr := try lower_src_with_env(src, env)
      body := lr.module.functions[0].body
      try assert.ok(has_loop(body), "expected Loop in iterator for-in")
      .Ok({})
    },
