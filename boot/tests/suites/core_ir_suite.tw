    "qualified variant uses qualifier TypeId",
    fn() Result<Void, String> {
      // QualifiedVariant should resolve TypeId from qualifier, not scrutinee
      src := "type Foo = { A(Int), B }\nfn f(x: Foo) Int { case x { Foo.A(n) => n, Foo.B => 0 } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body

      // Just check it lowers without error and has a Match
      case body.kind {
        .Match(_, arms) => {
          try assert.equal(arms.len(), 2)
          .Ok({})
        },
        _ => .Err("expected Match"),
      }
    },
  ).test(
    "imported prelude aliases reuse one phantom func id",
    fn() Result<Void, String> {
      filter_sig := resolver.FunctionSig.{
        name: "filter",
        type_params: plain_resolved_type_params(["T"]),
        param_names: ["xs", "pred"],
        params: [
          mono_type.MonoType.Vector(mono_type.MonoType.Var("T")),
          mono_type.MonoType.Function(
            [mono_type.MonoType.Var("T")],
            mono_type.MonoType.Bool,
          ),
        ],
        ret: .Some(mono_type.MonoType.Vector(mono_type.MonoType.Var("T"))),
        doc: .None,
        extern_module: .None,
      }
      vector_filter_sig := resolver.FunctionSig.{
        name: "vector_filter",
        type_params: plain_resolved_type_params(["T"]),
        param_names: ["xs", "pred"],
        params: [
          mono_type.MonoType.Vector(mono_type.MonoType.Var("T")),
          mono_type.MonoType.Function(
            [mono_type.MonoType.Var("T")],
            mono_type.MonoType.Bool,
          ),
        ],
        ret: .Some(mono_type.MonoType.Vector(mono_type.MonoType.Var("T"))),
        doc: .None,
        extern_module: .None,
      }
      origin := resolver.FunctionOrigin.{
        module_path: "prelude/vector.tw",
        func_name: "filter",
      }
      env := resolver.empty_env().with_functions([filter_sig, vector_filter_sig]).set_function_origin(
        "filter",
        origin,
      ).set_function_origin("vector_filter", origin)
      lr := try lower_src_with_env("fn main() Int { 0 }", env)
      filter_id := try lr.func_table["filter"].ok_or(
        "expected filter in func_table",
      )
      vector_filter_id := try lr.func_table["vector_filter"].ok_or(
        "expected vector_filter in func_table",
      )
      try assert.equal(filter_id.id, vector_filter_id.id)

      case lr.imported_func_origins[filter_id.id] {
        .Some(found) => {
          try assert.equal(found.module_path, "prelude/vector.tw")
          try assert.equal(found.func_name, "filter")
          .Ok({})
        },
        .None => .Err(
          "expected imported origin for shared prelude filter FuncId",
        ),
      }
    },
  ).test(
    "core linker validation rejects unresolved imported func ids",
    fn() Result<Void, String> {
      s := span.Span.{ file_id: 0, start: 0, end: 0 }
      body := core_ir.CoreExpr.{
        kind: .Call(
          core_ir.CoreExpr.{
            kind: .GlobalFunc(core_ir.FuncId.{ id: 100 }),
            ty: mono_type.MonoType.Void,
            span: s,
          },
          [],
        ),
        ty: mono_type.MonoType.Void,
        span: s,
      }
      func := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 10 },
        name: "main",
        params: [],
        body,
        return_ty: mono_type.MonoType.Void,
        is_init: false,
      }
      module := core_ir.CompiledModule.{
        path: "test/main.tw",
        core: core_ir.CoreModule.{
          functions: [func],
          type_env: resolver.empty_env(),
          init_func_id: .None,
          func_table: Dict.new(),
          extern_imports: Dict.new(),
        },
        func_table: Dict.new(),
        external_refs: Dict.new(),
        extern_imports: Dict.new(),
        builtin_count: 0,
        value_exports: Dict.new(),
        value_refs: Dict.new(),
        defined_global_count: 0,
      }
      global_ids: Dict<String, Dict<String, Int>> = Dict.new()
      mod_globals: Dict<String, Int> = Dict.new()
      mod_globals["main"] = 0
      global_ids["test/main.tw"] = mod_globals

      case core_linker.validate_compiled_module_links(module, global_ids) {
        .Ok(_) => .Err("expected unresolved imported FuncId validation failure"),
        .Err(msg) => {
          try assert.str_contains(msg, "unresolved imported FuncId=100")
          try assert.str_contains(msg, "test/main.tw")
          .Ok({})
        },
      }
    },
  ).test(
    "core linker validation rejects missing external targets",
    fn() Result<Void, String> {
      s := span.Span.{ file_id: 0, start: 0, end: 0 }
      body := core_ir.CoreExpr.{
        kind: .Call(
          core_ir.CoreExpr.{
            kind: .GlobalFunc(core_ir.FuncId.{ id: 100 }),
            ty: mono_type.MonoType.Void,
            span: s,
          },
          [],
        ),
        ty: mono_type.MonoType.Void,
        span: s,
      }
      func := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 10 },
        name: "main",
        params: [],
        body,
        return_ty: mono_type.MonoType.Void,
        is_init: false,
      }
      ext_refs: Dict<Int, core_ir.ExternalRef> = Dict.new()
      ext_refs[100] = core_ir.ExternalRef.{
        module_path: "dep/math.tw",
        func_name: "missing",
      }
      module := core_ir.CompiledModule.{
        path: "test/main.tw",
        core: core_ir.CoreModule.{
          functions: [func],
          type_env: resolver.empty_env(),
          init_func_id: .None,
          func_table: Dict.new(),
          extern_imports: Dict.new(),
        },
        func_table: Dict.new(),
        external_refs: ext_refs,
        extern_imports: Dict.new(),
        builtin_count: 0,
        value_exports: Dict.new(),
        value_refs: Dict.new(),
        defined_global_count: 0,
      }
      global_ids: Dict<String, Dict<String, Int>> = Dict.new()
      main_globals: Dict<String, Int> = Dict.new()
      main_globals["main"] = 0
      dep_globals: Dict<String, Int> = Dict.new()
      dep_globals["other"] = 1
      global_ids["test/main.tw"] = main_globals
      global_ids["dep/math.tw"] = dep_globals

      case core_linker.validate_compiled_module_links(module, global_ids) {
        .Ok(_) => .Err("expected missing external target validation failure"),
        .Err(msg) => {
          try assert.str_contains(msg, "missing function 'missing'")
          try assert.str_contains(msg, "dep/math.tw")
          .Ok({})
        },
      }
    },
  ).test(
    "core linker contract reachability prefers exact method target",
    fn() Result<Void, String> {
      s := span.Span.{ file_id: 0, start: 0, end: 0 }
      receiver := core_ir.CoreExpr.{
        kind: .LitInt(1),
        ty: mono_type.MonoType.Int,
        span: s,
      }
      body := core_ir.CoreExpr.{
        kind: .ContractCall(
          BuiltinContract.Stringify,
          "to_string",
          receiver,
          [],
        ),
        ty: mono_type.MonoType.String,
        span: s,
      }
      exact := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 42 },
        name: "int_to_string",
        params: [],
        body: core_ir.CoreExpr.{
          kind: .LitStr(""),
          ty: mono_type.MonoType.String,
          span: s,
        },
        return_ty: mono_type.MonoType.String,
        is_init: false,
      }
      fallback := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 99 },
        name: "Other.to_string",
        params: [],
        body: core_ir.CoreExpr.{
          kind: .LitStr(""),
          ty: mono_type.MonoType.String,
          span: s,
        },
        return_ty: mono_type.MonoType.String,
        is_init: false,
      }
      func_map: Dict<Int, core_ir.FunctionDef> = Dict.new()
      func_map[42] = exact
      func_map[99] = fallback
      func_table: Dict<String, core_ir.FuncId> = Dict.new()
      func_table["int_to_string"] = core_ir.FuncId.{ id: 42 }
      refs := dce.collect_func_refs(body, builtin_env(), func_table, func_map)
      try assert.equal(refs.len(), 1)
      try assert.equal(refs[0], 42)
      .Ok({})
    },
  ).test(
    "core linker contract fallback indexes method suffixes",
    fn() Result<Void, String> {
      s := span.Span.{ file_id: 0, start: 0, end: 0 }
      receiver := core_ir.CoreExpr.{
        kind: .LitInt(1),
        ty: mono_type.MonoType.Int,
        span: s,
      }
      body := core_ir.CoreExpr.{
        kind: .ContractCall(
          BuiltinContract.Stringify,
          "to_string",
          receiver,
          [],
        ),
        ty: mono_type.MonoType.String,
        span: s,
      }
      target := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 42 },
        name: "Int.to_string",
        params: [],
        body: core_ir.CoreExpr.{
          kind: .LitStr(""),
          ty: mono_type.MonoType.String,
          span: s,
        },
        return_ty: mono_type.MonoType.String,
        is_init: false,
      }
      func_map: Dict<Int, core_ir.FunctionDef> = Dict.new()
      func_map[42] = target
      func_table: Dict<String, core_ir.FuncId> = Dict.new()
      refs := dce.collect_func_refs(body, builtin_env(), func_table, func_map)
      try assert.equal(refs.len(), 1)
      try assert.equal(refs[0], 42)
      .Ok({})
    },
  ).test(
    "monomorphize transitive generics",
    fn() Result<Void, String> {
      src := "fn id<T>(x: T) T { x }\nfn wrap<T>(x: T) T { id(x) }\nfn f() Int { wrap(42) }"
      lr := try lower_src(src)
      result := monomorphize.monomorphize(lr.module)

      // Both id and wrap should be specialized, originals dropped
      for func in result.functions {
        try assert.ok(func.name != "id", "generic id should be dropped")
        try assert.ok(func.name != "wrap", "generic wrap should be dropped")
      }

      .Ok({})
    },
  )
}
