    "monomorphize infers nested return-only type params from contextual call type",
    fn() Result<Void, String> {
      src := "type Decoder<T> = .{ run: fn(Int) T }\nfn fail<T>(msg: String) Decoder<T> { .{ run: fn(_: Int) T { error(msg) } } }\nfn decode<T>(x: Int, d: Decoder<T>) T { d.run(x) }\nfn f() Int { decode(0, fail(\"oops\")) }"
      lr := try lower_src_with_builtin_env(src)
      result := monomorphize.monomorphize(lr.module)
      has_generic_fail := false
      spec_fail_id: Int? = .None
      f_body: core_ir.CoreExpr? = .None

      for func in result.functions {
        if func.name == "fail" { has_generic_fail = true }

        if func.name.starts_with("fail__") {
          spec_fail_id = .Some(func.func_id.id)
        }

        if func.name == "f" {
          f_body = .Some(func.body)
        }
      }

      try assert.ok(!has_generic_fail, "generic fail should be dropped")
      sid := case spec_fail_id {
        .Some(id) => id,
        .None => {
          return .Err("expected specialized fail function")
        },
      }
      body := case f_body {
        .Some(b) => b,
        .None => {
          return .Err("expected f body")
        },
      }
      try assert.ok(
        has_func_id(body, sid),
        "expected f body to reference specialized fail",
      )
      .Ok({})
    },
  ).test(
    "monomorphize generic closure-returning function rewrites make_closure target",
    fn() Result<Void, String> {
      src := "fn compose<A, B, C>(f: fn(B) C, g: fn(A) B) fn(A) C { fn(x) { f(g(x)) } }\ndouble := fn(x: Int) Int { x * 2 }\nadd1 := fn(x: Int) Int { x + 1 }\nf := compose(add1, double)"
      lr := try lower_src(src)
      result := monomorphize.monomorphize(lr.module)
      defined: Dict<Int, Bool> = Dict.new()
      compose_body: core_ir.CoreExpr? = .None
      has_generic_compose := false

      for func in result.functions {
        defined[func.func_id.id] = true

        if func.name == "compose" { has_generic_compose = true }

        if func.name.starts_with("compose__") {
          compose_body = .Some(func.body)
        }
      }

      try assert.ok(!has_generic_compose, "generic compose should be dropped")
      body := case compose_body {
        .Some(b) => b,
        .None => {
          return .Err("expected specialized compose function")
        },
      }
      targets := make_closure_targets(body, [])
      try assert.ok(
        targets.len() > 0,
        "expected specialized compose body to contain MakeClosure",
      )

      for tid in targets {
        try assert.ok(
          defined.has(tid),
          "expected make_closure target F${tid} to exist after monomorphization",
        )
      }

      .Ok({})
    },
  ).test(
    "end-to-end: generics + patterns",
    fn() Result<Void, String> {
