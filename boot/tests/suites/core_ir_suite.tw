// ── Helpers ──────────────────────────────────────────────────────────
fn parse_ok(src: String) Result<ast.Module, String> {
  parsed := parser.parse(src, 0)

  if parsed.diagnostics.len() > 0 {
    return .Err(
      "expected no diagnostics, got ${parsed.diagnostics.len()}: ${parsed.diagnostics[0].message()}",
    )
  }

  .Ok(parsed.value)
}

fn check_src(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := resolver.empty_env().resolve(parsed.value)
  checker.check(parsed.value, resolved.env)
}

fn lower_src(src: String) Result<lower_core.LowerResult, String> {
  parsed := parser.parse(src, 0)

  if parsed.diagnostics.len() > 0 {
    return .Err("parse error: ${parsed.diagnostics[0].message()}")
  }

  resolved := resolver.empty_env().resolve(parsed.value)

  if resolved.diagnostics.len() > 0 {
    return .Err("resolve error: ${resolved.diagnostics[0].message()}")
  }

  check_result := checker.check(parsed.value, resolved.env)

  if check_result.diagnostics.len() > 0 {
    return .Err("check error: ${check_result.diagnostics[0].message()}")
  }

  .Ok(
    lower_core.lower_module(parsed.value, check_result, make_builtin_registry()),
  )
}

fn lower_src_with_env(src: String, env: resolver.ResolvedEnv) Result<
  lower_core.LowerResult,
  String,
> {
  parsed := parser.parse(src, 0)

  if parsed.diagnostics.len() > 0 {
    return .Err("parse error: ${parsed.diagnostics[0].message()}")
  }

  resolved := env.resolve(parsed.value)

  if resolved.diagnostics.len() > 0 {
    return .Err("resolve error: ${resolved.diagnostics[0].message()}")
  }

  check_result := checker.check(parsed.value, resolved.env)

  if check_result.diagnostics.len() > 0 {
    return .Err("check error: ${check_result.diagnostics[0].message()}")
  }

  .Ok(
    lower_core.lower_module(parsed.value, check_result, make_builtin_registry()),
  )
}

fn lower_src_with_builtin_env(src: String) Result<
  lower_core.LowerResult,
  String,
> {
  parsed := parser.parse(src, 0)

  if parsed.diagnostics.len() > 0 {
    return .Err("parse error: ${parsed.diagnostics[0].message()}")
  }

  resolved := builtin_env().resolve(parsed.value)

  if resolved.diagnostics.len() > 0 {
    return .Err("resolve error: ${resolved.diagnostics[0].message()}")
  }

  check_result := checker.check(parsed.value, resolved.env)

  if check_result.diagnostics.len() > 0 {
    return .Err("check error: ${check_result.diagnostics[0].message()}")
  }

  .Ok(
    lower_core.lower_module(parsed.value, check_result, make_builtin_registry()),
  )
}

fn lower_fn_body(src: String) Result<core_ir.CoreExpr, String> {
  lr := try lower_src(src)

  if lr.module.functions.len() == 0 {
    return .Err("no functions in lowered module")
  }

  .Ok(lr.module.functions[0].body)
}

fn has_loop(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Loop(_) => true,
    .Let(_, val, body) => has_loop(val) or has_loop(body),
    .If(_, then_e, else_e) => has_loop(then_e) or has_loop(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_loop(arm.body) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

fn has_make_closure(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .MakeClosure(_, _) => true,
    .Let(_, val, body) => has_make_closure(val) or has_make_closure(body),
    .If(_, then_e, else_e) => has_make_closure(then_e)
    or has_make_closure(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_make_closure(arm.body) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

fn has_make_closure_capture(expr: core_ir.CoreExpr, target_local_id: Int) Bool {
  case expr.kind {
    .MakeClosure(_, free_vars) => {
      for fv in free_vars {
        if fv.id == target_local_id {
          return true
        }
      }

      false
    },
    .Let(_, val, body) => has_make_closure_capture(val, target_local_id)
    or has_make_closure_capture(body, target_local_id),
    .If(_, then_e, else_e) => has_make_closure_capture(then_e, target_local_id)
    or has_make_closure_capture(else_e, target_local_id),
    .Match(_, arms) => {
      for arm in arms {
        if has_make_closure_capture(arm.body, target_local_id) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

fn make_closure_targets(expr: core_ir.CoreExpr, out: Vector<Int>) Vector<Int> {
  case expr.kind {
    .MakeClosure(fid, _) => out.append(fid.id),
    .Let(_, val, body) => make_closure_targets(
      body,
      make_closure_targets(val, out),
    ),
    .If(_, then_e, else_e) => make_closure_targets(
      else_e,
      make_closure_targets(then_e, out),
    ),
    .Match(_, arms) => {
      cur := out

      for arm in arms { cur = make_closure_targets(arm.body, cur) }

      cur
    },
    .Loop(body) => make_closure_targets(body, out),
    .Assign(_, val) => make_closure_targets(val, out),
    .Record(_, fields) => {
      cur := out

      for field in fields { cur = make_closure_targets(field.value, cur) }

      cur
    },
    .RecordGet(target, _) => make_closure_targets(target, out),
    .RecordUpdate(base, _, value) => make_closure_targets(
      value,
      make_closure_targets(base, out),
    ),
    .Variant(_, _, args) => {
      cur := out

      for arg in args { cur = make_closure_targets(arg, cur) }

      cur
    },
    .ArrayLit(elems) => {
      cur := out

      for elem in elems { cur = make_closure_targets(elem, cur) }

      cur
    },
    .Index(base, idx) => make_closure_targets(
      idx,
      make_closure_targets(base, out),
    ),
    .Call(callee, args) => {
      cur := make_closure_targets(callee, out)

      for arg in args { cur = make_closure_targets(arg, cur) }

      cur
    },
    .UnOp(_, inner) => make_closure_targets(inner, out),
    .BinOp(_, lhs, rhs) => make_closure_targets(
      rhs,
      make_closure_targets(lhs, out),
    ),
    .Break(.Some(v)) => make_closure_targets(v, out),
    .Return(.Some(v)) => make_closure_targets(v, out),
    .Defer(inner) => make_closure_targets(inner, out),
    _ => out,
  }
}

fn has_match(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Match(_, _) => true,
    .Let(_, val, body) => has_match(val) or has_match(body),
    .If(_, then_e, else_e) => has_match(then_e) or has_match(else_e),
    _ => false,
  }
}

fn join_names(names: Vector<String>) String {
  if names.len() == 0 {
    return ""
  }

  result := names[0]
  i := 1

  for i < names.len() {
    result = .concat(", ").concat(names[i])
    i = i + 1
  }

  result
}

fn has_global_local(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .GlobalLocal(_) => true,
    .Let(_, val, body) => has_global_local(val) or has_global_local(body),
    .If(_, then_e, else_e) => has_global_local(then_e)
    or has_global_local(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_global_local(arm.body) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

// Check if a Return/Break/Continue appears in Let.value position (malformed Core IR)
fn has_terminal_in_let_value(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Let(_, val, body) => {
      case val.kind {
        .Return(_) => true,
        .Break(_) => true,
        .Continue => true,
        _ => has_terminal_in_let_value(val) or has_terminal_in_let_value(body),
      }
    },
    .If(cond, then_e, else_e) => {
      has_terminal_in_let_value(cond) or has_terminal_in_let_value(then_e)
      or has_terminal_in_let_value(else_e)
    },
    .Match(scrut, arms) => {
      if has_terminal_in_let_value(scrut) {
        return true
      }

      for arm in arms {
        if has_terminal_in_let_value(arm.body) {
          return true
        }
      }

      false
    },
    .Loop(inner) => has_terminal_in_let_value(inner),
    _ => false,
  }
}

fn has_func_id(expr: core_ir.CoreExpr, target_id: Int) Bool {
  case expr.kind {
    .Call(callee, args) => {
      case callee.kind {
        .GlobalFunc(fid) => {
          if fid.id == target_id {
            return true
          }
        },
        _ => {},
      }

      if has_func_id(callee, target_id) {
        return true
      }

      for a in args {
        if has_func_id(a, target_id) {
          return true
        }
      }

      false
    },
    .GlobalFunc(fid) => fid.id == target_id,
    .Let(_, val, body) => has_func_id(val, target_id)
    or has_func_id(body, target_id),
    .If(cond, then_e, else_e) => has_func_id(cond, target_id)
    or has_func_id(then_e, target_id)
    or has_func_id(else_e, target_id),
    .Match(scrut, arms) => {
      if has_func_id(scrut, target_id) {
        return true
      }

      for arm in arms {
        if has_func_id(arm.body, target_id) {
          return true
        }
      }

      false
    },
    .Loop(inner) => has_func_id(inner, target_id),
    .Assign(_, val) => has_func_id(val, target_id),
    _ => false,
  }
}

fn has_call(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Call(_, _) => true,
    .Let(_, val, body) => has_call(val) or has_call(body),
    .If(_, then_e, else_e) => has_call(then_e) or has_call(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_call(arm.body) {
          return true
        }
      }

      false
    },
    _ => false,
  }
}

// ── M0: Expression identity ─────────────────────────────────────────
pub fn suite() runner.Suite {
  runner.suite("core_ir").test(
    "expr has id field",
    fn() Result<Void, String> {
      mod := try parse_ok("fn f() Int { 42 }")

      case mod.items[0] {
        .Function(f) => {
          case f.body.tail {
            .Some(expr) => {
              assert.ok(expr.id >= 0, "expr.id should be non-negative")
            },
            .None => {
              return .Err("expected tail expression")
            },
          }
        },
        _ => {
          return .Err("expected function")
        },
      }

      .Ok({})
    },
  ).test(
    "distinct exprs get distinct ids",
    fn() Result<Void, String> {
      mod := try parse_ok("fn f() Int { 1 + 2 }")

      case mod.items[0] {
        .Function(f) => {
          case f.body.tail {
            .Some(expr) => {
              case expr.kind {
                .Binary(_, lhs, rhs) => {
                  try assert.ok(
                    expr.id != lhs.id,
                    "binary and lhs should have different ids",
                  )
                  try assert.ok(
                    expr.id != rhs.id,
                    "binary and rhs should have different ids",
                  )
                  assert.ok(
                    lhs.id != rhs.id,
                    "lhs and rhs should have different ids",
                  )
                },
                _ => {
                  return .Err("expected binary expression")
                },
              }
            },
            .None => {
              return .Err("expected tail expression")
            },
          }
        },
        _ => {
          return .Err("expected function")
        },
      }
    },
  ).test(
    "call expr and callee get distinct ids",
    fn() Result<Void, String> {
      mod := try parse_ok("fn foo() Int { 0 }\nfn f() Int { foo(1) }")

      case mod.items[1] {
        .Function(f) => {
          case f.body.tail {
            .Some(call_expr) => {
              case call_expr.kind {
                .Call(callee, args) => {
                  assert.ok(
                    call_expr.id != callee.id,
                    "call expr and callee should have different ids",
                  )
                },
                _ => {
                  return .Err("expected call expression")
                },
              }
            },
            .None => {
              return .Err("expected tail expression")
            },
          }
        },
        _ => {
          return .Err("expected function")
        },
      }
    },
  ).test(
    "CoreExpr construction",
    fn() Result<Void, String> {
      expr := core_ir.CoreExpr.{
        kind: .LitInt(42),
        ty: mono_type.MonoType.Int,
        span: span.new(0, 0, 2),
      }

      case expr.kind {
        .LitInt(n) => assert.equal(n, 42),
        _ => .Err("expected LitInt"),
      }
    },
  ).test(
    "FunctionDef construction",
    fn() Result<Void, String> {
      body := core_ir.CoreExpr.{
        kind: .LitInt(0),
        ty: mono_type.MonoType.Int,
        span: span.new(0, 0, 1),
      }
      def := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 1 },
        name: "test",
        params: [
          core_ir.Param.{
            local: core_ir.LocalId.{ id: 0 },
            ty: mono_type.MonoType.Int,
          },
        ],
        body: body,
        return_ty: mono_type.MonoType.Int,
        is_init: false,
      }
      try assert.equal(def.name, "test")
      assert.equal(def.params.len(), 1)
    },
  ).test(
    "CoreModule construction",
    fn() Result<Void, String> {
      mod := core_ir.CoreModule.{
        functions: [],
        type_env: resolver.empty_env(),
        init_func_id: .None,
        func_table: Dict.new(),
        extern_imports: Dict.new(),
      }
      assert.equal(mod.functions.len(), 0)
    },
  ).test(
    "lower int literal",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { 42 }")

      case body.kind {
        .LitInt(n) => assert.equal(n, 42),
        _ => .Err("expected LitInt, got other kind"),
      }
    },
  ).test(
    "lower hex literal",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { 0xFF }")

      case body.kind {
        .LitInt(n) => assert.equal(n, 255),
        _ => .Err("expected LitInt, got other kind"),
      }
    },
  ).test(
    "lower string literal",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() String { \"hello\" }")

      case body.kind {
        .LitStr(s) => assert.equal(s, "hello"),
        _ => .Err("expected LitStr, got other kind"),
      }
    },
  ).test(
    "lower float literal",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Float { 3.14 }")

      case body.kind {
        .LitFloat(_) => .Ok({}),
        _ => .Err("expected LitFloat, got other kind"),
      }
    },
  ).test(
    "lower bool literal",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Bool { true }")

      case body.kind {
        .LitBool(b) => assert.ok(b, "expected true"),
        _ => .Err("expected LitBool, got other kind"),
      }
    },
  ).test(
    "lower let binding",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { x := 5; x }")

      case body.kind {
        .Let(local, val, inner_body) => {
          case val.kind {
            .LitInt(n) => {
              try assert.equal(n, 5)

              case inner_body.kind {
                .Local(ref) => assert.equal(ref.id, local.id),
                _ => .Err("expected Local in body"),
              }
            },
            _ => .Err("expected LitInt in let value"),
          }
        },
        _ => .Err("expected Let, got other kind"),
      }
    },
  ).test(
    "lower binary add",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { 1 + 2 }")

      case body.kind {
        .BinOp(op, lhs, rhs) => {
          case op {
            .Add => {
              case lhs.kind {
                .LitInt(a) => {
                  case rhs.kind {
                    .LitInt(b) => {
                      try assert.equal(a, 1)
                      assert.equal(b, 2)
                    },
                    _ => .Err("expected LitInt rhs"),
                  }
                },
                _ => .Err("expected LitInt lhs"),
              }
            },
            _ => .Err("expected Add op"),
          }
        },
        _ => .Err("expected BinOp"),
      }
    },
  ).test(
    "lower if expression",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { if true { 1 } else { 2 } }")

      case body.kind {
        .If(cond, then_e, else_e) => {
          case cond.kind {
            .LitBool(b) => {
              try assert.ok(b, "expected true")

              case then_e.kind {
                .LitInt(a) => {
                  case else_e.kind {
                    .LitInt(b2) => {
                      try assert.equal(a, 1)
                      assert.equal(b2, 2)
                    },
                    _ => .Err("expected LitInt else"),
                  }
                },
                _ => .Err("expected LitInt then"),
              }
            },
            _ => .Err("expected LitBool cond"),
          }
        },
        _ => .Err("expected If"),
      }
    },
  ).test(
    "lower unary negation",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { -42 }")

      case body.kind {
        .UnOp(op, operand) => {
          case op {
            .Neg => {
              case operand.kind {
                .LitInt(n) => assert.equal(n, 42),
                _ => .Err("expected LitInt operand"),
              }
            },
            _ => .Err("expected Neg"),
          }
        },
        _ => .Err("expected UnOp"),
      }
    },
  ).test(
    "lower short-circuit and",
    fn() Result<Void, String> {
      body := try lower_fn_body("fn f(a: Bool, b: Bool) Bool { a and b }")

      // `and` desugars to If(a, b, false)
      case body.kind {
        .If(_, _, else_e) => {
          case else_e.kind {
            .LitBool(b) => assert.ok(!b, "expected false in else branch"),
            _ => .Err("expected LitBool(false) in else branch"),
          }
        },
        _ => .Err("expected If (short-circuit and)"),
      }
    },
  ).test(
    "lower function call",
    fn() Result<Void, String> {
      body := try lower_fn_body(
        "fn add(a: Int, b: Int) Int { a + b }\nfn f() Int { add(1, 2) }",
      )
      // lower_fn_body returns first function's body (add), we want the second (f)
      lr := try lower_src(
        "fn add(a: Int, b: Int) Int { a + b }\nfn f() Int { add(1, 2) }",
      )

      if lr.module.functions.len() < 2 {
        return .Err("expected 2 functions, got ${lr.module.functions.len()}")
      }

      call_body := lr.module.functions[1].body

      case call_body.kind {
        .Call(callee, args) => {
          case callee.kind {
            .GlobalFunc(fid) => {
              // add should have been assigned a FuncId
              reg := make_builtin_registry()
              try assert.ok(
                fid.id >= reg.next_id,
                "FuncId should be >= user func start",
              )
              assert.equal(args.len(), 2)
            },
            _ => .Err("expected GlobalFunc callee"),
          }
        },
        _ => .Err("expected Call"),
      }
    },
  ).test(
    "distinct FuncIds for multiple functions",
    fn() Result<Void, String> {
      lr := try lower_src(
        "fn a() Int { 1 }\nfn b() Int { 2 }\nfn c() Int { 3 }",
      )
      try assert.equal(lr.module.functions.len(), 3)
      f0 := lr.module.functions[0].func_id.id
      f1 := lr.module.functions[1].func_id.id
      f2 := lr.module.functions[2].func_id.id
      try assert.ok(f0 != f1, "f0 and f1 should differ")
      try assert.ok(f1 != f2, "f1 and f2 should differ")
      assert.ok(f0 != f2, "f0 and f2 should differ")
    },
  ).test(
    "lower named record",
    fn() Result<Void, String> {
      src := "type Point = .{ x: Int, y: Int }\nfn f() Point { Point.{ x: 1, y: 2 } }"
      lr := try lower_src(src)

      if lr.module.functions.len() < 1 {
        return .Err("expected at least 1 function")
      }

      body := lr.module.functions[0].body

      case body.kind {
        .Record(tid, fields) => { assert.equal(fields.len(), 2) },
        _ => .Err("expected Record"),
      }
    },
  ).test(
    "lower field access",
    fn() Result<Void, String> {
      src := "type Point = .{ x: Int, y: Int }\nfn f(p: Point) Int { p.x }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body

      case body.kind {
        .RecordGet(_, fid) => .Ok({}),
        _ => .Err("expected RecordGet"),
      }
    },
  ).test(
    "lower case match",
    fn() Result<Void, String> {
      src := "type MyOpt = { MyNone, MySome(Int) }\nfn f(o: MyOpt) Int { case o { .MySome(x) => x, .MyNone => 0 } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body

      case body.kind {
        .Match(scrut, arms) => { assert.equal(arms.len(), 2) },
        _ => .Err("expected Match"),
      }
    },
  ).test(
    "lower for-in vector loop",
    fn() Result<Void, String> {
      src := "fn f(xs: Vector<Int>) Void { for x in xs { x } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Structure: Let(_, for_desugaring, rest)
      // for_desugaring = Let(arr, xs, Let(len, ..., Let(idx, 0, Loop(...))))
      try assert.ok(has_loop(body), "expected Loop node in for-in desugaring")
      .Ok({})
    },
  ).test(
    "lower return as terminal",
    fn() Result<Void, String> {
      src := "fn f() Int { return 42 }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body

      case body.kind {
        .Return(val) => {
          case val {
            .Some(e) => {
              case e.kind {
                .LitInt(n) => assert.equal(n, 42),
                _ => .Err("expected LitInt in return value"),
              }
            },
            .None => .Err("expected return value"),
          }
        },
        _ => .Err("expected Return"),
      }
    },
  ).test(
    "lower simple assign",
    fn() Result<Void, String> {
      src := "fn f() Int { x := 1; x = x + 1; x }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body

      // Should be Let(x, 1, Let(_, Assign(x, x+1), Local(x)))
      case body.kind {
        .Let(x_local, _, inner) => {
          case inner.kind {
            .Let(_, assign_val, _) => {
              case assign_val.kind {
                .Assign(target, _) => { assert.equal(target.id, x_local.id) },
                _ => .Err("expected Assign"),
              }
            },
            _ => .Err("expected Let wrapping Assign"),
          }
        },
        _ => .Err("expected Let at top"),
      }
    },
  ).test(
    "type_map keyed by expr.id",
    fn() Result<Void, String> {
      src := "fn foo(x: Int) Int { x }\nfn f() Int { foo(1) }"
      parsed := parser.parse(src, 0)
      resolved := resolver.empty_env().resolve(parsed.value)
      result := checker.check(parsed.value, resolved.env)

      if result.diagnostics.len() > 0 {
        return .Err("unexpected diagnostic: ${result.diagnostics[0].message()}")
      }

      case parsed.value.items[1] {
        .Function(f) => {
          case f.body.tail {
            .Some(call_expr) => {
              case call_expr.kind {
                .Call(callee, _) => {
                  call_has := result.type_map.has(call_expr.id)
                  callee_has := result.type_map.has(callee.id)
                  try assert.ok(
                    call_has,
                    "call expr type not found in type_map",
                  )
                  assert.ok(callee_has, "callee type not found in type_map")
                },
                _ => {
                  return .Err("expected call expression")
                },
              }
            },
            .None => {
              return .Err("expected tail expression")
            },
          }
        },
        _ => {
          return .Err("expected function")
        },
      }
    },
  ).test(
