use tests.runner
use tests.assert
use compiler.parser
use compiler.resolver
use compiler.checker
use compiler.ast
use compiler.core_ir
use compiler.lower_core
use compiler.monomorphize
use lib.source.span

// ── Helpers ──────────────────────────────────────────────────────────

fn parse_ok(src: String) Result<ast.Module, String> {
  parsed := parser.parse(src, 0)
  if parsed.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got ${parsed.diagnostics.len()}: ${parsed.diagnostics[0].message}")
  }
  .Ok(parsed.value)
}

fn check_src(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := resolver.empty_env().resolve(parsed.value)
  checker.check(parsed.value, resolved.env)
}

fn lower_src(src: String) Result<lower_core.LowerResult, String> {
  parsed := parser.parse(src, 0)
  if parsed.diagnostics.len() > 0 {
    return .Err("parse error: ${parsed.diagnostics[0].message}")
  }
  resolved := resolver.empty_env().resolve(parsed.value)
  if resolved.diagnostics.len() > 0 {
    return .Err("resolve error: ${resolved.diagnostics[0].message}")
  }
  check_result := checker.check(parsed.value, resolved.env)
  if check_result.diagnostics.len() > 0 {
    return .Err("check error: ${check_result.diagnostics[0].message}")
  }
  .Ok(lower_core.lower_module(parsed.value, check_result))
}

fn lower_fn_body(src: String) Result<core_ir.CoreExpr, String> {
  lr := try lower_src(src)
  if lr.module.functions.len() == 0 {
    return .Err("no functions in lowered module")
  }
  .Ok(lr.module.functions[0].body)
}

fn has_loop(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Loop(_) => true,
    .Let(_, val, body) => has_loop(val) or has_loop(body),
    .If(_, then_e, else_e) => has_loop(then_e) or has_loop(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_loop(arm.body) { return true }
      }
      false
    },
    _ => false,
  }
}

fn has_make_closure(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .MakeClosure(_, _) => true,
    .Let(_, val, body) => has_make_closure(val) or has_make_closure(body),
    .If(_, then_e, else_e) => has_make_closure(then_e) or has_make_closure(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_make_closure(arm.body) { return true }
      }
      false
    },
    _ => false,
  }
}

fn has_match(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Match(_, _) => true,
    .Let(_, val, body) => has_match(val) or has_match(body),
    .If(_, then_e, else_e) => has_match(then_e) or has_match(else_e),
    _ => false,
  }
}

fn join_names(names: Vector<String>) String {
  if names.len() == 0 { return "" }
  result := names[0]
  i := 1
  for i < names.len() {
    result = result.concat(", ").concat(names[i])
    i = i + 1
  }
  result
}

fn has_global_local(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .GlobalLocal(_) => true,
    .Let(_, val, body) => has_global_local(val) or has_global_local(body),
    .If(_, then_e, else_e) => has_global_local(then_e) or has_global_local(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_global_local(arm.body) { return true }
      }
      false
    },
    _ => false,
  }
}

// Check if a Return/Break/Continue appears in Let.value position (malformed Core IR)
fn has_terminal_in_let_value(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Let(_, val, body) => {
      case val.kind {
        .Return(_) => true,
        .Break(_) => true,
        .Continue => true,
        _ => has_terminal_in_let_value(val) or has_terminal_in_let_value(body),
      }
    },
    .If(cond, then_e, else_e) => {
      has_terminal_in_let_value(cond) or has_terminal_in_let_value(then_e) or has_terminal_in_let_value(else_e)
    },
    .Match(scrut, arms) => {
      if has_terminal_in_let_value(scrut) { return true }
      for arm in arms {
        if has_terminal_in_let_value(arm.body) { return true }
      }
      false
    },
    .Loop(inner) => has_terminal_in_let_value(inner),
    _ => false,
  }
}

fn has_func_id(expr: core_ir.CoreExpr, target_id: Int) Bool {
  case expr.kind {
    .Call(callee, args) => {
      case callee.kind {
        .GlobalFunc(fid) => {
          if fid.id == target_id { return true }
        },
        _ => {},
      }
      if has_func_id(callee, target_id) { return true }
      for a in args {
        if has_func_id(a, target_id) { return true }
      }
      false
    },
    .GlobalFunc(fid) => fid.id == target_id,
    .Let(_, val, body) => has_func_id(val, target_id) or has_func_id(body, target_id),
    .If(cond, then_e, else_e) => has_func_id(cond, target_id) or has_func_id(then_e, target_id) or has_func_id(else_e, target_id),
    .Match(scrut, arms) => {
      if has_func_id(scrut, target_id) { return true }
      for arm in arms {
        if has_func_id(arm.body, target_id) { return true }
      }
      false
    },
    .Loop(inner) => has_func_id(inner, target_id),
    .Assign(_, val) => has_func_id(val, target_id),
    _ => false,
  }
}

fn has_call(expr: core_ir.CoreExpr) Bool {
  case expr.kind {
    .Call(_, _) => true,
    .Let(_, val, body) => has_call(val) or has_call(body),
    .If(_, then_e, else_e) => has_call(then_e) or has_call(else_e),
    .Match(_, arms) => {
      for arm in arms {
        if has_call(arm.body) { return true }
      }
      false
    },
    _ => false,
  }
}

// ── M0: Expression identity ─────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("core_ir")
    .test("expr has id field", fn() Result<Void, String> {
      mod := try parse_ok("fn f() Int { 42 }")
      case mod.items[0] {
        .Function(f) => {
          case f.body.tail {
            .Some(expr) => {
              assert.ok(expr.id >= 0, "expr.id should be non-negative")
            },
            .None => { return .Err("expected tail expression") },
          }
        },
        _ => { return .Err("expected function") },
      }
      .Ok({})
    })
    .test("distinct exprs get distinct ids", fn() Result<Void, String> {
      mod := try parse_ok("fn f() Int { 1 + 2 }")
      case mod.items[0] {
        .Function(f) => {
          case f.body.tail {
            .Some(expr) => {
              case expr.kind {
                .Binary(_, lhs, rhs) => {
                  try assert.ok(expr.id != lhs.id, "binary and lhs should have different ids")
                  try assert.ok(expr.id != rhs.id, "binary and rhs should have different ids")
                  assert.ok(lhs.id != rhs.id, "lhs and rhs should have different ids")
                },
                _ => { return .Err("expected binary expression") },
              }
            },
            .None => { return .Err("expected tail expression") },
          }
        },
        _ => { return .Err("expected function") },
      }
    })
    .test("call expr and callee get distinct ids", fn() Result<Void, String> {
      mod := try parse_ok("fn foo() Int { 0 }\nfn f() Int { foo(1) }")
      case mod.items[1] {
        .Function(f) => {
          case f.body.tail {
            .Some(call_expr) => {
              case call_expr.kind {
                .Call(callee, args) => {
                  assert.ok(call_expr.id != callee.id,
                    "call expr and callee should have different ids")
                },
                _ => { return .Err("expected call expression") },
              }
            },
            .None => { return .Err("expected tail expression") },
          }
        },
        _ => { return .Err("expected function") },
      }
    })
    // ── M1: Core IR types ─────────────────────────────────────────────
    .test("CoreExpr construction", fn() Result<Void, String> {
      expr := core_ir.CoreExpr.{
        kind: .LitInt(42),
        ty: resolver.MonoType.Int,
        span: span.new(0, 0, 2),
      }
      case expr.kind {
        .LitInt(n) => assert.int_eq(n, 42),
        _ => .Err("expected LitInt"),
      }
    })
    .test("FunctionDef construction", fn() Result<Void, String> {
      body := core_ir.CoreExpr.{
        kind: .LitInt(0),
        ty: resolver.MonoType.Int,
        span: span.new(0, 0, 1),
      }
      def := core_ir.FunctionDef.{
        func_id: core_ir.FuncId.{ id: 1 },
        name: "test",
        params: [core_ir.Param.{ local: core_ir.LocalId.{ id: 0 }, ty: resolver.MonoType.Int }],
        body: body,
        return_ty: resolver.MonoType.Int,
      }
      try assert.str_eq(def.name, "test")
      assert.int_eq(def.params.len(), 1)
    })
    .test("CoreModule construction", fn() Result<Void, String> {
      mod := core_ir.CoreModule.{
        functions: [],
        type_env: resolver.empty_env(),
        init_func_id: .None,
      }
      assert.int_eq(mod.functions.len(), 0)
    })
    // ── M2: Literals, identifiers, let bindings ───────────────────────
    .test("lower int literal", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { 42 }")
      case body.kind {
        .LitInt(n) => assert.int_eq(n, 42),
        _ => .Err("expected LitInt, got other kind"),
      }
    })
    .test("lower hex literal", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { 0xFF }")
      case body.kind {
        .LitInt(n) => assert.int_eq(n, 255),
        _ => .Err("expected LitInt, got other kind"),
      }
    })
    .test("lower string literal", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() String { \"hello\" }")
      case body.kind {
        .LitStr(s) => assert.str_eq(s, "hello"),
        _ => .Err("expected LitStr, got other kind"),
      }
    })
    .test("lower float literal", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Float { 3.14 }")
      case body.kind {
        .LitFloat(_) => .Ok({}),
        _ => .Err("expected LitFloat, got other kind"),
      }
    })
    .test("lower bool literal", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Bool { true }")
      case body.kind {
        .LitBool(b) => assert.ok(b, "expected true"),
        _ => .Err("expected LitBool, got other kind"),
      }
    })
    .test("lower let binding", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { x := 5; x }")
      case body.kind {
        .Let(local, val, inner_body) => {
          case val.kind {
            .LitInt(n) => {
              try assert.int_eq(n, 5)
              case inner_body.kind {
                .Local(ref) => assert.int_eq(ref.id, local.id),
                _ => .Err("expected Local in body"),
              }
            },
            _ => .Err("expected LitInt in let value"),
          }
        },
        _ => .Err("expected Let, got other kind"),
      }
    })
    // ── M3: Binary/unary operators, if expressions ────────────────────
    .test("lower binary add", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { 1 + 2 }")
      case body.kind {
        .BinOp(op, lhs, rhs) => {
          case op {
            .Add => {
              case lhs.kind {
                .LitInt(a) => {
                  case rhs.kind {
                    .LitInt(b) => {
                      try assert.int_eq(a, 1)
                      assert.int_eq(b, 2)
                    },
                    _ => .Err("expected LitInt rhs"),
                  }
                },
                _ => .Err("expected LitInt lhs"),
              }
            },
            _ => .Err("expected Add op"),
          }
        },
        _ => .Err("expected BinOp"),
      }
    })
    .test("lower if expression", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { if true { 1 } else { 2 } }")
      case body.kind {
        .If(cond, then_e, else_e) => {
          case cond.kind {
            .LitBool(b) => {
              try assert.ok(b, "expected true")
              case then_e.kind {
                .LitInt(a) => {
                  case else_e.kind {
                    .LitInt(b2) => {
                      try assert.int_eq(a, 1)
                      assert.int_eq(b2, 2)
                    },
                    _ => .Err("expected LitInt else"),
                  }
                },
                _ => .Err("expected LitInt then"),
              }
            },
            _ => .Err("expected LitBool cond"),
          }
        },
        _ => .Err("expected If"),
      }
    })
    .test("lower unary negation", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Int { -42 }")
      case body.kind {
        .UnOp(op, operand) => {
          case op {
            .Neg => {
              case operand.kind {
                .LitInt(n) => assert.int_eq(n, 42),
                _ => .Err("expected LitInt operand"),
              }
            },
            _ => .Err("expected Neg"),
          }
        },
        _ => .Err("expected UnOp"),
      }
    })
    .test("lower short-circuit and", fn() Result<Void, String> {
      body := try lower_fn_body("fn f(a: Bool, b: Bool) Bool { a && b }")
      // a && b desugars to If(a, b, false)
      case body.kind {
        .If(_, _, else_e) => {
          case else_e.kind {
            .LitBool(b) => assert.ok(!b, "expected false in else branch"),
            _ => .Err("expected LitBool(false) in else branch"),
          }
        },
        _ => .Err("expected If (short-circuit &&)"),
      }
    })
    // ── M4: Function calls, FuncId assignment ─────────────────────────
    .test("lower function call", fn() Result<Void, String> {
      body := try lower_fn_body("fn add(a: Int, b: Int) Int { a + b }\nfn f() Int { add(1, 2) }")
      // lower_fn_body returns first function's body (add), we want the second (f)
      lr := try lower_src("fn add(a: Int, b: Int) Int { a + b }\nfn f() Int { add(1, 2) }")
      if lr.module.functions.len() < 2 {
        return .Err("expected 2 functions, got ${lr.module.functions.len()}")
      }
      call_body := lr.module.functions[1].body
      case call_body.kind {
        .Call(callee, args) => {
          case callee.kind {
            .GlobalFunc(fid) => {
              // add should have been assigned a FuncId
              try assert.ok(fid.id >= 41, "FuncId should be >= USER_FUNC_START")
              assert.int_eq(args.len(), 2)
            },
            _ => .Err("expected GlobalFunc callee"),
          }
        },
        _ => .Err("expected Call"),
      }
    })
    .test("distinct FuncIds for multiple functions", fn() Result<Void, String> {
      lr := try lower_src("fn a() Int { 1 }\nfn b() Int { 2 }\nfn c() Int { 3 }")
      try assert.int_eq(lr.module.functions.len(), 3)
      f0 := lr.module.functions[0].func_id.id
      f1 := lr.module.functions[1].func_id.id
      f2 := lr.module.functions[2].func_id.id
      try assert.ok(f0 != f1, "f0 and f1 should differ")
      try assert.ok(f1 != f2, "f1 and f2 should differ")
      assert.ok(f0 != f2, "f0 and f2 should differ")
    })
    // ── M5: Records, variants, pattern matching ───────────────────────
    .test("lower named record", fn() Result<Void, String> {
      src := "type Point = .{ x: Int, y: Int }\nfn f() Point { Point.{ x: 1, y: 2 } }"
      lr := try lower_src(src)
      if lr.module.functions.len() < 1 {
        return .Err("expected at least 1 function")
      }
      body := lr.module.functions[0].body
      case body.kind {
        .Record(tid, fields) => {
          assert.int_eq(fields.len(), 2)
        },
        _ => .Err("expected Record"),
      }
    })
    .test("lower field access", fn() Result<Void, String> {
      src := "type Point = .{ x: Int, y: Int }\nfn f(p: Point) Int { p.x }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      case body.kind {
        .RecordGet(_, fid) => .Ok({}),
        _ => .Err("expected RecordGet"),
      }
    })
    .test("lower case match", fn() Result<Void, String> {
      src := "type MyOpt = { MyNone, MySome(Int) }\nfn f(o: MyOpt) Int { case o { .MySome(x) => x, .MyNone => 0 } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      case body.kind {
        .Match(scrut, arms) => {
          assert.int_eq(arms.len(), 2)
        },
        _ => .Err("expected Match"),
      }
    })
    // ── M6: For loops, break/continue, return, assign, defer ──────────
    .test("lower for-in vector loop", fn() Result<Void, String> {
      src := "fn f(xs: Vector<Int>) Void { for x in xs { x } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Structure: Let(_, for_desugaring, rest)
      // for_desugaring = Let(arr, xs, Let(len, ..., Let(idx, 0, Loop(...))))
      try assert.ok(has_loop(body), "expected Loop node in for-in desugaring")
      .Ok({})
    })
    .test("lower return as terminal", fn() Result<Void, String> {
      src := "fn f() Int { return 42 }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      case body.kind {
        .Return(val) => {
          case val {
            .Some(e) => {
              case e.kind {
                .LitInt(n) => assert.int_eq(n, 42),
                _ => .Err("expected LitInt in return value"),
              }
            },
            .None => .Err("expected return value"),
          }
        },
        _ => .Err("expected Return"),
      }
    })
    .test("lower simple assign", fn() Result<Void, String> {
      src := "fn f() Int { x := 1; x = x + 1; x }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should be Let(x, 1, Let(_, Assign(x, x+1), Local(x)))
      case body.kind {
        .Let(x_local, _, inner) => {
          case inner.kind {
            .Let(_, assign_val, _) => {
              case assign_val.kind {
                .Assign(target, _) => {
                  assert.int_eq(target.id, x_local.id)
                },
                _ => .Err("expected Assign"),
              }
            },
            _ => .Err("expected Let wrapping Assign"),
          }
        },
        _ => .Err("expected Let at top"),
      }
    })
    .test("type_map keyed by expr.id", fn() Result<Void, String> {
      src := "fn foo(x: Int) Int { x }\nfn f() Int { foo(1) }"
      parsed := parser.parse(src, 0)
      resolved := resolver.empty_env().resolve(parsed.value)
      result := checker.check(parsed.value, resolved.env)

      if result.diagnostics.len() > 0 {
        return .Err("unexpected diagnostic: ${result.diagnostics[0].message}")
      }

      case parsed.value.items[1] {
        .Function(f) => {
          case f.body.tail {
            .Some(call_expr) => {
              case call_expr.kind {
                .Call(callee, _) => {
                  call_has := result.type_map.has(call_expr.id)
                  callee_has := result.type_map.has(callee.id)
                  try assert.ok(call_has, "call expr type not found in type_map")
                  assert.ok(callee_has, "callee type not found in type_map")
                },
                _ => { return .Err("expected call expression") },
              }
            },
            .None => { return .Err("expected tail expression") },
          }
        },
        _ => { return .Err("expected function") },
      }
    })
    // ── M7: Closures, try, string interpolation, collect ──────────────
    .test("lower closure with capture", fn() Result<Void, String> {
      src := "fn f(y: Int) fn(Int) Int { fn(x: Int) Int { x + y } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should produce MakeClosure with free_vars containing y
      try assert.ok(has_make_closure(body), "expected MakeClosure in closure lowering")
      // Should have hoisted a function
      try assert.ok(lr.module.functions.len() >= 2, "expected hoisted lambda function")
      .Ok({})
    })
    .test("lower nested closure capture", fn() Result<Void, String> {
      src := "fn f(a: Int) fn(Int) fn(Int) Int { fn(b: Int) fn(Int) Int { fn(c: Int) Int { a + b + c } } }"
      lr := try lower_src(src)
      // Should have 3 functions: f + 2 hoisted lambdas
      try assert.ok(lr.module.functions.len() >= 3, "expected at least 3 functions (f + 2 lambdas)")
      .Ok({})
    })
    .test("lower try in result-returning fn", fn() Result<Void, String> {
      src := "fn parse(s: String) Result<Int, String> { .Ok(1) }\nfn f(s: String) Result<Int, String> { x := try parse(s); .Ok(x) }"
      lr := try lower_src(src)
      // f's body should contain a Match (try desugaring)
      body := lr.module.functions[1].body
      try assert.ok(has_match(body), "expected Match from try desugaring")
      .Ok({})
    })
    .test("lower try in option-returning fn", fn() Result<Void, String> {
      src := "fn find(x: Int) Int? { .Some(x) }\nfn f(x: Int) Int? { y := try find(x); .Some(y) }"
      lr := try lower_src(src)
      body := lr.module.functions[1].body
      try assert.ok(has_match(body), "expected Match from try desugaring")
      .Ok({})
    })
    .test("lower string interpolation", fn() Result<Void, String> {
      // Build source with interpolation syntax without triggering our own parser
      // Use from_code_point(36) to get "$" without triggering interpolation
      dollar: String = case String.from_code_point(36) {
        .Some(d) => d,
        .None => { return .Err("failed to create dollar sign") },
      }
      src: String = "fn f(n: Int) String { \"value: ".concat(dollar).concat("{n}\" }")
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should produce Call(string_concat, [...]) chain
      try assert.ok(has_call(body), "expected Call in string interpolation")
      .Ok({})
    })
    .test("lower collect expression", fn() Result<Void, String> {
      src := "fn f(xs: Vector<Int>) Vector<Int> { collect x in xs { x * 2 } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should produce builder pattern with loop
      try assert.ok(has_loop(body), "expected Loop in collect desugaring")
      .Ok({})
    })
    .test("lower array literal", fn() Result<Void, String> {
      body := try lower_fn_body("fn f() Vector<Int> { [1, 2, 3] }")
      case body.kind {
        .ArrayLit(elems) => assert.int_eq(elems.len(), 3),
        _ => .Err("expected ArrayLit"),
      }
    })
    // ── M8: Module-level lets, __init__ ───────────────────────────────
    .test("lower module-level let with __init__", fn() Result<Void, String> {
      src := "x := 42\nfn f() Int { x }"
      lr := try lower_src(src)
      // Should have __init__ func + f
      try assert.ok(lr.module.functions.len() >= 2, "expected at least 2 functions (f + __init__)")
      // init_func_id should be set
      case lr.module.init_func_id {
        .Some(_) => .Ok({}),
        .None => .Err("expected init_func_id to be set"),
      }
    })
    .test("module-level let produces GlobalLocal", fn() Result<Void, String> {
      src := "x := 42\nfn f() Int { x }"
      lr := try lower_src(src)
      // f should reference x via GlobalLocal
      f_body := lr.module.functions[0].body
      try assert.ok(has_global_local(f_body), "expected GlobalLocal reference in f body")
      .Ok({})
    })
    // ── M9: Monomorphization ─────────────────────────────────────────
    .test("monomorphize identity function", fn() Result<Void, String> {
      src := "fn id<T>(x: T) T { x }\nfn f() Int { id(42) }"
      lr := try lower_src(src)
      result := monomorphize.monomorphize(lr.module)
      // Generic id should be dropped, specialized version added
      // Only f and id__Int should remain
      has_generic := false
      has_specialized := false
      for func in result.functions {
        if func.name == "id" { has_generic = true }
        if func.name.len() > 2 and func.name.slice(0, 2) == "id" and func.name != "id" {
          has_specialized = true
        }
      }
      try assert.ok(!has_generic, "generic id should be dropped")
      try assert.ok(has_specialized, "specialized id should exist")
      .Ok({})
    })
    // ── M10: Integration / end-to-end ────────────────────────────────
    .test("end-to-end: generics + patterns", fn() Result<Void, String> {
      src := "fn first<T>(a: T, b: T) T { a }\nfn pick<T>(x: T) T { first(x, x) }\nfn f() Int { pick(42) }"
      lr := try lower_src(src)
      result := monomorphize.monomorphize(lr.module)
      // first and pick are generic, should be dropped
      // f + specialized first + specialized pick = 3 functions
      has_generic := false
      for func in result.functions {
        if func.name == "first" or func.name == "pick" { has_generic = true }
      }
      try assert.ok(!has_generic, "generic functions should be dropped after mono")
      try assert.ok(result.functions.len() >= 3, "expected at least 3 functions after mono")
      .Ok({})
    })
    // ── G3: Complex lvalue assignment ────────────────────────────────
    .test("lower field assignment", fn() Result<Void, String> {
      src := "type Point = .{ x: Int, y: Int }\nfn f(p: Point) Point { p.x = 42; p }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should produce: Let(_, Assign(p, RecordUpdate(Local(p), x_fid, LitInt(42))), Local(p))
      case body.kind {
        .Let(_, assign_expr, _) => {
          case assign_expr.kind {
            .Assign(_, update) => {
              case update.kind {
                .RecordUpdate(_, _, _) => .Ok({}),
                _ => .Err("expected RecordUpdate in assign value"),
              }
            },
            _ => .Err("expected Assign"),
          }
        },
        _ => .Err("expected Let wrapping field assignment"),
      }
    })
    .test("lower index assignment", fn() Result<Void, String> {
      src := "fn f(xs: Vector<Int>) Vector<Int> { xs[0] = 99; xs }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should produce: Let(_, Assign(xs, Call(VECTOR_SET_UNSAFE, [...])), Local(xs))
      case body.kind {
        .Let(_, assign_expr, _) => {
          case assign_expr.kind {
            .Assign(_, update) => {
              case update.kind {
                .Call(_, _) => .Ok({}),
                _ => .Err("expected Call (VECTOR_SET_UNSAFE) in assign value"),
              }
            },
            _ => .Err("expected Assign"),
          }
        },
        _ => .Err("expected Let wrapping index assignment"),
      }
    })
    .test("lower dict assignment", fn() Result<Void, String> {
      src := "fn f(m: Dict<String, Int>) Dict<String, Int> { m[\"k\"] = 1; m }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      case body.kind {
        .Let(_, assign_expr, _) => {
          case assign_expr.kind {
            .Assign(_, update) => {
              case update.kind {
                .Call(_, _) => .Ok({}),
                _ => .Err("expected Call (DICT_SET) in assign value"),
              }
            },
            _ => .Err("expected Assign"),
          }
        },
        _ => .Err("expected Let wrapping dict assignment"),
      }
    })
    // ── G4: For-loop type dispatch ──────────────────────────────────
    .test("lower for-in string loop", fn() Result<Void, String> {
      src := "fn f(s: String) Void { for b in s { b } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Should use string_len (FuncId 8), not vector_len
      try assert.ok(has_loop(body), "expected Loop in string for-in")
      // Check that the len call uses FuncId(8) = string_len
      try assert.ok(has_func_id(body, 8), "expected string_len (FuncId 8) call")
      .Ok({})
    })
    // Range for-loop test deferred — requires Range type in test env
    .test("lower for-in dict loop", fn() Result<Void, String> {
      src := "fn f(m: Dict<String, Int>) Void { for k in m { k } }"
      lr := try lower_src(src)
      body := lr.module.functions[0].body
      // Dict loop calls DICT_KEYS (FuncId 14) to get key vector
      try assert.ok(has_loop(body), "expected Loop in dict for-in")
      try assert.ok(has_func_id(body, 14), "expected DICT_KEYS (FuncId 14) call")
      .Ok({})
    })
    .test("monomorphize transitive generics", fn() Result<Void, String> {
      src := "fn id<T>(x: T) T { x }\nfn wrap<T>(x: T) T { id(x) }\nfn f() Int { wrap(42) }"
      lr := try lower_src(src)
      result := monomorphize.monomorphize(lr.module)
      // Both id and wrap should be specialized, originals dropped
      for func in result.functions {
        try assert.ok(func.name != "id", "generic id should be dropped")
        try assert.ok(func.name != "wrap", "generic wrap should be dropped")
      }
      .Ok({})
    })
}
