      src := "fn id<T>(x: T) T { x }\nfn f() Int { id(42) }"
      lr := try lower_src(src)
      result := monomorphize.monomorphize(lr.module)
      // Generic id should be dropped, specialized version added
      // Only f and id__Int should remain
      has_generic := false
      has_specialized := false

      for func in result.functions {
        if func.name == "id" { has_generic = true }

        if func.name.len() > 2 and func.name.slice(0, 2) == "id"
        and func.name != "id" { has_specialized = true }
      }

      try assert.ok(!has_generic, "generic id should be dropped")
      try assert.ok(has_specialized, "specialized id should exist")
      .Ok({})
    },
  ).test(
    "monomorphize infers return-only type params from call result type",
    fn() Result<Void, String> {
      src := "fn fail<T>(msg: String) T { error(msg) }\nfn f() Int { fail(\"oops\") }"
      lr := try lower_src_with_builtin_env(src)
      result := monomorphize.monomorphize(lr.module)
      has_generic_fail := false
      has_specialized_fail := false

      for func in result.functions {
        if func.name == "fail" { has_generic_fail = true }

        if func.name.starts_with("fail__") { has_specialized_fail = true }
      }

      try assert.ok(!has_generic_fail, "generic fail should be dropped")
      try assert.ok(has_specialized_fail, "specialized fail should exist")
      .Ok({})
    },
