use compiler.lexer
use compiler.parser
use compiler.tokens.{Token}
use lib.source.diagnostics as diag
use @std.testing.assert as assert
use @std.testing as runner

// Non-trivia, non-Eof tokens from lexing `src`.
fn lex_tokens(src: String) Vector<Token> {
  result := lexer.lex(src, 0)
  collect t in result.value {
    t
  }
}

fn parse_diag_count(src: String) Int {
  parser.parse(src, 0).diagnostics.len()
}

// Concatenated messages of all lex diagnostics for `src`.
fn lex_diag_messages(src: String) String {
  msgs := collect d in lexer.lex(src, 0).diagnostics {
    diag.message(d)
  }
  msgs.join(" | ")
}

pub fn suite() runner.Suite {
  runner
    .suite("string literals")
    .test(
      "raw single-line keeps backslashes literal",
      fn() {
        toks := lex_tokens("r\"\\d+\"")
        try assert.is_true(toks[0].kind == .StringLit)
        try assert.equal(toks[0].text, "\\d+")
        .Ok({})
      },
    )
    .test(
      "raw interpolation keeps both segments raw",
      fn() {
        // r"\d ${x} z\w" — backslashes stay literal across the interpolation.
        toks := lex_tokens("r\"\\d ".concat("$").concat("{x} z\\w\""))
        try assert.is_true(toks[0].kind == .StringStart)
        try assert.equal(toks[0].text, "\\d ")
        try assert.is_true(toks[1].kind == .Ident)
        try assert.is_true(toks[2].kind == .StringEnd)
        try assert.equal(toks[2].text, " z\\w")
        .Ok({})
      },
    )
    .test(
      "raw backslash-n is two chars, not a newline",
      fn() {
        toks := lex_tokens("r\"\\n\"")
        try assert.is_true(toks[0].kind == .StringLit)
        try assert.equal(toks[0].text, "\\n")
        try assert.equal(toks[0].text.len(), 2)
        .Ok({})
      },
    )
    .test(
      "raw string with a literal newline is unterminated",
      fn() {
        result := lexer.lex("r\"abc\ndef\"", 0)
        try assert.is_true(result.diagnostics.len() > 0)
        .Ok({})
      },
    )
    .test(
      "r prefix only applies immediately before a quote",
      fn() {
        red := lex_tokens("red")
        try assert.is_true(red[0].kind == .Ident)
        try assert.equal(red[0].text, "red")

        bare := lex_tokens("r + 1")
        try assert.is_true(bare[0].kind == .Ident)
        try assert.equal(bare[0].text, "r")
        .Ok({})
      },
    )
    .test(
      "multiline block joins lines with newline, no trailing newline",
      fn() {
        // \\a / \\b  ->  "a\nb"
        toks := lex_tokens("\\\\a\n\\\\b")
        try assert.is_true(toks[0].kind == .StringLit)
        try assert.equal(toks[0].text, "a\nb")
        .Ok({})
      },
    )
    .test(
      "trailing empty marker line adds a newline",
      fn() {
        // \\last / \\   ->  "last\n"
        toks := lex_tokens("\\\\last\n\\\\")
        try assert.equal(toks[0].text, "last\n")
        .Ok({})
      },
    )
    .test(
      "single marker line is its content with no newline",
      fn() {
        toks := lex_tokens("\\\\foo")
        try assert.is_true(toks[0].kind == .StringLit)
        try assert.equal(toks[0].text, "foo")
        .Ok({})
      },
    )
    .test(
      "marker indentation excluded, content indentation preserved",
      fn() {
        // Markers indented two spaces; the two spaces after a marker are content.
        src := "  \\\\<div>\n  \\\\  <h1>x</h1>\n  \\\\</div>"
        toks := lex_tokens(src)
        try assert.equal(toks[0].text, "<div>\n  <h1>x</h1>\n</div>")
        .Ok({})
      },
    )
    .test(
      "CRLF line endings normalize to LF",
      fn() {
        toks := lex_tokens("\\\\a\r\n\\\\b")
        try assert.equal(toks[0].text, "a\nb")
        .Ok({})
      },
    )
    .test(
      "a non-marker line ends the block",
      fn() {
        toks := lex_tokens("\\\\a\nfoo")
        try assert.is_true(toks[0].kind == .StringLit)
        try assert.equal(toks[0].text, "a")
        try assert.is_true(toks[1].kind == .Ident)
        try assert.equal(toks[1].text, "foo")
        .Ok({})
      },
    )
    .test(
      "multiline block parses as a binding value on following lines",
      fn() {
        src := "query :=\n  \\\\SELECT *\n  \\\\FROM users\n"
        try assert.equal(parse_diag_count(src), 0)
        .Ok({})
      },
    )
    .test(
      "multiline single interpolation",
      fn() {
        // \\a ${x} b
        toks := lex_tokens("\\\\a \${x} b")
        try assert.is_true(toks[0].kind == .StringStart)
        try assert.equal(toks[0].text, "a ")
        try assert.is_true(toks[1].kind == .Ident)
        try assert.equal(toks[1].text, "x")
        try assert.is_true(toks[2].kind == .StringEnd)
        try assert.equal(toks[2].text, " b")
        .Ok({})
      },
    )
    .test(
      "multiline interpolation accumulates earlier lines",
      fn() {
        // \\a / \\b ${x}
        toks := lex_tokens("\\\\a\n\\\\b \${x}")
        try assert.is_true(toks[0].kind == .StringStart)
        try assert.equal(toks[0].text, "a\nb ")
        try assert.is_true(toks[1].kind == .Ident)
        try assert.is_true(toks[2].kind == .StringEnd)
        try assert.equal(toks[2].text, "")
        .Ok({})
      },
    )
    .test(
      "multiline multiple interpolations",
      fn() {
        // \\${a} and ${b}!
        toks := lex_tokens("\\\\\${a} and \${b}!")
        try assert.is_true(toks[0].kind == .StringStart)
        try assert.equal(toks[0].text, "")
        try assert.is_true(toks[1].kind == .Ident)
        try assert.is_true(toks[2].kind == .StringContinue)
        try assert.equal(toks[2].text, " and ")
        try assert.is_true(toks[3].kind == .Ident)
        try assert.is_true(toks[4].kind == .StringEnd)
        try assert.equal(toks[4].text, "!")
        .Ok({})
      },
    )
    .test(
      "lone dollar in multiline stays literal",
      fn() {
        // \\price $5 (no interpolation)
        toks := lex_tokens("\\\\price $5")
        try assert.is_true(toks[0].kind == .StringLit)
        try assert.equal(toks[0].text, "price $5")
        .Ok({})
      },
    )
    .test(
      "interpolation spanning a line break in a multiline block errors",
      fn() {
        // \\a ${x  (newline before closing }) -> diagnostic
        result := lexer.lex("\\\\a \${x\n\\\\y}", 0)
        try assert.is_true(result.diagnostics.len() > 0)
        .Ok({})
      },
    )
    .test(
      "L1 lint suggests a single-line string for a one-line block",
      fn() {
        // plain content -> cooked string suggestion
        try assert.str_contains(lex_diag_messages("\\\\hello"), "\"hello\"")

        // backslash content -> raw string suggestion
        try assert.str_contains(lex_diag_messages("\\\\\\d+"), "r\"\\d+\"")

        // content with a quote -> escaped cooked suggestion
        try assert.str_contains(lex_diag_messages("\\\\say \"hi\""), "say \\\"hi\\\"")
        .Ok({})
      },
    )
    .test(
      "L1 lint does not fire for trailing-newline or multi-line blocks",
      fn() {
        // trailing empty marker => has a newline => not single-line
        try assert.equal(lex_diag_messages("\\\\last\n\\\\"), "")

        // genuinely multi-line
        try assert.equal(lex_diag_messages("\\\\a\n\\\\b"), "")
        .Ok({})
      },
    )
}
