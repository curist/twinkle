use compiler.base_env
use compiler.lint
use compiler.parser
use tests.assert
use tests.runner

fn findings(src: String) Vector<lint.LintFinding> {
  parsed := parser.parse(src, 0)
  lint.lint_module(parsed.value, base_env.builtin_env())
}

pub fn suite() runner.Suite {
  runner
    .suite("lint_pass")
    .test(
      "L4: unreachable statement after return",
      fn() {
        fs := findings("fn f() Int {\n  return 1\n  2\n}\n")
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "unreachable-code")
        .Ok({})
      },
    )
    .test(
      "L4: no finding when return is last",
      fn() {
        fs := findings("fn f() Int {\n  x := 1\n  return x\n}\n")
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L4: unreachable after error() trap",
      fn() {
        fs := findings("fn f() Int {\n  error(\"boom\")\n  1\n}\n")
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "unreachable-code")
        .Ok({})
      },
    )
    .test(
      "L4: plain reachable code is not flagged",
      fn() {
        fs := findings("fn f() Int {\n  x := 1\n  x + 1\n}\n")
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L4: unreachable after continue inside a loop body",
      fn() {
        fs := findings(
          "fn f() Int {\n  for true {\n    continue\n    println(\"x\")\n  }\n  0\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "unreachable-code")
        .Ok({})
      },
    )
    .test(
      "L4: one finding per block (first unreachable only)",
      fn() {
        fs := findings("fn f() Int {\n  return 1\n  2\n  3\n}\n")
        try assert.equal(fs.len(), 1)
        .Ok({})
      },
    )
    .test(
      "L3: flags a with_* field-copy helper (anonymous record)",
      fn() {
        fs := findings(
          "fn with_docs(state: State, docs: Int) State {\n  .{ initialized: state.initialized, docs }\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "record-copy-helper")
        .Ok({})
      },
    )
    .test(
      "L3: flags a named-record copy",
      fn() {
        fs := findings(
          "fn dup(state: State) State {\n  State.{ initialized: state.initialized }\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "record-copy-helper")
        .Ok({})
      },
    )
    .test(
      "L3: does not flag a function doing real work",
      fn() {
        fs := findings("fn bump(state: State) State {\n  .{ count: state.count + 1 }\n}\n")
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L3: does not flag when no parameter shares the record type",
      fn() {
        fs := findings("fn make(n: Int) State {\n  .{ initialized: n }\n}\n")
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: flags index temporary copied back to the same path",
      fn() {
        fs := findings(
          "fn f(pf: PF) PF {\n  slots := pf.slots\n  slots[id] = info\n  pf.slots = slots\n  pf\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "direct-rebinding")
        .Ok({})
      },
    )
    .test(
      "L5: flags whole-record temporary returned at tail",
      fn() {
        fs := findings(
          "fn f(info: Info) Info {\n  updated := info\n  updated.repr = repr\n  updated\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "direct-rebinding")
        .Ok({})
      },
    )
    .test(
      "L5: does not flag when temporary escapes to a call",
      fn() {
        fs := findings(
          "fn f(pf: PF) PF {\n  slots := pf.slots\n  slots[id] = info\n  other(slots)\n  pf.slots = slots\n  pf\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: flags pure-alias accumulator over a loop",
      fn() {
        fs := findings(
          "fn f(reg: Reg, specs: Specs) Reg {\n  cur := reg\n  for spec in specs {\n    cur = cur.add(spec)\n  }\n  cur\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "direct-rebinding")
        .Ok({})
      },
    )
    .test(
      "L5: flags whole-record temporary assigned back to the source",
      fn() {
        fs := findings(
          "fn f(state: State) State {\n  updated := state\n  updated.cache = cache\n  state = updated\n  state\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "direct-rebinding")
        .Ok({})
      },
    )
    .test(
      "L5: does not flag when the alias mixes in the old source value",
      fn() {
        fs := findings(
          "fn f(reg: Reg) Reg {\n  cur := reg\n  cur = cur.add(a)\n  cur = cur.merge(reg)\n  cur\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: does not flag when the source path is read between update and copy-back",
      fn() {
        fs := findings(
          "fn f(reg: Reg) Reg {\n  tmp := reg.by_name\n  tmp[k] = v\n  log(reg.by_name.len())\n  reg.by_name = tmp\n  reg\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: flags a deep field path copied back",
      fn() {
        fs := findings(
          "fn f(state: State) State {\n  tmp := state.registry.by_name\n  tmp[name] = entry\n  state.registry.by_name = tmp\n  state\n}\n",
        )
        try assert.equal(fs.len(), 1)
        try assert.equal(fs[0].rule, "direct-rebinding")
        .Ok({})
      },
    )
    .test(
      "L5: does not flag an indexed source path",
      fn() {
        fs := findings(
          "fn f(reg: Reg) Reg {\n  tmp := reg.by_name[key()]\n  tmp.value = v\n  reg.by_name[key()] = tmp\n  reg\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: does not flag an extracted (unwrapped) value",
      fn() {
        fs := findings(
          "fn f(reg: Reg) Reg {\n  entry := reg.by_name[name].unwrap()\n  entry.canonical = c\n  reg.by_name[name] = entry\n  reg\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: does not flag a conditionally-updated temporary (not straight-line)",
      fn() {
        fs := findings(
          "fn f(state: State) State {\n  tmp := state.config\n  if enabled {\n    tmp.debug = true\n  }\n  state.config = tmp\n  state\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
    .test(
      "L5: does not flag when a prefix of the source path is read",
      fn() {
        fs := findings(
          "fn f(state: State) State {\n  tmp := state.registry.by_name\n  tmp[k] = v\n  log(state.registry)\n  state.registry.by_name = tmp\n  state\n}\n",
        )
        try assert.equal(fs.len(), 0)
        .Ok({})
      },
    )
}
