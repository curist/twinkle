/// Tests for analyze_typed_fields in boot/compiler/backend/route_typed_vec.tw.
///
/// analyze_typed_fields decides, per (TypeId, FieldId), whether a Vector<Int>
/// record field can be physically stored as PVecI64. The conservative policy
/// (Approach B): a field is typed iff it has at least one typed-routable producer
/// (a collect/builder whose only other uses are index/len) and every producer and
/// consumer is typed-friendly. Any boxed producer (param/combinator result),
/// escaping consumer, or a value feeding multiple fields demotes the field.
///
/// These are end-to-end fixtures: each test compiles a tiny .tw source through
/// the real pipeline (compile_source -> closure_convert -> prepare_backend), then
/// runs analyze_typed_fields on the prepared funcs and inspects the decision dict.

use compiler.backend.closure_convert.{convert_closures}
use compiler.backend.prepare.{PreparedModule, prepare_backend, prepare_backend_preroute}
use compiler.backend.prepared_ir.{PreparedFunc, SlotInfo}
use compiler.backend.route_typed_vec.{analyze_typed_fields, route_typed_vectors}
use compiler.backend.verify.{verify_prepared_module_with_level}
use compiler.builtins.{BuiltinRegistry}
use compiler.pipeline
use compiler.resolver.{ResolvedEnv}
use tests.assert
use tests.runner

// Compile source to the prepared backend funcs + builtin registry, then run the
// whole-program typed-field analysis on them.
fn analyze_src(src: String) Result<Dict<String, Bool>, String> {
  artifacts := try pipeline.compile_source(src)
  cc := convert_closures(artifacts.opt, artifacts.env)

  // Analyze the pre-routing prepared funcs: routing retypes producer slots to
  // PVecI64, which would hide them from this analysis pass.
  prepared := prepare_backend_preroute(cc.anf, artifacts.env, artifacts.builtins, cc.captures)
  .Ok(analyze_typed_fields(prepared.funcs, artifacts.builtins))
}

type RouteInputs = .{ funcs: Vector<PreparedFunc>, builtins: BuiltinRegistry }

// Compile source to prepared backend funcs + registry (the raw inputs to both
// analyze_typed_fields and route_typed_vectors).
fn prepare_src(src: String) Result<RouteInputs, String> {
  artifacts := try pipeline.compile_source(src)
  cc := convert_closures(artifacts.opt, artifacts.env)

  // Use the pre-routing funcs so route_typed_vectors can be exercised on
  // un-routed slots (prepare_backend already routes its final funcs).
  prepared := prepare_backend_preroute(cc.anf, artifacts.env, artifacts.builtins, cc.captures)
  .Ok(.{ funcs: prepared.funcs, builtins: artifacts.builtins })
}

type VerifyInputs = .{ prepared: PreparedModule, env: ResolvedEnv, builtins: BuiltinRegistry }

// Compile source through the full backend preparation (including typed-vector
// routing), returning the routed PreparedModule plus the env/builtins the
// verifier consumes. The routed module's producer/field-read slots are already
// PVecI64 where the field set says the field is typed.
fn verify_inputs(src: String) Result<VerifyInputs, String> {
  artifacts := try pipeline.compile_source(src)
  cc := convert_closures(artifacts.opt, artifacts.env)
  prepared := prepare_backend(cc.anf, artifacts.env, artifacts.builtins, cc.captures)
  .Ok(.{ prepared, env: artifacts.env, builtins: artifacts.builtins })
}

// True if a slot's physical wasm storage is the typed PVecI64 ref.
fn is_pvec_i64(info: SlotInfo) Bool {
  case info.wasm_type {
    .Ref(_, ht) => case ht {
      .Named(n) => n == "rt_types__PVecI64",
      _ => false,
    },
    _ => false,
  }
}

// Count slots across all funcs whose physical wasm type is PVecI64.
fn pvec_i64_slot_count(funcs: Vector<PreparedFunc>) Int {
  n := 0

  for pf in funcs {
    for sid in pf.slots.keys() {
      case pf.slots[sid] {
        .Some(info) => if is_pvec_i64(info) {
          n = n + 1
        },
        .None => {},
      }
    }
  }

  n
}

// Count the (TypeId, FieldId) keys the analysis decided are typed (true).
fn typed_count(d: Dict<String, Bool>) Int {
  n := 0

  for k in d.keys() {
    case d[k] {
      .Some(v) => if v {
        n = n + 1
      },
      .None => {},
    }
  }

  n
}

// Source fixtures (escaped newlines — Twinkle string literals don't span lines).
fn positive_src() String {
  "type Box = .{ xs: Vector<Int> }\n"
    .concat("fn make(n: Int) Int {\n")
    .concat("  ys := collect i in range(n) { i * 2 }\n")
    .concat("  b := Box.{ xs: ys }\n")
    .concat("  zs := b.xs\n")
    .concat("  zs[0] + zs.len()\n")
    .concat("}\n")
    .concat("make(5)\n")
}

fn boxed_src() String {
  "type Box = .{ xs: Vector<Int> }\n"
    .concat("fn wrap(ys: Vector<Int>) Int {\n")
    .concat("  b := Box.{ xs: ys }\n")
    .concat("  zs := b.xs\n")
    .concat("  zs[0] + zs.len()\n")
    .concat("}\n")
    .concat("wrap([1, 2, 3])\n")
}

fn bad_consumer_src() String {
  "type Box = .{ xs: Vector<Int> }\n"
    .concat("fn use_box(n: Int) Vector<Int> {\n")
    .concat("  ys := collect i in range(n) { i * 2 }\n")
    .concat("  b := Box.{ xs: ys }\n")
    .concat("  zs := b.xs\n")
    .concat("  zs.append(0)\n")
    .concat("}\n")
    .concat("use_box(5)\n")
}

fn multi_field_src() String {
  "type Pair = .{ a: Vector<Int>, b: Vector<Int> }\n"
    .concat("fn dup(n: Int) Int {\n")
    .concat("  ys := collect i in range(n) { i * 2 }\n")
    .concat("  p := Pair.{ a: ys, b: ys }\n")
    .concat("  ra := p.a\n")
    .concat("  rb := p.b\n")
    .concat("  ra[0] + ra.len() + rb[0] + rb.len()\n")
    .concat("}\n")
    .concat("dup(5)\n")
}

// A collect whose result is a variant payload escapes: the payload slot stays a
// boxed PVec, so routing the producer to PVecI64 would create an unboxed store
// the boundary pass never covered (an invalid-wasm slot mismatch). The self-copy
// `Lx = init Lx` that lowering emits before the variant must not break the alias
// chain that makes this escape visible.
fn variant_payload_src() String {
  "type CD = { IntCol(Vector<Int>), Other(Int) }\n"
    .concat("fn build(n: Int) CD {\n")
    .concat("  ys := collect i in range(n) { i * 2 }\n")
    .concat("  CD.IntCol(ys)\n")
    .concat("}\n")
    .concat("build(5)\n")
}

// A typed Vector<Int> field set via ARecordUpdate rebinding (`c.data = <typed
// collect>`). The original Col literal also seeds the field with a typed collect,
// and the only field consumer is `c.data[k]` (index read). Both producers are
// typed-routable and no consumer escapes, so the field stays typed and the
// PVecI64-into-PVecI64 copy-through is sound.
fn record_update_src() String {
  "type Col = .{ data: Vector<Int>, n: Int }\n"
    .concat("fn build(n: Int) Col {\n")
    .concat("  c := Col.{ data: collect i in range(n) { i }, n }\n")
    .concat("  c.data = collect i in range(n) { i * 2 }\n")
    .concat("  c\n")
    .concat("}\n")
    .concat("fn sum(c: Col) Int {\n")
    .concat("  t := 0\n")
    .concat("  for k in range(c.n) { t = t + c.data[k] }\n")
    .concat("  t\n")
    .concat("}\n")
    .concat("sum(build(5))\n")
}

// A record with two independently-typed Vector<Int> fields: `a` and `b` each get
// their OWN collect producer (distinct vectors), and each is read via index.
// Contrast multi_field_src, which stores the SAME vector into both fields (and so
// demotes both). Two distinct typed producers => both fields typed.
fn two_typed_fields_src() String {
  "type Pair = .{ a: Vector<Int>, b: Vector<Int>, n: Int }\n"
    .concat("fn mk(n: Int) Pair {\n")
    .concat("  Pair.{ a: collect i in range(n) { i }, b: collect i in range(n) { i * 3 }, n }\n")
    .concat("}\n")
    .concat("fn use_pair(p: Pair) Int {\n")
    .concat("  t := 0\n")
    .concat("  for k in range(p.n) { t = t + p.a[k] + p.b[k] }\n")
    .concat("  t\n")
    .concat("}\n")
    .concat("use_pair(mk(5))\n")
}

pub fn suite() runner.Suite {
  runner
    .suite("typed record fields")
    .test(
      "positive: collect into field, read via index, is typed",
      fn() {
        d := try analyze_src(positive_src())
        try assert.equal(typed_count(d), 1)
        .Ok({})
      },
    )
    .test(
      "boxed producer: field fed by a parameter stays boxed",
      fn() {
        d := try analyze_src(boxed_src())
        try assert.equal(typed_count(d), 0)
        .Ok({})
      },
    )
    .test(
      "bad consumer: field read that escapes stays boxed",
      fn() {
        d := try analyze_src(bad_consumer_src())
        try assert.equal(typed_count(d), 0)
        .Ok({})
      },
    )
    .test(
      "multi-field producer: one vector into two fields demotes both",
      fn() {
        d := try analyze_src(multi_field_src())
        try assert.equal(typed_count(d), 0)
        .Ok({})
      },
    )
    .test(
      "positive case decides exactly one true key, no spurious entries",
      fn() {
        d := try analyze_src(positive_src())
        only_true := true

        for k in d.keys() {
          case d[k] {
            .Some(v) => if !v {
              only_true = false
            },
            .None => {},
          }
        }

        try assert.ok(only_true, "all decided keys should be true")
        try assert.equal(typed_count(d), 1)
        .Ok({})
      },
    )
    .test(
      "routing with the typed-field set retypes producer + field-read slots to PVecI64",
      fn() {
        p := try prepare_src(positive_src())
        tf := analyze_typed_fields(p.funcs, p.builtins)

        // Sanity: the analysis flagged the column field as typed.
        try assert.equal(typed_count(tf), 1)

        // Empty set: stores into the field escape and no field reads are typed,
        // so nothing retypes — proves the empty-set path preserves old behavior.
        empty: Dict<String, Bool> = Dict.new()
        routed_empty := route_typed_vectors(p.funcs, p.builtins, empty)
        try assert.equal(pvec_i64_slot_count(routed_empty), 0)

        // Real set: the producer (collect/builder_freeze result) AND the
        // field-read (b.xs) result slot retype to PVecI64. Both the freeze result
        // and its plain-copy aliases plus the read result get retyped, so expect
        // at least two typed slots and strictly more than the empty-set run.
        routed := route_typed_vectors(p.funcs, p.builtins, tf)
        n := pvec_i64_slot_count(routed)
        try assert.ok(n >= 2, "expected producer + field-read slots typed")
        try assert.ok(
          n > pvec_i64_slot_count(routed_empty),
          "non-empty set must type strictly more slots",
        )
        .Ok({})
      },
    )
    .test(
      "routing the boxed-producer source with a set never retypes (field stays boxed)",
      fn() {
        // The boxed source has no typed-routable producer, so analyze yields an
        // empty set and routing must leave everything boxed regardless.
        p := try prepare_src(boxed_src())
        tf := analyze_typed_fields(p.funcs, p.builtins)
        try assert.equal(typed_count(tf), 0)

        routed := route_typed_vectors(p.funcs, p.builtins, tf)
        try assert.equal(pvec_i64_slot_count(routed), 0)
        .Ok({})
      },
    )
    .test(
      "variant payload producer never retypes (would be an unboxed store)",
      fn() {
        // A collect feeding a variant payload escapes; routing must leave the
        // producer boxed. Routing it to PVecI64 once produced invalid wasm (a
        // PVecI64 stored straight into the PVec payload slot). Pass the analyzed
        // field set (empty here) just like the live pipeline does.
        p := try prepare_src(variant_payload_src())
        tf := analyze_typed_fields(p.funcs, p.builtins)
        routed := route_typed_vectors(p.funcs, p.builtins, tf)
        try assert.equal(pvec_i64_slot_count(routed), 0)
        .Ok({})
      },
    )
    .test(
      "ARecordUpdate setting a typed field with a typed value stays typed (copy-through)",
      fn() {
        // `c.data = collect ...` rebinds the typed field via ARecordUpdate. Both
        // the original literal and the update value are typed-routable collects and
        // the only consumer is an index read, so the field is decided typed and
        // routing yields PVecI64 slots — the PVecI64-into-PVecI64 copy is sound.
        d := try analyze_src(record_update_src())
        try assert.equal(typed_count(d), 1)

        p := try prepare_src(record_update_src())
        tf := analyze_typed_fields(p.funcs, p.builtins)
        try assert.equal(typed_count(tf), 1)
        routed := route_typed_vectors(p.funcs, p.builtins, tf)
        try assert.ok(
          pvec_i64_slot_count(routed) > 0,
          "expected PVecI64 slots for the updated field",
        )
        .Ok({})
      },
    )
    .test(
      "two independently-typed Vector<Int> fields are both typed",
      fn() {
        // Each field has its OWN collect producer (distinct vectors), unlike
        // multi_field_src which stores one vector into both. Both fields typed.
        d := try analyze_src(two_typed_fields_src())
        try assert.equal(typed_count(d), 2)
        .Ok({})
      },
    )
    .test(
      "verify accepts PVecI64 producer into a typed field under the matching env",
      fn() {
        vi := try verify_inputs(positive_src())

        // env2 mirrors the live pipeline: typed_vector_fields carries the routed
        // module's decisions, so layout_of yields PVecI64 for the typed field and
        // the routed producer slot (also PVecI64) matches.
        env2 := vi.env
        env2.typed_vector_fields = vi.prepared.typed_vector_fields

        case verify_prepared_module_with_level(vi.prepared, env2, vi.builtins, .Full) {
          .Ok(_) => .Ok({}),
          .Err(msg) => .Err("expected verify to accept matching env, got: ${msg}"),
        }
      },
    )
    .test(
      "verify rejects a PVecI64 producer stored into a boxed-PVec field slot",
      fn() {
        vi := try verify_inputs(positive_src())

        // Sanity: the routed module actually typed the field, so its producer
        // slot is PVecI64. Without that the mismatch below would be vacuous.
        try assert.ok(typed_count(vi.prepared.typed_vector_fields) >= 1, "expected a typed field")

        // Drop typed_vector_fields: layout_of now reports the field as a boxed
        // PVec, but the routed producer atom is still PVecI64 — exactly the
        // representation mismatch an over-eager routing pass would emit. The
        // field-store check must reject it (the generic Ref->Ref coercibility
        // rule would otherwise let it through, which is how the original routing
        // bug reached V8 instead of being caught here).
        env_boxed := vi.env
        env_boxed.typed_vector_fields = Dict.new()

        case verify_prepared_module_with_level(vi.prepared, env_boxed, vi.builtins, .Full) {
          .Ok(_) => .Err("expected verify to reject PVecI64-into-boxed-field mismatch"),
          .Err(_) => .Ok({}),
        }
      },
    )
}
