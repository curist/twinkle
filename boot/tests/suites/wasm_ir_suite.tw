use tests.runner
use tests.assert
use compiler.codegen.wasm_ir.{
  HeapType, ValType, FieldDef, TypeDef,
  Instr, FuncDef, ImportDef, GlobalDef, ExportDef,
  TableDef, ElemDef, DataSegment, WasmModule,
}

// ── HeapType ────────────────────────────────────────────────────────

fn test_heap_type_named() Result<Void, String> {
  h: HeapType = .Named("$Point")
  case h {
    .Named(s) => assert.str_eq(s, "$Point"),
    _ => assert.fail("expected Named"),
  }
}

fn test_heap_type_variants() Result<Void, String> {
  // just verify all variants construct without error
  _a: HeapType = .Any
  _e: HeapType = .Eq
  _i: HeapType = .I31
  _f: HeapType = .Func
  _n: HeapType = .None_
  _x: HeapType = .Extern
  .Ok({})
}

// ── ValType ─────────────────────────────────────────────────────────

fn test_val_type_scalars() Result<Void, String> {
  _a: ValType = .I8
  _b: ValType = .I32
  _c: ValType = .I64
  _d: ValType = .F64
  _e: ValType = .Anyref
  _f: ValType = .I31ref
  _g: ValType = .Funcref
  .Ok({})
}

fn test_val_type_ref() Result<Void, String> {
  r: ValType = .Ref(false, .Named("$Array"))
  case r {
    .Ref(nullable, ht) => {
      try assert.bool_eq(nullable, false)
      case ht {
        .Named(s) => assert.str_eq(s, "$Array"),
        _ => assert.fail("expected Named heap type"),
      }
    },
    _ => assert.fail("expected Ref"),
  }
}

// ── FieldDef ────────────────────────────────────────────────────────

fn test_field_def() Result<Void, String> {
  f := FieldDef.{ name: .Some("x"), mutable: true, ty: .I64 }
  name := case f.name { .Some(s) => s, .None => "" }
  try assert.str_eq(name, "x")
  try assert.bool_eq(f.mutable, true)
  case f.ty { .I64 => .Ok({}), _ => assert.fail("expected I64") }
}

// ── TypeDef ─────────────────────────────────────────────────────────

fn test_type_def_struct() Result<Void, String> {
  fields := [
    FieldDef.{ name: .Some("tag"), mutable: false, ty: .I32 },
    FieldDef.{ name: .Some("val"), mutable: false, ty: .I64 },
  ]
  td: TypeDef = .Struct("$MyStruct", fields, .None, false)
  case td {
    .Struct(name, fs, sup, nf) => {
      try assert.str_eq(name, "$MyStruct")
      try assert.int_eq(fs.len(), 2)
      try assert.bool_eq(nf, false)
      case sup { .None => .Ok({}), _ => assert.fail("expected no supertype") }
    },
    _ => assert.fail("expected Struct"),
  }
}

fn test_type_def_array() Result<Void, String> {
  elem := FieldDef.{ name: .None, mutable: true, ty: .Anyref }
  td: TypeDef = .Array("$ClosureEnv", elem)
  case td {
    .Array(name, f) => {
      try assert.str_eq(name, "$ClosureEnv")
      try assert.bool_eq(f.mutable, true)
      .Ok({})
    },
    _ => assert.fail("expected Array"),
  }
}

fn test_type_def_func_type() Result<Void, String> {
  td: TypeDef = .FuncType("$ft_i64_i64", [.I64], [.I64])
  case td {
    .FuncType(name, ps, rs) => {
      try assert.str_eq(name, "$ft_i64_i64")
      try assert.int_eq(ps.len(), 1)
      try assert.int_eq(rs.len(), 1)
      .Ok({})
    },
    _ => assert.fail("expected FuncType"),
  }
}

// ── Instr ───────────────────────────────────────────────────────────

fn test_instr_constants() Result<Void, String> {
  a: Instr = .I32Const(42)
  b: Instr = .I64Const(100)
  c: Instr = .F64Const(3.14)
  case a { .I32Const(n) => try assert.int_eq(n, 42), _ => { return .Err("expected I32Const") } }
  case b { .I64Const(n) => try assert.int_eq(n, 100), _ => { return .Err("expected I64Const") } }
  .Ok({})
}

fn test_instr_local_ops() Result<Void, String> {
  a: Instr = .LocalGet(0)
  b: Instr = .LocalSet(1)
  c: Instr = .LocalTee(2)
  case a { .LocalGet(i) => try assert.int_eq(i, 0), _ => { return .Err("expected LocalGet") } }
  case b { .LocalSet(i) => try assert.int_eq(i, 1), _ => { return .Err("expected LocalSet") } }
  case c { .LocalTee(i) => try assert.int_eq(i, 2), _ => { return .Err("expected LocalTee") } }
  .Ok({})
}

fn test_instr_struct_ops() Result<Void, String> {
  a: Instr = .StructNew("$Point")
  b: Instr = .StructGet("$Point", 0)
  c: Instr = .StructSet("$Point", 1)
  case a { .StructNew(s) => try assert.str_eq(s, "$Point"), _ => { return .Err("expected StructNew") } }
  case b {
    .StructGet(s, i) => {
      try assert.str_eq(s, "$Point")
      try assert.int_eq(i, 0)
      .Ok({})
    },
    _ => .Err("expected StructGet"),
  }
}

fn test_instr_call() Result<Void, String> {
  a: Instr = .Call("$my_func")
  b: Instr = .CallRef("$ft_closure")
  case a { .Call(s) => try assert.str_eq(s, "$my_func"), _ => { return .Err("expected Call") } }
  case b { .CallRef(s) => try assert.str_eq(s, "$ft_closure"), _ => { return .Err("expected CallRef") } }
  .Ok({})
}

fn test_instr_control_flow() Result<Void, String> {
  blk: Instr = .Block("$exit", .Some(.I64), [.I64Const(1)])
  case blk {
    .Block(label, result, body) => {
      try assert.str_eq(label, "$exit")
      try assert.int_eq(body.len(), 1)
      .Ok({})
    },
    _ => assert.fail("expected Block"),
  }
}

fn test_instr_if() Result<Void, String> {
  inst: Instr = .If(.Some(.I32), [.I32Const(1)], [.I32Const(0)])
  case inst {
    .If(result, then_body, else_body) => {
      try assert.int_eq(then_body.len(), 1)
      try assert.int_eq(else_body.len(), 1)
      .Ok({})
    },
    _ => assert.fail("expected If"),
  }
}

// ── FuncDef ─────────────────────────────────────────────────────────

fn test_func_def() Result<Void, String> {
  f := FuncDef.{
    name: "$add",
    params: [.I64, .I64],
    results: [.I64],
    locals: [],
    body: [.LocalGet(0), .LocalGet(1), .I64Add, .Return],
  }
  try assert.str_eq(f.name, "$add")
  try assert.int_eq(f.params.len(), 2)
  try assert.int_eq(f.results.len(), 1)
  try assert.int_eq(f.body.len(), 4)
  .Ok({})
}

// ── ImportDef ───────────────────────────────────────────────────────

fn test_import_def() Result<Void, String> {
  imp := ImportDef.{
    module: "rt.core",
    name: "print",
    as_sym: "$rt_core__print",
    params: [.Anyref],
    results: [],
  }
  try assert.str_eq(imp.module, "rt.core")
  try assert.str_eq(imp.name, "print")
  try assert.str_eq(imp.as_sym, "$rt_core__print")
  try assert.int_eq(imp.params.len(), 1)
  try assert.int_eq(imp.results.len(), 0)
  .Ok({})
}

// ── GlobalDef ───────────────────────────────────────────────────────

fn test_global_def() Result<Void, String> {
  g := GlobalDef.{
    name: "$str_0",
    mutable: true,
    ty: .Ref(true, .Named("$String")),
    init: [.RefNull(.Named("$String"))],
  }
  try assert.str_eq(g.name, "$str_0")
  try assert.bool_eq(g.mutable, true)
  try assert.int_eq(g.init.len(), 1)
  .Ok({})
}

// ── ExportDef ───────────────────────────────────────────────────────

fn test_export_def() Result<Void, String> {
  e := ExportDef.{ wasm_name: "main", func_sym: "$user__main" }
  try assert.str_eq(e.wasm_name, "main")
  try assert.str_eq(e.func_sym, "$user__main")
  .Ok({})
}

// ── TableDef & ElemDef ──────────────────────────────────────────────

fn test_table_def() Result<Void, String> {
  t := TableDef.{
    name: "$func_table",
    elem_type: .Funcref,
    min: 10,
    max: .Some(100),
  }
  try assert.str_eq(t.name, "$func_table")
  try assert.int_eq(t.min, 10)
  case t.max { .Some(n) => try assert.int_eq(n, 100), .None => { return .Err("expected Some") } }
  .Ok({})
}

fn test_elem_def() Result<Void, String> {
  e := ElemDef.{
    table: "$func_table",
    offset: [.I32Const(0)],
    func_syms: ["$f1", "$f2"],
  }
  try assert.str_eq(e.table, "$func_table")
  try assert.int_eq(e.func_syms.len(), 2)
  .Ok({})
}

// ── DataSegment ─────────────────────────────────────────────────────

fn test_data_segment() Result<Void, String> {
  d := DataSegment.{
    name: "$data_0",
    offset: [.I32Const(0)],
    bytes: [104, 105],
  }
  try assert.str_eq(d.name, "$data_0")
  try assert.int_eq(d.bytes.len(), 2)
  .Ok({})
}

// ── WasmModule ──────────────────────────────────────────────────────

fn test_wasm_module_empty() Result<Void, String> {
  m := WasmModule.{
    namespace: "user",
    types: [],
    imports: [],
    funcs: [],
    globals: [],
    tables: [],
    elems: [],
    exports: [],
    data: [],
    start: .None,
  }
  try assert.str_eq(m.namespace, "user")
  try assert.int_eq(m.types.len(), 0)
  try assert.int_eq(m.funcs.len(), 0)
  .Ok({})
}

fn test_wasm_module_with_func() Result<Void, String> {
  f := FuncDef.{
    name: "$main",
    params: [],
    results: [],
    locals: [.I64],
    body: [.I64Const(0), .LocalSet(0)],
  }
  m := WasmModule.{
    namespace: "user",
    types: [],
    imports: [],
    funcs: [f],
    globals: [],
    tables: [],
    elems: [],
    exports: [ExportDef.{ wasm_name: "_start", func_sym: "$main" }],
    data: [],
    start: .Some("$main"),
  }
  try assert.int_eq(m.funcs.len(), 1)
  try assert.str_eq(m.funcs[0].name, "$main")
  case m.start { .Some(s) => assert.str_eq(s, "$main"), .None => assert.fail("expected start") }
}

// ── Suite ───────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("wasm ir types")

    // HeapType
    .test("HeapType Named", test_heap_type_named)
    .test("HeapType all variants", test_heap_type_variants)

    // ValType
    .test("ValType scalars", test_val_type_scalars)
    .test("ValType Ref", test_val_type_ref)

    // FieldDef
    .test("FieldDef construction", test_field_def)

    // TypeDef
    .test("TypeDef Struct", test_type_def_struct)
    .test("TypeDef Array", test_type_def_array)
    .test("TypeDef FuncType", test_type_def_func_type)

    // Instr
    .test("Instr constants", test_instr_constants)
    .test("Instr local ops", test_instr_local_ops)
    .test("Instr struct ops", test_instr_struct_ops)
    .test("Instr call", test_instr_call)
    .test("Instr control flow Block", test_instr_control_flow)
    .test("Instr If", test_instr_if)

    // FuncDef
    .test("FuncDef construction", test_func_def)

    // ImportDef
    .test("ImportDef construction", test_import_def)

    // GlobalDef
    .test("GlobalDef construction", test_global_def)

    // ExportDef
    .test("ExportDef construction", test_export_def)

    // TableDef & ElemDef
    .test("TableDef construction", test_table_def)
    .test("ElemDef construction", test_elem_def)

    // DataSegment
    .test("DataSegment construction", test_data_segment)

    // WasmModule
    .test("WasmModule empty", test_wasm_module_empty)
    .test("WasmModule with func", test_wasm_module_with_func)
}
