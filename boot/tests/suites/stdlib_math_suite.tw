use @std.math

use @std.testing.assert as assert
use @std.testing as runner

pub fn suite() runner.Suite {
  runner
    .suite("stdlib math")
    .test(
      "abs and sign",
      fn() {
        try assert.equal(math.abs(-7), 7)
        try assert.equal(math.abs(7), 7)
        try assert.equal(math.abs(0), 0)
        try assert.equal(math.sign(-3), -1)
        try assert.equal(math.sign(0), 0)
        try assert.equal(math.sign(9), 1)
        .Ok({})
      },
    )
    .test(
      "gcd and lcm",
      fn() {
        try assert.equal(math.gcd(48, 36), 12)
        try assert.equal(math.gcd(-48, 36), 12)
        try assert.equal(math.gcd(0, 0), 0)
        try assert.equal(math.gcd(13, 0), 13)
        try assert.equal(math.lcm(4, 6), 12)
        try assert.equal(math.lcm(0, 5), 0)
        .Ok({})
      },
    )
    .test(
      "pow by squaring",
      fn() {
        try assert.equal(math.pow(2, 10), 1024)
        try assert.equal(math.pow(3, 0), 1)
        try assert.equal(math.pow(0, 0), 1)
        try assert.equal(math.pow(5, 3), 125)
        .Ok({})
      },
    )
    .test(
      "isqrt floors the root",
      fn() {
        try assert.equal(math.isqrt(0), 0)
        try assert.equal(math.isqrt(1), 1)
        try assert.equal(math.isqrt(99), 9)
        try assert.equal(math.isqrt(100), 10)
        try assert.equal(math.isqrt(101), 10)
        .Ok({})
      },
    )
    .test(
      "float helpers bridge to host Math",
      fn() {
        try assert.equal(math.sqrt(16.0), 4.0)
        try assert.equal(math.floor(2.7), 2.0)
        try assert.equal(math.ceil(2.3), 3.0)
        try assert.equal(math.round(2.5), 3.0)
        try assert.equal(math.trunc(2.7), 2.0)
        try assert.equal(math.abs_float(-2.5), 2.5)
        try assert.equal(math.sign_float(-2.5), -1.0)
        try assert.equal(math.cbrt(27.0), 3.0)
        try assert.equal(math.hypot(3.0, 4.0), 5.0)
        try assert.equal(math.pow_float(2.0, 8.0), 256.0)
        try assert.equal(math.sin(0.0), 0.0)
        try assert.equal(math.cos(0.0), 1.0)
        try assert.equal(math.tan(0.0), 0.0)
        try assert.equal(math.log(1.0), 0.0)
        try assert.equal(math.log2(8.0), 3.0)
        try assert.equal(math.log10(100.0), 2.0)
        try assert.equal(math.log1p(0.0), 0.0)
        try assert.equal(math.expm1(0.0), 0.0)
        try assert.equal(math.sinh(0.0), 0.0)
        try assert.equal(math.tanh(0.0), 0.0)
        try assert.equal(math.asin(0.0), 0.0)
        try assert.equal(math.atan(0.0), 0.0)
        try assert.equal(math.atan2(0.0, 1.0), 0.0)
        try assert.equal(math.asinh(0.0), 0.0)
        try assert.equal(math.atanh(0.0), 0.0)
        try assert.equal(math.acos(1.0), 0.0)
        try assert.equal(math.acosh(1.0), 0.0)
        try assert.equal(math.fround(1.0), 1.0)
        try assert.equal(math.pi, 3.141592653589793)
        try assert.equal(math.e, 2.718281828459045)
        r := math.random()
        try assert.ok(r >= 0.0 and r < 1.0, "random returns [0, 1)")
        .Ok({})
      },
    )
}
