use @std.regexp
use @std.regexp.{Match}

use tests.assert
use tests.runner

fn text_or(m: Match?, missing: String) String {
  case m {
    .Some(mm) => mm.text(),
    .None => missing,
  }
}

fn group_or(m: Match, i: Int, missing: String) String {
  case m.group(i) {
    .Some(s) => s,
    .None => missing,
  }
}

fn named_or(m: Match, name: String, missing: String) String {
  case m.group_named(name) {
    .Some(s) => s,
    .None => missing,
  }
}

fn opts(ignore_case: Bool, multiline: Bool, dotall: Bool) regexp.CompileOptions {
  .{ ignore_case, multiline, dotall }
}

fn err_at(p: String, want_pos: Int) Result<Void, String> {
  case regexp.compile(p) {
    .Err(e) => assert.equal(e.pos, want_pos),
    .Ok(_) => assert.fail("expected regexp compile error for ${p}"),
  }
}

pub fn suite() runner.Suite {
  runner
    .suite("stdlib regexp")
    .test(
      "find substring and test",
      fn() {
        case regexp.must("abc").find("xxabcyy") {
          .Some(m) => {
            try assert.equal(m.text(), "abc")
            try assert.equal(m.start, 2)
          },
          .None => { return assert.fail("expected match") },
        }
        try assert.is_true(regexp.must("abc").test("zabcz"))
        try assert.is_false(regexp.must("abc").test("abx"))
        .Ok({})
      },
    )
    .test(
      "raw string pattern passes backslashes through",
      fn() {
        // r"(\d+)-(\d+)" — no doubled backslashes needed.
        case regexp.must(r"(\d+)-(\d+)").find("order 42-17 done") {
          .Some(m) => {
            try assert.equal(m.text(), "42-17")
            try assert.equal(group_or(m, 1, "?"), "42")
            try assert.equal(group_or(m, 2, "?"), "17")
          },
          .None => { return assert.fail("expected raw-pattern match") },
        }
        .Ok({})
      },
    )
    .test(
      "classes and dot",
      fn() {
        try assert.is_true(regexp.must("a.c").test("axc"))
        try assert.is_false(regexp.must("a.c").test("a\nc"))
        try assert.equal(text_or(regexp.must("[0-9]").find("xx7yy"), "?"), "7")
        try assert.equal(text_or(regexp.must("[^abc]").find("abQ"), "?"), "Q")
        try assert.equal(text_or(regexp.must("\\d").find("a5"), "?"), "5")
        .Ok({})
      },
    )
    .test(
      "greedy quantifiers",
      fn() {
        try assert.equal(text_or(regexp.must("a+").find("aaa"), "?"), "aaa")
        try assert.equal(text_or(regexp.must("a*").find("aaa"), "?"), "aaa")
        try assert.equal(text_or(regexp.must("ab?c").find("ac"), "?"), "ac")
        try assert.equal(text_or(regexp.must("a{2,3}").find("aaaa"), "?"), "aaa")
        try assert.equal(text_or(regexp.must("a{2,}").find("aaaa"), "?"), "aaaa")
        .Ok({})
      },
    )
    .test(
      "captures",
      fn() {
        case regexp.must("(\\d+)-(\\d+)").find("ab 12-34 cd") {
          .Some(m) => {
            try assert.equal(m.text(), "12-34")
            try assert.equal(group_or(m, 1, "?"), "12")
            try assert.equal(group_or(m, 2, "?"), "34")
          },
          .None => { return assert.fail("expected match") },
        }

        case regexp.must("a(b)?c").find("ac") {
          .Some(m) => try assert.is_none(m.group(1)),
          .None => { return assert.fail("expected optional-group match") },
        }
        .Ok({})
      },
    )
    .test(
      "alternation priority",
      fn() {
        try assert.equal(text_or(regexp.must("a|aa").find("aa"), "?"), "a")
        try assert.equal(text_or(regexp.must("aa|a").find("aa"), "?"), "aa")
        try assert.equal(text_or(regexp.must("(a|aa)+").find("aa"), "?"), "aa")
        try assert.equal(text_or(regexp.must("red|green|blue").find("xbluey"), "?"), "blue")
        .Ok({})
      },
    )
    .test(
      "anchors",
      fn() {
        try assert.is_true(regexp.must("^ab").test("abc"))
        try assert.is_false(regexp.must("^ab").test("xab"))
        try assert.is_true(regexp.must("bc$").test("abc"))
        try assert.is_false(regexp.must("bc$").test("abcd"))
        .Ok({})
      },
    )
    .test(
      "find_all including empty matches",
      fn() {
        nums: Vector<String> = []
        for m in regexp.must("\\d+").find_all("a12 b3 c456") {
          nums = .append(m.text())
        }
        try assert.vec_len(nums, 3)
        try assert.equal(nums[0], "12")
        try assert.equal(nums[1], "3")
        try assert.equal(nums[2], "456")

        empty_count := 0
        for _ in regexp.must("a*").find_all("") {
          empty_count = empty_count + 1
        }
        try assert.equal(empty_count, 1)

        bb_count := 0
        for _ in regexp.must("a*").find_all("bb") {
          bb_count = bb_count + 1
        }
        try assert.equal(bb_count, 3)
        .Ok({})
      },
    )
    .test(
      "ignore case",
      fn() {
        try assert.is_true(regexp.must("(?i)abc").test("ABC"))
        try assert.is_true(regexp.must("(?i)abc").test("AbC"))
        try assert.equal(text_or(regexp.must("(?i)[a-z]+").find("XYz"), "?"), "XYz")
        try assert.is_err(regexp.compile("ab(?i)c"))
        .Ok({})
      },
    )
    .test(
      "replace",
      fn() {
        try assert.equal(regexp.must("\\d+").replace("a1b2", "#"), "a#b2")
        try assert.equal(regexp.must("\\d+").replace_all("a1b2", "#"), "a#b#")
        try assert.equal(regexp.must("(\\w+)@(\\w+)").replace_all("x@y", "$2.$1"), "y.x")
        try assert.equal(regexp.must("a").replace_all("a", "$$"), "$")
        try assert.equal(regexp.must("a").replace_all("a", "[$5]"), "[]")
        try assert.equal(regexp.must("a*").replace_all("", "X"), "X")
        try assert.equal(regexp.must("a*").replace_all("b", "X"), "XbX")
        try assert.equal(regexp.must("a+").replace_all("baab", "X"), "bXb")
        .Ok({})
      },
    )
    .test(
      "parser error positions",
      fn() {
        try err_at("a(b", 1)
        try err_at("ab)", 2)
        try err_at("a[bc", 1)
        try err_at("ab\\", 2)
        try err_at("*ab", 0)
        try err_at("a{2,x}", 1)
        .Ok({})
      },
    )
    .test(
      "compile_with options",
      fn() {
        try assert.is_true(regexp.must_with("abc", opts(true, false, false)).test("ABC"))
        try assert.is_true(regexp.must_with("^b", opts(false, true, false)).test("a\nb"))
        try assert.is_false(regexp.must_with("^b", opts(false, false, false)).test("a\nb"))
        try assert.is_true(regexp.must_with("b$", opts(false, true, false)).test("ab\nc"))
        try assert.is_true(regexp.must_with("a.b", opts(false, false, true)).test("a\nb"))
        try assert.is_false(regexp.must_with("a.b", opts(false, false, false)).test("a\nb"))
        .Ok({})
      },
    )
    .test(
      "scoped flag groups",
      fn() {
        try assert.is_true(regexp.must("a(?i:b)c").test("aBc"))
        try assert.is_false(regexp.must("a(?i:b)c").test("ABc"))
        try assert.is_true(regexp.must("(?s:a.b)").test("a\nb"))
        try assert.is_true(regexp.must("(?m:^b)").test("a\nb"))

        // A nested `(?-i:...)` turns ignore_case back off within its scope.
        try assert.is_false(regexp.must("(?i)a(?-i:b)").test("aB"))
        try assert.is_true(regexp.must("(?im)^b").test("A\nB"))

        // Bad flag groups are parse errors.
        try assert.is_err(regexp.compile("(?q:a)"))
        try assert.is_err(regexp.compile("(?i-:a)"))
        .Ok({})
      },
    )
    .test(
      "lazy quantifiers",
      fn() {
        try assert.equal(text_or(regexp.must("a+?").find("aaa"), "?"), "a")
        try assert.equal(text_or(regexp.must("a+?a").find("aaa"), "?"), "aa")
        try assert.equal(text_or(regexp.must("<.*?>").find("<a><b>"), "?"), "<a>")
        try assert.equal(text_or(regexp.must("a{2,4}?").find("aaaa"), "?"), "aa")

        // A lazy star prefers the shorter (empty) match where one suffices.
        try assert.equal(text_or(regexp.must("a*?b").find("aaab"), "?"), "aaab")
        .Ok({})
      },
    )
    .test(
      "named groups",
      fn() {
        case regexp.must(r"(?<id>\d+)-(?<color>\w+)").find("12-red") {
          .Some(m) => {
            try assert.equal(group_or(m, 1, "?"), "12")
            try assert.equal(group_or(m, 2, "?"), "red")
            try assert.equal(named_or(m, "id", "?"), "12")
            try assert.equal(named_or(m, "color", "?"), "red")
            try assert.is_none(m.group_named("missing"))
          },
          .None => { return assert.fail("expected named-group match") },
        }

        case regexp.must(r"(?P<n>\d+)").find("x42") {
          .Some(m) => try assert.equal(named_or(m, "n", "?"), "42"),
          .None => { return assert.fail("expected (?P<name>) match") },
        }
        .Ok({})
      },
    )
    .test(
      "named group and lazy errors",
      fn() {
        try assert.is_err(regexp.compile(r"(?<a>\d)(?<a>\d)"))
        try assert.is_err(regexp.compile(r"(?<Bad>\d)"))
        try assert.is_err(regexp.compile(r"(?<id\d)"))
        try assert.is_err(regexp.compile(r"\1"))
        try assert.is_err(regexp.compile(r"\k<id>"))
        try err_at("*?a", 0)
        .Ok({})
      },
    )
}
