use @std.testing.assert as assert
use @std.testing as runner

use compiler.query.cache as query_cache
use lib.json
use lib.lsp.document_store
use lib.lsp.protocol
use lib.lsp.server_core

fn state_with_doc(uri: String, text: String) server_core.State {
  docs := document_store.empty().open(uri, text, .Some(1))
  base := server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: true,
    diagnostics_deadline_ms: 0.0,
    last_published: Dict.new(),
    diagnostics_tier: .Full,
    parse_dirty_uris: Dict.new(),
    full_dirty: false,
    closure_snapshot: .None,
  }

  // Heavy features serve only a completed full snapshot, so warm the cache with a
  // full diagnostics pass before issuing feature requests.
  base.publish_due_diagnostics().state
}

fn state_with_two_docs(uri_a: String, text_a: String, uri_b: String, text_b: String) server_core.State {
  docs0 := document_store.empty().open(uri_a, text_a, .Some(1))
  docs := docs0.open(uri_b, text_b, .Some(2))
  base := server_core.State.{
    initialized: true,
    shutdown_requested: false,
    should_exit: false,
    documents: docs,
    query_cache: query_cache.empty(),
    diagnostics_pending: true,
    diagnostics_deadline_ms: 0.0,
    last_published: Dict.new(),
    diagnostics_tier: .Full,
    parse_dirty_uris: Dict.new(),
    full_dirty: false,
    closure_snapshot: .None,
  }

  // Heavy features serve only a completed full snapshot, so warm the cache with a
  // full diagnostics pass before issuing feature requests.
  base.publish_due_diagnostics().state
}

fn sem_tokens_request(id: Int, uri: String) protocol.Message {
  params := json.object([json.kv("textDocument", json.object([json.kv("uri", .Str(uri))]))])
  protocol.Message.Request(.{
    id: .IntId(id),
    method: "textDocument/semanticTokens/full",
    params: .Some(params),
  })
}

// Decode the flat "data" array from the semantic tokens response.
fn sem_token_data(step: server_core.Step) Vector<Int>!String {
  if step.outgoing.len() != 1 {
    return .Err("expected one outgoing message")
  }

  out := step.outgoing[0]
  result := try out.decode(json.field("result", json.raw()))
  data := try result.decode(json.field("data", json.int().list()))
  .Ok(data)
}

// Token type indices (must match the legend we advertise).
// namespace=0, type=1, typeParameter=2, function=3, method=4,
// parameter=5, variable=6, property=7, enumMember=8, keyword=9,
// string=10, number=11
tk_NAMESPACE: Int = 0
tk_TYPE: Int = 1
tk_TYPE_PARAMETER: Int = 2
tk_FUNCTION: Int = 3
tk_METHOD: Int = 4
tk_PARAMETER: Int = 5
tk_VARIABLE: Int = 6
tk_PROPERTY: Int = 7
tk_ENUM_MEMBER: Int = 8

// Modifier bitmask values.
mod_DECLARATION: Int = 1
mod_DEFINITION: Int = 2
mod_READONLY: Int = 4
mod_DEFAULT_LIBRARY: Int = 8

// Extract the nth token tuple from the flat data array.
// Returns (deltaLine, deltaStart, length, tokenType, tokenModifiers).
type TokenTuple = .{
  delta_line: Int,
  delta_start: Int,
  length: Int,
  token_type: Int,
  modifiers: Int,
}

fn nth_token(data: Vector<Int>, n: Int) TokenTuple!String {
  base := n * 5

  if base + 4 >= data.len() {
    return .Err("token index ${n} out of range (data len ${data.len()})")
  }

  .Ok(
    .{
      delta_line: data[base],
      delta_start: data[base + 1],
      length: data[base + 2],
      token_type: data[base + 3],
      modifiers: data[base + 4],
    },
  )
}

fn token_count(data: Vector<Int>) Int {
  data.len() / 5
}

pub fn suite() runner.Suite {
  runner
    .suite("lsp semantic tokens")
    .test(
      "function declaration gets function token with declaration modifier",
      fn() {
        // fn foo() Int { 42 }
        src := "fn foo() Int { 42 }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        // "foo" should appear as a function token with declaration modifier
        found := false
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_FUNCTION and (tok.modifiers & mod_DECLARATION) != 0 {
            // "foo" is 3 chars
            try assert.equal(tok.length, 3)
            found = true
          }

          i = i + 1
        }

        try assert.ok(found, "expected a function token with declaration modifier for 'foo'")
        .Ok({})
      },
    )
    .test(
      "function call site gets function token without declaration modifier",
      fn() {
        // fn greet() String { "hi" }
        // x := greet()
        src := "fn greet() String { \"hi\" }\nx := greet()\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        // Find function tokens — one should be declaration, one should not
        decl_count := 0
        call_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_FUNCTION and tok.length == 5 {
            if (tok.modifiers & mod_DECLARATION) != 0 {
              decl_count = decl_count + 1
            } else {
              call_count = call_count + 1
            }
          }

          i = i + 1
        }

        try assert.equal(decl_count, 1)
        try assert.equal(call_count, 1)
        .Ok({})
      },
    )
    .test(
      "type name gets type token",
      fn() {
        // type Point = .{ x: Int, y: Int }
        src := "type Point = .{ x: Int, y: Int }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        // "Point" should be a type token with declaration modifier
        found := false
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_TYPE
            and tok.length == 5 and (tok.modifiers & mod_DECLARATION) != 0 {
            found = true
          }

          i = i + 1
        }

        try assert.ok(found, "expected a type declaration token for 'Point'")
        .Ok({})
      },
    )
    .test(
      "type annotation gets type token without declaration",
      fn() {
        // type Msg = .{ text: String }
        // fn make() Msg { .{ text: "hi" } }
        src := "type Msg = .{ text: String }\nfn make() Msg { .{ text: \"hi\" } }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        // Should have at least one type token for "Msg" without declaration (the return type)
        ref_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_TYPE
            and tok.length == 3 and (tok.modifiers & mod_DECLARATION) == 0 {
            ref_count = ref_count + 1
          }

          i = i + 1
        }

        try assert.ok(ref_count >= 1, "expected at least one type reference token for 'Msg'")
        .Ok({})
      },
    )
    .test(
      "type parameter gets typeParameter token",
      fn() {
        // fn identity<T>(x: T) T { x }
        src := "fn identity<T>(x: T) T { x }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_TYPE_PARAMETER and tok.length == 1 {
            count = count + 1
          }

          i = i + 1
        }

        // T appears in 3 places: declaration, param type, return type
        try assert.ok(count >= 3, "expected at least 3 typeParameter tokens for 'T', got ${count}")
        .Ok({})
      },
    )
    .test(
      "function parameters get parameter token",
      fn() {
        // fn add(a: Int, b: Int) Int { a + b }
        src := "fn add(a: Int, b: Int) Int { a + b }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        param_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_PARAMETER and tok.length == 1 {
            param_count = param_count + 1
          }

          i = i + 1
        }

        // a and b: declarations + uses in body = at least 4
        try assert.ok(param_count >= 4, "expected at least 4 parameter tokens, got ${param_count}")
        .Ok({})
      },
    )
    .test(
      "local variable gets variable token",
      fn() {
        // x := 42
        // y := x + 1
        src := "x := 42\ny := x + 1\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        var_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_VARIABLE {
            var_count = var_count + 1
          }

          i = i + 1
        }

        // x (decl), y (decl), x (use) = at least 3
        try assert.ok(var_count >= 3, "expected at least 3 variable tokens, got ${var_count}")
        .Ok({})
      },
    )
    .test(
      "record field gets property token",
      fn() {
        // type Point = .{ x: Int, y: Int }
        // fn get_x(p: Point) Int { p.x }
        src := "type Point = .{ x: Int, y: Int }\nfn get_x(p: Point) Int { p.x }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        prop_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_PROPERTY {
            prop_count = prop_count + 1
          }

          i = i + 1
        }

        // x and y in the type decl + p.x field access = at least 3
        try assert.ok(prop_count >= 3, "expected at least 3 property tokens, got ${prop_count}")
        .Ok({})
      },
    )
    .test(
      "enum variant gets enumMember token",
      fn() {
        // type Color = { Red, Green, Blue }
        // c := Color.Red
        src := "type Color = { Red, Green, Blue }\nc := Color.Red\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        enum_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_ENUM_MEMBER {
            enum_count = enum_count + 1
          }

          i = i + 1
        }

        // Red, Green, Blue in decl + Red in expression = at least 4
        try assert.ok(enum_count >= 4, "expected at least 4 enumMember tokens, got ${enum_count}")
        .Ok({})
      },
    )
    .test(
      "local receiver is not highlighted as namespace",
      fn() {
        src := "fn f() Vector<Int> {\n  groups: Dict<String, Int> = Dict.new()\n  groups.values()\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        line := 0
        col := 0
        found_local_receiver := false
        found_namespace_receiver := false
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.delta_line > 0 {
            line = line + tok.delta_line
            col = tok.delta_start
          } else {
            col = col + tok.delta_start
          }

          if line == 2 and col == 2 and tok.length == 6 {
            if tok.token_type == tk_VARIABLE {
              found_local_receiver = true
            }

            if tok.token_type == tk_NAMESPACE {
              found_namespace_receiver = true
            }
          }

          i = i + 1
        }

        try assert.ok(
          found_local_receiver,
          "expected local receiver `groups` to be a variable token",
        )
        try assert.ok(
          !found_namespace_receiver,
          "local receiver `groups` must not be a namespace token",
        )
        .Ok({})
      },
    )
    .test(
      "module name gets namespace token",
      fn() {
        lib_uri := "file:///tmp/lsp_semtok_ns/lib.tw"
        main_uri := "file:///tmp/lsp_semtok_ns/main.tw"
        lib := "pub fn helper() Int { 42 }\n"
        main := "use lib\nx := lib.helper()\n"
        state := state_with_two_docs(lib_uri, lib, main_uri, main)

        step := state.handle_message(sem_tokens_request(1, main_uri))
        data := try sem_token_data(step)

        ns_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_NAMESPACE {
            ns_count = ns_count + 1
          }

          i = i + 1
        }

        // "lib" in use statement and "lib" in lib.helper() = at least 1
        try assert.ok(ns_count >= 1, "expected at least 1 namespace token, got ${ns_count}")
        .Ok({})
      },
    )
    .test(
      "public type after relative import highlights the type name",
      fn() {
        triple_uri := "file:///tmp/lsp_semtok_pub_type/tuple/triple.tw"
        tuple_uri := "file:///tmp/lsp_semtok_pub_type/tuple.tw"
        triple := "pub type Triple<A, B, C> = .{ first: A, second: B, third: C }\n"
        tuple := "use .tuple.triple as triple_mod\n\npub type Pair<A, B> = .{ first: A, second: B }\n"
        state := state_with_two_docs(triple_uri, triple, tuple_uri, tuple)

        step := state.handle_message(sem_tokens_request(1, tuple_uri))
        data := try sem_token_data(step)

        line := 0
        col := 0
        found_pair := false
        found_split_type_keyword := false
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.delta_line > 0 {
            line = line + tok.delta_line
            col = tok.delta_start
          } else {
            col = col + tok.delta_start
          }

          if line == 2
            and col == 9 and tok.length == 4 and tok.token_type == tk_TYPE
            and (tok.modifiers & mod_DECLARATION) != 0 {
            found_pair = true
          }

          if line == 2 and col == 5 and tok.length == 4 and tok.token_type == tk_TYPE {
            found_split_type_keyword = true
          }

          i = i + 1
        }

        try assert.ok(found_pair, "expected the Pair identifier to get the type token")
        try assert.ok(!found_split_type_keyword, "type token must not cover `ype ` from `pub type`")
        .Ok({})
      },
    )
    .test(
      "relative import keeps semantic token deltas valid",
      fn() {
        foo_uri := "file:///tmp/lsp_semtok_relative/foo.tw"
        main_uri := "file:///tmp/lsp_semtok_relative/main.tw"
        foo := "pub fn helper() Int { 42 }\n"
        main := "use .foo\nx := foo.helper()\n"
        state := state_with_two_docs(foo_uri, foo, main_uri, main)

        step := state.handle_message(sem_tokens_request(1, main_uri))
        data := try sem_token_data(step)
        try assert.ok(
          token_count(data) > 0,
          "expected semantic tokens for relative-import document",
        )

        line := 0
        col := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)
          try assert.ok(tok.delta_line >= 0, "delta_line should be >= 0")
          try assert.ok(tok.delta_start >= 0, "delta_start should be >= 0")

          if tok.delta_line > 0 {
            line = line + tok.delta_line
            col = tok.delta_start
          } else {
            col = col + tok.delta_start
          }

          try assert.ok(line >= 0 and col >= 0, "absolute token position should stay valid")
          try assert.ok(tok.length > 0, "token length should be > 0")
          i = i + 1
        }

        .Ok({})
      },
    )
    .test(
      "delta encoding is correct for multi-line tokens",
      fn() {
        // Line 0: fn foo() Int { 42 }
        // Line 1: fn bar() Int { foo() }
        src := "fn foo() Int { 42 }\nfn bar() Int { foo() }\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        // All data should be multiples of 5
        try assert.equal(data.len() % 5, 0)

        // First token should have delta_line >= 0
        if token_count(data) > 0 {
          first := try nth_token(data, 0)
          try assert.ok(first.delta_line >= 0, "first token delta_line should be >= 0")
        }

        // Check that we can reconstruct absolute positions without negative deltas
        line := 0
        col := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)
          try assert.ok(tok.delta_line >= 0, "delta_line should be >= 0 at token ${i}")

          if tok.delta_line > 0 {
            line = line + tok.delta_line
            col = tok.delta_start
          } else {
            col = col + tok.delta_start
          }

          try assert.ok(tok.length > 0, "token length should be > 0 at token ${i}")
          i = i + 1
        }

        .Ok({})
      },
    )
    .test(
      "empty document returns empty data",
      fn() {
        src := ""
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)
        try assert.equal(data.len(), 0)
        .Ok({})
      },
    )
    .test(
      "unknown document returns empty data",
      fn() {
        state := state_with_doc("file:///a.tw", "x := 1\n")
        step := state.handle_message(sem_tokens_request(1, "file:///unknown.tw"))
        data := try sem_token_data(step)
        try assert.equal(data.len(), 0)
        .Ok({})
      },
    )
    .test(
      "semanticTokensProvider advertised in capabilities",
      fn() {
        msg := protocol.Message.Request(.{ id: .IntId(1), method: "initialize", params: .None })
        step := server_core.initial_state().handle_message(msg)

        if step.outgoing.len() != 1 {
          return .Err("expected one message")
        }

        out := step.outgoing[0]
        result := try out.decode(json.field("result", json.raw()))
        caps := try result.decode(json.field("capabilities", json.raw()))
        sem_cap := try caps.decode(json.field("semanticTokensProvider", json.raw()))

        // Should have a "legend" with tokenTypes and tokenModifiers
        legend := try sem_cap.decode(json.field("legend", json.raw()))
        token_types := try legend.decode(json.field("tokenTypes", json.string().list()))
        token_modifiers := try legend.decode(json.field("tokenModifiers", json.string().list()))
        try assert.ok(token_types.len() > 0, "expected non-empty tokenTypes")
        try assert.ok(token_modifiers.len() > 0, "expected non-empty tokenModifiers")

        // Should have "full" support
        full := try sem_cap.decode(json.field("full", json.bool()))
        try assert.equal(full, true)
        .Ok({})
      },
    )
    .test(
      "pattern match variables get correct tokens",
      fn() {
        // type Shape = { Circle(Float), Rect(Float, Float) }
        // fn area(s: Shape) Float {
        //   case s {
        //     .Circle(r) => r,
        //     .Rect(w, h) => w,
        //   }
        // }
        src := "type Shape = { Circle(Float), Rect(Float, Float) }\nfn area(s: Shape) Float {\n  case s {\n    .Circle(r) => r,\n    .Rect(w, h) => w,\n  }\n}\n"
        state := state_with_doc("file:///a.tw", src)
        step := state.handle_message(sem_tokens_request(1, "file:///a.tw"))
        data := try sem_token_data(step)

        // Circle and Rect should be enumMember tokens
        enum_count := 0
        i := 0

        for i < token_count(data) {
          tok := try nth_token(data, i)

          if tok.token_type == tk_ENUM_MEMBER {
            enum_count = enum_count + 1
          }

          i = i + 1
        }

        // Circle, Rect in type decl + .Circle, .Rect in pattern = at least 4
        try assert.ok(enum_count >= 4, "expected at least 4 enumMember tokens, got ${enum_count}")
        .Ok({})
      },
    )
}
