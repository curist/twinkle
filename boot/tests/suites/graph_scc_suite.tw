use @std.testing.assert as assert
use @std.testing as runner

use compiler.graph_scc

pub fn suite() runner.Suite {
  runner
    .suite("graph_scc")
    .test(
      "singletons in reverse-topological order",
      fn() {
        // a -> b -> c (a depends on b, b depends on c)
        edges: Dict<String, Vector<String>> = Dict.new()
        edges["a"] = ["b"]
        edges["b"] = ["c"]
        edges["c"] = []
        comps := graph_scc.strongly_connected(["a", "b", "c"], edges)

        // dependency-before-dependent: c, then b, then a
        try assert.equal(comps.len(), 3)
        try assert.equal(comps[0].len(), 1)
        try assert.equal(comps[0][0], "c")
        try assert.equal(comps[1].len(), 1)
        try assert.equal(comps[1][0], "b")
        try assert.equal(comps[2].len(), 1)
        try assert.equal(comps[2][0], "a")
        .Ok({})
      },
    )
    .test(
      "a 2-cycle is one component",
      fn() {
        edges: Dict<String, Vector<String>> = Dict.new()
        edges["a"] = ["b"]
        edges["b"] = ["a"]
        comps := graph_scc.strongly_connected(["a", "b"], edges)
        try assert.equal(comps.len(), 1)
        try assert.equal(comps[0].len(), 2)
        try assert.vec_contains(comps[0], "a")
        try assert.vec_contains(comps[0], "b")
        .Ok({})
      },
    )
    .test(
      "three-module cycle a->b->c->a is one component",
      fn() {
        edges: Dict<String, Vector<String>> = Dict.new()
        edges["a"] = ["b"]
        edges["b"] = ["c"]
        edges["c"] = ["a"]
        comps := graph_scc.strongly_connected(["a", "b", "c"], edges)
        try assert.equal(comps.len(), 1)
        try assert.equal(comps[0].len(), 3)
        try assert.vec_contains(comps[0], "a")
        try assert.vec_contains(comps[0], "b")
        try assert.vec_contains(comps[0], "c")
        .Ok({})
      },
    )
    .test(
      "self-loop is a singleton SCC",
      fn() {
        edges: Dict<String, Vector<String>> = Dict.new()
        edges["a"] = ["a"]
        comps := graph_scc.strongly_connected(["a"], edges)
        try assert.equal(comps.len(), 1)
        try assert.equal(comps[0].len(), 1)
        try assert.vec_contains(comps[0], "a")
        .Ok({})
      },
    )
    .test(
      "disconnected graph yields multiple singleton components",
      fn() {
        edges: Dict<String, Vector<String>> = Dict.new()
        edges["a"] = []
        edges["b"] = []
        comps := graph_scc.strongly_connected(["a", "b"], edges)
        try assert.equal(comps.len(), 2)
        try assert.equal(comps[0].len(), 1)
        try assert.equal(comps[1].len(), 1)
        try assert.vec_contains(comps[0], "a")
        try assert.vec_contains(comps[1], "b")
        .Ok({})
      },
    )
}
