use compiler.ast.{
  Expr, ExprKind, ExprStmt, ImportItem, ImportTypeItem, ImportValueItem, Item, Module, Stmt, UseDecl,
}
use compiler.unused_imports.{check_unused_imports, reconstruct_use_decl}
use lib.source.span
use tests.assert
use tests.runner

fn dummy_span() span.Span { span.Span.{ file_id: 0, start: 0, end: 0 } }

fn dummy_expr(kind: ExprKind) Expr { Expr.{ id: 0, kind, span: dummy_span() } }

fn make_value_item(name: String) ImportItem {
  .Value(ImportValueItem.{ name, alias: .None, span: dummy_span() })
}

fn make_value_item_aliased(name: String, alias: String) ImportItem {
  .Value(ImportValueItem.{ name, alias: .Some(alias), span: dummy_span() })
}

fn make_type_item(name: String) ImportItem {
  .Type(ImportTypeItem.{ name, alias: .None, span: dummy_span() })
}

fn make_use_decl(path: Vector<String>, items: Vector<ImportItem>?) UseDecl {
  UseDecl.{ is_stdlib: false, is_relative: false, path, alias: .None, items, span: dummy_span() }
}

pub fn suite() runner.Suite {
  runner.suite("unused imports").test(
    "reconstruct_use_decl: filters out single unused item from selective import",
    fn() {
      decl := make_use_decl(
        ["foo"],
        .Some([make_value_item("A"), make_value_item("B"), make_value_item("C")]),
      )
      result := reconstruct_use_decl(decl, ["B"])
      try assert.equal(result, "use foo.{A, C}\n")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: all items unused produces empty string",
    fn() {
      decl := make_use_decl(["foo"], .Some([make_value_item("A"), make_value_item("B")]))
      result := reconstruct_use_decl(decl, ["A", "B"])
      try assert.equal(result, "")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: single item kept uses brace syntax",
    fn() {
      decl := make_use_decl(["foo", "bar"], .Some([make_value_item("X"), make_value_item("Y")]))
      result := reconstruct_use_decl(decl, ["Y"])
      try assert.equal(result, "use foo.bar.{X}\n")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: preserves aliases",
    fn() {
      decl := make_use_decl(
        ["lib", "math"],
        .Some([make_value_item_aliased("add", "plus"), make_value_item("sub")]),
      )
      result := reconstruct_use_decl(decl, ["sub"])
      try assert.equal(result, "use lib.math.{add as plus}\n")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: handles type items",
    fn() {
      decl := make_use_decl(
        ["models"],
        .Some([make_type_item("Foo"), make_type_item("Bar"), make_value_item("baz")]),
      )
      result := reconstruct_use_decl(decl, ["Bar"])
      try assert.equal(result, "use models.{Foo, baz}\n")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: stdlib prefix",
    fn() {
      decl := UseDecl.{
        is_stdlib: true,
        is_relative: false,
        path: ["fs"],
        alias: .None,
        items: .Some([make_value_item("read"), make_value_item("write")]),
        span: dummy_span(),
      }
      result := reconstruct_use_decl(decl, ["write"])
      try assert.equal(result, "use @std.fs.{read}\n")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: relative prefix",
    fn() {
      decl := UseDecl.{
        is_stdlib: false,
        is_relative: true,
        path: ["utils"],
        alias: .None,
        items: .Some([make_value_item("helper"), make_value_item("unused_fn")]),
        span: dummy_span(),
      }
      result := reconstruct_use_decl(decl, ["unused_fn"])
      try assert.equal(result, "use .utils.{helper}\n")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: full module import produces empty string",
    fn() {
      decl := make_use_decl(["foo", "bar"], .None)
      result := reconstruct_use_decl(decl, ["bar"])
      try assert.equal(result, "")
      .Ok({})
    },
  ).test(
    "reconstruct_use_decl: no items unused keeps all",
    fn() {
      decl := make_use_decl(["foo"], .Some([make_value_item("A"), make_value_item("B")]))
      result := reconstruct_use_decl(decl, [])
      try assert.equal(result, "use foo.{A, B}\n")
      .Ok({})
    },
  ).test(
    "check_unused_imports: field access through module alias does not suppress selective import",
    fn() {
      // `use bar` (module import) + `use foo.{remove}` (selective import)
      // Code: `bar.remove(x)` — accesses remove through module bar, not the selective import
      bar_decl := make_use_decl(["bar"], .None)
      foo_decl := UseDecl.{
        is_stdlib: false,
        is_relative: false,
        path: ["foo"],
        alias: .None,
        items: .Some([make_value_item("remove")]),
        span: span.Span.{ file_id: 0, start: 0, end: 20 },
      }
      call_expr := dummy_expr(
        .Call(dummy_expr(.Field(dummy_expr(.Ident("bar")), "remove")), [dummy_expr(.Ident("x"))]),
      )
      module := Module.{
        items: [
          Item.Use(bar_decl),
          Item.Use(foo_decl),
          Item.Stmt(Stmt.Expr(ExprStmt.{ expr: call_expr, span: dummy_span() })),
        ],
        span: dummy_span(),
      }
      result := check_unused_imports(module)
      // "remove" from `use foo.{remove}` should be flagged as unused
      try assert.equal(result.items.len(), 1)
      try assert.str_contains(result.items[0].kind.message(), "remove")
      .Ok({})
    },
  ).test(
    "check_unused_imports: inherent method call does not suppress unused selective import",
    fn() {
      // `use foo.{translate}` (selective import)
      // Code: `p.translate(1, 2)` — inherent method, doesn't use the import
      foo_decl := UseDecl.{
        is_stdlib: false,
        is_relative: false,
        path: ["foo"],
        alias: .None,
        items: .Some([make_value_item("translate")]),
        span: span.Span.{ file_id: 0, start: 0, end: 30 },
      }
      // p.translate(1, 2)
      call_expr := dummy_expr(
        .Call(
          dummy_expr(.Field(dummy_expr(.Ident("p")), "translate")),
          [dummy_expr(.IntLit(1)), dummy_expr(.IntLit(2))],
        ),
      )
      module := Module.{
        items: [
          Item.Use(foo_decl),
          Item.Stmt(Stmt.Expr(ExprStmt.{ expr: call_expr, span: dummy_span() })),
        ],
        span: dummy_span(),
      }
      result := check_unused_imports(module)
      // "translate" from `use foo.{translate}` should be flagged as unused
      try assert.equal(result.items.len(), 1)
      try assert.str_contains(result.items[0].kind.message(), "translate")
      .Ok({})
    },
  ).test(
    "check_unused_imports: inherent method on complex expr does not suppress unused import",
    fn() {
      // `use foo.{transform}` (selective import)
      // Code: `get_items().transform()` — inherent method on return value
      foo_decl := UseDecl.{
        is_stdlib: false,
        is_relative: false,
        path: ["foo"],
        alias: .None,
        items: .Some([make_value_item("transform")]),
        span: span.Span.{ file_id: 0, start: 0, end: 30 },
      }
      // get_items().transform()
      call_expr := dummy_expr(
        .Call(
          dummy_expr(.Field(dummy_expr(.Call(dummy_expr(.Ident("get_items")), [])), "transform")),
          [],
        ),
      )
      module := Module.{
        items: [
          Item.Use(foo_decl),
          Item.Stmt(Stmt.Expr(ExprStmt.{ expr: call_expr, span: dummy_span() })),
        ],
        span: dummy_span(),
      }
      result := check_unused_imports(module)
      try assert.equal(result.items.len(), 1)
      try assert.str_contains(result.items[0].kind.message(), "transform")
      .Ok({})
    },
  ).test(
    "check_unused_imports: bare call to imported function is not flagged",
    fn() {
      // `use foo.{translate}` (selective import)
      // Code: `translate(p, 1, 2)` — bare call, DOES use the import
      foo_decl := UseDecl.{
        is_stdlib: false,
        is_relative: false,
        path: ["foo"],
        alias: .None,
        items: .Some([make_value_item("translate")]),
        span: span.Span.{ file_id: 0, start: 0, end: 30 },
      }
      call_expr := dummy_expr(.Call(dummy_expr(.Ident("translate")), [dummy_expr(.Ident("p"))]))
      module := Module.{
        items: [
          Item.Use(foo_decl),
          Item.Stmt(Stmt.Expr(ExprStmt.{ expr: call_expr, span: dummy_span() })),
        ],
        span: dummy_span(),
      }
      result := check_unused_imports(module)
      try assert.equal(result.items.len(), 0)
      .Ok({})
    },
  ).test(
    "check_unused_imports: empty module returns empty result",
    fn() {
      module := Module.{ items: [], span: dummy_span() }
      result := check_unused_imports(module)
      try assert.equal(result.items.len(), 0)
      .Ok({})
    },
  ).test(
    "check_unused_imports: unused selective item returns edit info",
    fn() {
      use_span := span.Span.{ file_id: 0, start: 0, end: 25 }
      decl := UseDecl.{
        is_stdlib: false,
        is_relative: false,
        path: ["foo"],
        alias: .None,
        items: .Some(
          [
            make_value_item("used_fn"),
            ImportItem.Value(ImportValueItem.{
              name: "unused_fn",
              alias: .None,
              span: span.Span.{ file_id: 0, start: 15, end: 24 },
            }),
          ],
        ),
        span: use_span,
      }
      // Module that uses `used_fn` but not `unused_fn`
      call_expr := dummy_expr(.Call(dummy_expr(.Ident("used_fn")), []))
      module := Module.{
        items: [
          Item.Use(decl),
          Item.Stmt(Stmt.Expr(ExprStmt.{ expr: call_expr, span: dummy_span() })),
        ],
        span: dummy_span(),
      }
      result := check_unused_imports(module)
      try assert.equal(result.items.len(), 1)
      diag := result.items[0]
      try assert.str_contains(diag.kind.message(), "unused_fn")
      // Edit should span the whole use statement
      try assert.equal(diag.edit.use_span.start, 0)
      try assert.equal(diag.edit.use_span.end, 25)
      // Replacement should reconstruct with only used_fn
      try assert.equal(diag.edit.replacement, "use foo.{used_fn}\n")
      .Ok({})
    },
  )
}
