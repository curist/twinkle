use @std.path

use compiler.base_env.{builtin_env}
use compiler.imports
use compiler.query.analyze
use compiler.query.cache
use lib.module.loader
use lib.source.identity
use lib.source.overlay
use tests.assert
use tests.runner

fn fixtures_dir() String {
  root := loader.find_project_root("boot")
  "${root}/tests/fixtures/multi"
}

fn canon(entry_path: String) String {
  project_root := loader.find_project_root(path.dirname(entry_path))
  roots := imports.make_canonical_roots(project_root)
  imports.canonical_module_path(entry_path, roots)
}

/// Drive the (not-yet-wired) two-pass SCC driver over a real entry file.
fn run_scc(entry_path: String) analyze.ModuleResult {
  project_root := loader.find_project_root(path.dirname(entry_path))
  base_env := builtin_env()
  state := analyze.new_state(base_env, cache.empty(), overlay.empty(), project_root)
  entry_id := identity.from_path(canon(entry_path))
  analyze.analyze_module_scc(entry_id, base_env, state)
}

fn error_diag_count(result: analyze.ModuleResult) Int {
  n := 0

  for d in result.diagnostics {
    case d.kind {
      .Error(_) => n = n + 1,
      .Warning(_) => {},
    }
  }

  n
}

fn first_error_message(result: analyze.ModuleResult) String {
  for d in result.diagnostics {
    case d.kind {
      .Error(.ParseError(g)) => return g.message,
      .Error(_) => return "error",
      .Warning(_) => {},
    }
  }

  ""
}

pub fn suite() runner.Suite {
  runner
    .suite("group resolution (SCC driver)")
    .test(
      "mutually-recursive types across two modules resolve as a group",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/cycle_type_a.tw")
        try assert.is_true(result.ok)
        try assert.equal(error_diag_count(result), 0)
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_type_a.tw"))
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_type_b.tw"))
        .Ok({})
      },
    )
    .test(
      "mutually-recursive functions across two modules resolve as a group",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/cycle_fn_a.tw")
        try assert.is_true(result.ok)
        try assert.equal(error_diag_count(result), 0)
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_fn_a.tw"))
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_fn_b.tw"))
        .Ok({})
      },
    )
    .test(
      "import cycle without cross-module dependency resolves through the driver",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/circular_a.tw")
        try assert.is_true(result.ok)
        try assert.equal(error_diag_count(result), 0)
        try assert.vec_contains(result.state.module_order, canon("${dir}/circular_a.tw"))
        try assert.vec_contains(result.state.module_order, canon("${dir}/circular_b.tw"))
        .Ok({})
      },
    )
    .test(
      "a value of a sibling-defined record type keeps its fields across the cycle",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/cycle_field_a.tw")
        try assert.is_true(result.ok)
        try assert.equal(error_diag_count(result), 0)
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_field_a.tw"))
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_field_b.tw"))
        .Ok({})
      },
    )
    .test(
      "cross-referencing types keep resolved fields when accessed through the cycle",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/cycle_xref_a.tw")
        try assert.is_true(result.ok)
        try assert.equal(error_diag_count(result), 0)
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_xref_a.tw"))
        try assert.vec_contains(result.state.module_order, canon("${dir}/cycle_xref_b.tw"))
        .Ok({})
      },
    )
    .test(
      "top-level value-init cycle is rejected with an initialization-cycle diagnostic",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/cycle_value_a.tw")
        try assert.is_false(result.ok)
        try assert.str_contains(first_error_message(result), "initialization cycle")
        .Ok({})
      },
    )
    .test(
      "acyclic multi-module closure resolves through the singleton driver path",
      fn() {
        dir := fixtures_dir()
        result := run_scc("${dir}/uses_math.tw")
        try assert.is_true(result.ok)
        try assert.equal(error_diag_count(result), 0)
        try assert.is_true(result.state.module_order.len() > 0)
        try assert.vec_contains(result.state.module_order, canon("${dir}/uses_math.tw"))
        .Ok({})
      },
    )
}
