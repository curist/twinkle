          .empty_env()
          .register_type_entry(color_entry, "dep.Color")
          .bind_type("Color", color_tid)
        src := "fn f(c: Color) Int {\ncase c {\nColor.Red => 1,\nColor.Blue => 2,\n}\n}"
        _ := try check_ok_with_env(src, env)
        .Ok({})
      },
