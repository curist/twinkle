use tests.runner
use tests.assert
use compiler.parser
use compiler.resolver
use compiler.checker
use tests.suites.resolver_suite as rsuite

// ── Helpers ──────────────────────────────────────────────────────────

fn check_src(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := resolver.resolve(parsed.value, resolver.empty_env())
  checker.check(parsed.value, resolved.env)
}

fn builtin_sig(name: String, params: Vector<String>, param_tys: Vector<resolver.MonoType>, ret: resolver.MonoType?) resolver.FunctionSig {
  resolver.FunctionSig.{
    name: name,
    type_params: [],
    param_names: params,
    params: param_tys,
    ret: ret,
  }
}

fn test_env() resolver.ResolvedEnv {
  fns: Vector<resolver.FunctionSig> = [
    builtin_sig("range", ["n"], [resolver.MonoType.Int], .Some(resolver.MonoType.Vector(resolver.MonoType.Int))),
    builtin_sig("range_from", ["start", "end"], [resolver.MonoType.Int, resolver.MonoType.Int], .Some(resolver.MonoType.Vector(resolver.MonoType.Int))),
    builtin_sig("error", ["msg"], [resolver.MonoType.String], .Some(resolver.MonoType.Never)),
    builtin_sig("println", ["s"], [resolver.MonoType.String], .Some(resolver.MonoType.Void)),
    builtin_sig("int_to_string", ["n"], [resolver.MonoType.Int], .Some(resolver.MonoType.String)),
  ]
  env := resolver.env_with_functions(resolver.empty_env(), fns)
  resolver.register_builtin_methods(env)
}

fn check_src_with_builtins(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := resolver.resolve(parsed.value, test_env())
  checker.check(parsed.value, resolved.env)
}

fn check_ok_builtins(src: String) Result<checker.CheckResult, String> {
  r := check_src_with_builtins(src)
  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message}")
  }
  .Ok(r)
}

fn check_errs_builtins(src: String) Result<Vector<String>, String> {
  r := check_src_with_builtins(src)
  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }
  msgs: Vector<String> = []
  for d in r.diagnostics {
    msgs = msgs.push(d.message)
  }
  .Ok(msgs)
}

fn check_ok(src: String) Result<checker.CheckResult, String> {
  r := check_src(src)
  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message}")
  }
  .Ok(r)
}

fn check_errs(src: String) Result<Vector<String>, String> {
  r := check_src(src)
  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }
  msgs: Vector<String> = []
  for d in r.diagnostics {
    msgs = msgs.push(d.message)
  }
  .Ok(msgs)
}

fn type_at(result: checker.CheckResult, src: String, needle: String) Result<String, String> {
  // Find the offset of needle in src, then look it up in type_map
  offset := find_offset(src, needle)
  case offset {
    .Some(off) => {
      case result.type_map[off] {
        .Some(ty) => .Ok(rsuite.mono_to_string(ty)),
        .None => .Err("no type at offset ${off} for '${needle}'"),
      }
    },
    .None => .Err("'${needle}' not found in source"),
  }
}

fn find_offset(src: String, needle: String) Int? {
  find_offset_after(src, needle, 0)
}

fn find_offset_after(src: String, needle: String, start: Int) Int? {
  if needle.len() > src.len() { return .None }
  limit := src.len() - needle.len()
  for i in range(limit + 1) {
    if i >= start and src.slice(i, i + needle.len()) == needle {
      return .Some(i)
    }
  }
  .None
}

fn find_offset_nth(src: String, needle: String, n: Int) Int? {
  count := 0
  if needle.len() > src.len() { return .None }
  limit := src.len() - needle.len()
  for i in range(limit + 1) {
    if src.slice(i, i + needle.len()) == needle {
      if count == n { return .Some(i) }
      count = count + 1
    }
  }
  .None
}

fn type_at_nth(result: checker.CheckResult, src: String, needle: String, n: Int) Result<String, String> {
  offset := find_offset_nth(src, needle, n)
  case offset {
    .Some(off) => {
      case result.type_map[off] {
        .Some(ty) => .Ok(rsuite.mono_to_string(ty)),
        .None => .Err("no type at offset ${off} for '${needle}' (occurrence ${n})"),
      }
    },
    .None => .Err("'${needle}' occurrence ${n} not found in source"),
  }
}

// ── Suite ────────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("checker")
    // ── M1: Literals ──
    .test("int literal", fn() {
      src := "fn answer() Int { 42 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    .test("string literal", fn() {
      src := "fn greeting() String { \"hello\" }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "\"hello\""), "String")
      .Ok({})
    })
    .test("bool literal", fn() {
      src := "fn flag() Bool { true }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "true"), "Bool")
      .Ok({})
    })
    .test("float literal", fn() {
      src := "fn ratio() Float { 3.14 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "3.14"), "Float")
      .Ok({})
    })
    .test("return type mismatch", fn() {
      src := "fn answer() String { 42 }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    // ── M2: Let, Ident, Call ──
    .test("annotated let", fn() {
      src := "fn f() Int { x: Int = 5\n x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "5"), "Int")
      .Ok({})
    })
    .test("inferred let", fn() {
      src := "fn f() Int { x := 42\n x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    .test("annotated let type mismatch", fn() {
      src := "fn f() Int { x: Bool = 5\n x }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    .test("ident resolves param", fn() {
      src := "fn f(x: Int) Int { x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "x }"), "Int")
      .Ok({})
    })
    .test("function call", fn() {
      src := "fn add(a: Int, b: Int) Int { a }\nfn main() Int { add(1, 2) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "add(1"), "Int")
      .Ok({})
    })
    .test("wrong arg count", fn() {
      src := "fn add(a: Int, b: Int) Int { a }\nfn main() Int { add(1) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "expected 2 arguments")
      .Ok({})
    })
    // ── M3: Operators, Indexing ──
    .test("arithmetic int", fn() {
      src := "fn f() Int { 1 + 2 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "1 + 2"), "Int")
      .Ok({})
    })
    .test("comparison", fn() {
      src := "fn f() Bool { 1 < 2 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "1 < 2"), "Bool")
      .Ok({})
    })
    .test("logical and", fn() {
      src := "fn f() Bool { true && false }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "true && false"), "Bool")
      .Ok({})
    })
    .test("negate int", fn() {
      src := "fn f() Int { -5 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "-5"), "Int")
      .Ok({})
    })
    .test("not bool", fn() {
      src := "fn f() Bool { !true }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "!true"), "Bool")
      .Ok({})
    })
    .test("bool plus int error", fn() {
      src := "fn f() Int { true + 1 }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    // string interp test deferred — can't embed ${} in string literals without outer interpolation
    .test("equality", fn() {
      src := "fn f() Bool { 1 == 2 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "1 == 2"), "Bool")
      .Ok({})
    })
    // ── M4: Records, Fields, Variants ──
    .test("record field access", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn get_x(p: Point) Int { p.x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "p.x"), "Int")
      .Ok({})
    })
    .test("record bad field", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn get_z(p: Point) Int { p.z }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "no field 'z'")
      .Ok({})
    })
    .test("anonymous record lit check mode", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1, y: 2 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("record missing field", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "missing field 'y'")
      .Ok({})
    })
    .test("option some check", fn() {
      src := "fn wrap(x: Int) Int? { .Some(x) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("option none check", fn() {
      src := "fn nothing() Int? { .None }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("result ok check", fn() {
      src := "fn ok_val(x: Int) Result<Int, String> { .Ok(x) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("result err check", fn() {
      src := "fn err_val() Result<Int, String> { .Err(\"bad\") }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("array literal", fn() {
      src := "fn nums() Vector<Int> { [1, 2, 3] }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("array element mismatch", fn() {
      src := "fn bad() Vector<Int> { [1, \"two\", 3] }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    // ── M5: Generics ──
    .test("generic identity", fn() {
      src := "fn identity<A>(x: A) A { x }\nfn main() Int { identity(42) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "identity(42)"), "Int")
      .Ok({})
    })
    .test("generic with array", fn() {
      src := "fn first<T>(xs: Vector<T>) T { xs[0] }\nfn main() Int { first([1, 2, 3]) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "first([1"), "Int")
      .Ok({})
    })
    .test("generic type mismatch", fn() {
      src := "fn identity<A>(x: A) A { x }\nfn main() String { identity(42) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    .test("generic two params", fn() {
      src := "fn pair<A, B>(a: A, b: B) A { a }\nfn main() Int { pair(1, \"hi\") }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "pair(1"), "Int")
      .Ok({})
    })
    // ── M6: If, Case, For ──
    .test("if else unify", fn() {
      src := "fn abs(x: Int) Int { if x < 0 { -x } else { x } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("if no else is void", fn() {
      src := "fn f(x: Int) Void { if x > 0 { x } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("if branch mismatch", fn() {
      src := "fn f(x: Int) Int { if x > 0 { 1 } else { \"no\" } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    .test("case option with wildcard", fn() {
      src := "fn unwrap(o: Int?) Int { case o { .Some(x) => x, _ => 0 } }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "case o"), "Int")
      .Ok({})
    })
    .test("case binds pattern var", fn() {
      src := "fn unwrap(o: Int?) Int { case o { .Some(x) => x, _ => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("case non-exhaustive", fn() {
      src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "non-exhaustive")
      .Ok({})
    })
    .test("case wildcard exhaustive", fn() {
      src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1, _ => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("for condition", fn() {
      src := "fn f() Void { x := 0\n for x < 10 { x = x + 1 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("for in vector", fn() {
      src := "fn sum(xs: Vector<Int>) Int { s := 0\n for x in xs { s = s + x }\n s }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("for with index", fn() {
      src := "fn f(xs: Vector<Int>) Int { s := 0\n for x, i in xs { s = s + i }\n s }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── M7: Closures, Try ──
    .test("closure annotated", fn() {
      src := "fn apply(f: fn(Int) Int, x: Int) Int { f(x) }\nfn main() Int { apply(fn(x: Int) Int { x + 1 }, 5) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("closure inferred from context", fn() {
      src := "fn apply(f: fn(Int) Int, x: Int) Int { f(x) }\nfn main() Int { apply(fn(x) { x + 1 }, 5) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("try option", fn() {
      src := "fn get(o: Int?) Int? {\n  x := try o\n  r: Int? = .Some(x + 1)\n  r\n}"
      r := try check_ok(src)
      .Ok({})
    })
    .test("try result", fn() {
      src := "fn inc(r: Result<Int, String>) Result<Int, String> {\n  x := try r\n  out: Result<Int, String> = .Ok(x + 1)\n  out\n}"
      r := try check_ok(src)
      .Ok({})
    })
    .test("try on non-option", fn() {
      src := "fn f(x: Int) Int { try x }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "try requires Option or Result")
      .Ok({})
    })
    // ── M8: Collect ──
    .test("collect", fn() {
      src := "fn squares(xs: Vector<Int>) Vector<Int> { collect x in xs { x * x } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("empty array annotated", fn() {
      src := "fn empty() Vector<Int> { [] }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── M9: Integration with builtins ──
    .test("case option exhaustive without wildcard", fn() {
      src := "fn unwrap_or(o: Int?, d: Int) Int { case o { .Some(x) => x, .None => d } }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "case o"), "Int")
      .Ok({})
    })
    .test("case result exhaustive without wildcard", fn() {
      src := "fn handle(r: Result<Int, String>) Int { case r { .Ok(x) => x, .Err(e) => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("case diverging arm with error", fn() {
      src := "fn unwrap(o: Int?) Int { case o { .None => error(\"missing\"), .Some(x) => x } }"
      r := try check_ok_builtins(src)
      try assert.str_eq(try type_at(r, src, "case o"), "Int")
      .Ok({})
    })
    .test("case all arms diverge is Never", fn() {
      src := "fn boom(o: Int?) Int { case o { .None => error(\"a\"), .Some(x) => error(\"b\") } }"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("collect with range", fn() {
      src := "fn squares(n: Int) Vector<Int> { collect i in range(n) { i * i } }"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("error returns Never", fn() {
      src := "fn fail() Int { error(\"boom\") }"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("call println", fn() {
      src := "fn greet() Void { println(\"hi\") }"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("integration no errors", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn dist(p: Point) Int { p.x + p.y }\nfn main() Int { dist(.{ x: 1, y: 2 }) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "dist(.{"), "Int")
      .Ok({})
    })
    .test("integration partial typemap on error", fn() {
      src := "fn f() Int { x := 42\n y: Bool = x\n x }"
      r := check_src(src)
      // Should have diagnostics (type mismatch) but still have type info for 42
      if r.diagnostics.len() == 0 {
        return .Err("expected diagnostics")
      }
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    // ── String interpolation with method registry ──
    .test("interpolation of Int is ok", fn() {
      dollar := "$"
      src := "fn f(n: Int) String { \"hello ${dollar}{n}\" }"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("interpolation of Named without to_string errors", fn() {
      dollar := "$"
      src := "type Point = .{ x: Int, y: Int }\nfn f(p: Point) String { \"at ${dollar}{p}\" }"
      msgs := try check_errs_builtins(src)
      found := false
      for m in msgs {
        if m.contains("to_string") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("interpolation of Named with to_string registered is ok", fn() {
      dollar := "$"
      src := "type Point = .{ x: Int, y: Int }\nfn to_string(p: Point) String { \"\" }\nfn f(p: Point) String { \"at ${dollar}{p}\" }"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("multifunction program", fn() {
      src := "fn add(a: Int, b: Int) Int { a + b }\nfn double(x: Int) Int { add(x, x) }\nfn main() Int { double(21) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "double(21)"), "Int")
      try assert.str_eq(try type_at(r, src, "add(x"), "Int")
      .Ok({})
    })
    // ── F2: Bool exhaustiveness ──
    .test("F2 bool case exhaustive", fn() {
      src := "fn f(b: Bool) Int { case b { true => 1, false => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("F2 bool case non-exhaustive", fn() {
      src := "fn f(b: Bool) Int { case b { true => 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "non-exhaustive")
      .Ok({})
    })
    .test("F2 bool case with wildcard", fn() {
      src := "fn f(b: Bool) Int { case b { true => 1, _ => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── F3: try validates enclosing return type ──
    .test("F3 try option in option-returning fn ok", fn() {
      src := "fn find(x: Int?) Int? { v := try x\nresult: Int? = .Some(v)\n result }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("F3 try option in int-returning fn errors", fn() {
      src := "fn find(x: Int?) Int { try x }"
      msgs := try check_errs(src)
      found := false
      for m in msgs {
        if m.contains("try") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    .test("F3 try result in int-returning fn errors", fn() {
      src := "fn parse(x: Result<Int, String>) Int { try x }"
      msgs := try check_errs(src)
      found := false
      for m in msgs {
        if m.contains("try") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    // ── F4: inferred return types written back ──
    .test("F4 inferred return type propagates", fn() {
      src := "fn double(x: Int) { x * 2 }\nfn use_it() Int { double(3) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "double(3)"), "Int")
      .Ok({})
    })
    .test("F4 inferred void return", fn() {
      src := "fn noop() { }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── F5: qualified variant path validation ──
    .test("F5 qualified variant correct type", fn() {
      src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { Color.Red => 1, Color.Green => 2, Color.Blue => 3 } }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── F8: check_function context restore ──
    .test("F8 second function independent of first", fn() {
      src := "fn first() Int { 1 }\nfn second() String { \"hello\" }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "\"hello\""), "String")
      .Ok({})
    })
    // ── F9: return records Never ──
    .test("F9 return has Never type", fn() {
      src := "fn f() Int { return 42 }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("F9 if-else with returns in both branches diverges", fn() {
      src := "fn f(x: Bool) Int {\nif x { return 1 } else { return 2 }\n}"
      r := try check_ok(src)
      .Ok({})
    })
    .test("F9 error() call diverges", fn() {
      src := "fn f(x: Bool) Int {\nif x { return 1 } else { error(\"fail\") }\n}"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    // ── F3: try threads unification context ──
    .test("F3 try on Result threads error type unification", fn() {
      // Verify that try on Result properly threads u.ctx so MetaVar substitutions are preserved
      src := "type E = { Bad }\nfn inner() Result<Int, E> { .Ok(1) }\nfn outer() Result<Int, E> { x := try inner(); .Ok(x) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("F3 try on Result in non-Result function errors", fn() {
      src := "type E = { Bad }\nfn inner() Result<Int, E> { .Ok(1) }\nfn outer() Int {\ntry inner()\n}"
      msgs := try check_errs(src)
      try assert.is_true(msgs[0].contains("try on Result requires"))
      .Ok({})
    })
    // ── F5: qualified variant path validation ──
    .test("F5 correct qualifier accepted", fn() {
      src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int {\ncase c {\nColor.Red => 1,\nColor.Green => 2,\nColor.Blue => 3,\n}\n}"
      r := try check_ok(src)
      .Ok({})
    })
    .test("F5 wrong qualifier produces diagnostic", fn() {
      src := "type Color = { Red, Green, Blue }\ntype Shape = { Red, Circle }\nfn f(c: Color) Int {\ncase c {\nShape.Red => 1,\n_ => 0,\n}\n}"
      msgs := try check_errs(src)
      try assert.is_true(msgs[0].contains("does not match"))
      .Ok({})
    })
    // ── C1: type alias expansion ──
    .test("C1 alias field access", fn() {
      src := "type Pt = .{ x: Int, y: Int }\ntype MyPt = Pt\nfn get_x(p: MyPt) Int { p.x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "p.x"), "Int")
      .Ok({})
    })
    .test("C1 alias variant pattern match", fn() {
      src := "type MaybeInt = Int?\nfn unwrap(m: MaybeInt) Int {\ncase m { .Some(x) => x, .None => 0 }\n}"
      r := try check_ok(src)
      .Ok({})
    })
    // ── C2: element_type_of for Iterator and Range ──
    .test("C2 for over range produces Int", fn() {
      src := "fn f() Int {\nx := 0\nfor i in range(10) { x = i }\nx\n}"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("C2 for over non-iterable produces diagnostic", fn() {
      src := "fn f() Void { for x in 42 { x } }"
      msgs := try check_errs(src)
      try assert.is_true(msgs[0].contains("cannot iterate"))
      .Ok({})
    })
    // ── C3: break, continue, defer, assign ──
    .test("C3 break in for loop ok", fn() {
      src := "fn f() Void {\nfor i in range(10) { if i > 5 { break } }\n}"
      r := try check_ok_builtins(src)
      .Ok({})
    })
    .test("C3 defer synths body", fn() {
      src := "fn f() Void { defer 42 + true }"
      msgs := try check_errs(src)
      try assert.is_true(msgs.len() > 0)
      .Ok({})
    })
    .test("C3 assign checks type", fn() {
      src := "fn f() Void {\nx := 42\nx = \"hi\"\n}"
      msgs := try check_errs(src)
      try assert.is_true(msgs[0].contains("type mismatch"))
      .Ok({})
    })
    .test("C3 assign matching type ok", fn() {
      src := "fn f() Void {\nx := 42\nx = 99\n}"
      r := try check_ok(src)
      .Ok({})
    })
    // ── C4: top-level statement checking ──
    .test("C4 top-level let populates type map", fn() {
      src := "x := 42"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    .test("C4 top-level type mismatch", fn() {
      src := "x: Bool = 42"
      msgs := try check_errs(src)
      try assert.is_true(msgs[0].contains("type mismatch"))
      .Ok({})
    })
    // ── C6: exhaustiveness lists missing variants ──
    .test("C6 non-exhaustive lists missing variants", fn() {
      src := "type Shape = { Circle, Rect, UnitSquare }\nfn f(s: Shape) Int {\ncase s { .Circle => 1 }\n}"
      msgs := try check_errs(src)
      try assert.is_true(msgs[0].contains("Rect"))
      .Ok({})
    })
    // ── C9: Var in unification ──
    .test("C9 no uninstantiated Var in existing tests", fn() {
      // Regression guard: basic generic call should not produce Var errors
      src := "fn identity<T>(x: T) T { x }\nfn f() Int { identity(42) }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── C5: closure call check mode ──
    .test("C5 closure call basic", fn() {
      src := "fn f() Int { g := fn(x: Int) Int { x + 1 }\n g(5) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "g(5)"), "Int")
      .Ok({})
    })
    .test("C5 closure call pushes expected type to record arg", fn() {
      src := "type Pt = .{ x: Int, y: Int }\nfn f() Int { g := fn(p: Pt) Int { p.x }\n g(.{ x: 1, y: 2 }) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("C5 closure call pushes expected type to variant arg", fn() {
      src := "fn f() Int { g := fn(o: Int?) Int { case o { .Some(x) => x, .None => 0 } }\n g(.Some(42)) }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── C7: named record constructor ──
    .test("C7 named record constructor synth", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn f() Point { p := Point.{ x: 1, y: 2 }\n p }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("C7 named record missing field", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn f() Point { Point.{ x: 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "missing field 'y'")
      .Ok({})
    })
    .test("C7 named record unknown type", fn() {
      src := "fn f() Void { Nonexistent.{ x: 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "unknown type")
      .Ok({})
    })
    // ── C8: ambiguous MetaVar detection ──
    .test("C8 solved MetaVar no diagnostic", fn() {
      src := "fn identity<T>(x: T) T { x }\nfn f() Int { identity(42) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("C8 unsolved MetaVar produces diagnostic", fn() {
      src := "fn identity<T>(x: T) T { x }\nfn f() Void { identity(identity(identity([]))) }"
      msgs := try check_errs(src)
      found := false
      for m in msgs {
        if m.contains("ambiguous") or m.contains("cannot infer") { found = true }
      }
      try assert.is_true(found)
      .Ok({})
    })
    // ── C10: resolver documentation (no behavioral test needed, just smoke) ──
    // ── T2: Checker error path tests ──
    .test("T2 wrong variant arg count: Some(1,2)", fn() {
      src := "fn f() Int? { .Some(1, 2) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "expects 1 argument")
      .Ok({})
    })
    .test("T2 wrong variant arg count: None(1)", fn() {
      src := "fn f() Int? { .None(1) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "expects 0 argument")
      .Ok({})
    })
    .test("T2 wrong variant arg count: Ok()", fn() {
      src := "fn f() Result<Int, String> { .Ok() }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "expects 1 argument")
      .Ok({})
    })
    .test("T2 wrong variant arg count: Err(1,2)", fn() {
      src := "fn f() Result<Int, String> { .Err(1, 2) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "expects 1 argument")
      .Ok({})
    })
    .test("T2 unknown variant for Option", fn() {
      src := "fn f() Int? { .Foo(1) }"
      msgs := try check_errs(src)
      found := false
      for m in msgs { if m.contains("unknown variant") or m.contains("variant") { found = true } }
      try assert.is_true(found)
      .Ok({})
    })
    .test("T2 user sum variant in check mode", fn() {
      src := "type Shape = { Circle(Float), Rect(Float, Float) }\nfn f() Shape { .Circle(1.0) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 user sum pattern", fn() {
      src := "type Shape = { Circle(Float), Rect(Float, Float) }\nfn f(s: Shape) Float {\ncase s { .Circle(r) => r, .Rect(w, h) => w }\n}"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 wrong sub-pattern count in user sum", fn() {
      src := "type Shape = { Circle(Float) }\nfn f(s: Shape) Float {\ncase s { .Circle(r, s) => r }\n}"
      msgs := try check_errs(src)
      found := false
      for m in msgs { if m.contains("expects") and m.contains("binding") { found = true } }
      try assert.is_true(found)
      .Ok({})
    })
    .test("T2 field access on sum type", fn() {
      src := "type Shape = { Circle(Float) }\nfn f(s: Shape) Float { s.foo }"
      msgs := try check_errs(src)
      try assert.is_true(msgs.len() > 0)
      .Ok({})
    })
    .test("T2 field access on primitive", fn() {
      src := "fn f(x: Int) Int { x.foo }"
      msgs := try check_errs(src)
      found := false
      for m in msgs { if m.contains("field") or m.contains("cannot access") { found = true } }
      try assert.is_true(found)
      .Ok({})
    })
    .test("T2 record lit with extra field", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1, y: 2, z: 3 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "unknown field")
      .Ok({})
    })
    .test("T2 record literal in non-Named context", fn() {
      src := "fn f() Int { .{ x: 1 } }"
      msgs := try check_errs(src)
      try assert.is_true(msgs.len() > 0)
      .Ok({})
    })
    .test("T2 dict indexing", fn() {
      src := "fn f(d: Dict<String, Int>) Int? { d[\"key\"] }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 string indexing", fn() {
      src := "fn f(s: String) Byte { s[0] }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 indexing non-indexable", fn() {
      src := "fn f(x: Int) Int { x[0] }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "cannot index")
      .Ok({})
    })
    .test("T2 range operator", fn() {
      src := "fn f() Vector<Int> { 1..10 }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 string concatenation", fn() {
      src := "fn f() String { \"a\" + \"b\" }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "\"a\" + \"b\""), "String")
      .Ok({})
    })
    .test("T2 bitwise and", fn() {
      src := "fn f(a: Int, b: Int) Int { a & b }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 bitwise or", fn() {
      src := "fn f(a: Int, b: Int) Int { a | b }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 bitwise xor", fn() {
      src := "fn f(a: Int, b: Int) Int { a ^ b }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("T2 bitwise not", fn() {
      src := "fn f(a: Int) Int { ~a }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "~a"), "Int")
      .Ok({})
    })
    .test("T2 self-application type error", fn() {
      src := "fn f<T>(x: T) T { f(f) }"
      msgs := try check_errs(src)
      try assert.is_true(msgs.len() > 0)
      .Ok({})
    })
    .test("T2 scope shadowing", fn() {
      src := "fn f() Int {\nx := 42\nif true {\nx := \"hello\"\nx\n}\nx\n}"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    .test("T2 literal pattern in case", fn() {
      src := "fn f(x: Int) String {\ncase x {\n1 => \"one\",\n_ => \"other\",\n}\n}"
      r := try check_ok(src)
      .Ok({})
    })
    // ── T3: Checker synthesis path tests ──
    .test("T3 field access on generic record", fn() {
      src := "type Box<T> = .{ value: T }\nfn get_val(b: Box<Int>) Int { b.value }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "b.value"), "Int")
      .Ok({})
    })
}
