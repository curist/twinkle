use compiler.base_env
use compiler.checker
use compiler.mono_type as mono_type
use compiler.parser
use compiler.resolver
use compiler.resolver.{plain_resolved_type_params}
use lib.source.span
use @std.testing.assert as assert
use @std.testing as runner
use tests.suites.resolver_suite as rsuite

// ── Helpers ──────────────────────────────────────────────────────────
fn check_src(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := resolver.empty_env().resolve(parsed.value)
  checker.check(parsed.value, resolved.env, false)
}

fn check_src_with_env(src: String, env: resolver.ResolvedEnv) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := env.resolve(parsed.value)
  checker.check(parsed.value, resolved.env, false)
}

fn builtin_sig(
  name: String,
  params: Vector<String>,
  param_tys: Vector<mono_type.MonoType>,
  ret: mono_type.MonoType?,
) resolver.FunctionSig {
  resolver.FunctionSig.{
    name,
    type_params: [],
    param_names: params,
    params: param_tys,
    ret,
    doc: .None,
    extern_module: .None,
  }
}

fn test_env() resolver.ResolvedEnv {
  fns: Vector<resolver.FunctionSig> = [
    builtin_sig(
      "range",
      ["n"],
      [mono_type.MonoType.Int],
      .Some(mono_type.MonoType.Vector(mono_type.MonoType.Int)),
    ),
    builtin_sig(
      "range_from",
      ["start", "end"],
      [mono_type.MonoType.Int, mono_type.MonoType.Int],
      .Some(mono_type.MonoType.Vector(mono_type.MonoType.Int)),
    ),
    builtin_sig("error", ["msg"], [mono_type.MonoType.String], .Some(mono_type.MonoType.Never)),
    builtin_sig("println", ["s"], [mono_type.MonoType.String], .Some(mono_type.MonoType.Void)),
    builtin_sig("int$to_string", ["n"], [mono_type.MonoType.Int], .Some(mono_type.MonoType.String)),
    builtin_sig(
      "bool$to_string",
      ["b"],
      [mono_type.MonoType.Bool],
      .Some(mono_type.MonoType.String),
    ),
  ]
  env := resolver.empty_env().with_registered_functions(fns)
  env = .bind_function("range", "range")
  env = .bind_function("range_from", "range_from")
  env = .bind_function("error", "error")
  env = .bind_function("println", "println")

  // Register Iterator type so checker can look it up by name for iteration checks
  iter_entry := resolver.TypeEntry.{
    id: mono_type.TypeId.{ id: 0 },
    arity: 1,
    def: .Some(
      resolver.ResolvedTypeDef.Sum(
        "Iterator",
        plain_resolved_type_params(["T"]),
        [resolver.ResolvedVariant.{ name: "Item", fields: [mono_type.MonoType.Var("T")], tag: 0 }],
      ),
    ),
    span: span.Span.{ file_id: 0, start: 0, end: 0 },
    is_extern: false,
  }
  env = .add_type(iter_entry, "Iterator")

  // Register Range type (TypeId 3 in stage0) so range operator tests work
  range_entry := resolver.TypeEntry.{
    id: mono_type.TypeId.{ id: 3 },
    arity: 0,
    def: .Some(
      resolver.ResolvedTypeDef.Record(
        "Range",
        [],
        [
          resolver.ResolvedField.{ name: "start", ty: mono_type.MonoType.Int },
          resolver.ResolvedField.{ name: "end", ty: mono_type.MonoType.Int },
        ],
      ),
    ),
    span: span.Span.{ file_id: 0, start: 0, end: 0 },
    is_extern: false,
  }
  env = .add_type(range_entry, "Range")
  env = .register_bound_methods(
    "Int",
    [resolver.MethodEntry.{ method_name: "to_string", function_name: "int$to_string" }],
  )
  env = .register_bound_methods(
    "Bool",
    [resolver.MethodEntry.{ method_name: "to_string", function_name: "bool$to_string" }],
  )
  env
}

fn check_src_with_builtins(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := base_env.builtin_env().resolve(parsed.value)
  checker.check(parsed.value, resolved.env, false)
}

fn check_ok_builtins(src: String) Result<checker.CheckResult, String> {
  r := check_src_with_builtins(src)

  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message()}")
  }

  .Ok(r)
}

fn check_errs_builtins(src: String) Result<Vector<String>, String> {
  r := check_src_with_builtins(src)

  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }

  msgs: Vector<String> = []

  for d in r.diagnostics {
    msgs = .append(d.message())
  }

  .Ok(msgs)
}

fn check_ok(src: String) Result<checker.CheckResult, String> {
  r := check_src(src)

  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message()}")
  }

  .Ok(r)
}

fn check_ok_with_env(src: String, env: resolver.ResolvedEnv) Result<checker.CheckResult, String> {
  r := check_src_with_env(src, env)

  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message()}")
  }

  .Ok(r)
}

fn check_errs(src: String) Result<Vector<String>, String> {
  r := check_src(src)

  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }

  msgs: Vector<String> = []

  for d in r.diagnostics {
    msgs = .append(d.message())
  }

  .Ok(msgs)
}

fn check_errs_with_env(src: String, env: resolver.ResolvedEnv) Result<Vector<String>, String> {
  r := check_src_with_env(src, env)

  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }

  msgs: Vector<String> = []

  for d in r.diagnostics {
    msgs = .append(d.message())
  }

  .Ok(msgs)
}

fn find_id_by_span(result: checker.CheckResult, target_offset: Int) Int? {
  best: Int? = .None

  for eid in result.expr_spans.keys() {
    case result.expr_spans[eid] {
      .Some(span_start) => if span_start == target_offset {
        best = case best {
          .None => .Some(eid),
          .Some(prev) => if eid > prev {
            .Some(eid)
          } else {
            .Some(prev)
          },
        }
      },
      .None => {},
    }
  }

  best
}

fn type_at(result: checker.CheckResult, src: String, needle: String) Result<String, String> {
  offset := find_offset(src, needle)

  case offset {
    .Some(off) => case find_id_by_span(result, off) {
      .Some(eid) => case result.type_map[eid] {
        .Some(ty) => .Ok(rsuite.mono_to_string(ty)),
        .None => .Err("no type at offset ${off} for '${needle}' (id=${eid})"),
      },
      .None => .Err("no expr id at offset ${off} for '${needle}'"),
    },
    .None => .Err("'${needle}' not found in source"),
  }
}

fn find_offset(src: String, needle: String) Int? {
  find_offset_after(src, needle, 0)
}

fn find_offset_after(src: String, needle: String, start: Int) Int? {
  if needle.len() > src.len() {
    return .None
  }

  limit := src.len() - needle.len()

  for i in 0..limit + 1 {
    if i >= start and src.slice(i, i + needle.len()) == needle {
      return .Some(i)
    }
  }

  .None
}

fn find_offset_nth(src: String, needle: String, n: Int) Int? {
  count := 0

  if needle.len() > src.len() {
    return .None
  }

  limit := src.len() - needle.len()

  for i in 0..limit + 1 {
    if src.slice(i, i + needle.len()) == needle {
      if count == n {
        return .Some(i)
      }

      count = count + 1
    }
  }

  .None
}

fn type_at_nth(result: checker.CheckResult, src: String, needle: String, n: Int) Result<
  String,
  String,
> {
  offset := find_offset_nth(src, needle, n)

  case offset {
    .Some(off) => case find_id_by_span(result, off) {
      .Some(eid) => case result.type_map[eid] {
        .Some(ty) => .Ok(rsuite.mono_to_string(ty)),
        .None => .Err("no type at offset ${off} for '${needle}' (occurrence ${n}, id=${eid})"),
      },
      .None => .Err("no expr id at offset ${off} for '${needle}' (occurrence ${n})"),
    },
    .None => .Err("'${needle}' occurrence ${n} not found in source"),
  }
}

// ── Suite ────────────────────────────────────────────────────────────
pub fn suite() runner.Suite {
  runner
    .suite("checker")
    .test(
      "int literal",
      fn() {
        src := "fn answer() Int { 42 }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "42"), "Int")
        .Ok({})
      },
    )
    .test(
      "string literal",
      fn() {
        src := "fn greeting() String { \"hello\" }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "\"hello\""), "String")
        .Ok({})
      },
    )
    .test(
      "bool literal",
      fn() {
        src := "fn flag() Bool { true }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "true"), "Bool")
        .Ok({})
      },
    )
    .test(
      "float literal",
      fn() {
        src := "fn ratio() Float { 3.14 }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "3.14"), "Float")
        .Ok({})
      },
    )
    .test(
      "return type mismatch",
      fn() {
        src := "fn answer() String { 42 }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "type mismatch")
        .Ok({})
      },
    )
    .test(
      "annotated let",
      fn() {
        src := "fn f() Int { x: Int = 5\n x }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "5"), "Int")
        .Ok({})
      },
    )
    .test(
      "inferred let",
      fn() {
        src := "fn f() Int { x := 42\n x }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "42"), "Int")
        .Ok({})
      },
    )
    .test(
      "annotated let type mismatch",
      fn() {
        src := "fn f() Int { x: Bool = 5\n x }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "type mismatch")
        .Ok({})
      },
    )
    .test(
      "ident resolves param",
      fn() {
        src := "fn f(x: Int) Int { x }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "x }"), "Int")
        .Ok({})
      },
    )
    .test(
      "function call",
      fn() {
        src := "fn add(a: Int, b: Int) Int { a }\nfn main() Int { add(1, 2) }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "add(1"), "Int")
        .Ok({})
      },
    )
    .test(
      "local closure shadows prelude function in call position",
      fn() {
        env := test_env().add_function(
          builtin_sig(
            "count",
            ["s", "needle"],
            [mono_type.MonoType.String, mono_type.MonoType.String],
            .Some(mono_type.MonoType.Int),
          ),
        )
        src := "fn main() Int {\n  count := fn(n: Int) Int { n + 1 }\n  count(41)\n}"
        r := try check_ok_with_env(src, env)
        try assert.equal(try type_at(r, src, "count(41"), "Int")
        .Ok({})
      },
    )
    .test(
      "wrong arg count",
      fn() {
        src := "fn add(a: Int, b: Int) Int { a }\nfn main() Int { add(1) }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "expected 2 arguments")
        .Ok({})
      },
    )
    .test(
      "arithmetic int",
      fn() {
        src := "fn f() Int { 1 + 2 }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "1 + 2"), "Int")
        .Ok({})
      },
    )
    .test(
      "comparison",
      fn() {
        src := "fn f() Bool { 1 < 2 }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "1 < 2"), "Bool")
        .Ok({})
      },
    )
    .test(
      "logical and",
      fn() {
        src := "fn f() Bool { true and false }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "true and false"), "Bool")
        .Ok({})
      },
    )
    .test(
      "negate int",
      fn() {
        src := "fn f() Int { -5 }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "-5"), "Int")
        .Ok({})
      },
    )
    .test(
      "not bool",
      fn() {
        src := "fn f() Bool { !true }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "!true"), "Bool")
        .Ok({})
      },
    )
    .test(
      "bool plus int error",
      fn() {
        src := "fn f() Int { true + 1 }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "operator not supported")
        .Ok({})
      },
    )
    .test(
      "string plus suggests concat or interpolation",
      fn() {
        src := "fn f() String { \"hello\" + \"world\" }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "cannot concatenate strings with `+`")
        .Ok({})
      },
    )
    .test(
      "equality",
      fn() {
        src := "fn f() Bool { 1 == 2 }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "1 == 2"), "Bool")
        .Ok({})
      },
    )
    .test(
      "record field access",
      fn() {
        src := "type Point = .{ x: Int, y: Int }\nfn get_x(p: Point) Int { p.x }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "p.x"), "Int")
        .Ok({})
      },
    )
    .test(
      "record bad field",
      fn() {
        src := "type Point = .{ x: Int, y: Int }\nfn get_z(p: Point) Int { p.z }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "no field `z`")
        .Ok({})
      },
    )
    .test(
      "anonymous record lit check mode",
      fn() {
        src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1, y: 2 } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "enum tag: .tag on field-less enum is Int",
      fn() {
        src := "type K = { A, B }\nfn f(k: K) Int { k.tag }"
        r := try check_ok(src)
        try assert.str_contains(try type_at(r, src, "k.tag"), "Int")
        .Ok({})
      },
    )
    .test(
      "enum tag: D2 rejects .tag on payload enum",
      fn() {
        src := "type Shape = { Circle(Float), Unit }\nfn f(s: Shape) Int { s.tag }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "`.tag` is only available on field-less enums")
        .Ok({})
      },
    )
    .test(
      "enum tag: from_tag on field-less enum returns Option",
      fn() {
        src := "type K = { A, B }\nfn f() K? { K.from_tag(0) }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "enum tag: from_tag arg must be Int",
      fn() {
        src := "type K = { A, B }\nfn f() K? { K.from_tag(\"x\") }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "type mismatch")
        .Ok({})
      },
    )
    .test(
      "enum tag: D3 rejects from_tag on payload enum",
      fn() {
        src := "type Shape = { Circle(Float), Unit }\nfn f() Shape? { Shape.from_tag(0) }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "`from_tag` is only available on field-less enums")
        .Ok({})
      },
    )
    .test(
      "enum tag: from_tag method collision is rejected",
      fn() {
        src := "type K = { A, B }\nfn from_tag(k: K) Int { 0 }\nfn g() K? { K.from_tag(0) }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "`from_tag` is reserved on field-less enums")
        .Ok({})
      },
    )
    .test(
      "record missing field",
      fn() {
        src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "missing field 'y'")
        .Ok({})
      },
    )
    .test(
      "option some check",
      fn() {
        src := "fn wrap(x: Int) Int? { .Some(x) }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "option none check",
      fn() {
        src := "fn nothing() Int? { .None }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "result ok check",
      fn() {
        src := "fn ok_val(x: Int) Result<Int, String> { .Ok(x) }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "result err check",
      fn() {
        src := "fn err_val() Result<Int, String> { .Err(\"bad\") }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "array literal",
      fn() {
        src := "fn nums() Vector<Int> { [1, 2, 3] }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "array element mismatch",
      fn() {
        src := "fn bad() Vector<Int> { [1, \"two\", 3] }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "type mismatch")
        .Ok({})
      },
    )
    .test(
      "generic identity",
      fn() {
        src := "fn identity<A>(x: A) A { x }\nfn main() Int { identity(42) }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "identity(42)"), "Int")
        .Ok({})
      },
    )
    .test(
      "generic with array",
      fn() {
        src := "fn first<T>(xs: Vector<T>) T { xs[0] }\nfn main() Int { first([1, 2, 3]) }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "first([1"), "Int")
        .Ok({})
      },
    )
    .test(
      "generic type mismatch",
      fn() {
        src := "fn identity<A>(x: A) A { x }\nfn main() String { identity(42) }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "type mismatch")
        .Ok({})
      },
    )
    .test(
      "generic two params",
      fn() {
        src := "fn pair<A, B>(a: A, b: B) A { a }\nfn main() Int { pair(1, \"hi\") }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "pair(1"), "Int")
        .Ok({})
      },
    )
    .test(
      "generic type variable in nested local annotation",
      fn() {
        src := "fn keep<A>(d: Dict<String, A>) Dict<String, A> {\n  out: Dict<String, A> = d\n  out\n}\nfn main(d: Dict<String, Int>) Dict<String, Int> { keep(d) }"
        _ := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "bounded type parameter method lookup",
      fn() {
        src := "fn show<T: Stringify>(x: T) String { x.to_string() }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "x.to_string()"), "String")
        .Ok({})
      },
    )
    .test(
      "generic bound satisfied by primitive",
      fn() {
        src := "fn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(42) }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "show(42)"), "String")
        .Ok({})
      },
    )
    .test(
      "generic bound satisfied by inherent witness",
      fn() {
        src := "type User = .{ name: String }\nfn to_string(u: User) String { u.name }\nfn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(User.{ name: \"Ada\" }) }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "show(User"), "String")
        .Ok({})
      },
    )
    .test(
      "generic bound satisfaction recurses through witness bounds",
      fn() {
        src := "type Box<T> = .{ value: T }\nfn to_string<T: Stringify>(b: Box<T>) String { b.value.to_string() }\nfn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(Box.{ value: 42 }) }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "show(Box"), "String")
        .Ok({})
      },
    )
    .test(
      "generic bound rejects unsatisfied type argument",
      fn() {
        src := "type Foo = .{}\nfn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(Foo.{}) }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "does not satisfy Stringify")
        .Ok({})
      },
    )
    .test(
      "bounded type declaration allows satisfying record construction",
      fn() {
        src := "type Box<T: Stringify> = .{ value: T }\nfn main() Box<Int> { Box.{ value: 1 } }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "Box.{ value: 1 }"), "Named(0)<Int>")
        .Ok({})
      },
    )
    .test(
      "bounded type declaration rejects record construction",
      fn() {
        src := "type Foo = .{}\ntype Box<T: Stringify> = .{ value: T }\nfn main() Box<Foo> { Box.{ value: Foo.{} } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "required by Box<T: Stringify>")
        .Ok({})
      },
    )
    .test(
      "bounded type declaration rejects annotation",
      fn() {
        src := "type Foo = .{}\ntype Box<T: Stringify> = .{ value: T }\nfn main() Void { x: Box<Foo> = error(\"boom\") }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "required by Box<T: Stringify>")
        .Ok({})
      },
    )
    .test(
      "bounded sum declaration rejects named variant construction",
      fn() {
        src := "type Foo = .{}\ntype Wrap<T: Stringify> = { Wrap(T) }\nfn main() Wrap<Foo> { Wrap.Wrap(Foo.{}) }"
