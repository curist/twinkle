      fn() {
        src := "type Mono = { Void, Int }\nfn f(flag: Bool, xs: Vector<Mono>) Mono { case flag { true => .Void, _ => xs[0] } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "G14 case arm block tail resolves variant shorthand from later arm",
      fn() {
        src := "type Mono = { Void, Int }\nfn f(flag: Bool, xs: Vector<Mono>) Mono { case flag { true => { .Void }, _ => xs[0] } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "G13 if-else branch mismatch still errors",
      fn() {
        src := "fn f(x: Int) Int { if x > 0 { 1 } else { \"no\" } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "type mismatch")
        .Ok({})
      },
    )
    .test(
      "anon record variant construction and pattern match",
      fn() {
        src := "type Msg = { Hello(.{ name: String }), Bye } fn greet(m: Msg) String { case m { .Hello(h) => h.name, .Bye => \"bye\" } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "anon record variant with shorthand literal",
      fn() {
        src := "type Msg = { Data(.{ x: Int, y: Int }) } fn f() Msg { .Data(.{ x: 1, y: 2 }) }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "anon record variant mixed with regular variants",
      fn() {
        src := "type Shape = { Circle(.{ r: Float }), Square(Float), Unit } fn f(s: Shape) Float { case s { .Circle(c) => c.r, .Square(side) => side, .Unit => 0.0 } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "case on Byte scrutinee accepts in-range literals",
      fn() {
        src := "fn f(b: Byte) String { case b { 0x41 => \"A\", 0x00 => \"null\", 255 => \"max\", _ => \"other\" } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "case on Byte scrutinee rejects out-of-range literal",
      fn() {
        src := "fn f(b: Byte) String { case b { 999 => \"big\", _ => \"ok\" } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "out of range")
        .Ok({})
      },
    )
    .test(
      "unreachable: wildcard before string literal",
      fn() {
        src := "fn f(s: String) Int { case s { _ => 1, \"foo\" => 2 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: ident catch-all before later arm",
      fn() {
        src := "fn f(x: Int) Int { case x { n => n, 1 => 99 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: duplicate string literal",
      fn() {
        src := "fn f(s: String) Int { case s { \"a\" => 1, \"b\" => 2, \"a\" => 3, _ => 0 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: duplicate int literal",
      fn() {
        src := "fn f(x: Int) Int { case x { 1 => 10, 2 => 20, 1 => 30, _ => 0 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: duplicate bool literal",
      fn() {
        src := "fn f(b: Bool) Int { case b { true => 1, false => 0, true => 99 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: duplicate nullary variant",
      fn() {
        src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1, .Green => 2, .Red => 3, .Blue => 4 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: variant with irrefutable payload covers later same-variant",
      fn() {
        src := "fn f(o: Int?) Int { case o { .Some(x) => x, .Some(_) => 0, .None => -1 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "reachable: variant with literal payload does not cover broader arm",
      fn() {
        src := "fn f(o: Int?) Int { case o { .Some(1) => 10, .Some(_) => 0, .None => -1 } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "reachable: catch-all as final arm is valid",
      fn() {
        src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1, .Green => 2, _ => 0 } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "reachable: exhaustive enum match without unreachable",
      fn() {
        src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1, .Green => 2, .Blue => 3 } }"
        r := try check_ok(src)
        .Ok({})
      },
    )
    .test(
      "unreachable: wildcard before variant",
      fn() {
        src := "fn f(o: Int?) Int { case o { _ => 0, .Some(x) => x, .None => -1 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: duplicate qualified variant",
      fn() {
        src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { Color.Red => 1, Color.Green => 2, Color.Red => 3, Color.Blue => 4 } }"
        msgs := try check_errs(src)
        try assert.str_contains(msgs[0], "unreachable case arm")
        .Ok({})
      },
    )
    .test(
      "unreachable: multiple arms after catch-all",
      fn() {
        src := "fn f(x: Int) Int { case x { _ => 0, 1 => 1, 2 => 2 } }"
        msgs := try check_errs(src)

        // Both arms after _ should be reported
        try assert.ok(msgs.len() >= 2, "expected at least 2 unreachable diagnostics")
        .Ok({})
      },
    )
}
