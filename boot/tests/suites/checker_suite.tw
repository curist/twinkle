use tests.runner
use tests.assert
use compiler.parser
use compiler.resolver
use compiler.resolver.{plain_resolved_type_params}
use compiler.checker
use compiler.base_env
use tests.suites.resolver_suite as rsuite
use lib.source.span

// ── Helpers ──────────────────────────────────────────────────────────

fn check_src(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := resolver.empty_env().resolve(parsed.value)
  checker.check(parsed.value, resolved.env)
}

fn check_src_with_env(src: String, env: resolver.ResolvedEnv) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := env.resolve(parsed.value)
  checker.check(parsed.value, resolved.env)
}

fn builtin_sig(name: String, params: Vector<String>, param_tys: Vector<resolver.MonoType>, ret: resolver.MonoType?) resolver.FunctionSig {
  resolver.FunctionSig.{
    name: name,
    type_params: [],
    param_names: params,
    params: param_tys,
    ret: ret,
  }
}

fn test_env() resolver.ResolvedEnv {
  fns: Vector<resolver.FunctionSig> = [
    builtin_sig("range", ["n"], [resolver.MonoType.Int], .Some(resolver.MonoType.Vector(resolver.MonoType.Int))),
    builtin_sig("range_from", ["start", "end"], [resolver.MonoType.Int, resolver.MonoType.Int], .Some(resolver.MonoType.Vector(resolver.MonoType.Int))),
    builtin_sig("error", ["msg"], [resolver.MonoType.String], .Some(resolver.MonoType.Never)),
    builtin_sig("println", ["s"], [resolver.MonoType.String], .Some(resolver.MonoType.Void)),
    builtin_sig("int_to_string", ["n"], [resolver.MonoType.Int], .Some(resolver.MonoType.String)),
    builtin_sig("bool_to_string", ["b"], [resolver.MonoType.Bool], .Some(resolver.MonoType.String)),
  ]
  env := resolver.empty_env().with_registered_functions(fns)
  env = env.bind_function("range", "range")
  env = env.bind_function("range_from", "range_from")
  env = env.bind_function("error", "error")
  env = env.bind_function("println", "println")
  // Register Iterator type so checker can look it up by name for iteration checks
  iter_entry := resolver.TypeEntry.{
    id: resolver.TypeId.{ id: 0 },
    arity: 1,
    def: .Some(resolver.ResolvedTypeDef.Sum("Iterator", plain_resolved_type_params(["T"]), [
      resolver.ResolvedVariant.{ name: "Item", fields: [resolver.MonoType.Var("T")] },
    ])),
    span: span.Span.{ file_id: 0, start: 0, end: 0 },
  }
  env = env.add_type(iter_entry, "Iterator")
  // Register Range type (TypeId 3 in stage0) so range operator tests work
  range_entry := resolver.TypeEntry.{
    id: resolver.TypeId.{ id: 3 },
    arity: 0,
    def: .Some(resolver.ResolvedTypeDef.Record("Range", [], [
      resolver.ResolvedField.{ name: "start", ty: resolver.MonoType.Int },
      resolver.ResolvedField.{ name: "end", ty: resolver.MonoType.Int },
    ])),
    span: span.Span.{ file_id: 0, start: 0, end: 0 },
  }
  env = env.add_type(range_entry, "Range")
  env.register_builtin_methods()
}

fn check_src_with_builtins(src: String) checker.CheckResult {
  parsed := parser.parse(src, 0)
  resolved := test_env().resolve(parsed.value)
  checker.check(parsed.value, resolved.env)
}

fn check_ok_builtins(src: String) Result<checker.CheckResult, String> {
  r := check_src_with_builtins(src)
  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message}")
  }
  .Ok(r)
}

fn check_errs_builtins(src: String) Result<Vector<String>, String> {
  r := check_src_with_builtins(src)
  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }
  msgs: Vector<String> = []
  for d in r.diagnostics {
    msgs = msgs.append(d.message)
  }
  .Ok(msgs)
}

fn check_ok(src: String) Result<checker.CheckResult, String> {
  r := check_src(src)
  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message}")
  }
  .Ok(r)
}

fn check_ok_with_env(src: String, env: resolver.ResolvedEnv) Result<checker.CheckResult, String> {
  r := check_src_with_env(src, env)
  if r.diagnostics.len() > 0 {
    return .Err("expected no diagnostics, got: ${r.diagnostics[0].message}")
  }
  .Ok(r)
}

fn check_errs(src: String) Result<Vector<String>, String> {
  r := check_src(src)
  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }
  msgs: Vector<String> = []
  for d in r.diagnostics {
    msgs = msgs.append(d.message)
  }
  .Ok(msgs)
}

fn check_errs_with_env(src: String, env: resolver.ResolvedEnv) Result<Vector<String>, String> {
  r := check_src_with_env(src, env)
  if r.diagnostics.len() == 0 {
    return .Err("expected diagnostics, got none")
  }
  msgs: Vector<String> = []
  for d in r.diagnostics {
    msgs = msgs.append(d.message)
  }
  .Ok(msgs)
}

fn find_id_by_span(result: checker.CheckResult, target_offset: Int) Int? {
  best: Int? = .None
  for eid in result.expr_spans.keys() {
    case result.expr_spans[eid] {
      .Some(span_start) => {
        if span_start == target_offset {
          best = case best {
            .None => .Some(eid),
            .Some(prev) => if eid > prev { .Some(eid) } else { .Some(prev) },
          }
        }
      },
      .None => {},
    }
  }
  best
}

fn type_at(result: checker.CheckResult, src: String, needle: String) Result<String, String> {
  offset := find_offset(src, needle)
  case offset {
    .Some(off) => {
      case find_id_by_span(result, off) {
        .Some(eid) => {
          case result.type_map[eid] {
            .Some(ty) => .Ok(rsuite.mono_to_string(ty)),
            .None => .Err("no type at offset ${off} for '${needle}' (id=${eid})"),
          }
        },
        .None => .Err("no expr id at offset ${off} for '${needle}'"),
      }
    },
    .None => .Err("'${needle}' not found in source"),
  }
}

fn find_offset(src: String, needle: String) Int? {
  find_offset_after(src, needle, 0)
}

fn find_offset_after(src: String, needle: String, start: Int) Int? {
  if needle.len() > src.len() { return .None }
  limit := src.len() - needle.len()
  for i in 0..limit + 1 {
    if i >= start and src.slice(i, i + needle.len()) == needle {
      return .Some(i)
    }
  }
  .None
}

fn find_offset_nth(src: String, needle: String, n: Int) Int? {
  count := 0
  if needle.len() > src.len() { return .None }
  limit := src.len() - needle.len()
  for i in 0..limit + 1 {
    if src.slice(i, i + needle.len()) == needle {
      if count == n { return .Some(i) }
      count = count + 1
    }
  }
  .None
}

fn type_at_nth(result: checker.CheckResult, src: String, needle: String, n: Int) Result<String, String> {
  offset := find_offset_nth(src, needle, n)
  case offset {
    .Some(off) => {
      case find_id_by_span(result, off) {
        .Some(eid) => {
          case result.type_map[eid] {
            .Some(ty) => .Ok(rsuite.mono_to_string(ty)),
            .None => .Err("no type at offset ${off} for '${needle}' (occurrence ${n}, id=${eid})"),
          }
        },
        .None => .Err("no expr id at offset ${off} for '${needle}' (occurrence ${n})"),
      }
    },
    .None => .Err("'${needle}' occurrence ${n} not found in source"),
  }
}

// ── Suite ────────────────────────────────────────────────────────────

pub fn suite() runner.Suite {
  runner.suite("checker")
    // ── M1: Literals ──
    .test("int literal", fn() {
      src := "fn answer() Int { 42 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    .test("string literal", fn() {
      src := "fn greeting() String { \"hello\" }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "\"hello\""), "String")
      .Ok({})
    })
    .test("bool literal", fn() {
      src := "fn flag() Bool { true }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "true"), "Bool")
      .Ok({})
    })
    .test("float literal", fn() {
      src := "fn ratio() Float { 3.14 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "3.14"), "Float")
      .Ok({})
    })
    .test("return type mismatch", fn() {
      src := "fn answer() String { 42 }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    // ── M2: Let, Ident, Call ──
    .test("annotated let", fn() {
      src := "fn f() Int { x: Int = 5\n x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "5"), "Int")
      .Ok({})
    })
    .test("inferred let", fn() {
      src := "fn f() Int { x := 42\n x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "42"), "Int")
      .Ok({})
    })
    .test("annotated let type mismatch", fn() {
      src := "fn f() Int { x: Bool = 5\n x }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    .test("ident resolves param", fn() {
      src := "fn f(x: Int) Int { x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "x }"), "Int")
      .Ok({})
    })
    .test("function call", fn() {
      src := "fn add(a: Int, b: Int) Int { a }\nfn main() Int { add(1, 2) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "add(1"), "Int")
      .Ok({})
    })
    .test("wrong arg count", fn() {
      src := "fn add(a: Int, b: Int) Int { a }\nfn main() Int { add(1) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "expected 2 arguments")
      .Ok({})
    })
    // ── M3: Operators, Indexing ──
    .test("arithmetic int", fn() {
      src := "fn f() Int { 1 + 2 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "1 + 2"), "Int")
      .Ok({})
    })
    .test("comparison", fn() {
      src := "fn f() Bool { 1 < 2 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "1 < 2"), "Bool")
      .Ok({})
    })
    .test("logical and", fn() {
      src := "fn f() Bool { true && false }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "true && false"), "Bool")
      .Ok({})
    })
    .test("negate int", fn() {
      src := "fn f() Int { -5 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "-5"), "Int")
      .Ok({})
    })
    .test("not bool", fn() {
      src := "fn f() Bool { !true }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "!true"), "Bool")
      .Ok({})
    })
    .test("bool plus int error", fn() {
      src := "fn f() Int { true + 1 }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "operator not supported")
      .Ok({})
    })
    // string interp test deferred — can't embed ${} in string literals without outer interpolation
    .test("equality", fn() {
      src := "fn f() Bool { 1 == 2 }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "1 == 2"), "Bool")
      .Ok({})
    })
    // ── M4: Records, Fields, Variants ──
    .test("record field access", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn get_x(p: Point) Int { p.x }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "p.x"), "Int")
      .Ok({})
    })
    .test("record bad field", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn get_z(p: Point) Int { p.z }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "no field 'z'")
      .Ok({})
    })
    .test("anonymous record lit check mode", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1, y: 2 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("record missing field", fn() {
      src := "type Point = .{ x: Int, y: Int }\nfn make() Point { .{ x: 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "missing field 'y'")
      .Ok({})
    })
    .test("option some check", fn() {
      src := "fn wrap(x: Int) Int? { .Some(x) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("option none check", fn() {
      src := "fn nothing() Int? { .None }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("result ok check", fn() {
      src := "fn ok_val(x: Int) Result<Int, String> { .Ok(x) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("result err check", fn() {
      src := "fn err_val() Result<Int, String> { .Err(\"bad\") }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("array literal", fn() {
      src := "fn nums() Vector<Int> { [1, 2, 3] }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("array element mismatch", fn() {
      src := "fn bad() Vector<Int> { [1, \"two\", 3] }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    // ── M5: Generics ──
    .test("generic identity", fn() {
      src := "fn identity<A>(x: A) A { x }\nfn main() Int { identity(42) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "identity(42)"), "Int")
      .Ok({})
    })
    .test("generic with array", fn() {
      src := "fn first<T>(xs: Vector<T>) T { xs[0] }\nfn main() Int { first([1, 2, 3]) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "first([1"), "Int")
      .Ok({})
    })
    .test("generic type mismatch", fn() {
      src := "fn identity<A>(x: A) A { x }\nfn main() String { identity(42) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    .test("generic two params", fn() {
      src := "fn pair<A, B>(a: A, b: B) A { a }\nfn main() Int { pair(1, \"hi\") }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "pair(1"), "Int")
      .Ok({})
    })
    .test("generic type variable in nested local annotation", fn() {
      src := "fn keep<A>(d: Dict<String, A>) Dict<String, A> {\n  out: Dict<String, A> = d\n  out\n}\nfn main(d: Dict<String, Int>) Dict<String, Int> { keep(d) }"
      _ := try check_ok(src)
      .Ok({})
    })
    .test("bounded type parameter method lookup", fn() {
      src := "fn show<T: Stringify>(x: T) String { x.to_string() }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "x.to_string()"), "String")
      .Ok({})
    })
    .test("generic bound satisfied by primitive", fn() {
      src := "fn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(42) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "show(42)"), "String")
      .Ok({})
    })
    .test("generic bound satisfied by inherent witness", fn() {
      src := "type User = .{ name: String }\nfn to_string(u: User) String { u.name }\nfn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(User.{ name: \"Ada\" }) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "show(User"), "String")
      .Ok({})
    })
    .test("generic bound satisfaction recurses through witness bounds", fn() {
      src := "type Box<T> = .{ value: T }\nfn to_string<T: Stringify>(b: Box<T>) String { b.value.to_string() }\nfn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(Box.{ value: 42 }) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "show(Box"), "String")
      .Ok({})
    })
    .test("generic bound rejects unsatisfied type argument", fn() {
      src := "type Foo = .{}\nfn show<T: Stringify>(x: T) String { x.to_string() }\nfn main() String { show(Foo.{}) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "does not satisfy Stringify")
      .Ok({})
    })
    .test("bounded type declaration allows satisfying record construction", fn() {
      src := "type Box<T: Stringify> = .{ value: T }\nfn main() Box<Int> { Box.{ value: 1 } }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "Box.{ value: 1 }"), "Named(0)<Int>")
      .Ok({})
    })
    .test("bounded type declaration rejects record construction", fn() {
      src := "type Foo = .{}\ntype Box<T: Stringify> = .{ value: T }\nfn main() Box<Foo> { Box.{ value: Foo.{} } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "required by Box<T: Stringify>")
      .Ok({})
    })
    .test("bounded type declaration rejects annotation", fn() {
      src := "type Foo = .{}\ntype Box<T: Stringify> = .{ value: T }\nfn main() Void { x: Box<Foo> = error(\"boom\") }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "required by Box<T: Stringify>")
      .Ok({})
    })
    .test("bounded sum declaration rejects named variant construction", fn() {
      src := "type Foo = .{}\ntype Wrap<T: Stringify> = { Wrap(T) }\nfn main() Wrap<Foo> { Wrap.Wrap(Foo.{}) }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "required by Wrap<T: Stringify>")
      .Ok({})
    })
    .test("generic interpolation checks Stringify bound", fn() {
      dollar := "$"
      src := "fn show<T: Stringify>(x: T) String { \"${dollar}{x}\" }\nfn main() String { show(42) }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "show(42)"), "String")
      .Ok({})
    })
    .test("vector stringify witness comes from bounded prelude method", fn() {
      src := "fn main() String { xs: Vector<Int> = [1, 2]\n xs.to_string() }"
      r := try check_ok_with_env(src, base_env.builtin_env())
      try assert.str_eq(try type_at(r, src, "xs.to_string()"), "String")
      .Ok({})
    })
    .test("vector stringify rejects unsatisfied element type", fn() {
      src := "type Foo = .{}\nfn main() String { xs: Vector<Foo> = [Foo.{}]\n xs.to_string() }"
      msgs := try check_errs_with_env(src, base_env.builtin_env())
      try assert.str_contains(msgs[0], "does not satisfy Stringify")
      .Ok({})
    })
    // ── M6: If, Case, For ──
    .test("if else unify", fn() {
      src := "fn abs(x: Int) Int { if x < 0 { -x } else { x } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("if else pushes expected type into sum variants", fn() {
      src := "type Cmp = { Lt, Eq, Gt }\nfn cmp(a: Int, b: Int) Cmp { if a < b { .Lt } else if a > b { .Gt } else { .Eq } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("collect continue branch diverges in check mode", fn() {
      src := "fn f(xs: Vector<Int>) Vector<Int> { collect x in xs { if x > 0 { x } else { continue } } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("if no else is void", fn() {
      src := "fn f(x: Int) Void { if x > 0 { x } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("if branch mismatch", fn() {
      src := "fn f(x: Int) Int { if x > 0 { 1 } else { \"no\" } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    .test("case option with wildcard", fn() {
      src := "fn unwrap(o: Int?) Int { case o { .Some(x) => x, _ => 0 } }"
      r := try check_ok(src)
      try assert.str_eq(try type_at(r, src, "case o"), "Int")
      .Ok({})
    })
    .test("case binds pattern var", fn() {
      src := "fn unwrap(o: Int?) Int { case o { .Some(x) => x, _ => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("case non-exhaustive", fn() {
      src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1 } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "non-exhaustive")
      .Ok({})
    })
    .test("case wildcard exhaustive", fn() {
      src := "type Color = { Red, Green, Blue }\nfn f(c: Color) Int { case c { .Red => 1, _ => 0 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("for condition", fn() {
      src := "fn f() Void { x := 0\n for x < 10 { x = x + 1 } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("for in vector", fn() {
      src := "fn sum(xs: Vector<Int>) Int { s := 0\n for x in xs { s = s + x }\n s }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("for with index", fn() {
      src := "fn f(xs: Vector<Int>) Int { s := 0\n for x, i in xs { s = s + i }\n s }"
      r := try check_ok(src)
      .Ok({})
    })
    // ── M7: Closures, Try ──
    .test("closure annotated", fn() {
      src := "fn apply(f: fn(Int) Int, x: Int) Int { f(x) }\nfn main() Int { apply(fn(x: Int) Int { x + 1 }, 5) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("closure inferred from context", fn() {
      src := "fn apply(f: fn(Int) Int, x: Int) Int { f(x) }\nfn main() Int { apply(fn(x) { x + 1 }, 5) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("try option", fn() {
