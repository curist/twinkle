    })
    .test("G11 negation on non-numeric errors", fn() {
      src := "fn f(x: Bool) Bool { -x }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "negate")
      .Ok({})
    })
    .test("G11 logical not on non-Bool errors", fn() {
      src := "fn f(x: Int) Bool { !x }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
    // ── G12: Method chains ──────────────────────────────────────────────
    .test("G12 method chain on user types", fn() {
      src := "type Builder = .{ count: Int }\nfn inc(b: Builder) Builder { Builder.{ count: b.count + 1 } }\nfn value(b: Builder) Int { b.count }\nfn f() Int {\nb := Builder.{ count: 0 }\nb.inc().inc().value()\n}"
      r := try check_ok(src)
      .Ok({})
    })
    // ── G13: If-else branch type unification ────────────────────────────
    .test("G13 if-else else branch resolves variant shorthand from then type", fn() {
      src := "type Mono = { Void, Int }\nfn f(flag: Bool, args: Vector<Mono>) { if flag { args[0] } else { .Void } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("G13 if-else else branch resolves Option shorthand from then type", fn() {
      src := "type MaybeInt = { Some(Int), None }\nfn f(flag: Bool, xs: Vector<Int>) { if flag { MaybeInt.Some(xs[0]) } else { .None } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("G14 case arm resolves variant shorthand from later arm", fn() {
      src := "type Mono = { Void, Int }\nfn f(flag: Bool, xs: Vector<Mono>) Mono { case flag { true => .Void, _ => xs[0] } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("G14 case arm block tail resolves variant shorthand from later arm", fn() {
      src := "type Mono = { Void, Int }\nfn f(flag: Bool, xs: Vector<Mono>) Mono { case flag { true => { .Void }, _ => xs[0] } }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("G13 if-else branch mismatch still errors", fn() {
      src := "fn f(x: Int) Int { if x > 0 { 1 } else { \"no\" } }"
      msgs := try check_errs(src)
      try assert.str_contains(msgs[0], "type mismatch")
      .Ok({})
    })
}
