      "P2 receiver method call dispatches through method registry",
      fn() {
        src := "type Point = .{ x: Int }\nfn len(p: Point) Int { p.x }\nfn f(p: Point) Int { p.len() }"
        r := try check_ok(src)
        try assert.equal(try type_at(r, src, "p.len()"), "Int")
        .Ok({})
      },
    )
    .test(
      "P2 receiver method lookup follows receiver identity rather than preferred name",
      fn() {
        point_tid := mono_type.TypeId.{ id: 41 }
        point_entry := resolver.TypeEntry.{
          id: point_tid,
          arity: 0,
          def: .Some(
            resolver.ResolvedTypeDef.Record(
              "dep.Point",
              [],
              [resolver.ResolvedField.{ name: "x", ty: mono_type.MonoType.Int }],
            ),
          ),
          span: span.Span.{ file_id: 0, start: 0, end: 0 },
          is_extern: false,
        }
        len_sig := resolver.FunctionSig.{
          name: "len",
          type_params: [],
          param_names: ["p"],
          params: [mono_type.MonoType.Named(point_tid, [])],
          ret: .Some(mono_type.MonoType.Int),
          doc: .None,
          extern_module: .None,
        }
        env := resolver
          .empty_env()
          .register_type_entry(point_entry, "dep.Point")
          .bind_type("Point", point_tid)
          .add_function(len_sig)
          .register_bound_methods(
            "Point",
            [resolver.MethodEntry.{ method_name: "len", function_name: "len" }],
          )
        src := "fn f(p: Point) Int { p.len() }"
        r := try check_ok_with_env(src, env)
        try assert.equal(try type_at(r, src, "p.len()"), "Int")
        .Ok({})
      },
    )
