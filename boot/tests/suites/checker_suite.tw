      r := try check_ok(src)
      .Ok({})
    })
    .test("D13 generic call with anonymous record arg needs return-type context", fn() {
      // make<T>(x: T) Vector<T> — when T is only solvable from return context
      src := "type Pair = .{ a: Int, b: Int }\nfn wrap<T>(x: T) Vector<T> { [x] }\nfn f() Vector<Pair> { wrap(.{ a: 1, b: 2 }) }"
      r := try check_ok(src)
      .Ok({})
    })
    .test("D13 method call pre-unifies return type for generic methods", fn() {
      // wrap_thing<T>(self: Thing, x: T) Vector<T> — method on Thing
      // When called as thing.wrap_thing(.{ a: 1 }), T needs return-type context
      src := "type Pair = .{ a: Int, b: Int }\ntype Thing = .{ id: Int }\nfn wrap_thing<T>(self: Thing, x: T) Vector<T> { [x] }\nfn f(t: Thing) Vector<Pair> { t.wrap_thing(.{ a: 1, b: 2 }) }"
      r := try check_ok(src)
      .Ok({})
    })
