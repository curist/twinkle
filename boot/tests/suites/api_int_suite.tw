use tests.assert
use tests.runner

pub fn suite() runner.Suite {
  runner.suite("api Int")
    .test(
      "min returns the smaller argument",
      fn() {
        try assert.equal(Int.min(3, 7), 3)
        try assert.equal(Int.min(7, 3), 3)
        try assert.equal(Int.min(-2, 5), -2)
        try assert.equal(4.min(4), 4)
        .Ok({})
      },
    )
    .test(
      "max returns the larger argument",
      fn() {
        try assert.equal(Int.max(3, 7), 7)
        try assert.equal(Int.max(7, 3), 7)
        try assert.equal(Int.max(-2, 5), 5)
        try assert.equal(4.max(4), 4)
        .Ok({})
      },
    )
    .test(
      "clamp pins a value into [lo, hi]",
      fn() {
        try assert.equal(5.clamp(0, 10), 5)
        try assert.equal((-3).clamp(0, 10), 0)
        try assert.equal(42.clamp(0, 10), 10)
        try assert.equal(0.clamp(0, 10), 0)
        try assert.equal(10.clamp(0, 10), 10)
        .Ok({})
      },
    )
}
