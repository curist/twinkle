pub type ArgKind = { Positional, Flag, Opt }

pub type Arg = .{
  name: String,
  short_name: String?,
  help: String,
  kind: ArgKind,
  is_required: Bool,
}

pub fn positional(name: String, help: String) Arg {
  Arg.{ name, short_name: .None, help, kind: .Positional, is_required: false }
}

pub fn flag(name: String, help: String) Arg {
  Arg.{ name, short_name: .None, help, kind: .Flag, is_required: false }
}

pub fn option(name: String, help: String) Arg {
  Arg.{ name, short_name: .None, help, kind: .Opt, is_required: false }
}

pub fn short(a: Arg, s: String) Arg {
  Arg.{ name: a.name, short_name: .Some(s), help: a.help, kind: a.kind, is_required: a.is_required }
}

pub fn required(a: Arg) Arg {
  Arg.{ name: a.name, short_name: a.short_name, help: a.help, kind: a.kind, is_required: true }
}
