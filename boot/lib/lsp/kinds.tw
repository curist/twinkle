//! LSP CompletionItemKind values, as a field-less enum with explicit integer
//! tags. `k.tag` gives the LSP wire number; `CompletionKind.from_tag(n)` decodes
//! one back (used at the JSON boundary, not in the in-memory model).

pub type CompletionKind = {
  Text = 1,
  Method = 2,
  Function = 3,
  Field = 5,
  Variable = 6,
  Class = 7,
  Module = 9,
  Enum = 13,
  Keyword = 14,
  EnumMember = 20,
  Constant = 21,
}
