  doc := case state.documents.get(sig_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.null_response_step(req),
  }
  offset := case position_offset(doc.index, sig_params.position) {
    .Some(o) => o,
    .None => return state.null_response_step(req),
  }
  snap := state.editor_snapshot(doc)
  state.query_cache = snap.cache

  case query_signature_help.signature_help(snap, offset, doc.text) {
