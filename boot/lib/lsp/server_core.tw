}

fn handle_code_action(state: State, req: protocol.Request) Step {
  action_params := case params.decode_code_action(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(action_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  actions := lsp_code_action.fix_actions(doc.uri, doc.index, action_params.context_diagnostics)
  .{ state, outgoing: [req.id.success_response(json.array(actions))] }
}

