//! Pure LSP/JSON-RPC message handling.
//!
//! Transport code owns framing and I/O. This module owns protocol state and
//! responses so server behavior can be tested without stdio.

use @std.date
use @std.fs
use @std.path

use compiler.fmt.formatter
use compiler.imports
use compiler.lexer
use compiler.parser
use compiler.query.analyze
use compiler.query.cache as query_cache
use compiler.query.completion as query_completion
use compiler.query.definition as query_definition
use compiler.query.diagnostics as query_diagnostics
use compiler.query.document_highlight as query_document_highlight
use compiler.query.document_symbols as query_document_symbols
use compiler.query.folding_range as query_folding_range
use compiler.query.hover as query_hover
use compiler.query.inlay_hints as query_inlay_hints
use compiler.query.progress.{ProgressSink}
use compiler.query.references as query_references
use compiler.query.semantic
use compiler.query.semantic_tokens as query_semantic_tokens
use compiler.query.signature_help as query_signature_help
use compiler.query.workspace_symbols as query_workspace_symbols
use lib.json
use lib.lsp.code_action as lsp_code_action
use lib.lsp.completion as lsp_completion
use lib.lsp.definition as lsp_definition
use lib.lsp.diagnostics as lsp_diagnostics
use lib.lsp.document_highlight as lsp_document_highlight
use lib.lsp.document_store
use lib.lsp.document_symbol as lsp_document_symbol
use lib.lsp.folding_range as lsp_folding_range
use lib.lsp.hover as lsp_hover
use lib.lsp.inlay_hint as lsp_inlay_hint
use lib.lsp.params
use lib.lsp.protocol
use lib.lsp.range as lsp_range
use lib.lsp.references as lsp_references
use lib.lsp.semantic_tokens as lsp_semantic_tokens
use lib.lsp.signature_help as lsp_signature_help
use lib.lsp.workspace_symbol as lsp_workspace_symbol
use lib.module.loader
use lib.query.keys
use lib.source.identity
use lib.text.line_index

pub type DiagTier = { Parse, Full }

pub type State = .{
  initialized: Bool,
  shutdown_requested: Bool,
  should_exit: Bool,
  documents: document_store.Store,
  query_cache: query_cache.Store,
  diagnostics_pending: Bool,
  diagnostics_deadline_ms: Float,
  diagnostics_tier: DiagTier,
  parse_dirty_uris: Dict<String, Bool>,
  full_dirty: Bool,
  last_published: Dict<String, String>,
  closure_snapshot: analyze.ClosureSnapshot?,
}

pub type Step = .{ state: State, outgoing: Vector<json.Json> }

pub fn initial_state() State {
  .{
    initialized: false,
    shutdown_requested: false,
    should_exit: false,
    documents: document_store.empty(),
    query_cache: query_cache.empty(),
    diagnostics_pending: false,
    diagnostics_deadline_ms: 0.0,
    diagnostics_tier: .Full,
    parse_dirty_uris: Dict.new(),
    full_dirty: false,
    last_published: Dict.new(),
    closure_snapshot: .None,
  }
}

pub fn handle_message(state: State, message: protocol.Message) Step {
  case message {
    .Request(req) => state.handle_request(req),
    .Notification(note) => state.handle_notification(note),
    .Response(_) => .{ state, outgoing: [] },
  }
}

fn handle_request(state: State, req: protocol.Request) Step {
  case req.method {
    "initialize" => {
      result := json.object([
        json.kv(
          "capabilities",
          json.object([
            json.kv("positionEncoding", .Str("utf-16")),
            json.kv(
              "textDocumentSync",
              json.object([
                json.kv("openClose", .Bool(true)),
                json.kv("change", .Int(2)),
                json.kv("save", json.object([json.kv("includeText", .Bool(false))])),
              ]),
            ),
            json.kv("hoverProvider", .Bool(true)),
            json.kv("definitionProvider", .Bool(true)),
            json.kv("typeDefinitionProvider", .Bool(true)),
            json.kv("referencesProvider", .Bool(true)),
            json.kv("documentHighlightProvider", .Bool(true)),
            json.kv("documentFormattingProvider", .Bool(true)),
            json.kv(
              "completionProvider",
              json.object([json.kv("triggerCharacters", json.array([.Str(".")]))]),
            ),
            json.kv("codeActionProvider", .Bool(true)),
            json.kv("documentSymbolProvider", .Bool(true)),
            json.kv("workspaceSymbolProvider", .Bool(true)),
            json.kv("inlayHintProvider", .Bool(true)),
            json.kv("foldingRangeProvider", .Bool(true)),
            json.kv("semanticTokensProvider", lsp_semantic_tokens.capability()),
            json.kv(
              "signatureHelpProvider",
              json.object([json.kv("triggerCharacters", json.array([.Str("("), .Str(",")]))]),
            ),
          ]),
        ),
        json.kv("serverInfo", json.object([json.kv("name", .Str("twinkle-lsp"))])),
      ])
      .{ state, outgoing: [req.id.success_response(result)] }
    },
    "textDocument/hover" => state.handle_hover(req),
    "textDocument/definition" => state.handle_definition(req),
    "textDocument/typeDefinition" => state.handle_type_definition(req),
    "textDocument/references" => state.handle_references(req),
    "textDocument/documentHighlight" => state.handle_document_highlight(req),
    "textDocument/completion" => state.handle_completion(req),
    "textDocument/codeAction" => state.handle_code_action(req),
    "textDocument/documentSymbol" => state.handle_document_symbol(req),
    "textDocument/signatureHelp" => state.handle_signature_help(req),
    "textDocument/formatting" => state.handle_formatting(req),
    "textDocument/inlayHint" => state.handle_inlay_hint(req),
    "textDocument/foldingRange" => state.handle_folding_range(req),
    "textDocument/semanticTokens/full" => state.handle_semantic_tokens(req),
    "workspace/symbol" => state.handle_workspace_symbol(req),
    "shutdown" => {
      state.shutdown_requested = true
      .{ state, outgoing: [req.id.success_response(.Null)] }
    },
    _ => {
      err := protocol.RpcError.{ code: -32601, message: "method not found", data: .None }
      .{ state, outgoing: [req.id.error_response(err)] }
    },
  }
}

fn handle_notification(state: State, note: protocol.Notification) Step {
  case note.method {
    "initialized" => {
      state.initialized = true
      .{ state, outgoing: [] }
    },
    "exit" => {
      state.should_exit = true
      .{ state, outgoing: [] }
    },
    "textDocument/didOpen" => state.handle_did_open(note),
    "textDocument/didChange" => state.handle_did_change(note),
    "textDocument/didClose" => state.handle_did_close(note),
    "textDocument/didSave" => state.handle_did_save(note),
    _ => .{ state, outgoing: [] },
  }
}

fn handle_did_open(state: State, note: protocol.Notification) Step {
  case params.decode_did_open(note.params) {
    .Ok(open) => {
      doc := open.text_document
      state.documents = .open(doc.uri, doc.text, .Some(doc.version))
      state = .note_changed_document_source(doc.uri, doc.text)
      state.mark_diagnostics_pending(.Full, .None)
    },
    .Err(_) => .{ state, outgoing: [] },
  }
}

fn handle_did_change(state: State, note: protocol.Notification) Step {
  case params.decode_did_change(note.params) {
    .Ok(change) => {
      if change.content_changes.len() == 0 {
        return .{ state, outgoing: [] }
      }

      doc := change.text_document

      for event in change.content_changes {
        case event.range {
          .Some(range) => {
            // Incremental change — convert UTF-16 range to byte offsets.
            cur_doc := case state.documents.get(doc.uri) {
              .Some(d) => d,
              .None => continue,
            }
            start_offset := case position_offset(
              cur_doc.index,
              .{ line: range.start.line, character: range.start.character },
            ) {
              .Some(o) => o,
              .None => continue,
            }
            end_offset := case position_offset(
              cur_doc.index,
              .{ line: range.end.line, character: range.end.character },
            ) {
              .Some(o) => o,
              .None => continue,
            }
            state.documents = .change_incremental(
              doc.uri,
              start_offset,
              end_offset,
              event.text,
              doc.version,
            )
          },
          .None => {
            // Full-text change — no range means replace everything.
            state.documents = .change_full_text(doc.uri, event.text, doc.version)
          },
        }
      }

      final_text := case state.documents.get(doc.uri) {
        .Some(d) => d.text,
        .None => return .{ state, outgoing: [] },
      }
      state = .note_changed_document_source(doc.uri, final_text)
      state.mark_diagnostics_pending(.Parse, .Some(doc.uri))
    },
    .Err(_) => .{ state, outgoing: [] },
  }
}

fn handle_did_close(state: State, note: protocol.Notification) Step {
  case params.decode_did_close(note.params) {
    .Ok(close) => {
      uri := close.text_document.uri
      version := case state.documents.get(uri) {
        .Some(doc) => doc.version,
        .None => .None,
      }
      state.documents = .close(uri)
      state.parse_dirty_uris = .remove(uri)
      cleared := lsp_diagnostics.clear_diagnostics(uri, version)

      // Closing an unsaved overlay shifts the rest of the workspace back to
      // disk-backed analysis, so refresh the remaining open docs. With nothing
      // open there is nothing to analyze, so just clear the dirty flag.
      if state.documents.docs.values().len() == 0 {
        state.full_dirty = false
        .{ state, outgoing: [cleared] }
      } else {
        refreshed := state.mark_diagnostics_pending(.Full, .None)
        .{ state: refreshed.state, outgoing: [cleared] }
      }
    },
    .Err(_) => .{ state, outgoing: [] },
  }
}

fn handle_did_save(state: State, note: protocol.Notification) Step {
  case params.decode_did_save(note.params) {
    .Ok(_) => state.mark_diagnostics_pending(.Full, .None),
    .Err(_) => .{ state, outgoing: [] },
  }
}

fn workspace_snapshot(state: State, doc: document_store.Document) semantic.SemanticSnapshot {
  input := state.workspace_input(doc)

  case semantic.snapshot_workspace_from_cache(state.query_cache, input) {
    .Some(snap) => snap,
    .None => semantic.snapshot_workspace(state.query_cache, input),
  }
}

// Cache-only snapshot: returns the last completed full snapshot when present, and
// never falls back to inline workspace analysis. Heavy editor features use this so
// a request can never block the dispatcher on a compiler pass.
fn workspace_snapshot_cached(state: State, doc: document_store.Document) semantic.SemanticSnapshot? {
  semantic.snapshot_workspace_from_cache(state.query_cache, state.workspace_input(doc))
}

fn editor_snapshot(state: State, doc: document_store.Document) semantic.SemanticSnapshot {
  semantic.snapshot_workspace_for_editor(state.query_cache, state.workspace_input(doc))
}

fn workspace_input(state: State, doc: document_store.Document) query_diagnostics.WorkspaceInput {
  open_docs := state.documents.docs.values()
  overlay_docs := collect d in open_docs {
    query_diagnostics.DocumentInput.{ uri: d.uri, text: d.text, version: d.version }
  }
  .{
    entry_uri: doc.uri,
    project_root: project_root_for_document(doc.identity.path),
    open_documents: overlay_docs,
  }
}

fn handle_hover(state: State, req: protocol.Request) Step {
  hover_params := case params.decode_hover(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.null_response_step(req),
  }
  doc := case state.documents.get(hover_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.null_response_step(req),
  }
  offset := case position_offset(doc.index, hover_params.position) {
    .Some(o) => o,
    .None => return state.null_response_step(req),
  }
  snap := state.workspace_snapshot(doc)
  state.query_cache = snap.cache

  case query_hover.hover(snap, offset, doc.text) {
    .Some(result) => .{
      state,
      outgoing: [req.id.success_response(lsp_hover.hover_response(doc.index, result))],
    },
    .None => state.null_response_step(req),
  }
}

fn handle_definition(state: State, req: protocol.Request) Step {
  def_params := case params.decode_definition(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.null_response_step(req),
  }
  doc := case state.documents.get(def_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.null_response_step(req),
  }
  offset := case position_offset(doc.index, def_params.position) {
    .Some(o) => o,
    .None => return state.null_response_step(req),
  }
  snap := state.workspace_snapshot(doc)
  state.query_cache = snap.cache

  case query_definition.definition(snap, offset) {
    .Some(result) => {
      target_index := definition_target_index(state.documents, result.uri, doc.index)
      .{
        state,
        outgoing: [
          req.id.success_response(lsp_definition.definition_response(target_index, result)),
        ],
      }
    },
    .None => state.null_response_step(req),
  }
}

fn handle_type_definition(state: State, req: protocol.Request) Step {
  def_params := case params.decode_definition(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.null_response_step(req),
