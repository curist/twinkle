fn handle_references(state: State, req: protocol.Request) Step {
  ref_params := case params.decode_references(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(ref_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  offset := case position_offset(doc.index, ref_params.position) {
    .Some(o) => o,
    .None => return state.empty_array_response_step(req),
  }

  // Populate the cache from all open documents so cross-module refs work.
  // Each open doc may be a separate import-graph root; snapshotting each one
  // ensures every reachable module is in the cache.
  for open_doc in state.documents.docs.values() {
    ws := state.workspace_snapshot(open_doc)
    state.query_cache = ws.cache
  }

  snap := state.workspace_snapshot(doc)
  state.query_cache = snap.cache
  results := query_references.find_references(snap, offset, ref_params.context.include_declaration)
  response := lsp_references.references_response(
    results,
    fn(uri: String) line_index.LineIndex? {
      case document_by_identity_uri(state.documents, uri) {
        .Some(d) => return .Some(d.index),
        .None => {},
      }

      p := case identity_path_from_uri(uri) {
        .Some(path) => path,
        .None => return .None,
      }

      case fs.read_text(p) {
        .Ok(text) => .Some(line_index.new(text)),
        .Err(_) => .None,
      }
    },
  )
  .{ state, outgoing: [req.id.success_response(response)] }
}

fn handle_document_highlight(state: State, req: protocol.Request) Step {
  hl_params := case params.decode_definition(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(hl_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  offset := case position_offset(doc.index, hl_params.position) {
    .Some(o) => o,
    .None => return state.empty_array_response_step(req),
  }

  snap := state.workspace_snapshot(doc)
  state.query_cache = snap.cache
  results := query_document_highlight.document_highlights(snap, offset)
  response := lsp_document_highlight.document_highlight_response(results, doc.index)
  .{ state, outgoing: [req.id.success_response(response)] }
}

