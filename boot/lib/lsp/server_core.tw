    .None => state.null_response_step(req),
  }
}

fn handle_document_symbol(state: State, req: protocol.Request) Step {
  sym_params := case params.decode_document_symbol(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(sym_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  if state.full_dirty {
    return state.empty_array_response_step(req)
  }
  snap := case state.workspace_snapshot_cached(doc) {
    .Some(s) => s,
    .None => return state.empty_array_response_step(req),
  }
  state.query_cache = snap.cache
  symbols := query_document_symbols.document_symbols(snap)
  .{
    state,
    outgoing: [
      req.id.success_response(lsp_document_symbol.document_symbol_response(doc.index, symbols)),
    ],
  }
}

fn handle_folding_range(state: State, req: protocol.Request) Step {
  fr_params := case params.decode_folding_range(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(fr_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  if state.full_dirty {
    return state.empty_array_response_step(req)
  }
  snap := case state.workspace_snapshot_cached(doc) {
    .Some(s) => s,
    .None => return state.empty_array_response_step(req),
  }
  state.query_cache = snap.cache
  ranges := query_folding_range.folding_ranges(snap)
  .{
    state,
    outgoing: [req.id.success_response(lsp_folding_range.folding_range_response(ranges, doc.index))],
  }
}

fn handle_inlay_hint(state: State, req: protocol.Request) Step {
  hint_params := case params.decode_inlay_hint(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(hint_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  range_start := case position_offset(doc.index, hint_params.range_start) {
    .Some(o) => o,
    .None => 0,
  }
  range_end := case position_offset(doc.index, hint_params.range_end) {
    .Some(o) => o,
    .None => doc.text.len(),
  }
  if state.full_dirty {
    return state.empty_array_response_step(req)
  }
  snap := case state.workspace_snapshot_cached(doc) {
    .Some(s) => s,
    .None => return state.empty_array_response_step(req),
  }
  state.query_cache = snap.cache
  hints := query_inlay_hints.inlay_hints(snap, range_start, range_end)
  .{
    state,
    outgoing: [req.id.success_response(lsp_inlay_hint.inlay_hint_response(doc.index, hints))],
  }
}

fn handle_semantic_tokens(state: State, req: protocol.Request) Step {
  sem_params := case params.decode_semantic_tokens(req.params) {
    .Ok(p) => p,
    .Err(_) => return .{
      state,
      outgoing: [req.id.success_response(json.object([json.kv("data", json.array([]))]))],
    },
  }
  doc := case state.documents.get(sem_params.text_document.uri) {
    .Some(d) => d,
    .None => return .{
      state,
      outgoing: [req.id.success_response(json.object([json.kv("data", json.array([]))]))],
    },
  }
  if state.full_dirty {
    return .{
      state,
      outgoing: [req.id.success_response(json.object([json.kv("data", json.array([]))]))],
    }
  }
  snap := case state.workspace_snapshot_cached(doc) {
    .Some(s) => s,
    .None => return .{
      state,
      outgoing: [req.id.success_response(json.object([json.kv("data", json.array([]))]))],
    },
  }
  state.query_cache = snap.cache
  tokens := query_semantic_tokens.semantic_tokens(snap)
  .{
    state,
    outgoing: [
      req.id.success_response(lsp_semantic_tokens.semantic_tokens_response(doc.index, tokens)),
    ],
  }
}

fn handle_workspace_symbol(state: State, req: protocol.Request) Step {
  ws_params := case params.decode_workspace_symbol(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }

  // We need at least one open document to anchor workspace analysis.
  open_docs := state.documents.docs.values()

  if open_docs.len() == 0 {
    return state.empty_array_response_step(req)
  }

  // Use the first open doc to trigger workspace analysis, which populates
  // the cache with all reachable modules.
  doc := open_docs[0]
  snap := state.workspace_snapshot(doc)
  state.query_cache = snap.cache

  symbols := query_workspace_symbols.workspace_symbols(snap.cache, ws_params.query)
  response := lsp_workspace_symbol.workspace_symbol_response(
    symbols,
    fn(uri: String) line_index.LineIndex? {
      // Prefer open-doc indexes; fall back to reading from disk.
      case document_by_identity_uri(state.documents, uri) {
        .Some(d) => return .Some(d.index),
        .None => {},
      }

      p := case identity_path_from_uri(uri) {
        .Some(path) => path,
        .None => return .None,
      }

      case fs.read_text(p) {
        .Ok(text) => .Some(line_index.new(text)),
        .Err(_) => .None,
      }
    },
  )
  .{ state, outgoing: [req.id.success_response(response)] }
}

fn handle_formatting(state: State, req: protocol.Request) Step {
  fmt_params := case params.decode_document_formatting(req.params) {
    .Ok(p) => p,
    .Err(_) => return state.empty_array_response_step(req),
  }
  doc := case state.documents.get(fmt_params.text_document.uri) {
    .Some(d) => d,
    .None => return state.empty_array_response_step(req),
  }
  lexed := lexer.lex(doc.text, 0)

  if lexed.diagnostics.len() > 0 {
    return state.empty_array_response_step(req)
  }

  parsed := parser.parse_tokens(doc.text, 0, lexed.value, lexed.diagnostics)

  if parsed.diagnostics.len() > 0 {
    return state.empty_array_response_step(req)
  }

  formatted := formatter.format(parsed.value, lexed.value, doc.text)

  if formatted == doc.text {
    return state.empty_array_response_step(req)
  }

  range := lsp_range.byte_range_to_lsp_range(doc.index, 0, doc.text.len())
  edit := lsp_code_action.text_edit(range, formatted)
  .{ state, outgoing: [req.id.success_response(json.array([edit]))] }
}

fn position_offset(index: line_index.LineIndex, position: params.Position) Int? {
  line_index.position_to_byte_offset(
    index,
    .{ line: position.line, character: position.character },
    .Utf16,
  )
}

fn null_response_step(state: State, req: protocol.Request) Step {
  .{ state, outgoing: [req.id.success_response(.Null)] }
}

fn empty_array_response_step(state: State, req: protocol.Request) Step {
  .{ state, outgoing: [req.id.success_response(json.array([]))] }
}

fn project_root_for_document(file_path: String) String {
  dir := path.dirname(file_path)
  root := loader.find_project_root(dir)

  if root == path.normalize(".") {
    dir
  } else {
    root
  }
}

pub fn next_poll_timeout_ms(state: State) Int? {
  if !state.diagnostics_pending {
    return .None
  }

  if date.now() >= state.diagnostics_deadline_ms {
    .Some(0)
  } else {
    .Some(25)
  }
}

pub fn diagnostics_due(state: State) Bool {
  state.diagnostics_pending and date.now() >= state.diagnostics_deadline_ms
}

pub fn publish_due_diagnostics(state: State) Step {
  state.publish_due_diagnostics_with_progress(.None)
}

/// Progress-aware variant of `publish_due_diagnostics`. When `progress` is
/// `.Some`, full workspace analysis emits coarse module-stage events through the
/// sink. The plain entry point delegates here with `.None`.
pub fn publish_due_diagnostics_with_progress(state: State, progress: ProgressSink?) Step {
  if !(state.diagnostics_pending and date.now() >= state.diagnostics_deadline_ms) {
    return .{ state, outgoing: [] }
  }

  state.diagnostics_pending = false

  case state.diagnostics_tier {
    .Parse => state.publish_parse_diagnostics(),
    .Full => {
      step := state.publish_workspace_diagnostics(progress)
      done := step.state
      done.full_dirty = false

      // Full analysis supersedes any pending parse run, so drop the dirty set.
      done.parse_dirty_uris = Dict.new()
      .{ state: done, outgoing: step.outgoing }
    },
  }
}

fn publish_parse_diagnostics(state: State) Step {
  outgoing: Vector<json.Json> = []

  for uri in state.parse_dirty_uris.keys() {
    doc := case state.documents.get(uri) {
      .Some(d) => d,
      .None => continue,
    }
    result := query_diagnostics.analyze_parse(
      state.query_cache,
      .{ uri: doc.uri, text: doc.text, version: doc.version },
    )
    state.query_cache = result.cache

    if state.should_publish_diagnostics(doc, result.diagnostics) {
      outgoing = .append(
        lsp_diagnostics.publish_diagnostics(doc.uri, doc.version, doc.index, result.diagnostics),
      )
      state = .mark_published(doc, result.diagnostics)
    }
  }

  state.parse_dirty_uris = Dict.new()
  .{ state, outgoing }
}

fn mark_diagnostics_pending(state: State, tier: DiagTier, uri: String?) Step {
  state.diagnostics_pending = true
  state.diagnostics_tier = tier

  case tier {
    .Parse => {
      state.diagnostics_deadline_ms = date.now() + 150.to_float()
      case uri {
        .Some(u) => state.parse_dirty_uris[u] = true,
        .None => {},
      }
    },
    .Full => state.diagnostics_deadline_ms = date.now(),
  }

  .{ state, outgoing: [] }
}

fn note_changed_document_source(state: State, uri: String, text: String) State {
  id := case identity.from_file_uri(uri) {
    .Ok(parsed) => parsed,
    .Err(_) => identity.from_path(uri),
  }
  root := project_root_for_document(id.path)
  canonical := imports.canonical_module_path(id.path, imports.make_canonical_roots(root))
  state.query_cache = .note_source_hash(canonical, keys.hash_text(text))
  state.full_dirty = true
  state
}

fn publish_workspace_diagnostics(state: State, progress: ProgressSink?) Step {
  open_docs := state.documents.docs.values()
  overlay_docs := collect doc in open_docs {
    query_diagnostics.DocumentInput.{ uri: doc.uri, text: doc.text, version: doc.version }
  }

  // Group open docs by project root so we run one analysis per project
  // instead of one per open document.
  by_project: Dict<String, Vector<document_store.Document>> = Dict.new()

  for doc in open_docs {
    root := project_root_for_document(doc.identity.path)
    existing := case by_project[root] {
      .Some(ds) => ds,
      .None => [],
    }
    by_project[root] = existing.append(doc)
  }

  cur_cache := state.query_cache
  outgoing: Vector<json.Json> = []
  published: Dict<String, Bool> = Dict.new()

  for root in by_project.keys() {
    docs := case by_project[root] {
      .Some(ds) => ds,
      .None => continue,
    }

    // Use first doc as entry — analysis walks all deps anyway.
    // Track which open-doc URIs are covered by this analysis.
    entry := docs[0]
    result := query_diagnostics.analyze_workspace_with_progress(
      cur_cache,
      .{ entry_uri: entry.uri, project_root: root, open_documents: overlay_docs },
      state.closure_snapshot,
      progress,
    )
    cur_cache = result.cache
    state.closure_snapshot = result.snapshot

    for group in result.diagnostics_by_uri {
      if group.diagnostics.len() == 0 and group.uri != entry.identity.uri {
        continue
      }

      case document_by_identity_uri(state.documents, group.uri) {
        .Some(group_doc) => if !published.has(group.uri)
          and state.should_publish_diagnostics(group_doc, group.diagnostics) {
          outgoing = .append(
            lsp_diagnostics.publish_diagnostics(
              group_doc.uri,
              group_doc.version,
              group_doc.index,
              group.diagnostics,
            ),
          )
          state = .mark_published(group_doc, group.diagnostics)
          published[group.uri] = true
        },
        .None => {},
      }
    }

    // If any open docs in this project weren't covered, analyze them
    // as separate entries to catch disjoint dependency graphs.
    for doc in docs {
      if published.has(doc.identity.uri) {
        continue
      }

      extra := query_diagnostics.analyze_workspace(
        cur_cache,
        .{ entry_uri: doc.uri, project_root: root, open_documents: overlay_docs },
        state.closure_snapshot,
      )
      cur_cache = extra.cache
      state.closure_snapshot = extra.snapshot

      for group in extra.diagnostics_by_uri {
        if group.diagnostics.len() == 0 and group.uri != doc.identity.uri {
          continue
        }

        case document_by_identity_uri(state.documents, group.uri) {
          .Some(group_doc) => if !published.has(group.uri)
            and state.should_publish_diagnostics(group_doc, group.diagnostics) {
            outgoing = .append(
              lsp_diagnostics.publish_diagnostics(
                group_doc.uri,
                group_doc.version,
                group_doc.index,
                group.diagnostics,
              ),
            )
            state = .mark_published(group_doc, group.diagnostics)
            published[group.uri] = true
          },
          .None => {},
        }
      }
    }
  }

  state.query_cache = cur_cache
  .{ state, outgoing }
}

fn diagnostics_signature(version: Int?, diags: Vector<query_diagnostics.Diagnostic>) String {
  acc := case version {
    .Some(n) => "${n}",
    .None => "none",
  }

  for d in diags {
    acc = "${acc}\n${query_diagnostics.diagnostic_key(d)}"
  }

  acc
}

fn should_publish_diagnostics(
  state: State,
  doc: document_store.Document,
  diags: Vector<query_diagnostics.Diagnostic>,
) Bool {
  sig := diagnostics_signature(doc.version, diags)

  case state.last_published[doc.identity.uri] {
    .Some(prev) => prev != sig,
    .None => true,
  }
}

fn mark_published(
  state: State,
  doc: document_store.Document,
  diags: Vector<query_diagnostics.Diagnostic>,
) State {
  state.last_published[doc.identity.uri] = diagnostics_signature(doc.version, diags)
  state
}

fn document_by_identity_uri(store: document_store.Store, identity_uri: String) document_store.Document? {
  for doc in store.docs.values() {
    if doc.identity.uri == identity_uri {
      return .Some(doc)
    }
  }

  .None
}

fn definition_target_index(
  store: document_store.Store,
  target_uri: String,
  fallback: line_index.LineIndex,
) line_index.LineIndex {
  case document_by_identity_uri(store, target_uri) {
    .Some(target_doc) => return target_doc.index,
    .None => {},
  }

  target_path := case identity_path_from_uri(target_uri) {
    .Some(p) => p,
    .None => return fallback,
  }

  case fs.read_text(target_path) {
    .Ok(text) => line_index.new(text),
    .Err(_) => fallback,
  }
}

fn identity_path_from_uri(uri: String) String? {
  case identity.from_file_uri(uri) {
    .Ok(id) => .Some(id.path),
    .Err(_) => .None,
  }
}
