// Diagnostic types for compiler error reporting.

use .span

pub type Severity = { Error, Warning, Hint, Info }

pub type RelatedInfo = .{ span: span.Span, message: String }

pub type Diagnostic = .{
  span: span.Span,
  severity: Severity,
  message: String,
  related: Vector<RelatedInfo>,
}

pub type StageResult<T> = .{ value: T, diagnostics: Vector<Diagnostic> }

pub fn error(span: span.Span, message: String) Diagnostic {
  .{ span, severity: .Error, message: message, related: [] }
}

pub fn warning(span: span.Span, message: String) Diagnostic {
  .{ span, severity: .Warning, message, related: [] }
}

pub fn stage_result<T>(value: T, diagnostics: Vector<Diagnostic>) StageResult<T> {
  .{ value, diagnostics }
}
