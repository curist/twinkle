/// Compare two Ints.
pub fn compare(a: Int, b: Int) Order {
  if a < b { .Lt } else if a > b { .Gt } else { .Eq }
}

/// Convert Int to Float.
pub fn to_float(n: Int) Float {
  case Float.from_string(n.to_string()) {
    .Some(v) => v,
    .None => {
      error("Int.to_float: internal conversion failure")
      0.0
    },
  }
}
